[Unit]
Description=Claude Code log rotation (oneshot)

[Service]
Type=oneshot
ExecStart=__BIN_DIR__/claude-control-logrotate
Environment=CLAUDE_CONTROL_DIR=__CONTROL_DIR__
Environment=PATH=__BIN_DIR__:/usr/local/bin:/usr/bin:/bin
# Optional override file (CLAUDE_CONTROL_LOG_MAX_BYTES etc.); missing is fine.
EnvironmentFile=-%h/.config/claude-control/env
# stdout/stderr go to the journal (no extra file); logrotate appends its trim
# notes to watchdog.log itself.
