[Unit]
Description=Claude Code autonomous worker "%i"
PartOf=default.target

[Service]
Type=simple
ExecStart=__BIN_DIR__/claude-auto-run %i
Restart=always
# Minimum delay between relaunches so a worker that dies on startup (auth
# refresh, bad config) doesn't tight-loop.
RestartSec=30
# Reap the WHOLE cgroup on stop. This is the systemd default, but we set it EXPLICITLY
# because it is now both safe and desirable: each worker runs its OWN tmux server on a
# dedicated `-L claude-%i` socket (see bin/claude-auto-run), so that server — and the
# claude/event-bridge processes under it — live in THIS unit's cgroup. control-group then
# reaps exactly this worker on stop/restart, nothing else. (Before per-worker sockets all
# workers shared the default-socket server, which lived in whichever worker started it
# first; stopping THAT worker control-group-killed the shared server → the whole fleet's
# sessions died → mass restart cascade. Per-socket isolation makes that impossible.)
KillMode=control-group
# claude (auth, --resume) and bun (event-bridge channel) must be on PATH.
Environment=PATH=__BIN_DIR__:%h/.local/bin:%h/.bun/bin:%h/bin:/usr/local/bin:/usr/bin:/bin
Environment=CLAUDE_CONTROL_DIR=__CONTROL_DIR__
# Optional overrides (CLAUDE_BIN, proxy vars, …). Missing file is fine.
EnvironmentFile=-%h/.config/claude-control/env
# Per-worker unit log (the worker's own tmux/claude output is in workers/%i/logs/worker.log).
StandardOutput=append:__CONTROL_DIR__/workers/%i/logs/unit.log
StandardError=append:__CONTROL_DIR__/workers/%i/logs/unit.err

[Install]
WantedBy=default.target
