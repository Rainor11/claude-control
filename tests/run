#!/bin/bash
# tests/run — ЕДИНСТВЕННЫЙ санкционированный способ запускать tests/*.test.sh и
# tests/*.test.mjs (T3 изоляции тестов от боевого рантайма, см.
# .superpowers/sdd/iso-t3-brief.md). До этого файла защита T1 (lib/runtime-root.sh) и T2
# (lib/process-control.sh) работала ТОЛЬКО для теста, который сам не забыл выставить маркер
# CLAUDE_CONTROL_TEST_ROOT — резолвер под отсутствующим маркером законно применяет боевой
# дефолт, и добровольный пролог механической границей не является (см. brief). Этот раннер —
# рубеж 1 из двух: он ГОТОВИТ песочницу (маркер + sentinel + заглушки процесс-контроля) ДО
# старта каждого теста; рубеж 2 (tests/lib/bootstrap.sh / .mjs) отказывает, если тест
# запущен НЕ через этот раннер.
#
# set -u ЗДЕСЬ уместен (это исполняемый скрипт, не source-able библиотека — тот же
# конвенционный выбор, что у install.sh/uninstall.sh, см. .superpowers/sdd/iso-t3-brief.md
# «Конвенции репозитория»).
set -u

_RUN_TESTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_RUN_REPO_DIR="$(cd "$_RUN_TESTS_DIR/.." && pwd)"

# Тестируемость (используется ТОЛЬКО tests/run.test.sh): TESTS_RUN_DIR_OVERRIDE заставляет
# раннер сканировать/исполнять тесты из ДРУГОГО каталога (игрушечные fixture-тесты во
# временной директории) вместо реального tests/ — так механику раннера (discovery/песочница/
# карантин/PASS-FAIL/уборка) можно проверить, ни разу не запустив ни один настоящий тест
# из боевого набора. _RUN_REPO_DIR (откуда берутся lib/runtime-root.sh и
# lib/process-control.sh) вычислен ВЫШЕ, ДО этой проверки, — override его не трогает, иначе
# сломался бы поиск библиотек. Без переменной поведение НЕ меняется вовсе.
if [ -n "${TESTS_RUN_DIR_OVERRIDE:-}" ]; then
  _RUN_TESTS_DIR="$TESTS_RUN_DIR_OVERRIDE"
fi

# Переиспользуем T1 ИСКЛЮЧИТЕЛЬНО за именем sentinel-файла (_RUNTIME_ROOT_SENTINEL_NAME) —
# бриф прямо требует "имя sentinel уже определено в T1 — возьми оттуда, не выдумывай своё".
# Раннер — единственное место, которое ЭТОТ файл СОЗДАЁТ; резолв/containment/проверку
# заглушек мы здесь не делаем вовсе (это работа T1/T2 внутри самих тестов через bootstrap) —
# раннер только строит песочницу и передаёт готовые пути через env.
# shellcheck disable=SC1091
. "$_RUN_REPO_DIR/lib/runtime-root.sh"
SENTINEL_NAME="$_RUNTIME_ROOT_SENTINEL_NAME"

# detect_bootstrap_connection (uses_bootstrap ниже — тонкая обёртка) — общий с
# tests/lint-bootstrap.test.sh детектор, см. tests/lib/bootstrap-detect.sh (К1 ревью T3: там
# же — почему "первая значимая строка", а не substring по всему файлу). Источник — от
# _RUN_REPO_DIR (РЕАЛЬНЫЙ репозиторий), НЕ от _RUN_TESTS_DIR — та уже могла быть подменена
# TESTS_RUN_DIR_OVERRIDE выше (fixture-каталог не содержит lib/bootstrap-detect.sh).
# shellcheck disable=SC1091
. "$_RUN_REPO_DIR/tests/lib/bootstrap-detect.sh"

# -----------------------------------------------------------------------------------------
# УБОРКА ПЕСОЧНИЦЫ — защита от прерывания (В3, ревью T3). Раньше `rm -rf "$canon_sandbox"` в
# run_one был ЕДИНСТВЕННОЙ попыткой уборки, без trap — SIGTERM/SIGINT, полученный ПОКА тест
# ещё выполняется (раннер блокирован в command substitution, ждёт дочерний bash/node), обрывал
# tests/run ДО этой строки, и песочница оставалась в $TMPDIR НАВСЕГДА (не боевой урон — всё в
# $TMPDIR, но мусор, подтверждено эмпирически ревьюером). Второй найденный случай: тест,
# ограничивший права внутри своей же песочницы (`chmod 000` на подкаталог, проверяет свою
# логику), приводил к ТИХОМУ провалу `rm -rf` — результат нигде не проверялся.
#
# Best-effort, честно (тот же принцип, что T2 про свой guard): SIGKILL не перехватить в
# принципе (это ОС, не bash). Сигнал, отправленный ТОЛЬКО дочернему exec'нутому процессу теста
# (не всей группе процессов), тоже не долетит до этого trap — под systemd (KillMode=
# control-group по умолчанию) сигнал уйдёт всей группе разом, но при ручном
# `kill -TERM <pid раннера>` это ограничение остаётся. Не выдаём best-effort за гарантию.
_CURRENT_SANDBOX=""

# _sandbox_looks_safe <path>: 0, если path непустой, абсолютный и лежит СТРОГО внутри
# канонического ${TMPDIR:-/tmp} — защита от классического `rm -rf ""` → `rm -rf /`, если
# переменная окажется пустой/невыставленной, и от уборки чего-либо ВНЕ песочницы (бриф:
# «раннер убирает за собой песочницу, но НЕ удаляет ничего вне неё»).
_sandbox_looks_safe() {
  local path="$1" tmpbase
  [ -n "$path" ] || return 1
  case "$path" in
    /*) ;;
    *) return 1 ;;
  esac
  tmpbase="$(realpath -e "${TMPDIR:-/tmp}" 2>/dev/null)" || return 1
  case "$path" in
    "$tmpbase"/*) return 0 ;;
    *) return 1 ;;
  esac
}

# _cleanup_sandbox: убирает _CURRENT_SANDBOX, если она выставлена и выглядит безопасной.
# chmod -R u+rwx ПЕРЕД rm -rf — тест внутри своей песочницы мог сам себе `chmod 000` на
# какой-то подкаталог (проверяет свою же логику прав) — `rm -rf` тогда не может рекурсивно
# зайти внутрь (нужны r+x на директорию), молча проваливаясь (В3, подтверждено эмпирически).
# Мы — владелец (mktemp создал от нашего uid), chmod от владельца работает НЕЗАВИСИМО от
# текущих битов прав (это право владельца, не текущего режима файла).
_cleanup_sandbox() {
  local path="$_CURRENT_SANDBOX"
  [ -n "$path" ] || return 0
  if ! _sandbox_looks_safe "$path"; then
    echo "tests/run: ОТКАЗ убрать '$path' — путь не похож на нашу песочницу внутри \${TMPDIR:-/tmp}, уборка пропущена (защита от удаления вне границ)" >&2
    return 1
  fi
  chmod -R u+rwx "$path" 2>/dev/null
  if rm -rf -- "$path"; then
    _CURRENT_SANDBOX=""
    return 0
  fi
  echo "tests/run: ПРЕДУПРЕЖДЕНИЕ — не удалось полностью убрать песочницу '$path' (rm -rf вернул ошибку), проверь вручную" >&2
  return 1
}

# _on_term_signal <sig>: убрать текущую песочницу, снять свой же trap (не зациклиться) и
# завершиться конвенционным кодом 128+N — стандартный паттерн "cleanup, затем честно
# завершиться сигналом", а не тихо проглотить INT/TERM и продолжить как ни в чём не бывало.
_on_term_signal() {
  local sig="$1" rc
  _cleanup_sandbox
  trap - EXIT INT TERM
  case "$sig" in
    INT) rc=130 ;;
    TERM) rc=143 ;;
    *) rc=1 ;;
  esac
  exit "$rc"
}
trap '_cleanup_sandbox' EXIT
trap '_on_term_signal INT' INT
trap '_on_term_signal TERM' TERM

# -----------------------------------------------------------------------------------------
# КАРАНТИН — явный deny-list с причиной (проектное решение, см. отчёт iso-t3-report.md).
#
# Механизм остаётся общим: ЛЮБОЙ тест, который вызывает bin/* код, реально дёргающий
# systemctl/systemd-run/tmux в обход переопределяемого seam guard'а (T2), долетал бы до
# настоящего бинаря независимо от маркера/заглушек. Такой файл заносится сюда ТЕМ ЖЕ
# способом (ключ = "tests/<имя>", значение = причина).
#
# СЕЙЧАС СПИСОК ПУСТ. Единственный исторический жилец —
# tests/asana-project-integration.test.sh — СНЯТ в T4: guard процесс-контроля подключён к
# bin/claude-auto cmd_sleep (`process_control_systemctl`/`process_control_tmux`), поэтому его
# `claude-auto sleep testw` под маркером теперь уходит В ЗАГЛУШКУ (доказано логом заглушки в
# .superpowers/sdd/iso-t4-report.md), а не в настоящий `systemctl --user disable --now` +
# `tmux kill-session`. Сам тест доработан (control-dir внутрь test root), чтобы guard
# резолвил шов в заглушку, а не fail-closed'ился на легаси-переменной наружу root.
#
# Карантин проверяется ПЕРВЫМ, ДО построения списка на выполнение — is_quarantined
# вызывается на любом источнике кандидатов (auto-discovery ИЛИ явный аргумент командной
# строки) и ПОБЕЖДАЕТ даже явное указание файла по имени: раннер спроектирован так, чтобы
# карантинный файл было ФИЗИЧЕСКИ НЕВОЗМОЖНО запустить через него, а не просто "по
# умолчанию пропускается, если не попросить иначе".
#
# В2 (ревью T3) — ЧЕГО ЭТОТ КАРАНТИН НЕ ГАРАНТИРУЕТ (та же честность, что T2 про свой guard,
# см. lib/process-control.sh «ЧЕГО ЭТОТ GUARD НЕ ГАРАНТИРУЕТ»): is_quarantined проверяет
# РАСПОЛОЖЕНИЕ/СОДЕРЖИМОЕ файла (имя ИЛИ канонический realpath, см. QUARANTINE_REAL ниже —
# закрывает симлинк/копию-по-inode под другим именем), а НЕ его БЕЗВРЕДНОСТЬ. Единственная
# защита от переписанного-под-новым-именем side-effect — статический grep-аудит
# (iso-t3-report.md) плюс PATH-shadow defense-in-depth (см. ниже, ловит ГОЛЫЕ имена команд
# независимо от карантина). T4/T5 не должны считать карантин сильнее, чем он есть.
declare -A QUARANTINE=()

# QUARANTINE_REAL — канонические (realpath) абсолютные пути карантинных файлов, вычисленные
# от их РЕАЛЬНОГО расположения в tests/ репозитория (карантинный файл физически лежит только
# там, независимо от TESTS_RUN_DIR_OVERRIDE). Закрывает В2 (ревью T3): tests/asana-copy.test.sh
# — СИМЛИНК на tests/asana-project-integration.test.sh под другим именем — раньше проходил
# discovery по ИМЕНИ (не совпадало ни с одним ключом QUARANTINE) и физически исполнялся бы,
# долетая до настоящего systemd/tmux. realpath разыменовывает симлинк до канонического файла —
# сравнение "то же физическое содержимое", а не "то же имя". См. is_quarantined ниже — сначала
# быстрая проверка по имени (частый случай, без обращения к ФС), затем по realpath (закрывает
# симлинк/копию-по-inode).
declare -A QUARANTINE_REAL=()
_build_quarantine_real() {
  local rel abs real
  for rel in "${!QUARANTINE[@]}"; do
    # _RUN_REPO_DIR — корень репозитория (НЕ tests/), rel уже содержит префикс "tests/" —
    # конкатенация НАПРЯМУЮ, без strip (в отличие от run_one::abs, который строится от
    # _RUN_TESTS_DIR, а не от _RUN_REPO_DIR).
    abs="$_RUN_REPO_DIR/$rel"
    if [ -e "$abs" ]; then
      real="$(realpath -e "$abs" 2>/dev/null)" && QUARANTINE_REAL["$real"]="${QUARANTINE[$rel]}"
    fi
  done
}

# Тест-шов (используется ТОЛЬКО tests/run.test.sh — тот же класс, что TESTS_RUN_DIR_OVERRIDE
# выше): QUARANTINE_TEST_ADD добавляет ОДИН карантинный ключ, чтобы проверить МЕХАНИКУ карантина
# (имя/realpath/приоритет над явным аргументом), не завися от конкретного боевого жильца. После
# T4 боевой список QUARANTINE ПУСТ — asana-project-integration снят (guard процесс-контроля
# подключён к claude-auto cmd_sleep), и проверять механику стало не на чем без такого шва. Шов
# ТОЛЬКО ДОБАВЛЯЕТ запись (никогда не убирает) — ослабить боевую защиту им нельзя; в проде
# переменная не выставлена, поведение не меняется вовсе (как у TESTS_RUN_DIR_OVERRIDE).
if [ -n "${QUARANTINE_TEST_ADD:-}" ]; then
  QUARANTINE["$QUARANTINE_TEST_ADD"]="тест-шов QUARANTINE_TEST_ADD: искусственный карантин для проверки механики (tests/run.test.sh) — эмулирует случай 'claude-auto sleep → настоящий systemctl disable' до подключения guard'а"
fi
_build_quarantine_real
unset -f _build_quarantine_real

usage() {
  cat <<'EOF'
Использование: tests/run [--list] [файл ...]

Без аргументов — запускает ВСЕ обнаруженные tests/*.test.sh и tests/*.test.mjs (кроме
карантина, см. ниже) в свежей песочнице на каждый файл.

С аргументами — запускает только явно перечисленные файлы (относительный путь вида
"tests/foo.test.sh" ИЛИ голое имя "foo.test.sh") — карантин ПОБЕЖДАЕТ даже явное указание,
физически невозможно запустить карантинный файл через этот раннер.

  --list    только показать обнаруженные тесты + карантин (с причиной), ничего не запускать
  --help    эта справка
EOF
}

# discover(): печатает относительные пути (tests/xxx) всех *.test.sh и *.test.mjs
# НЕПОСРЕДСТВЕННО в tests/ (без рекурсии — сегодня все тесты плоские), отсортированные —
# автоматически, НЕ жёстким списком (бриф: "жёсткий список сам станет местом, где забудут").
discover() {
  local f
  shopt -s nullglob
  local files=("$_RUN_TESTS_DIR"/*.test.sh "$_RUN_TESTS_DIR"/*.test.mjs)
  shopt -u nullglob
  for f in "${files[@]}"; do
    printf 'tests/%s\n' "$(basename "$f")"
  done | sort
}

# is_quarantined <rel> <abs>: 0, если файл в deny-list — ПО ИМЕНИ (быстрый путь, частый
# случай, без обращения к ФС) ИЛИ по каноническому realpath (В2 — закрывает симлинк/копию-по-
# inode под ДРУГИМ именем, см. QUARANTINE_REAL выше). <abs> опционален — если не передан или
# не существует, работает только проверка по имени (тот же результат, что и раньше).
is_quarantined() {
  local rel="$1" abs="${2:-}" real
  [ -n "${QUARANTINE[$rel]+set}" ] && return 0
  [ -n "$abs" ] && [ -e "$abs" ] || return 1
  real="$(realpath -e "$abs" 2>/dev/null)" || return 1
  [ -n "${QUARANTINE_REAL[$real]+set}" ]
}

# quarantine_reason <rel> <abs>: причина карантина — по имени (QUARANTINE) ИЛИ по realpath
# (QUARANTINE_REAL, В2 — симлинк/копия-по-inode под другим именем). Вызывать ТОЛЬКО после
# is_quarantined вернул истину (иначе пусто) — не дублирует её проверку, просто достаёт текст.
quarantine_reason() {
  local rel="$1" abs="${2:-}" real
  if [ -n "${QUARANTINE[$rel]+set}" ]; then
    printf '%s' "${QUARANTINE[$rel]}"
    return 0
  fi
  if [ -n "$abs" ] && real="$(realpath -e "$abs" 2>/dev/null)" && [ -n "${QUARANTINE_REAL[$real]+set}" ]; then
    printf '%s' "${QUARANTINE_REAL[$real]}"
  fi
}

# make_stub <path>: исполняемая заглушка процесс-контроля — логирует свой вызов (argv0 +
# аргументы, TAB-разделено) в $STUB_LOG (если задан) и завершается успешно. Дефолт "тихого
# успеха" достаточен для большинства тестов; тесты, которым нужно конкретное поведение
# (эмуляция ошибки, конкретный stdout), продолжают подставлять СВОЙ мок через тот же env var
# (прецедент — tests/dept-requests.test.sh FAKE_SYSTEMCTL) — заглушка раннера лишь
# базовая страховка "не долетело до настоящего бинаря", не более.
make_stub() {
  local path="$1"
  cat > "$path" <<'STUB'
#!/bin/bash
# Заглушка процесс-контроля, созданная tests/run (НЕ настоящий бинарь). См.
# tests/run::make_stub — логирует argv в $STUB_LOG и завершается успешно.
if [ -n "${STUB_LOG:-}" ]; then
  { printf '%s' "$(basename "$0")"; for a in "$@"; do printf '\t%s' "$a"; done; printf '\n'; } >> "$STUB_LOG"
fi
exit 0
STUB
  chmod +x "$path"
}

# uses_bootstrap <abs>: 0, если файл уже подключает tests/lib/bootstrap.{sh,mjs} — тот же
# признак "тест мигрирован", что использует tests/lint-bootstrap.test.sh (has_bootstrap).
# Решает, обязан ли раннер ПРИНУДИТЕЛЬНО экспортировать SYSTEMCTL/DEPT_SYSTEMD_RUN/TMUX_BIN:
# их консультирует ТОЛЬКО bootstrap-preflight (T2) — НЕ мигрированные (allow-list, T6) тесты
# строят СВОИ собственные моки этих же переменных внутри себя И явно тестируют сценарий
# "переменная НЕ задана — резолв через PATH" (прецедент, найденный ЭМПИРИЧЕСКИ при
# верификации раннера: tests/process-control.test.sh, сценарий «process_control_systemctl без
# маркера: прокси на настоящий бинарь, проверяем фейковым бинарём в PATH» — принудительный
# SYSTEMCTL от раннера ломает именно этот сценарий, подменяя собой ожидаемый PATH-fallback).
# Раннер не навязывает ещё не принятый тестом контракт — sentinel/маркер/HOME/
# TELEGRAM_NOTIFY/RNR_ASKS_DB/PATH-shadow остаются БЕЗ УСЛОВИЙ (ни один существующий тест не
# тестирует ИХ отсутствие).
#
# Тонкая обёртка над detect_bootstrap_connection (tests/lib/bootstrap-detect.sh, sourced
# выше) — ОДНА и та же реализация, что и tests/lint-bootstrap.test.sh::has_bootstrap, вынесена
# в общий файл ПОСЛЕ находки К1 (ревью T3): прежний "голый substring по всему файлу"
# засчитывал bootstrap подключённым в 4 случаях без реальной защиты (comment-trailing trick,
# heredoc-заглушка, недостижимая ветка, bootstrap последней строкой ПОСЛЕ опасного кода) — см.
# полное обоснование в tests/lib/bootstrap-detect.sh. Дублировать НОВУЮ (многострочную)
# логику в двух местах значило бы гарантированно разойтись — общий файл делает это
# структурно невозможным.
uses_bootstrap() {
  detect_bootstrap_connection "$1"
}

# run_one <rel>: свежая песочница → выполнить → уборка. Возвращает 0/1/2
# (0=PASS, 1=FAIL, 2=QUARANTINED) через RUN_ONE_STATUS (не через return — нужен ещё и текст).
run_one() {
  # abs строится от _RUN_TESTS_DIR (не от _RUN_REPO_DIR/rel напрямую) — важно под
  # TESTS_RUN_DIR_OVERRIDE (см. выше): "rel" ВСЕГДА ярлык вида "tests/<basename>" (для
  # единообразия с QUARANTINE/discover), а физическое расположение файла зависит от того,
  # сканируем ли реальный tests/ или fixture-override.
  local rel="$1" abs="$_RUN_TESTS_DIR/${1#tests/}"

  if is_quarantined "$rel" "$abs"; then
    echo "QUARANTINE: $rel"
    echo "  причина: $(quarantine_reason "$rel" "$abs")"
    RUN_ONE_STATUS=2
    return 0
  fi

  if [ ! -f "$abs" ]; then
    echo "FAIL: $rel — файл не найден ($abs)"
    RUN_ONE_STATUS=1
    return 0
  fi

  local sandbox canon_sandbox
  sandbox="$(mktemp -d "${TMPDIR:-/tmp}/claude-control-test.XXXXXX")" || {
    echo "FAIL: $rel — mktemp -d не смог создать песочницу"
    RUN_ONE_STATUS=1
    return 0
  }
  # _CURRENT_SANDBOX (ГЛОБАЛЬНАЯ, не local!) — с этого момента trap на EXIT/INT/TERM (см.
  # заголовок файла, В3) видит путь и уберёт его даже при прерывании ДО того, как тест
  # закончится штатно. Обновляем на canon_sandbox ниже, как только он резолвится.
  _CURRENT_SANDBOX="$sandbox"
  canon_sandbox="$(realpath -e "$sandbox")" || {
    echo "FAIL: $rel — realpath не смог канонизировать песочницу $sandbox"
    rm -rf "$sandbox"
    _CURRENT_SANDBOX=""
    RUN_ONE_STATUS=1
    return 0
  }
  _CURRENT_SANDBOX="$canon_sandbox"

  # --- контракт песочницы (см. brief «Контракт песочницы») ------------------------------
  : > "$canon_sandbox/$SENTINEL_NAME"

  local stub_dir="$canon_sandbox/stubs"
  mkdir -p "$stub_dir"
  make_stub "$stub_dir/systemctl"
  make_stub "$stub_dir/systemd-run"
  make_stub "$stub_dir/tmux"
  make_stub "$stub_dir/telegram-notify.sh"

  local home_dir="$canon_sandbox/home"
  mkdir -p "$home_dir"
  local rnr_db_dir="$canon_sandbox/rnr-db"
  mkdir -p "$rnr_db_dir"

  local rc out
  # `{ ...; } 2>&1` ВНУТРИ command substitution — сливает stderr в stdout ДЛЯ ВСЕГО блока
  # (включая exec bash/node ниже, которые заменяют образ процесса, но наследуют уже
  # перенаправленные fd) — без этой группы stderr теста утекал бы мимо `out=`, минуя лог.
  out="$(
    {
      # Легаси-переменные + сам маркер + все 3 seam-переменные ГАРАНТИРОВАННО unset ДО
      # экспорта наших значений — даже если оператор (или ВНЕШНИЙ, обёртывающий вызов
      # tests/run — regression-тест, найденный эмпирически: tests/run.test.sh гоняет
      # НЕСТИРОВАННЫЙ tests/run уже ПОД bootstrap-песочницей самого себя, и SYSTEMCTL от
      # ВНЕШНЕГО раннера иначе утёк бы через inheritance во ВНУТРЕННИЙ прогон, обходя
      # uses_bootstrap для тестов, которые его не заслужили) уже унаследовал
      # SYSTEMCTL/DEPT_SYSTEMD_RUN/TMUX_BIN откуда-то ещё — без explicit unset здесь
      # unconditional-ветка `if uses_bootstrap` ниже не помогла бы: она лишь РЕШАЕТ,
      # экспортировать ли НАШЕ значение, но не убирает УЖЕ унаследованное чужое.
      unset CLAUDE_CONTROL_DIR CLAUDE_AUTO_HOME DEPT_HOME CLAUDE_CONTROL_TEST_ROOT \
            SYSTEMCTL DEPT_SYSTEMD_RUN TMUX_BIN

      export CLAUDE_CONTROL_TEST_ROOT="$canon_sandbox"
      export HOME="$home_dir"
      # SYSTEMCTL/DEPT_SYSTEMD_RUN/TMUX_BIN — ТОЛЬКО для тестов, уже подключивших bootstrap
      # (см. uses_bootstrap выше) — bootstrap.preflight ИМЕННО их и требует. Не мигрированные
      # тесты не ждут эти переменные от окружения и МОГУТ явно тестировать их отсутствие.
      if uses_bootstrap "$abs"; then
        export SYSTEMCTL="$stub_dir/systemctl"
        export DEPT_SYSTEMD_RUN="$stub_dir/systemd-run"
        export TMUX_BIN="$stub_dir/tmux"
      fi
      export TELEGRAM_NOTIFY="$stub_dir/telegram-notify.sh"
      # CLAUDE_CONTROL_TG / CLAUDE_AUTO_TG — ДРУГИЕ имена ТОГО ЖЕ телеграм-notify-seam'а в
      # нескольких bin/* файлах (bin/claude-auto-url-notify, bin/claude-auto-notify,
      # bin/event-bridge-watch — сверено grep'ом, см. iso-t3-report.md). Бриф явно требует
      # только TELEGRAM_NOTIFY, но цель ("тест не написал живым людям в Telegram") шире
      # одного имени переменной — дублируем ту же заглушку под остальными известными
      # именами, это дёшево и ничего не ломает (переменная, которую код не читает, просто
      # игнорируется).
      export CLAUDE_CONTROL_TG="$stub_dir/telegram-notify.sh"
      export CLAUDE_AUTO_TG="$stub_dir/telegram-notify.sh"
      export RNR_ASKS_DB="$rnr_db_dir/asks.db"
      export STUB_LOG="$canon_sandbox/stub-calls.log"

      # Defense-in-depth ПОВЕРХ обязательных seam-переменных (не замена им): stub_dir
      # ПЕРЕД остальным PATH — код, который (как СЕГОДНЯШНИЙ bin/claude-auto, см.
      # iso-t3-report.md) вызывает `systemctl`/`tmux`/`systemd-run` ГОЛЫМ именем команды, а
      # не через переопределяемую переменную, тоже находит нашу заглушку через PATH lookup,
      # а не настоящий бинарь. Не полагаемся на это как на единственную защиту (карантин
      # выше — всё равно обязателен для известного случая), но для ЕЩЁ НЕ обнаруженных
      # похожих случаев это дополнительный рубеж, который ничего не стоит.
      export PATH="$stub_dir:$PATH"

      case "$rel" in
        *.test.sh) exec bash "$abs" ;;
        *.test.mjs) exec node --test "$abs" ;;
        *) echo "tests/run: неизвестное расширение теста: $rel" >&2; exit 1 ;;
      esac
    } 2>&1
  )"
  rc=$?

  # shellcheck disable=SC2001  # префикс КАЖДОЙ строки многострочного $out — не одиночная
  # замена, `${var//search/replace}` (предложение SC2001) не расставит префикс на КАЖДОЙ
  # строке без отдельного цикла построчного чтения; sed здесь проще и надёжнее.
  echo "$out" | sed "s|^|[$rel] |"
  # _cleanup_sandbox (В3) — chmod -R u+rwx перед rm -rf (тест мог сам себе ограничить права
  # внутри своей же песочницы) + проверка результата с сообщением оператору, вместо
  # непроверяемого голого `rm -rf`. Она же — обработчик EXIT/INT/TERM (см. заголовок файла) —
  # здесь вызывается ЯВНО в штатном пути, чтобы не копить песочницы до самого конца всего
  # прогона (много тестов подряд), trap остаётся страховкой ТОЛЬКО на случай прерывания.
  _cleanup_sandbox

  if [ "$rc" -eq 0 ]; then
    echo "PASS: $rel"
    RUN_ONE_STATUS=0
  else
    echo "FAIL: $rel (rc=$rc)"
    RUN_ONE_STATUS=1
  fi
}

# -----------------------------------------------------------------------------------------
# CLI
# -----------------------------------------------------------------------------------------
list_only=false
declare -a selected=()

for arg in "$@"; do
  case "$arg" in
    --help|-h) usage; exit 0 ;;
    --list) list_only=true ;;
    tests/*) selected+=("$arg") ;;
    *) selected+=("tests/$arg") ;;
  esac
done

declare -a all_tests=()
while IFS= read -r line; do
  [ -n "$line" ] && all_tests+=("$line")
done < <(discover)

if [ "${#selected[@]}" -eq 0 ]; then
  declare -a candidates=("${all_tests[@]}")
else
  declare -a candidates=()
  for rel in "${selected[@]}"; do
    found=false
    for known in "${all_tests[@]}"; do
      [ "$known" = "$rel" ] && { found=true; break; }
    done
    if [ "$found" = false ]; then
      echo "tests/run: '$rel' не найден среди tests/*.test.sh|*.test.mjs (см. tests/run --list)" >&2
      exit 1
    fi
    candidates+=("$rel")
  done
fi

if [ "$list_only" = true ]; then
  echo "Обнаружено (${#all_tests[@]}):"
  for rel in "${all_tests[@]}"; do
    list_abs="$_RUN_TESTS_DIR/${rel#tests/}"
    if is_quarantined "$rel" "$list_abs"; then
      echo "  [КАРАНТИН] $rel — $(quarantine_reason "$rel" "$list_abs")"
    else
      echo "  $rel"
    fi
  done
  exit 0
fi

declare -a passed=() failed=() quarantined=()
for rel in "${candidates[@]}"; do
  echo "=== $rel ==="
  RUN_ONE_STATUS=1
  run_one "$rel"
  case "$RUN_ONE_STATUS" in
    0) passed+=("$rel") ;;
    2) quarantined+=("$rel") ;;
    *) failed+=("$rel") ;;
  esac
done

echo "-----------------------------------------------------------------"
echo "Итог: ${#passed[@]} passed, ${#failed[@]} failed, ${#quarantined[@]} quarantined из ${#candidates[@]}"
[ "${#failed[@]}" -eq 0 ] || { printf 'FAILED: %s\n' "${failed[@]}"; }
[ "${#quarantined[@]}" -eq 0 ] || { printf 'QUARANTINED: %s\n' "${quarantined[@]}"; }

[ "${#failed[@]}" -eq 0 ]
