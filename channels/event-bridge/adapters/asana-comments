#!/bin/bash
# asana-comments — event-bridge probe: print NEW Asana comments (one per line).
#
# Single-shot (the bridge loops it on its interval). Mirrors the polling/dedup
# of server_monitor/asana_reply_watch.sh (the donor) but is source-only: no
# Telegram, no loop — it just prints new comments for the bridge to push as data.
#
# Baseline/dedup: a per-(task,author) baseline file holds the latest seen
# comment timestamp. First run establishes baseline=now and prints nothing
# (so a fresh worker is not flooded with history). Later runs print author
# comments created strictly after baseline, then advance baseline. The bridge
# also dedups by line hash, so restarts never double-push.
#
# EDIT detection: an edited story keeps its gid and created_at (only text and
# is_edited change; is_edited stays true forever, so it cannot distinguish a
# 2nd edit from the 1st). We therefore keep a per-story CONTENT fingerprint
# (sha256, first 32 hex) in .asana-comments-<key>.fingerprints ("gid<TAB>hash"
# lines). A story whose current content differs from its stored fingerprint is
# emitted as an "[edited]" line whose hidden marker id is <gid>@e<current-hash>
# — a distinct dedup key per content VERSION. Stored fingerprints are
# write-once per gid (content as FIRST seen): like the ts baseline, we never
# advance them on print — the line re-prints every poll and dedup-after-delivery
# stays the bridge's job (.seen after successful inject), so an edit whose
# injection failed (worker busy) is retried, not lost, while a delivered edit
# never re-wakes (same key). First fetch with no fingerprint file registers ALL
# existing comments silently (migration: history is never replayed as edits).
# Both the fingerprint state and the "[edited]" emission are gated on
# EB_ASANA_EMIT_ID=1 — a legacy (marker-unaware) runner gets the byte-identical
# old behavior.
#
# Token: ASANA_ACCESS_TOKEN from /home/rainor/server/.env (Bearer via curl
# --config so it never appears in argv).
#
# Usage:
#   asana-comments --task <gid> [--author <gid>] [--state-dir <dir>] [--project <gid>]
set -u

# Test seams (mirror adapters/asana-project): env-file and API-base overrides.
ENV_FILE="${ASANA_COMMENTS_ENV_FILE:-/home/rainor/server/.env}"
API_BASE="${ASANA_COMMENTS_API_BASE:-https://app.asana.com/api/1.0}"
STATE_DIR_DEFAULT="$(cd "$(dirname "$0")/.." && pwd)/state"

TASK_GID=""
AUTHOR_GID=""           # empty = any author
STATE_DIR="$STATE_DIR_DEFAULT"
PROJECT_GID=""

die() { echo "asana-comments: $*" >&2; exit 1; }

while [ $# -gt 0 ]; do
  case "$1" in
    --task) TASK_GID="${2:-}"; shift 2 ;;
    --author) AUTHOR_GID="${2:-}"; shift 2 ;;
    --state-dir) STATE_DIR="${2:-}"; shift 2 ;;
    --project) PROJECT_GID="${2:-}"; shift 2 ;;
    -h|--help) grep '^#' "$0" | sed 's/^# \?//'; exit 0 ;;
    *) [ -z "$TASK_GID" ] && { TASK_GID="$1"; shift; } || die "unexpected arg: $1" ;;
  esac
done
[ -n "$TASK_GID" ] || die "--task <gid> required"
command -v jq >/dev/null 2>&1 || die "jq not found"

ASANA_TOKEN=$(grep -E '^ASANA_ACCESS_TOKEN=' "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2-)
ASANA_TOKEN=${ASANA_TOKEN%\"}; ASANA_TOKEN=${ASANA_TOKEN#\"}
ASANA_TOKEN=${ASANA_TOKEN%\'}; ASANA_TOKEN=${ASANA_TOKEN#\'}
ASANA_TOKEN=$(printf '%s' "$ASANA_TOKEN" | tr -d '[:space:]')
[ -n "$ASANA_TOKEN" ] || die "ASANA_ACCESS_TOKEN empty/missing in $ENV_FILE"

mkdir -p "$STATE_DIR" 2>/dev/null || die "cannot create state dir $STATE_DIR"
BASE_KEY="$TASK_GID"; [ -n "$AUTHOR_GID" ] && BASE_KEY="${TASK_GID}-${AUTHOR_GID}"
BASELINE_FILE="${STATE_DIR}/.asana-comments-${BASE_KEY}.baseline"
FPR_FILE="${STATE_DIR}/.asana-comments-${BASE_KEY}.fingerprints"
FPR_TMP=""

CURL_CFG=$(mktemp /tmp/.asana-comments-curl.XXXXXX) || die "mktemp curl cfg"
trap 'rm -f "$CURL_CFG" ${FPR_TMP:+"$FPR_TMP"}' EXIT
chmod 600 "$CURL_CFG"
printf 'header = "Authorization: Bearer %s"\n' "$ASANA_TOKEN" > "$CURL_CFG"

# T8 п.4: отметка времени с НАСТОЯЩИМИ миллисекундами вместо литеральных ".000".
#
# ЧТО ЧИНИТ. Эта отметка становится write-once baseline'ом (см. ниже), а он сравнивается со
# СТРОКАМИ created_at из Asana лексикографически (`select(.created_at > $ts)`). Обрубая
# дробную часть, мы записывали момент «сейчас» задним числом на величину до целой секунды:
# коммент, созданный в ту же секунду, но ПОЗЖЕ старта первого прогона, выглядел новее
# baseline'а и выдавался повторно. Окна реплея у этого адаптера нет, поэтому флака (как в T7
# у adapters/asana-project) здесь не было — оставалось узкое окно повторной выдачи.
#
# ШИРИНА — РОВНО 3 ЗНАКА, тот же вывод, что в T7 (см. iso-t7-report.md): created_at у Asana
# всегда с тремя цифрами, а лексикографическое сравнение требует ОДНОГО домена. Микросекунды
# ломают его в обратную сторону: "…00.123456Z" лексикографически МЕНЬШЕ "…00.123Z" (после
# '.123' сравниваются '4' и 'Z'), хотя во времени больше — водяной знак откатывался бы
# назад. Ширина 3 совпадает с той, что этот файл писал всегда, поэтому УЖЕ записанные
# ".000Z"-baseline'ы остаются в том же домене сравнения и миграции не требуют.
#
# ФОЛБЭК на прежнюю строку, если `date` не GNU (%3N не поддержан): лучше сегодняшнее
# поведение, чем мусор в baseline — мусорная строка сломала бы сравнение целиком (либо поток
# дублей, либо молчащий датчик). Проверяем ФОРМУ вывода, а не платформу: `?` в case-глобе —
# ровно один символ, так что и длина, и раскладка обязаны совпасть.
now_ts() {
  local t
  t="$(date -u '+%Y-%m-%dT%H:%M:%S.%3NZ')"
  case "$t" in
    ????-??-??T??:??:??.???Z) printf '%s\n' "$t" ;;
    *) date -u '+%Y-%m-%dT%H:%M:%S.000Z' ;;
  esac
}

# Anti-runaway guard (NOT a data limit): caps the pagination loop so a buggy/cyclic
# offset from Asana can't spin forever if this adapter is ever run outside the watcher's
# `timeout`. 1000 pages = 100k stories — unreachable in practice. The real bound is the
# probe's `timeout` in event-bridge-watch (~30s ≈ 50 fast pages).
SANITY_MAX_PAGES="${ASANA_COMMENTS_MAX_PAGES:-1000}"
{ [[ "$SANITY_MAX_PAGES" =~ ^[0-9]+$ ]] && [ "$SANITY_MAX_PAGES" -ge 1 ]; } || SANITY_MAX_PAGES=1000

# Fetch ALL pages of stories and emit one combined {data:[...]} on stdout.
# Asana returns stories OLDEST-FIRST, so recent comments live on the LAST page — we
# MUST follow next_page to the end (a single page silently loses recent comments once
# a task accumulates >100 stories). Any page failure -> return 1 so the caller fail-opens
# (exit 0, retry next poll) and never emits a partial view.
fetch_all_stories() {
  local pages="" page i=0
  # Follow Asana's own next_page.uri (opaque, already URL-encoded) rather than
  # hand-building &offset= — never assume the token's character set.
  local next="${API_BASE}/tasks/${TASK_GID}/stories?limit=100&opt_fields=gid,created_at,created_by.gid,created_by.name,text,type"
  while [ -n "$next" ]; do
    i=$((i+1))
    if [ "$i" -gt "$SANITY_MAX_PAGES" ]; then
      echo "asana-comments: SANITY page guard ($SANITY_MAX_PAGES) hit for task $TASK_GID — aborting (likely API/offset bug)" >&2
      return 1
    fi
    page=$(curl -fsS --max-time 30 --config "$CURL_CFG" "$next" 2>/dev/null) || return 1
    # Require data to be a real array — a malformed {"data":null} must NOT pass as an
    # empty page (that would silently drop this page's stories).
    printf '%s' "$page" | jq -e '(.data | type) == "array"' >/dev/null 2>&1 || return 1
    pages="${pages}${page}"$'\n'
    next=$(printf '%s' "$page" | jq -r '.next_page.uri // empty' 2>/dev/null)
  done
  printf '%s' "$pages" | jq -s '{data: (map(.data[]?))}'
}

# First run: set baseline=now, print nothing.
if [ ! -f "$BASELINE_FILE" ]; then
  now_ts > "$BASELINE_FILE"
  exit 0
fi
BASELINE_TS=$(cat "$BASELINE_FILE" 2>/dev/null)
[ -n "$BASELINE_TS" ] || { BASELINE_TS=$(now_ts); echo "$BASELINE_TS" > "$BASELINE_FILE"; }

combined=$(fetch_all_stories) || exit 0
printf '%s' "$combined" | jq -e '(.data | type) == "array"' >/dev/null 2>&1 || exit 0

# Self-echo suppression: the worker posts comments under the SAME Asana identity
# as the human (Maxim), so we cannot filter by author. Instead, a PostToolUse hook
# (claude-auto-asana-self-ledger) records the story GID of every comment THIS
# worker posts into this ledger; we drop those GIDs here. Human-Maxim and
# third-party comments carry other GIDs → still emitted. The ledger is read into
# an --arg string (not --rawfile) so a missing/empty ledger just means "exclude
# nothing" — never a fetch-time failure that would silence real comments.
SELF_LEDGER="${STATE_DIR}/.asana-self-stories"
self_gids=""
if [ -f "$SELF_LEDGER" ] && [ ! -L "$SELF_LEDGER" ]; then
  # Bound the read (tail, not cat): the hook caps the ledger at 2000 lines, but a
  # ledger poisoned out-of-band could be huge and make `jq --arg` fail on argument
  # size → that would silence ALL real comments this poll. 5000 >> hook cap (2000)
  # >> fetch window (limit=100), so this never drops a legitimately-ledgered GID.
  self_gids="$(tail -n 5000 "$SELF_LEDGER" 2>/dev/null)"
fi

# Print author comments newer than the WRITE-ONCE baseline. We deliberately do
# NOT advance the baseline here: dedup-after-delivery is the bridge's job (its
# per-probe .seen is updated only after a successful inject). If we advanced the
# baseline on print, an event whose injection later failed (worker busy/blocked)
# would never be re-printed and would be lost. So we re-print the (small) window
# of post-baseline author comments each poll; the bridge dedups what it already
# delivered. The baseline only caps how far back we ever look (set on first run).
# When EB_ASANA_EMIT_ID=1 (set only by a marker-aware event-bridge-watch), prepend a
# HIDDEN stable-id marker  \x1eebid=<story_gid>\x1e  so the watcher can dedup by the immutable story gid instead of the whole
# line (an edited comment does not re-fire THIS line; the edit-detection block below
# emits it as its own "[edited]" event instead).
# The VISIBLE part after the marker is byte-identical to the legacy line, so an old
# (marker-unaware) watcher — which never sets the env — keeps getting the exact prior
# output, and the watcher's legacy-hash back-compat path recognizes already-seen lines.
printf '%s' "$combined" | jq -r --arg ts "$BASELINE_TS" --arg author "$AUTHOR_GID" --arg self "$self_gids" --arg emitid "${EB_ASANA_EMIT_ID:-}" '
  ($self | split("\n") | map(select(length>0))) as $selfids
  | .data[]
  | select(.type=="comment")
  | select(.created_at > $ts)
  | select($author=="" or (.created_by.gid==$author))
  | select(((.gid // "") | tostring) as $g | ($g=="" or ($selfids | index($g) | not)))
  | (if $emitid=="1" then "ebid=\((.gid // "")|tostring)" else "" end)
    + "[asana \(.created_at)] \(.created_by.name // .created_by.gid): \((.text // "") | gsub("[\r\n]+";" "))"
'

# --- edit detection (marker-aware runners only; see header) -------------------
# The fingerprint map covers EVERY comment story regardless of baseline/author/
# self filters (those apply at EMISSION) — edits of PRE-baseline comments are
# detected too, which the ts-window above can never see.
if [ "${EB_ASANA_EMIT_ID:-}" = "1" ]; then
  # "gid<TAB>base64(text)" per comment story; the fingerprint is sha256 of the
  # @base64 string (deterministic for a given text; first 32 hex, like the
  # watcher's legacy hash).
  fpr_tsv=$(printf '%s' "$combined" | jq -r '
    .data[] | select(.type=="comment")
    | [((.gid // "") | tostring), ((.text // "") | @base64)] | @tsv')
  if [ ! -f "$FPR_FILE" ]; then
    # Migration/first fetch: register every existing comment silently — history
    # (including pre-deploy edits) must never replay as "[edited]". Temp+mv in
    # the state dir so a crash mid-write can't leave a torn map (a torn hash
    # would fire a spurious edit).
    FPR_TMP=$(mktemp "${FPR_FILE}.XXXXXX" 2>/dev/null) && {
      while IFS=$'\t' read -r gid b64; do
        [ -n "$gid" ] || continue
        printf '%s\t%s\n' "$gid" "$(printf '%s' "$b64" | sha256sum | cut -c1-32)"
      done <<< "$fpr_tsv" > "$FPR_TMP"
      mv -f "$FPR_TMP" "$FPR_FILE" && FPR_TMP=""
    }
  else
    # Load stored fingerprints (last line wins — a raced duplicate registration
    # then converges on the newer content instead of firing a spurious edit).
    declare -A FPR=()
    while IFS=$'\t' read -r gid h; do
      [ -n "$gid" ] && FPR[$gid]="$h"
    done < "$FPR_FILE"
    changed=""   # "gid<TAB>current-hash" lines -> formatted by jq below
    while IFS=$'\t' read -r gid b64; do
      [ -n "$gid" ] || continue
      h=$(printf '%s' "$b64" | sha256sum | cut -c1-32)
      if [ -z "${FPR[$gid]:-}" ]; then
        # First sighting of this gid: register only (single appended line —
        # O_APPEND, no torn-map risk). The new-comment window above already
        # emits it; a same-poll create+edit is indistinguishable anyway (we
        # fingerprint the text as first seen).
        printf '%s\t%s\n' "$gid" "$h" >> "$FPR_FILE"
      elif [ "${FPR[$gid]}" != "$h" ]; then
        changed+="$gid"$'\t'"$h"$'\n'
      fi
    done <<< "$fpr_tsv"
    # Emit one "[edited]" line per changed story. Marker id <gid>@e<hash> gives
    # the bridge a distinct dedup key per content VERSION: the same edit
    # re-prints every poll (retry until delivered, then .seen silences it), a
    # NEWER edit gets a new key and fires again. Author/self filters mirror the
    # new-comment path (Asana does not expose WHO edited; created_by is the
    # original author; edits of the worker's own ledgered comments stay muted).
    if [ -n "$changed" ]; then
      printf '%s' "$combined" | jq -r --arg author "$AUTHOR_GID" --arg self "$self_gids" --arg changed "$changed" '
        ($self | split("\n") | map(select(length>0))) as $selfids
        | ($changed | split("\n") | map(select(length>0) | split("\t") | {key: .[0], value: .[1]}) | from_entries) as $ch
        | .data[]
        | select(.type=="comment")
        | ((.gid // "") | tostring) as $g
        | $ch[$g] as $h
        | select($h != null)
        | select($author=="" or (.created_by.gid==$author))
        | select($selfids | index($g) | not)
        | "ebid=\($g)@e\($h)[asana \(.created_at)] [edited] \(.created_by.name // .created_by.gid): \((.text // "") | gsub("[\r\n]+";" "))"
      '
    fi
  fi
fi
exit 0
