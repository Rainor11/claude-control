#!/bin/bash
# dept-approve — открыть аппрув в ledger и запросить решение оператора через
# structured-approval бота (@RnR_Workers, карточка ✅/❌). Решение в ledger
# записывает БОТ (approval-resolve) — воркер сам аппрув НЕ закрывает, а ждёт
# инжект исхода и действует по нему.
# WORKER-ONLY: идентичность — spoof-resistant /proc-предок (resolve_name,
# дословно из claude-auto-request), НЕ env CLAUDE_AUTO_NAME текущего процесса.
# Раньше идентичность читалась из env CLAUDE_AUTO_NAME напрямую — лазейка:
# `CLAUDE_AUTO_NAME=чужое dept-approve …` подписывался чужим именем и обходил
# policy-турникет. resolve_name() поднимается по /proc-предкам до процесса с
# `--resume` в cmdline и exe внутри доверенного CLAUDE_INSTALL, и читает
# CLAUDE_AUTO_NAME из ЕГО собственного /proc/<pid>/environ — подмена в своём
# окружении ничего не даёт. Флага --actor нет намеренно (он позволял бы
# обходить policy-турникет подменой имени).
set -euo pipefail
CLAUDE_INSTALL="/home/rainor/.local/share/claude"        # trusted claude tree

die() { echo "dept-approve: $*" >&2; exit 1; }

# ---- identity (spoof-resistant) — дословно из claude-auto-request resolve_name --
resolve_name() {
  local pid="$PPID" depth=0 nm exe
  while [ "${pid:-0}" -gt 1 ] && [ "$depth" -lt 25 ]; do
    # --resume ИЛИ --session-id — fresh-запуск spawn/rebase (claude --session-id <W>
    # без --resume до первого рестарта). Остальные проверки (exe в CLAUDE_INSTALL,
    # CLAUDE_AUTO_NAME из environ предка) не меняются — спуф-стойкость сохранена.
    if tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null | grep -qxE -- '--resume|--session-id'; then
      exe="$(readlink -f "/proc/$pid/exe" 2>/dev/null)"
      case "$exe" in
        "$CLAUDE_INSTALL"/*)
          nm="$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | sed -n 's/^CLAUDE_AUTO_NAME=//p' | head -1)"
          [ -n "$nm" ] && { printf '%s' "$nm"; return 0; }
          ;;
      esac
    fi
    pid="$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null)"
    depth=$((depth+1))
  done
  return 1
}

kind_of="" summary="" detail="" request_json=""
while [ $# -gt 0 ]; do
  case "$1" in
    --kind-of) kind_of="$2"; shift 2 ;;
    --summary) summary="$2"; shift 2 ;;
    --detail) detail="$2"; shift 2 ;;
    --request-json) request_json="$2"; shift 2 ;;
    *) die "unknown arg: $1" ;;
  esac
done
# DEPT_APPROVE_TEST_ACTOR — тестовый bypass ТОЛЬКО для tests/dept-approve.test.sh (там нет
# настоящего /proc-предка с --resume). Боевые рамки (supervisor/tmux воркера) её не
# выставляют — в проде единственный источник identity — resolve_name().
actor="$(resolve_name)" || actor="${DEPT_APPROVE_TEST_ACTOR:-}"
[ -n "$actor" ] || { echo 'dept-approve: запускается только из сессии воркера' >&2; exit 1; }
[ -n "$kind_of" ] && [ -n "$summary" ] || { echo 'usage: dept-approve --kind-of <k> --summary <s> [--detail <d>]' >&2; exit 1; }
# Пре-валидация ДО открытия аппрува в ledger: claude-auto-request отвергает summary >400
# уже ПОСЛЕ approval-open, оставляя orphan-open аппрув (оператор увидит открытый, но
# никогда не доставленный запрос). Отсекаем здесь, до первой записи в ledger.
[ "${#summary}" -le 400 ] || { echo 'dept-approve: --summary длиннее 400 символов — сократи (полный текст клади в --detail)' >&2; exit 1; }
BINDIR="$(cd "$(dirname "$0")" && pwd)"
DL="$BINDIR/dept-ledger"
RQ="$BINDIR/claude-auto-request"
# Policy-турникет (§6 спеки: решение «по памяти» запрещено механически). Без исключений.
"$DL" policy-check --worker "$actor" >/dev/null || exit 1
args=(approval-open --kind-of "$kind_of" --summary "$summary" --actor "$actor")
[ -n "$detail" ] && args+=(--detail "$detail")
[ -n "$request_json" ] && args+=(--request-json "$request_json")
out="$("$DL" "${args[@]}")"
eid="$(echo "$out" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>console.log(JSON.parse(s).event_id))')"
# КРИТИЧНО: ошибку постановки запроса НЕ глотать — иначе открытый аппрув повиснет,
# а оператор о нём не узнает (это главный safety-gate отдела).
rq_args=(--action dept-approval --event-id "$eid" --summary "$summary")
[ -n "$detail" ] && rq_args+=(--detail "$detail")
if ! "$RQ" "${rq_args[@]}"; then
  echo "dept-approve: НЕ удалось передать запрос оператору (approval $eid остаётся open). Эскалируй другим каналом (claude-auto-tg) и повтори." >&2
  exit 1
fi
echo "$out"
