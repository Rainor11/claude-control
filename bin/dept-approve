#!/bin/bash
# dept-approve — открыть аппрув в ledger и запросить решение оператора через
# structured-approval бота (@RnR_Workers, карточка ✅/❌). Решение в ledger
# записывает БОТ (approval-resolve) — воркер сам аппрув НЕ закрывает, а ждёт
# инжект исхода и действует по нему.
# WORKER-ONLY: идентичность — из CLAUDE_AUTO_NAME (ставит супервизор); флага
# --actor нет намеренно (он позволял бы обходить policy-турникет подменой имени).
set -euo pipefail
kind_of="" summary="" detail=""
while [ $# -gt 0 ]; do
  case "$1" in
    --kind-of) kind_of="$2"; shift 2 ;;
    --summary) summary="$2"; shift 2 ;;
    --detail) detail="$2"; shift 2 ;;
    *) shift ;;
  esac
done
actor="${CLAUDE_AUTO_NAME:-}"
[ -n "$actor" ] || { echo 'dept-approve: запускается только из сессии воркера (нет CLAUDE_AUTO_NAME)' >&2; exit 1; }
[ -n "$kind_of" ] && [ -n "$summary" ] || { echo 'usage: dept-approve --kind-of <k> --summary <s> [--detail <d>]' >&2; exit 1; }
BINDIR="$(cd "$(dirname "$0")" && pwd)"
DL="$BINDIR/dept-ledger"
RQ="$BINDIR/claude-auto-request"
# Policy-турникет (§6 спеки: решение «по памяти» запрещено механически). Без исключений.
"$DL" policy-check --worker "$actor" >/dev/null || exit 1
args=(approval-open --kind-of "$kind_of" --summary "$summary" --actor "$actor")
[ -n "$detail" ] && args+=(--detail "$detail")
out="$("$DL" "${args[@]}")"
eid="$(echo "$out" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>console.log(JSON.parse(s).event_id))')"
# КРИТИЧНО: ошибку постановки запроса НЕ глотать — иначе открытый аппрув повиснет,
# а оператор о нём не узнает (это главный safety-gate отдела).
rq_args=(--action dept-approval --event-id "$eid" --summary "$summary")
[ -n "$detail" ] && rq_args+=(--detail "$detail")
if ! "$RQ" "${rq_args[@]}"; then
  echo "dept-approve: НЕ удалось передать запрос оператору (approval $eid остаётся open). Эскалируй другим каналом (claude-auto-tg) и повтори." >&2
  exit 1
fi
echo "$out"
