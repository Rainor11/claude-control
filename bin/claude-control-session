#!/usr/bin/env bash
# claude-control-session: service entrypoint for the always-on "control"
# remote-control session. It runs claude in the ~/.claude-control directory,
# so the project-level CLAUDE.md there is loaded as context.
# ГРАНИЦА ДЛЯ ТЕСТОВ (В2, ревью T8): этот скрипт НАЗНАЧАЕТ СЕБЕ PATH — значит PATH-shadow
# раннера (tests/run кладёт свой stub_dir первым) сюда НЕ доживает, и голое имя `claude` в
# `${CLAUDE_BIN:-claude}` ниже искалось бы по ЭТОМУ списку. Поэтому tests/run форсит
# CLAUDE_BIN на заглушку внутри песочницы (раньше он его просто unset'ил, и тест зависел от
# того, что настоящий claude лежит в подменённом $HOME/.local/bin — случайность, не граница).
# Кто добавит сюда ещё один вызов внешнего бинаря голым именем — обязан завести ему такой же
# явный шов, PATH его не прикроет.
case "$(uname -s)" in
  Darwin) export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/bin:/usr/bin:/bin" ;;
  *)      export PATH="$HOME/.local/bin:$HOME/bin:/usr/local/bin:/usr/bin:/bin" ;;
esac

# Optional env overrides (CLAUDE_BIN, proxy vars). On Linux the systemd unit
# already sources this via EnvironmentFile; we source it here too so macOS/launchd
# (no EnvironmentFile) and manual runs honor the same file. Auto-export so children
# spawned during the session (claude-rc -> project sessions) inherit the values.
ENV_FILE="${CLAUDE_CONTROL_ENV_FILE:-$HOME/.config/claude-control/env}"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck source=/dev/null
  . "$ENV_FILE"
  set +a
fi

# T8 п.3: корень рантайма — через единый резолвер (lib/runtime-root.sh, задача T1), как у
# остальных control_only-точек после T5; до этого файл резолвил $HOME/.claude-control сам,
# мимо резолвера. Source стоит ПОСЛЕ загрузки ENV_FILE выше — намеренно: если оператор
# положил в env-файл CLAUDE_CONTROL_DIR, резолвер обязан его увидеть (control_only это и
# значит). Библиотека НЕ ставит `set -u` (см. её шапку), поэтому подключение в скрипт без
# `set -u` ничего ему не навязывает.
#
# `readlink -f "$0"` ОБЯЗАТЕЛЕН: install.sh кладёт этот файл в ~/.local/bin СИМЛИНКОМ на
# репозиторий (проверено на живом сервере), а ~/.local/lib пуст — без разыменования
# `dirname "$0"/../lib` промахнулся бы и ExecStart юнита claude-control.service упал бы.
_t8_self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
_t8_bindir="$(cd "$(dirname "$_t8_self")" && pwd)"
# shellcheck disable=SC1091
. "$_t8_bindir/../lib/runtime-root.sh"
CONTROL_DIR="$(resolve_runtime_root control_only)" || exit 1

cd "$CONTROL_DIR" || exit 1
# --debug-file gives the watchdog a real liveness signal: it records actual
# network/poll activity, unlike control.log which only updates on TUI redraws and
# so looks identical when healthy-idle vs frozen ("zombie-Connected" after a 403
# flap). The watchdog heartbeats on this file's mtime. logrotate caps its growth.
DEBUG_FILE="${CLAUDE_CONTROL_DEBUG_FILE:-$CONTROL_DIR/control.debug.log}"
exec "${CLAUDE_BIN:-claude}" remote-control --name control --capacity 1 \
  --debug-file "$DEBUG_FILE"
