#!/usr/bin/env bash
# claude-control-session: entrypoint for the always-on "control" remote-control
# session, run by launchd on macOS or systemd --user on Linux. It runs claude
# in the ~/.claude-control directory so the project-level CLAUDE.md there is
# loaded as context.
#
# PATH:
#   1. Directory this script lives in — handles `./install.sh --prefix DIR`
#      so claude-rc and friends are found by the dispatcher's bash tool.
#   2. Standard user prefixes — $HOME/.local/bin is where the official claude
#      installer puts the binary on both platforms.
#   3. Homebrew prefixes for macOS, then /usr/local/bin, /usr/bin, /bin.
# CLAUDE_BIN: override the binary name without editing this script (useful
# when the user installs the CLI under a different name or via a wrapper).
self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$self_dir:$HOME/.local/bin:$HOME/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
cd "$HOME/.claude-control" || exit 1
exec "${CLAUDE_BIN:-claude}" remote-control --name control --capacity 1
