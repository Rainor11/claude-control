#!/usr/bin/env bash
# claude-control-watchdog: periodic check that the control remote-control session
# is still actually talking to the server. The supervisor (launchd/systemd) keeps
# the *process* alive, but the process can wedge into a "zombie-Connected" state:
# the TUI keeps rendering its last "Connected" frame while the backend poll loop
# has died (e.g. after a 403 flap when a VPN drops). KeepAlive never fires because
# the process did not exit.
#
# Why not just scrape control.log: a healthy *idle* session and a frozen zombie
# look identical there - both show the last "control ... Connected" frame and then
# go silent. So control.log presence/freshness cannot tell them apart.
#
# The reliable signal is the --debug-file the control session now writes (see
# claude-control-session). It records the real bridge poll loop:
#   [bridge:api] GET .../work/poll -> 200 (no work, N consecutive empty polls)
# Behavior we rely on:
#   - healthy idle: a long-poll holds the GET open for minutes, so the file goes
#     SILENT between polls, but the last bridge:api line is a 2xx.
#   - VPN/network down, still trying: polls return 403 *immediately*, so the file
#     is written rapidly (fresh mtime) and the last status is an error. This path
#     self-heals when the network returns - we must NOT kick it.
#   - zombie: the poll loop stopped writing entirely -> mtime goes stale and keeps
#     aging. THIS is what we kick.
#
# Decision (see session_state):
#   age      = seconds since the debug file was last written
#   last     = HTTP status of the last [bridge:api] line (2xx healthy / else error)
#   healthy        : age < STALE_SECONDS (loop is actively writing - poll or retry)
#   healthy (wait) : last is 2xx and age < MAX_STALE_SECONDS (normal long-poll gap)
#   active-retry   : last is an error and age < STALE_SECONDS (network down, trying)
#   frozen         : otherwise -> suspected zombie -> kick
# A frozen verdict must repeat for MISS_THRESHOLD consecutive ticks before we kick,
# and only if armed (CLAUDE_CONTROL_WATCHDOG_ARM=1); otherwise we log-only (dry run).
set -u

OS_KIND="$(uname -s)"
case "$OS_KIND" in
  Darwin) export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/bin:/usr/bin:/bin" ;;
  *)      export PATH="$HOME/.local/bin:$HOME/bin:/usr/local/bin:/usr/bin:/bin" ;;
esac

# T8 п.3: корень рантайма — через единый резолвер (lib/runtime-root.sh, задача T1), как у
# остальных control_only-точек после T5; до этого файл резолвил $HOME/.claude-control сам,
# мимо резолвера. Из той же библиотеки (transitively через process-control.sh) берётся guard
# процесс-контроля для kick() ниже.
#
# `readlink -f "$0"` ОБЯЗАТЕЛЕН: install.sh кладёт этот файл в ~/.local/bin СИМЛИНКОМ на
# репозиторий (проверено на живом сервере), а ~/.local/lib пуст — без разыменования
# `dirname "$0"/../lib` промахнулся бы и source упал. Переменная `self_dir` ниже (резолв
# соседнего claude-control-logrotate) НАМЕРЕННО остаётся без readlink: у неё другая
# семантика — «хелпер из ТОГО ЖЕ install'а», см. комментарий на месте.
_t8_self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
_t8_bindir="$(cd "$(dirname "$_t8_self")" && pwd)"
# shellcheck disable=SC1091
. "$_t8_bindir/../lib/process-control.sh"
CONTROL_DIR="$(resolve_runtime_root control_only)" || exit 1

LOG="${CLAUDE_CONTROL_LOG:-$CONTROL_DIR/control.log}"
DEBUG_FILE="${CLAUDE_CONTROL_DEBUG_FILE:-$CONTROL_DIR/control.debug.log}"
WLOG="${CLAUDE_CONTROL_WATCHDOG_LOG:-$CONTROL_DIR/watchdog.log}"
# Default LABEL depends on supervisor: launchd uses reverse-DNS, systemd
# uses a fixed unit name.
case "$OS_KIND" in
  Darwin) LABEL="${CLAUDE_CONTROL_LABEL:-com.${USER}.claude-control}" ;;
  *)      LABEL="${CLAUDE_CONTROL_LABEL:-claude-control.service}" ;;
esac
SESSION_NAME="${CLAUDE_CONTROL_SESSION_NAME:-control}"

ts() { date '+%Y-%m-%d %H:%M:%S'; }

# SESSION_NAME is interpolated into a grep -E pattern in heartbeat_seen below
# (the legacy fallback). Restrict it to a safe charset (same as project names) so
# an override like '.*' can't turn the heartbeat into an always-match.
if [[ ! "$SESSION_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "$(ts) invalid CLAUDE_CONTROL_SESSION_NAME='${SESSION_NAME}', using 'control'" >> "$WLOG"
  SESSION_NAME="control"
fi

# Freshness tuning. STALE_SECONDS: below this the poll loop is actively writing
# (a long-poll just returned, or it's retrying fast) so the session is alive.
# MAX_STALE_SECONDS: an absolute ceiling that must sit ABOVE the healthy long-poll
# duration; past it we treat even a "last poll was 2xx" session as frozen. Kick
# only after MISS_THRESHOLD consecutive frozen ticks; count persisted in MISS_FILE.
STALE_SECONDS="${CLAUDE_CONTROL_STALE_SECONDS:-150}"
MAX_STALE_SECONDS="${CLAUDE_CONTROL_MAX_STALE_SECONDS:-900}"
MISS_THRESHOLD="${CLAUDE_CONTROL_MISS_THRESHOLD:-2}"
MISS_FILE="${CLAUDE_CONTROL_MISS_FILE:-$CONTROL_DIR/.watchdog-misses}"
# ARM gates the actual kick. Default 0 = dry run (log the verdict, never restart),
# so the detector can be calibrated against real traffic before it's allowed to
# kill a session. Set to 1 to arm.
ARM="${CLAUDE_CONTROL_WATCHDOG_ARM:-0}"
# Guard numeric tunables: a non-integer override would crash arithmetic under set -u.
[[ "$STALE_SECONDS"     =~ ^[1-9][0-9]*$ ]] || STALE_SECONDS=150
[[ "$MAX_STALE_SECONDS" =~ ^[1-9][0-9]*$ ]] || MAX_STALE_SECONDS=900
[[ "$MISS_THRESHOLD"    =~ ^[1-9][0-9]*$ ]] || MISS_THRESHOLD=2

esc=$'\033'
# Drop CSI escape sequences so TUI redraw noise doesn't split the session name
# from its whitespace boundary before we grep for it (legacy fallback only).
strip_ansi() { sed -E "s/${esc}\\[[0-9;?]*[a-zA-Z]//g"; }

# kick the supervisor to restart the control unit.
#
# T8 п.3: linux-ветка идёт через guard процесс-контроля (process_control_systemctl, T2), а не
# голым `systemctl`. Это была ЕДИНСТВЕННАЯ оставшаяся точка, где боевой systemctl вызывался в
# обход шва: под маркером её прикрывала только PATH-заглушка раннера, то есть
# defense-in-depth вместо проверки. Паритет: без маркера guard делает
# `"${SYSTEMCTL:-systemctl}" "$@"` — при невыставленной SYSTEMCTL это буквально прежняя
# строка (тот же переопределяемый шов, что уже у bin/dept-liveness-exec).
#
# Darwin-ветка (`launchctl kickstart`) НЕ переведена: guard'а класса launchctl не существует,
# а выдумывать его ради ветки, недостижимой на этом сервере, — новая непроверяемая
# поверхность. Зафиксировано как известная граница, а не забыто.
kick() {
  case "$OS_KIND" in
    Darwin) launchctl kickstart -k "gui/$UID/$LABEL" ;;
    *)      process_control_systemctl --user restart "$LABEL" ;;
  esac
}

# Seconds since a file was last modified; large number if it doesn't exist.
file_age() {
  local f="$1" m now
  now="$(date +%s)"
  case "$OS_KIND" in
    Darwin) m="$(stat -f %m "$f" 2>/dev/null)" ;;
    *)      m="$(stat -c %Y "$f" 2>/dev/null)" ;;
  esac
  [[ "$m" =~ ^[0-9]+$ ]] || { echo 999999; return; }
  echo $(( now - m ))
}

# HTTP status of the last bridge poll/api line, or empty if none yet.
last_bridge_status() {
  tail -n 300 "$DEBUG_FILE" 2>/dev/null \
    | grep -E '\[bridge:api\].*-> [0-9]{3}' \
    | tail -1 | sed -E 's/.*-> ([0-9]{3}).*/\1/'
}

# A SEVERE agent-session fault the current bridge process has NOT recovered from.
# This is a DIFFERENT failure mode than the poll-loop health below: the bridge can
# keep polling happily (last status 2xx, file fresh) while the interactive session
# child has crashed and was never respawned — the app then shows the session as
# present but dead, and nothing self-heals until the unit is restarted. (Observed
# 2026-06-20: token-refresh 401 -> child exit_code=1 -> "Bridge session failed" ->
# bridge idle for ~2 days while still polling 200.) The poll-loop detector reads
# that as "healthy" forever, so we need this separate, order-based check.
#
# Detection by LOG ORDER (not timestamps — bash ISO8601 parsing is brittle across
# GNU/BSD), one awk pass over the WHOLE debug file (the fault scrolls far past any
# tail -N over days of polls; claude-control-logrotate trims the file in place so
# it stays small enough for a full scan each tick):
#   recovery = latest "Starting poll loop" (process re-registered) OR
#              latest "Spawning sessionId="  (this process accepted later work)
#   severe   = latest child exit whose code is NOT a clean/stop code (0/130/143).
#              A bare "status=failed" is NOT a crash signal: an intentional SIGTERM
#              logs exit_code=143 status=failed, so we key on the child EXIT CODE.
#   token    = latest "[bridge:token] reconnectSession(...) failed:"
# Frozen iff a severe exit (or a token failure paired with "Bridge session failed")
# is NEWER than the latest recovery. A restart or a later respawn makes recovery
# newest -> clears automatically (no re-kick loop). Echoes a reason and returns 0
# when faulted; returns 1 otherwise.
session_fault_after_recovery() {
  [[ -f "$DEBUG_FILE" ]] || return 1
  awk '
    /\[bridge:work\] Starting poll loop/         { if (NR > recovery) recovery = NR }
    /\[bridge:session\] Spawning sessionId=/      { if (NR > recovery) recovery = NR }
    /\[ERROR\] \[bridge:token\] reconnectSession\(.*\) failed:/ { token_fail = NR }
    /\[bridge:session\] sessionId=.* failed exit_code=/ {
      code = $0
      sub(/^.*failed exit_code=/, "", code)
      sub(/[^0-9].*$/, "", code)
      if (code != "" && code != "0" && code != "130" && code != "143") {
        severe = NR; why = "exit_code=" code
      }
    }
    /\[ERROR\] Bridge session failed: Process exited with error/ {
      if (severe > recovery || token_fail > recovery) {
        fault = NR; if (why == "") why = "bridge-session-failed"
      }
    }
    END {
      if (fault > recovery || severe > recovery) {
        printf "session-fault(%s)", (why != "" ? why : "unknown")
        exit 0
      }
      exit 1
    }
  ' "$DEBUG_FILE" 2>/dev/null
}

# Legacy fallback for sessions started without --debug-file: look for the session
# name as a standalone token in the recent control.log tail. 0 = seen, 1 = not.
HEARTBEAT_WINDOW="${CLAUDE_CONTROL_HEARTBEAT_WINDOW:-80}"
[[ "$HEARTBEAT_WINDOW" =~ ^[1-9][0-9]*$ ]] || HEARTBEAT_WINDOW=80
heartbeat_seen() {
  [[ -f "$LOG" ]] || return 1
  tail -n "$HEARTBEAT_WINDOW" "$LOG" | strip_ansi \
    | grep -qE "(^|[[:space:]])${SESSION_NAME}([[:space:]]|$)"
}

# Emit the session verdict on stdout: "healthy", "active-retry", or "frozen".
# No debug file yet (old session, or just (re)started) -> defer to the legacy
# control.log heartbeat so we don't false-kick during the transition / startup.
session_state() {
  # A crashed agent session that the bridge never respawned is frozen even when the
  # poll loop below still looks healthy — check it FIRST so fresh 2xx polling can't
  # mask a dead interactive session.
  if session_fault_after_recovery >/dev/null; then echo "frozen"; return; fi
  if [[ ! -f "$DEBUG_FILE" ]]; then
    if heartbeat_seen; then echo "healthy"; else echo "frozen"; fi
    return
  fi
  local age last
  age="$(file_age "$DEBUG_FILE")"
  last="$(last_bridge_status)"
  # Actively writing (a long-poll just returned, or fast 403 retries): alive.
  if (( age < STALE_SECONDS )); then echo "healthy"; return; fi
  # Silent, but the last poll succeeded: normal long-poll wait until the ceiling.
  if [[ "$last" == 2* ]] && (( age < MAX_STALE_SECONDS )); then echo "healthy"; return; fi
  # Silent after an error but not yet past STALE was handled above; reaching here
  # with an error status and age >= STALE means it failed then stopped retrying.
  echo "frozen"
}

# ---- logrotate (every tick, independent of control's health) ----
# Sibling-first (next to $0), then PATH - so a stale copy on PATH can't shadow the
# logrotate that ships with this watchdog install.
self_dir="$(cd "$(dirname "$0")" 2>/dev/null && pwd)" || self_dir=""
if [[ -n "$self_dir" && -x "$self_dir/claude-control-logrotate" ]]; then
  logrotate_bin="$self_dir/claude-control-logrotate"
else
  logrotate_bin="$(command -v claude-control-logrotate 2>/dev/null || true)"
fi
if [[ -n "$logrotate_bin" && -x "$logrotate_bin" ]]; then
  "$logrotate_bin" || true
fi

# ---- miss counter, persisted across ticks ----
read_misses() {
  local n
  n="$(cat "$MISS_FILE" 2>/dev/null || echo 0)"
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  printf '%s' "$n"
}
write_misses() { echo "$1" > "$MISS_FILE" 2>/dev/null || true; }

# ---- decide ----
state="$(session_state)"
age_now="$(file_age "$DEBUG_FILE")"
last_now="$(last_bridge_status)"
fault_now="$(session_fault_after_recovery || true)"
ctx="age=${age_now}s last=${last_now:-none}${fault_now:+ ${fault_now}}"

if [[ "$state" != "frozen" ]]; then
  write_misses 0
  exit 0
fi

misses=$(( $(read_misses) + 1 ))
if (( misses >= MISS_THRESHOLD )); then
  if [[ "$ARM" == 1 ]]; then
    echo "$(ts) frozen for ${misses} checks ($ctx) - kick $LABEL" >> "$WLOG"
    kick
  else
    echo "$(ts) frozen for ${misses} checks ($ctx) - WOULD kick $LABEL [dry-run, ARM=0]" >> "$WLOG"
  fi
  write_misses 0
else
  echo "$(ts) frozen ${misses}/${MISS_THRESHOLD} ($ctx) - no kick yet" >> "$WLOG"
  write_misses "$misses"
fi
