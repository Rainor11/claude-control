#!/usr/bin/env bash
# claude-control-watchdog: periodic check that the control remote-control
# session is still registered. The supervisor (launchd or systemd) keeps the
# process alive but does not know if the named session went away (the process
# can stay healthy while the session capacity drops to 0 and the phone-side
# entry disappears).
#
# Strategy: read the last lines of control.log and look for a heartbeat that
# mentions our session name (ANSI stripped). If we don't see one, sleep briefly
# and re-check to absorb a same-tick startup race; the miss is counted, and we
# only kick after MISS_THRESHOLD consecutive missed ticks, so one transient blip
# doesn't trigger a needless restart.
set -u

OS_KIND="$(uname -s)"
case "$OS_KIND" in
  Darwin) export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/bin:/usr/bin:/bin" ;;
  *)      export PATH="$HOME/.local/bin:$HOME/bin:/usr/local/bin:/usr/bin:/bin" ;;
esac

LOG="${CLAUDE_CONTROL_LOG:-$HOME/.claude-control/control.log}"
WLOG="${CLAUDE_CONTROL_WATCHDOG_LOG:-$HOME/.claude-control/watchdog.log}"
# Default LABEL depends on supervisor: launchd uses reverse-DNS, systemd
# uses a fixed unit name.
case "$OS_KIND" in
  Darwin) LABEL="${CLAUDE_CONTROL_LABEL:-com.${USER}.claude-control}" ;;
  *)      LABEL="${CLAUDE_CONTROL_LABEL:-claude-control.service}" ;;
esac
SESSION_NAME="${CLAUDE_CONTROL_SESSION_NAME:-control}"

ts() { date '+%Y-%m-%d %H:%M:%S'; }

# SESSION_NAME is interpolated into a grep -E pattern in heartbeat_seen below.
# Restrict it to a safe charset (same as project names) so an override like '.*'
# can't turn the heartbeat into an always-match. Fall back to the default.
if [[ ! "$SESSION_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "$(ts) invalid CLAUDE_CONTROL_SESSION_NAME='${SESSION_NAME}', using 'control'" >> "$WLOG"
  SESSION_NAME="control"
fi

# Soft heartbeat tuning (phase 2). Wider window than before (reconnect spam can
# push the name out of the last few lines); kick only after this many consecutive
# missed ticks; the miss count is persisted between ticks in MISS_FILE.
HEARTBEAT_WINDOW="${CLAUDE_CONTROL_HEARTBEAT_WINDOW:-80}"
MISS_THRESHOLD="${CLAUDE_CONTROL_MISS_THRESHOLD:-2}"
MISS_FILE="${CLAUDE_CONTROL_MISS_FILE:-$HOME/.claude-control/.watchdog-misses}"
# Guard the numeric tunables: a non-integer override (e.g. a typo) would crash the
# arithmetic below under set -u. Fall back to defaults on anything not a positive int.
[[ "$HEARTBEAT_WINDOW" =~ ^[1-9][0-9]*$ ]] || HEARTBEAT_WINDOW=80
[[ "$MISS_THRESHOLD"   =~ ^[1-9][0-9]*$ ]] || MISS_THRESHOLD=2

esc=$'\033'
# Drop CSI escape sequences so TUI redraw noise doesn't split the session name
# from its whitespace boundary before we grep for it.
strip_ansi() { sed -E "s/${esc}\\[[0-9;?]*[a-zA-Z]//g"; }

# kick the supervisor to restart the control unit.
kick() {
  case "$OS_KIND" in
    Darwin) launchctl kickstart -k "gui/$UID/$LABEL" ;;
    *)      systemctl --user restart "$LABEL" ;;
  esac
}

# heartbeat_seen: 0 = found, 1 = not found (or no log yet).
heartbeat_seen() {
  [[ -f "$LOG" ]] || return 1
  # Match SESSION_NAME as a whitespace-bounded token in the recent tail, after
  # stripping ANSI. We don't pin to specific bullet decoration (it has changed
  # before) - only that the name is present as a standalone word.
  tail -n "$HEARTBEAT_WINDOW" "$LOG" | strip_ansi \
    | grep -qE "(^|[[:space:]])${SESSION_NAME}([[:space:]]|$)"
}

# Consecutive-miss counter, persisted across watchdog ticks.
read_misses() {
  local n
  n="$(cat "$MISS_FILE" 2>/dev/null || echo 0)"
  [[ "$n" =~ ^[0-9]+$ ]] || n=0
  printf '%s' "$n"
}
write_misses() { echo "$1" > "$MISS_FILE" 2>/dev/null || true; }

# Reap/trim ALL logs every tick, independent of control's own health. Delegated
# to claude-control-logrotate (shared with claude-rc's start path) so the file
# list and trim policy live in one place and cover control.log/.err and the
# watchdog.* logs too, not just per-project session logs. Best-effort.
# Sibling-first (next to $0), then PATH - so a stale copy on PATH can't shadow the
# logrotate that ships with this watchdog install (custom --prefix, link mode).
self_dir="$(cd "$(dirname "$0")" 2>/dev/null && pwd)" || self_dir=""
if [[ -n "$self_dir" && -x "$self_dir/claude-control-logrotate" ]]; then
  logrotate_bin="$self_dir/claude-control-logrotate"
else
  logrotate_bin="$(command -v claude-control-logrotate 2>/dev/null || true)"
fi
if [[ -n "$logrotate_bin" && -x "$logrotate_bin" ]]; then
  "$logrotate_bin" || true
fi

# Determine this tick's outcome. A missing control.log counts as a miss too
# (control may never have started). We no longer kick on a single miss: require
# MISS_THRESHOLD consecutive missed ticks so one transient blip (reconnect, brief
# redraw spam, a log not yet flushed) doesn't trigger a needless restart.
seen=0
if heartbeat_seen; then
  seen=1
else
  # Absorb a same-tick startup race before counting the miss.
  sleep 5
  if heartbeat_seen; then
    echo "$(ts) heartbeat appeared on second check - no kick" >> "$WLOG"
    seen=1
  fi
fi

if [[ "$seen" == 1 ]]; then
  write_misses 0
  exit 0
fi

misses=$(( $(read_misses) + 1 ))
if (( misses >= MISS_THRESHOLD )); then
  echo "$(ts) session '${SESSION_NAME}' missing for ${misses} consecutive checks - kick $LABEL" >> "$WLOG"
  kick
  write_misses 0
else
  echo "$(ts) session '${SESSION_NAME}' miss ${misses}/${MISS_THRESHOLD} - no kick yet" >> "$WLOG"
  write_misses "$misses"
fi
