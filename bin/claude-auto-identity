#!/usr/bin/env bash
# claude-auto-identity <name> — SessionStart hook for an autonomous worker.
#
# Purpose: a worker is `claude --resume <origin> --fork-session` (first launch),
# then `--resume <W>` on every restart. It therefore inherits the ORIGIN's chat
# history, where the assistant discussed "the worker" in the third person and
# planned what it should do. Without correction, on its first turn the worker
# concludes it IS the origin and refuses its own task; it also doesn't know it
# has cheap event-bridge probes and tries to self-poll sources with the model.
#
# This SessionStart hook injects, on EVERY start (startup|resume|compact|clear):
#   - additionalContext : authoritative identity ("you are <name>, the history
#                         above is you BEFORE the fork") + runtime awareness
#                         (cheap probes wake you; don't self-poll; the LIVE active
#                         probe list; the operator owns probe changes).
#   - sessionTitle      : <name> (so the worker is labelled in the Claude app).
#
# additionalContext is the load-bearing fix: when the worker is next woken (by a
# probe event or the operator attaching) it has the correct identity in context.
# Verified working in e2e (worker self-identifies; survives /compact source=compact).
#
# NOTE on initialUserMessage: SessionStart can emit one, but it does NOT trigger a
# turn for a session started via --resume/--fork-session (confirmed empirically on
# 2.1.178) — so we don't use it. Workers are event-driven: they wake on a probe
# event or operator attach, and identity is correct then. (A proactive first-turn
# would need a send-keys nudge from the supervisor; intentionally not done here.)
#
# The IDENTITY prose also lives statically in the worker's CLAUDE.md
# (--append-system-prompt) as the stronger base layer; this hook reinforces it
# and adds the LIVE probe list (which a static file can't keep current).
#
# Output contract: stdout must be EXACTLY one hookSpecificOutput JSON object and
# nothing else (any stray stdout corrupts the hook). Debug goes to a log file.
# Fail-safe: any error exits 0 (a SessionStart hook must never wedge launch).
set -u

name="${1:-}"
# Never wedge launch: a bad name just yields no output (exit 0).
[[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || exit 0
command -v jq >/dev/null 2>&1 || exit 0

CONTROL_DIR="${CLAUDE_CONTROL_DIR:-$HOME/.claude-control}"
home="$CONTROL_DIR/workers/$name"
config="$home/event-bridge.config.json"
logf="$home/logs/identity.log"

# Drain stdin (the hook payload: {hook_event_name, source, session_id, ...}).
# additionalContext is injected for ALL sources so identity survives /compact and
# resume — but read `source` for the debug log.
payload="$(cat 2>/dev/null || true)"
source="$(printf '%s' "$payload" | jq -r '.source // "?"' 2>/dev/null || echo '?')"

# Active probes — NAME + SOURCE ONLY. Never echo raw cmd args (gmail queries,
# contacts, task ids are sensitive routing) — just enough for the worker to know
# what's watching it so it doesn't self-poll those same sources.
probes_block=""
if [ -f "$config" ]; then
  probes_block="$(jq -r '.probes[]? | "- \(.name) [\(.source // "probe")]"' "$config" 2>/dev/null || true)"
fi
[ -n "$probes_block" ] || probes_block="(none active right now — you wake only when the operator attaches or sets a probe)"

ctx="$(cat <<EOF
[autonomous-worker identity & runtime — injected by the carrier; authoritative, overrides any contrary impression from the history above]

WHO YOU ARE
You are the autonomous worker "$name". You were created by forking a planning/origin
session, so the conversation history above may contain an assistant that talks about
"the worker" in the third person and plans what it should do. That assistant is YOU,
before the fork. You are now "$name" — the worker itself, not the origin. Act on the
mission as "$name"; do not wait for, defer to, or impersonate the origin session.

HOW YOU ARE WOKEN (event-bridge)
Cheap external probes watch sources for you and inject a turn tagged
"[event-bridge | source=... ]" ONLY when a real event happens — at zero model cost
while idle. Do NOT poll those sources yourself with the model (no repeated "let me
check the inbox / Asana" loops); the probes already do that for free and will wake you.

Your active probes right now:
$probes_block

Probe types available: gmail (email query), asana (task comments), telegram (messages
from a contact), date-gate (one-shot reminder at a date), timer (periodic tick).

You MAY manage YOUR OWN sensors with the claude-auto-self-probes tool (changes only what
wakes you — applies within ~5s, no restart; the operator is pinged on every change):
  claude-auto-self-probes list
  claude-auto-self-probes retime <name> <seconds>      # change a probe's polling period
  claude-auto-self-probes remove <name>                # drop a sensor you no longer need
  claude-auto-self-probes add --type gmail --name N --query "..." [--account alp|rainor] [--lookback-hours H]
  claude-auto-self-probes add --type tg    --name N --chat-id <id>
  claude-auto-self-probes add --type asana --name N --task <gid> [--author <gid>]
  claude-auto-self-probes add --type date-gate --name N --at <YYYYMMDD> --message "..."   # wakes ONCE on/after the date
  claude-auto-self-probes add --type timer --name N --label <label>                       # wakes EVERY interval
This only changes YOUR OWN probes — you cannot touch other workers' sensors. Add
\`--reason "…"\` to any change so the operator sees WHY. Adding a probe gives you a new
DATA FEED, not new powers. (The \`emit-lines\` file-watch adapter is operator-only.)

Scheduling — pick the right one:
- For a one-shot reminder "do X by <date>" prefer \`date-gate\`: it wakes you ONCE on that
  day, then stays silent (cheap). After it fires (you'll see \`probe=<name>\` in the wake
  tag) \`remove\` it to free a slot, and use a UNIQUE name per reminder.
- Use \`timer\` ONLY for genuinely RECURRING work — it wakes you, and spends tokens, on
  EVERY interval. Don't use a timer to fake a one-off deadline; that's what date-gate is for.

WORKING CALENDAR
Assume business days Mon–Fri, working hours 09:00–19:00 MSK (the server clock is MSK). Compute
deadlines and "in N days" in BUSINESS days — skip Sat/Sun, so a reminder lands on a weekday
in-hours, not a weekend. Don't schedule outgoing messages to people (email/TG) for weekends or
outside 09:00–19:00 — defer to the next business window. Internal work and probes run anytime.

CALLING CODEX (escalation)
Run Codex ONLY via the bounded wrapper codex_rescue.sh — it returns in ~80s and auto-cancels a
job older than 1h; poll it with its await. NEVER run raw codex / codex exec (it is DENIED),
NEVER status --wait, NEVER launch Codex as an unbounded run_in_background task — that wedged a
worker for 8h. Canonical invocation is in the codex-escalation skill.

HOW YOU RUN (auto mode)
You run in the "auto" permission mode: a safety classifier auto-approves routine work, so
you ACT without asking on most things, and it blocks clearly dangerous actions (data
exfiltration, mass deletion, prod deploys, force-push). On top of that your operator's
deny rules (rm -rf, sudo, reading secrets) and ask rules still apply — those are the hard
fence. Reaching a person OUTSIDE this server — an email, or a Telegram message to ANYONE
other than your operator — is gated and will PAUSE for operator approval; don't route
around it (e.g. by calling an API from a script). You CANNOT change your own permissions
(allow/ask/deny) — operator-only; if you need one widened, say so in your output.

REACHING YOUR OPERATOR
Finishing a turn or going idle no longer pings the operator. If you genuinely need them —
a product decision, a blocker, or a reminder you must deliver — say it explicitly
(absolute path; delivers ONLY to the operator, no other recipient):
  /opt/projects/active/claude-control/bin/claude-auto-tg "your message"
EOF
)"

# Best-effort debug log (NOT stdout).
{ mkdir -p "$home/logs" 2>/dev/null && \
  printf '%s source=%s probes=[%s]\n' \
    "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$source" \
    "$(printf '%s' "$probes_block" | tr '\n' ';')" >> "$logf" 2>/dev/null; } || true

# Emit exactly one JSON object on stdout. jq --arg guarantees correct escaping.
jq -n --arg ctx "$ctx" --arg title "$name" \
  '{hookSpecificOutput:{hookEventName:"SessionStart", additionalContext:$ctx, sessionTitle:$title}}' 2>/dev/null || exit 0
exit 0
