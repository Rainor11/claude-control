#!/usr/bin/env bash
# claude-auto-tg — let an autonomous worker notify the OPERATOR on Telegram.
#
# Operator-only BY CONSTRUCTION:
#   * recipient (operator chat_id) is read from a FIXED absolute file (the operator's
#     server .env), and the notifier path is HARDCODED — NOT from $PATH/env/argv — so a
#     worker supplies ONLY the message text and cannot redirect the recipient;
#   * the message is passed to telegram_notify.sh as a SINGLE argv element, and that
#     script's arg parser breaks on the first non-flag (so a message containing
#     "--chat-id 999" is treated as text, never re-parsed into flags);
#   * the notifier is an ABSOLUTE path, not taken from $PATH or env, so a worker
#     cannot swap it via `PATH=/evil claude-auto-tg ...` or CLAUDE_AUTO_TG=…
#     (T8: the ONLY way to override it is $TELEGRAM_NOTIFY under a VALID
#     CLAUDE_CONTROL_TEST_ROOT marker — a sentinel-bearing dir outside the live tree.
#     WITHOUT that marker nothing at all is read from the environment and nothing is
#     sourced: the assignment below is a plain literal, see the K1 note there.)
#
# Use it for autonomous reminders and escalations to the operator (idle/turn-finish
# no longer pings — claude-auto-notify only forwards real permission blocks). To reach
# ANY OTHER person, use telegram_notify.sh directly — that path is in `ask`, so the
# operator approves it; this primitive deliberately cannot.
#
# Allow it in a worker by its ABSOLUTE path only:
#   Bash(/opt/projects/active/claude-control/bin/claude-auto-tg:*)
set -u

# Recipient = the operator's OWN Telegram chat. Read it from the operator's server .env
# (fixed absolute path, NOT $PATH/env/argv) so a worker still cannot redirect it — a
# plain env var would be worker-overridable and break the operator-only guarantee.
OPERATOR_ENV="/home/rainor/server/.env"
OPERATOR_CHAT_ID="$(awk -F= '/^TELEGRAM_CHAT_ID=/{gsub(/[^0-9]/,"",$2);print $2;exit}' "$OPERATOR_ENV" 2>/dev/null)"
# Путь нотификатора: БОЕВОЕ значение — голый литерал, ровно как до T8 («absolute — NOT
# $PATH/env» из шапки). Тестовый шов (T8 п.1, process_control_notifier_path) живёт ЦЕЛИКОМ
# внутри маркер-гейта ниже.
TG="/home/rainor/server/server_monitor/telegram_notify.sh"     # absolute — NOT $PATH/env
# K1 (ревью T8): гейтируется САМ source библиотеки, а не только вызов функции. Пролог
# резолва каталога (`readlink`/`dirname`/`cd`/`pwd`) — это ВНЕШНИЕ команды, а bash на старте
# импортирует функции из окружения (`BASH_FUNC_x%%=…`) и исполняет `$BASH_ENV`. Подменив
# `readlink` функцией, воркер уводил резолв в свой каталог и подсовывал оттуда СВОЙ
# lib/process-control.sh со своей process_control_notifier_path — то есть безусловный пролог
# T8 сделал НЕперекрываемый путь перекрываемым (воспроизведено: без маркера TG уезжал в
# /tmp/EVIL/telegram_notify.sh; до T8 этот файл библиотеку не подключал вовсе и был иммунен).
# Теперь в бою не исполняется ни одна внешняя команда и ничего не source'ится — значение
# остаётся литералом побитово.
#
# Условие — ИМЕННО `[[ ]]`, не `[ ]`: `[[` зарезервированное слово, bash отказывается
# импортировать функцию с таким именем («error importing function definition for `[[`»), а
# `[` — обычный builtin, и `BASH_FUNC_[%%=() { return 0; }` открыл бы гейт (проверено).
# Под ВАЛИДНЫМ маркером (каталог с sentinel вне боевого дерева, проверка T1) допускается
# заглушка внутри test root — иначе тестовый прогон отправлял бы сообщение живому оператору.
# `readlink -f "$0"`: install.sh симлинкует этот файл в ~/.local/bin, и без разыменования
# `dirname "$0"/../lib` указывал бы в ~/.local/lib мимо репозитория.
if [[ -n "${CLAUDE_CONTROL_TEST_ROOT+set}" ]]; then
  _cat_self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
  _cat_bindir="$(cd "$(dirname "$_cat_self")" && pwd)"
  # shellcheck disable=SC1091
  . "$_cat_bindir/../lib/process-control.sh"
  TG="$(process_control_notifier_path "$TG")" || exit 1
fi
CLAUDE_INSTALL="/home/rainor/.local/share/claude"              # trusted claude tree
DB="/opt/projects/active/claude-control/bot/rnr_db.py"          # outbox (reply routing)

[ -n "$OPERATOR_CHAT_ID" ] || { echo "claude-auto-tg: operator chat_id unavailable ($OPERATOR_ENV)" >&2; exit 1; }
[ -x "$TG" ] || { echo "claude-auto-tg: notifier unavailable ($TG)" >&2; exit 1; }

# Spoof-resistant worker identity (mirrors claude-auto-send) — used ONLY to route the
# operator's reply back to the RIGHT session. Recipient/notifier stay fixed regardless.
resolve_name() {
  local pid="$PPID" depth=0 nm exe
  while [ "${pid:-0}" -gt 1 ] && [ "$depth" -lt 25 ]; do
    # --resume ИЛИ --session-id — fresh-spawn/rebase (claude --session-id <W> без
    # --resume до первого рестарта). Без этого свежеспавненный воркер не мог вызвать
    # claude-auto-tg вообще (найдено Codex-ревью Task 10 канона, 2026-07-15) — та же
    # правка, что уже применена в claude-auto-send/self-probes/dept-*-request.
    if tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null | grep -qxE -- '--resume|--session-id'; then
      exe="$(readlink -f "/proc/$pid/exe" 2>/dev/null)"
      case "$exe" in
        "$CLAUDE_INSTALL"/*)
          nm="$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | sed -n 's/^CLAUDE_AUTO_NAME=//p' | head -1)"
          [ -n "$nm" ] && { printf '%s' "$nm"; return 0; }
          ;;
      esac
    fi
    pid="$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null)"
    depth=$((depth+1))
  done
  return 1
}

# Everything passed is the message body. We do NOT parse flags: the worker controls
# text only, never the recipient or notifier.
msg="$*"
[ -n "$msg" ] || { echo "claude-auto-tg: usage: claude-auto-tg <message…>" >&2; exit 2; }

# Best-effort worker label for the operator (NOT security-critical: the recipient is
# fixed regardless of what the label says).
name="${CLAUDE_AUTO_NAME:-}"
case "$name" in ""|*[!a-zA-Z0-9_-]*) name="worker" ;; esac

# Sanitize control chars (keep tab/newline/CR), cap length well under Telegram's limit.
msg="$(printf '%s' "$msg" | tr -d '\000-\010\013\014\016-\037' | cut -c1-3500)"
# A payload of only control bytes is empty after stripping (Codex MED-5).
[ -n "${msg//[[:space:]]/}" ] || { echo "claude-auto-tg: message empty after sanitization" >&2; exit 2; }

# --- @RnR_Workers bot, gracefully ---
# Use the dedicated worker bot ONLY if its token is configured AND well-formed
# (digits:secret) in .env; otherwise fall back to the default bot (so deploying this
# script BEFORE the token is added — or a placeholder/malformed value — never breaks
# notifications). When a valid token lands, escalations auto-switch with no edit.
rnr_val="$(grep -E '^RNR_WORKERS_BOT_TOKEN=' "$OPERATOR_ENV" 2>/dev/null | head -1 \
            | sed -e 's/^RNR_WORKERS_BOT_TOKEN=//' -e 's/^["'\'' ]*//' -e 's/["'\'' ]*$//')"
botflag=(); rnr_ok=0
[[ "$rnr_val" =~ ^[0-9]+:[A-Za-z0-9_-]+$ ]] && { rnr_ok=1; botflag=(--bot-token-env RNR_WORKERS_BOT_TOKEN); }

# Reply routing: if this is a real worker (spoof-resistant), the bot is configured, and
# the session is live, register a `notify` row so the operator can REPLY to this message
# and have the reply injected back. A visible `🆔 RNR-<qid>` lets the bot map a reply even
# before message_id lands (race-proof). Non-worker callers just send (no routing).
route=0; qid=""
wname="$(resolve_name 2>/dev/null || true)"
if [ "$rnr_ok" = 1 ] && [[ "$wname" =~ ^[a-zA-Z0-9_-]+$ ]] \
   && command -v tmux >/dev/null 2>&1 && tmux -L "claude-$wname" has-session -t "claude-$wname" 2>/dev/null \
   && [ -f "$DB" ] && command -v python3 >/dev/null 2>&1; then
  qid="$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 16)"
  if [ -n "$qid" ] && python3 "$DB" insert-ask --qid "$qid" --kind notify --worker "$wname" \
        --tmux-target "claude-$wname" --chat-id "$OPERATOR_CHAT_ID" \
        --question="$msg" --options-json '[]' 2>/dev/null; then
    route=1
  fi
fi

full="🤖 Воркер «$name»:
$msg"
[ "$route" = 1 ] && full="$full

🆔 RNR-$qid"

# `--` ends flag parsing → the message is never re-parsed as a flag.
out="$("$TG" "${botflag[@]}" --chat-id "$OPERATOR_CHAT_ID" -- "$full" 2>&1)"; rc=$?

# If the RnR bot send failed, fall back to the DEFAULT bot so an escalation is never lost
# (Codex MED-4). The default bot has no reply-poller, so drop the route row.
if [ "$rc" != 0 ] && [ "$rnr_ok" = 1 ]; then
  out="$("$TG" --chat-id "$OPERATOR_CHAT_ID" -- "$full" 2>&1)"; rc=$?
  if [ "$route" = 1 ]; then python3 "$DB" delete-ask --qid "$qid" 2>/dev/null || true; route=0; fi
fi

if [ "$route" = 1 ]; then
  if [ "$rc" = 0 ]; then
    # Sent OK. Record message_id if we can parse it; if not, KEEP the row — a reply
    # still routes via the visible 🆔 RNR-<qid> fallback. Never delete a live message.
    mid="$(printf '%s' "$out" | grep -oE 'message_id=[0-9]+' | head -1 | grep -oE '[0-9]+')"
    [ -n "$mid" ] && python3 "$DB" set-message-id --qid "$qid" --message-id "$mid" 2>/dev/null || true
  else
    python3 "$DB" delete-ask --qid "$qid" 2>/dev/null || true          # send failed → drop the row
  fi
fi

printf '%s\n' "$out"
exit "$rc"
