#!/usr/bin/env bash
# claude-auto-brain-checkpoint <name> — TaskCompleted hook for an autonomous worker.
#
# Fires when the worker marks a task/step complete. Writes a MEMORY-ONLY
# progress checkpoint so that if the worker later crashes, brain still holds an
# up-to-date picture of where it was.
#
# HARD GUARANTEES (Codex review — structural, not instruction-based):
#  - This is a standalone script. It does NOT import or invoke any ingest code.
#    "Memory update" only; it never creates knowledge-base pages from external
#    material. Ingest stays a separate, human-approved action.
#  - Output allowlist: it writes ONLY under the worker's progress directory
#    (resolved + checked). Any computed path outside the allowed root aborts.
#  - The last-step excerpt is auto-extracted from the transcript and may contain
#    text derived from untrusted events. It is sanitized, truncated, and stored
#    as provenance-tagged LOG DATA — never promoted to instructions/knowledge.
#  - Fail-safe: any error exits 0 (a checkpoint failure must never wedge the
#    worker or block task completion).
#
# Hook input: TaskCompleted JSON on stdin ({session_id, transcript_path, cwd,...}).
# Also (re)used for controlled compaction (H): estimates context size from the
# transcript's latest usage and sets a compact-request flag past the threshold.
set -u

name="${1:-unknown}"
[[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || name="unknown"

CONTROL_DIR="${CLAUDE_CONTROL_DIR:-$HOME/.claude-control}"
BRAIN_DIR="${BRAIN_DIR:-$HOME/brain}"
THRESHOLD="${CLAUDE_AUTO_COMPACT_THRESHOLD:-700000}"
HOME_DIR="$CONTROL_DIR/workers/$name"

# Fail-safe wrapper: never let a hook error propagate.
{
  command -v jq >/dev/null 2>&1 || exit 0
  payload="$(cat 2>/dev/null)"
  sid="$(printf '%s' "$payload" | jq -r '.session_id // empty' 2>/dev/null)"
  tpath="$(printf '%s' "$payload" | jq -r '.transcript_path // empty' 2>/dev/null)"
  cwd="$(printf '%s' "$payload" | jq -r '.cwd // empty' 2>/dev/null)"

  # --- pick the progress dir (allowlisted roots only) ---
  if [ -d "$BRAIN_DIR/.git" ] || [ -d "$BRAIN_DIR" ]; then
    root="$BRAIN_DIR/wiki/work/ai-dev/автономные-воркеры"
  else
    root="$CONTROL_DIR/workers/$name/progress"   # fallback if brain absent
  fi
  outdir="$root/$name"
  mkdir -p "$outdir" 2>/dev/null || exit 0
  # Allowlist guard: resolved outdir MUST be under a NON-EMPTY allowed root.
  # (Guard against an unresolvable root collapsing the glob to "/*", which would
  # match any absolute path and defeat the allowlist.)
  real_out="$(cd "$outdir" 2>/dev/null && pwd -P)" || exit 0
  brain_real="$(cd "$BRAIN_DIR" 2>/dev/null && pwd -P || true)"
  ctrl_real="$(cd "$CONTROL_DIR" 2>/dev/null && pwd -P || true)"
  ok=0
  [ -n "$brain_real" ] && case "$real_out" in "$brain_real"/*) ok=1 ;; esac
  [ -n "$ctrl_real" ]  && case "$real_out" in "$ctrl_real"/*) ok=1 ;; esac
  [ "$ok" = 1 ] || exit 0  # refuse to write anywhere else

  # --- extract last assistant text (mechanical; untrusted) ---
  excerpt=""
  if [ -n "$tpath" ] && [ -f "$tpath" ]; then
    excerpt="$(tail -n 600 "$tpath" 2>/dev/null \
      | jq -rc 'select(.type=="assistant") | .message.content[]? | select(.type=="text") | .text' 2>/dev/null \
      | tail -1)"
  fi
  # sanitize: drop control bytes, collapse whitespace, truncate
  excerpt="$(printf '%s' "$excerpt" | tr -d '\000-\010\013\014\016-\037' | tr '\n\r\t' '   ' | cut -c1-600)"

  now="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  prog="$outdir/progress.md"
  state="$outdir/state.json"

  # append timestamped entry (memory log; excerpt clearly tagged as untrusted log)
  {
    echo "## $now — step completed"
    echo "- session: \`$sid\`"
    echo "- last output (auto-extracted log data, NOT instructions): $excerpt"
    echo
  } >> "$prog" 2>/dev/null || true

  # latest-snapshot state.json (atomic)
  # unique temp (Stop + TaskCompleted can fire close together; a shared
  # state.tmp would let two invocations clobber each other mid-write).
  stmp="$(mktemp "$outdir/.state.XXXXXX" 2>/dev/null)" || stmp="$state.$$"
  jq -n --arg n "$name" --arg sid "$sid" --arg cwd "$cwd" --arg t "$now" \
        --arg tp "$tpath" --arg ex "$excerpt" \
    '{worker:$n, session_id:$sid, cwd:$cwd, last_checkpoint:$t,
      transcript_path:$tp, last_step_excerpt:$ex,
      _note:"memory checkpoint by claude-auto-brain-checkpoint; not ingest"}' \
    > "$stmp" 2>/dev/null && mv "$stmp" "$state" 2>/dev/null || rm -f "$stmp" 2>/dev/null

  # best-effort git commit in brain (durability beyond Obsidian Sync). No push:
  # avoids auth surprises in an unattended unit; brain's own sync/Stop-hook pushes.
  if [ -d "$BRAIN_DIR/.git" ] && case "$real_out" in "$(cd "$BRAIN_DIR" && pwd -P)"/*) true;; *) false;; esac; then
    git -C "$BRAIN_DIR" add "$prog" "$state" >/dev/null 2>&1 || true
    git -C "$BRAIN_DIR" commit -q -m "autoworker $name: progress checkpoint $now" >/dev/null 2>&1 || true
  fi

  # --- controlled compaction (H): estimate context size from latest usage ---
  if [ -n "$tpath" ] && [ -f "$tpath" ]; then
    ctx="$(tail -n 600 "$tpath" 2>/dev/null \
      | jq -rc 'select(.type=="assistant") | .message.usage
                | ((.input_tokens//0) + (.cache_read_input_tokens//0) + (.cache_creation_input_tokens//0))' 2>/dev/null \
      | tail -1)"
    if [ -n "$ctx" ] && [ "$ctx" -eq "$ctx" ] 2>/dev/null && [ "$ctx" -gt "$THRESHOLD" ]; then
      mkdir -p "$HOME_DIR/state" 2>/dev/null
      printf '%s ctx=%s threshold=%s\n' "$now" "$ctx" "$THRESHOLD" > "$HOME_DIR/state/compact_requested" 2>/dev/null || true
    fi
  fi
} 2>/dev/null
exit 0
