#!/usr/bin/env node
// claude-auto-liveness — детерминированный watchdog «жив, но не отвечает».
// hung = busy-маркер на экране + замерший screen-hash + замерший транскрипт
// дольше HUNG_MIN. Лестница: alert → карточка перезапуска (кнопка оператора) → incident (ТП).
// Решение оператора 19.07: авто-рестарт отменён навсегда — сторож только подаёт заявку
// через dept-liveness-request, исполняет диспетчер по ✅ (см. liveness-button-plan.md).
// ИСКЛЮЧЕНИЕ (оператор 22.07): ветка #rc — отвалившийся Remote Control у ЖИВОГО воркера
// авто-рестартится (busy → DEFERRED, cap 2/24ч, гейты auth/карточки) — см. rcSignal ниже.
// Запуск: systemd-таймер каждые 5 минут. Флаг --dry-run: только печать решений.
'use strict';
const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');
const crypto = require('crypto');
// T5: корень рантайма — через единый резолвер (lib/runtime-root.js, задача T1). Профиль
// auto_then_hardcoded воспроизводит прежнюю строку (CLAUDE_AUTO_HOME || '/home/rainor/.claude-control')
// без маркера; под CLAUDE_CONTROL_TEST_ROOT — fail-closed на корень песочницы. require('../lib')
// верен в repo- и install-layout (node резолвит по realpath модуля, как process-control.js в T4).
const { resolveRuntimeRoot } = require('../lib/runtime-root.js');
// Рендер операторских карточек. Булев контракт notify() СОХРАНЁН — от него зависят
// дедуп-эпизоды (alerted/animAlerted/escalated пишутся только по факту доставки).
const card = require('../lib/notify-card.js');

const CC_HOME = resolveRuntimeRoot('auto_then_hardcoded');
// DEPT остаётся производным от резолвленного CC_HOME (композитный DEPT): DEPT_HOME → CC_HOME/department.
const DEPT = process.env.DEPT_HOME || path.join(CC_HOME, 'department');
const STATE_FILE = path.join(DEPT, 'watchdog-state.json');
const BIN = __dirname;
// Number(garbage) === NaN, и NaN "просачивался" бы во все сравнения decide() как false —
// это ОТКЛЮЧАЕТ и fresh-check, и hung-порог разом (см. /bug-раунд), а не просто ломает дефолт.
function numEnv(name, def) {
  const n = Number(process.env[name]);
  return Number.isFinite(n) && n > 0 ? n : def;
}
const CFG = {
  hungMin: numEnv('LIVENESS_HUNG_MIN', 30),
  reincidentMin: numEnv('LIVENESS_REINCIDENT_MIN', 60),
  animMin: numEnv('LIVENESS_ANIM_HUNG_MIN', 90),
  // Как часто напоминать про НЕразрешённый эпизод протухшей авторизации. Эскалации дальше
  // (карточка/инцидент) на этой ветке нет по решению оператора 21.07 — напоминание и есть
  // единственная защита от «алерт пришёл в 00:40, оператор спал, простой 8 часов».
  remindMin: numEnv('LIVENESS_AUTH_REMIND_MIN', 60),
  // RC-проба (ветка #rc, оператор 22.07). Grace после (пере)запуска сессии — RC подключается
  // не мгновенно; absent/transient — раздельные пороги подтверждения (transient дольше:
  // рестарт не должен сбивать штатный сетевой backoff reconnect'а); gap — разрыв наблюдений,
  // рвущий streak (3x интервал таймера: опоздавший тик не должен склеивать разные эпизоды).
  rcGraceMin: numEnv('LIVENESS_RC_GRACE_MIN', 10),
  rcAbsentMin: numEnv('LIVENESS_RC_ABSENT_MIN', 15),
  rcTransientMin: numEnv('LIVENESS_RC_TRANSIENT_MIN', 25),
  rcGapMin: numEnv('LIVENESS_RC_GAP_MIN', 15),
  rcMaxRestarts: numEnv('LIVENESS_RC_MAX_RESTARTS', 2),
  rcWindowH: numEnv('LIVENESS_RC_WINDOW_H', 24),
};
// Служебные ключи в watchdog-state.json. '#' невозможен в имени воркера (валидация
// ^[a-zA-Z0-9_-]+$) — коллизия с записью воркера исключена by construction. Cleanup
// внизу файла обязан щадить ВЕСЬ набор — точечное исключение одного ключа уже чуть не
// стёрло второй (Codex-ревью плана #rc).
const AUTH_KEY = '#auth';
const RC_KEY = '#rc';
const SERVICE_KEYS = new Set([AUTH_KEY, RC_KEY]);
const BUSY_RE = /esc to interrupt|Thinking|Compacting|Forking|Summariz|tokens · esc/i;
// Маркеры протухшей авторизации хоста («жив, но тихо мёртв»: tmux-сессия и юнит живы, экран
// статичен, ни одно событие не обрабатывается). Строки — из самого CLI (проверено в
// ~/.local/share/claude/versions/2.1.216); инцидент 21.07 показал первую из них на экранах
// четырёх воркеров. Держим рядом с BUSY_RE намеренно: обе — «что видно на экране».
const AUTH_RE = /Login expired|OAuth token revoked|Session expired|Please run \/login|run \/login to (re-authenticate|sign in)|credential is missing or expired|invalid_grant/i;
const NOTIFY = process.env.TELEGRAM_NOTIFY || '/home/rainor/server/server_monitor/telegram_notify.sh';

// Чистая функция: машинный вердикт «логин протух» по ХВОСТУ транскрипта воркера.
// Экранный маркер сам по себе доказательством не является (воркер мог процитировать текст
// ошибки; строка могла остаться в скроллбеке после восстановления) — источник истины здесь:
// синтетическая запись {type:"assistant", isApiErrorMessage:true, message.content[].text},
// формат подтверждён по транскриптам инцидента 21.07.
// Идём С КОНЦА и возвращаем то, что встретилось РАНЬШЕ: auth-ошибка → 'unresolved' (логин
// всё ещё мёртв), обычный ответ ассистента → 'resolved' (воркер ожил). «Последняя запись =
// ошибка» было бы слишком строго: после неё ложатся user-записи от инжектов event-bridge.
// 'unknown' — ни того, ни другого в окне (вызывающий обязан трактовать как «не смог узнать»,
// не как выздоровление).
function authVerdict(tail) {
  const lines = String(tail || '').split('\n');
  for (let i = lines.length - 1; i >= 0; i--) {
    const l = lines[i].trim();
    if (!l) continue;
    let e;
    // Битая строка — это НОРМА для первой строки окна (хвост режется по байтам, не по
    // строкам). Пропускаем молча: идя с конца, до обрезанной строки мы доходим последней.
    try { e = JSON.parse(l); } catch { continue; }
    if (!e || e.type !== 'assistant' || !e.message) continue;
    // content бывает не массивом (битая/иная запись) — .map() на строке бросил бы, и в
    // authVerdictFromFile это стало бы 'unknown', а у прямого вызова функции — падением.
    const c = e.message.content;
    const text = Array.isArray(c) ? c.map((x) => (x && x.text) || '').join(' ') : (typeof c === 'string' ? c : '');
    // isApiErrorMessage — ворота: auth-текст ВНУТРИ обычного ответа ассистента это цитата
    // (воркер отдела обсуждает инцидент), а не отказ. Не-auth ошибка (500, сетевой флап) не
    // означает ни выздоровления, ни протухшего логина — пропускаем и ищем доказательство глубже.
    if (e.isApiErrorMessage) { if (AUTH_RE.test(text)) return 'unresolved'; continue; }
    return 'resolved';
  }
  return 'unknown';
}

// authVerdict по хвосту РЕАЛЬНОГО файла транскрипта. Целиком читать нельзя: транскрипты
// воркеров — десятки мегабайт (сессии 265k-431k токенов). Любой сбой чтения → 'unknown'
// («не смог узнать»), НЕ 'resolved': сбой не является доказательством выздоровления.
// Окно РАСШИРЯЕТСЯ, пока вердикт не определится: между auth-ошибкой и концом файла лежит
// сколько угодно user-записей от инжектов event-bridge (в инциденте 21.07 датчики стучались
// часами после отказа). Фиксированное окно упёрлось бы в них и отдало 'unknown' — сторож
// снова ничего бы не увидел. Потолок 4 МБ: дальше искать бессмысленно, это уже не «хвост».
const AUTH_TAIL_WINDOWS = [64 * 1024, 512 * 1024, 4 * 1024 * 1024];
function authVerdictFromFile(file) {
  try {
    const size = fs.statSync(file).size;
    const fd = fs.openSync(file, 'r');
    try {
      for (const win of AUTH_TAIL_WINDOWS) {
        const start = Math.max(0, size - win);
        const len = size - start;
        const buf = Buffer.alloc(len);
        fs.readSync(fd, buf, 0, len, start);
        const v = authVerdict(buf.toString('utf8'));
        if (v !== 'unknown') return v;
        if (start === 0) break; // окно уже покрыло файл целиком — расширять некуда
      }
      return 'unknown';
    } finally { fs.closeSync(fd); }
  } catch { return 'unknown'; }
}

// Чистая функция: сигнал по одному воркеру — 'blocked' (логин протух) / 'clear' (жив) /
// 'unknown' (не смогли узнать). Требует ДВА ключа: маркер на экране и машинный вердикт
// транскрипта. Экран один даёт ложняки (цитата инцидента в ответе, старый кадр в скроллбеке),
// транскрипт один не отличает «мёртв» от «читаем не тот файл».
// busy — по ХВОСТУ экрана (12 строк, как в session-inject), а НЕ по всему pane: decide()
// проверяет весь pane, и остаточная строка «esc to interrupt» из истории прошлого хода
// прятала бы мёртвый логин навсегда. В хвосте живёт актуальное состояние TUI.
// verdict может быть ФУНКЦИЕЙ (ленивое чтение транскрипта): без маркера на экране читать
// многомегабайтный хвост у каждого из ~20 воркеров каждые 5 минут незачем. Порядок проверок
// тоже важен: 'unknown' отдаём ТОЛЬКО когда маркер на экране есть, а подтвердить его нечем —
// иначе воркер с чистым экраном и временно нечитаемым транскриптом получал бы 'unknown' и
// залипал в эпизоде навсегда ('unknown' наблюдение не снимает), а оператор — почасовые
// напоминания про уже живого воркера.
const AUTH_TAIL_LINES = 12;
function authSignal(screen, verdict) {
  const s = String(screen || '');
  const tail = s.split('\n').slice(-AUTH_TAIL_LINES).join('\n');
  if (BUSY_RE.test(tail)) return 'clear'; // идёт ход — воркер жив, что бы ни висело выше
  if (!AUTH_RE.test(s)) return 'clear';
  const v = typeof verdict === 'function' ? verdict() : verdict;
  if (v === 'unknown') return 'unknown';
  return v === 'unresolved' ? 'blocked' : 'clear';
}

// Чистая функция: эпизод отказа авторизации ЦЕЛИКОМ (все воркеры разом). Протухший логин —
// свойство хоста, а не воркера: оператору нужно ОДНО сообщение со списком, а не N штук.
// Фаза эпизода живёт в одном месте (ключ #auth в watchdog-state.json), а не флагами в
// per-worker state: nextState('reset') конструирует запись воркера заново, а ветки
// close_executed/incident заменяют её целиком — auth-флаги там бы молча терялись.
// Подтверждение — 2 подряд тика со СТАТИЧНЫМ экраном (таймер ходит раз в 5 минут).
function authEpisode(prev, observations, now, cfg) {
  // Состояние приходит из watchdog-state.json — файла, который могли править руками или
  // повредить. Структурно битый эпизод (members не объект, notified не массив) обязан
  // деградировать в «эпизода нет», а не ронять весь тик сторожа до saveState().
  const prevMembers = prev && prev.members && typeof prev.members === 'object' ? prev.members : {};
  const members = { ...prevMembers };
  for (const o of observations) {
    if (o.signal !== 'blocked') continue;
    const m = members[o.name];
    if (!m) members[o.name] = { firstSeen: now, screenHash: o.screenHash, confirmed: false };
    else if (m.screenHash === o.screenHash) members[o.name] = { ...m, confirmed: true };
    else members[o.name] = { ...m, screenHash: o.screenHash, confirmed: false };
  }
  // Выбытие: воркер ожил (clear) ИЛИ пропал из наблюдения вовсе (снесён/остановлен/не
  // проверялся). 'unknown' НЕ выбытие — сбой чтения не лечит воркера. Из notified выбывший
  // тоже вычищается: ожив и упав снова, он обязан снова считаться НОВЫМ участником, иначе
  // повторный отказ пройдёт молча.
  const seen = new Set(observations.map((o) => o.name));
  for (const o of observations) if (o.signal === 'clear') delete members[o.name];
  for (const n of Object.keys(members)) if (!seen.has(n)) delete members[n];
  const confirmed = Object.keys(members).filter((n) => members[n].confirmed).sort();
  const prevNotified = prev && Array.isArray(prev.notified) ? prev.notified : [];
  const notified = prevNotified.filter((n) => members[n]);
  const fresh = confirmed.filter((n) => !notified.includes(n));
  const episode = { ...(prev || {}), members, notified };
  // В алерте — ПОЛНЫЙ список подтверждённых, а не дельта: оператору нужен масштаб («логин
  // протух на хосте, лежат вот эти»), а не «добавился ещё один».
  if (fresh.length) return { episode, alert: { kind: 'new', members: confirmed } };
  // Напоминание: состав тот же, но эпизод не рассосался. Без него алерт в 00:40, пока
  // оператор спит, снова превращается в восьмичасовой простой (инцидент 21.07).
  const lastAlertAt = (prev && prev.lastAlertAt) || 0;
  if (confirmed.length && now - lastAlertAt >= cfg.remindMin * 60_000) {
    return { episode, alert: { kind: 'remind', members: confirmed } };
  }
  return { episode, alert: null };
}

// Фиксация ФАКТА доставки группового алерта. Отдельным шагом намеренно: пометить «уведомлён»
// ДО успешной отправки значит съесть алерт на сетевом сбое Telegram — тот же двухфазный
// принцип, что p3#33 применяет к alerted в основной лестнице.
function authNotified(episode, alert, now) {
  if (!alert) return episode;
  const prevNotified = Array.isArray(episode.notified) ? episode.notified : [];
  const notified = Array.from(new Set([...prevNotified, ...alert.members]));
  return { ...episode, notified, notifiedAt: episode.notifiedAt || now, lastAlertAt: now };
}

// ---- Remote Control (#rc) -----------------------------------------------------------------
// Оператор 22.07: у воркеров с remote_control=true в spec периодически отваливается RC —
// сессия пропадает из аппки claude.ai, процесс при этом жив (не hung, не auth). Диагноз по
// ФУТЕРУ TUI: подключённый RC рисует маркер '/rc' (варианты '/rc active|connecting|
// reconnecting|failed' зашиты в CLI, проверено strings'ом по 2.1.217) в chrome-зоне ПОД
// нижним бордером поля ввода. Лечение — обычный `claude-auto restart` (та же сессия
// резюмится с --remote-control из spec). Это осознанное ИСКЛЮЧЕНИЕ из запрета авто-рестартов
// 19.07: тот касался ЗАВИСШИХ (рестарт им не помогал); здесь воркер живой и idle (busy →
// cmd_restart сам DEFERRED/exit 3), рестарт решает проблему. Подробнее — docs/autonomous.md.

// Диалоги/промпты поверх TUI — зеркало worker_busy (bin/claude-auto) и session-inject:
// пока они открыты, футер судить нельзя (skip), рестартить тем более.
const RC_PROMPT_RE = /Do you want to|Allow .* to (run|use|edit|create|read)|trust (this )?(folder|directory)|new MCP server|resume .*session|Continue\?/i;
// Маркер — строго в КОНЦЕ строки chrome-зоны (правый нижний угол футера). Якорь $ отсекает
// цитаты «/rc failed» в тексте разговора: те живут выше бордера и не в конце chrome-строки.
const RC_MARK_RE = /(^|\s)\/rc(?: (active|connecting|reconnecting|failed))?\s*$/;

// Чистая функция: сигнал RC по одному экрану.
//   'ok'        — маркер /rc (или /rc active) на месте
//   'transient' — connecting/reconnecting (штатный reconnect, не трогаем до таймаута)
//   'failed'    — /rc failed
//   'absent'    — chrome-зона распознана, маркера нет (главный симптом обрыва)
//   'skip'      — busy/промпт: судить нельзя, наблюдением не считается
//   'unknown'   — капчер пуст / структура экрана не распознана (тоже не наблюдение)
// Зона поиска СТРУКТУРНАЯ: строки ниже ПОСЛЕДНЕГО горизонтального бордера (нижняя граница
// поля ввода), а не фиксированный tail: на узких панелях футер переносится и '/rc' уезжает
// на отдельную строку (наблюдалось вживую на 80-колоночных панелях воркеров).
function rcSignal(screen) {
  if (screen == null) return 'unknown';
  const s = String(screen);
  const tail = s.split('\n').slice(-AUTH_TAIL_LINES).join('\n');
  if (BUSY_RE.test(tail) || RC_PROMPT_RE.test(tail)) return 'skip';
  const lines = s.split('\n');
  let sep = -1;
  for (let i = lines.length - 1; i >= 0; i--) {
    if (/─{10,}/.test(lines[i])) { sep = i; break; }
  }
  if (sep < 0) return 'unknown';
  const zone = lines.slice(sep + 1).filter((l) => l.trim() !== '');
  if (!zone.length) return 'unknown';
  for (const l of zone) {
    const m = RC_MARK_RE.exec(l);
    if (!m) continue;
    const kind = m[2] || 'active';
    if (kind === 'failed') return 'failed';
    if (kind === 'connecting' || kind === 'reconnecting') return 'transient';
    return 'ok';
  }
  return 'absent';
}

// Чистая функция: эпизод RC-обрывов по наблюдениям тика. Логика TIME-BASED, не «тики
// подряд»: systemd-тик может опоздать, busy-'skip' — не наблюдение (замораживает эпизод,
// не двигая и не разрывая его; разрыв меряется по lastObservedAt при следующем ПЛОХОМ
// наблюдении). Смена sessionCreated (воркер пересоздан кем угодно) сбрасывает эпизод.
// obs: [{name, signal, sessionCreated}] — только воркеры под RC-надзором в этом тике;
// не попавшие в obs выбывают из members (сняты/усыплены/rc выключен), как в authEpisode.
// prev может быть битым (файл правили руками) — деградируем в пустой эпизод, не роняем тик.
// Возвращает { members, due }: due — имена с ПОДТВЕРЖДЁННЫМ обрывом. Пороги по виду:
// failed — ≥2 наблюдений; absent — ≥3 наблюдений И ≥ rcAbsentMin от firstBadAt;
// transient — ≥3 И ≥ rcTransientMin.
function rcEpisode(prev, obs, now, cfg) {
  const prevMembers = prev && prev.members && typeof prev.members === 'object' ? prev.members : {};
  // Object.create(null): имя воркера '__proto__' валидно по ^[a-zA-Z0-9_-]+$, а на обычном
  // объекте members['__proto__']= дёргает сеттер прототипа вместо создания свойства —
  // эпизод такого воркера молча исчезал бы при сериализации (Codex-ревью, low).
  const members = Object.create(null);
  const due = [];
  for (const o of obs) {
    const m = prevMembers[o.name];
    if (o.signal === 'ok') continue; // выздоровел — member не переносим
    if (o.signal === 'skip' || o.signal === 'unknown') {
      if (m) members[o.name] = m; // заморозка как есть
      continue;
    }
    // плохой сигнал: absent / transient / failed. Битый member (файл правили руками:
    // NaN/мусор в числовых полях навсегда глушил бы пороги — NaN-сравнения все false)
    // деградирует в НОВЫЙ эпизод, как authEpisode деградирует в «эпизода нет».
    const corrupt = m && !(Number.isFinite(m.firstBadAt) && Number.isFinite(m.obsCount) && Number.isFinite(m.lastObservedAt));
    if (!m || corrupt || m.sessionCreated !== o.sessionCreated || now - m.lastObservedAt > cfg.rcGapMin * 60_000) {
      members[o.name] = { firstBadAt: now, badKind: o.signal, obsCount: 1, lastObservedAt: now, sessionCreated: o.sessionCreated };
      continue;
    }
    const nm = { ...m, badKind: o.signal, obsCount: m.obsCount + 1, lastObservedAt: now };
    members[o.name] = nm;
    const sinceMin = (now - nm.firstBadAt) / 60_000;
    // Быстрый путь failed — только ДВА failed ПОДРЯД (m.badKind хранит предыдущий вид):
    // иначе смешанная серия absent→failed срабатывала бы на первом же failed, минуя
    // absent-пороги (Codex-ревью, medium). Смешанные серии ждут следующего failed
    // или добирают свой absent/transient-порог.
    if (o.signal === 'failed' && nm.obsCount >= 2 && m.badKind === 'failed') due.push(o.name);
    else if (o.signal === 'absent' && nm.obsCount >= 3 && sinceMin >= cfg.rcAbsentMin) due.push(o.name);
    else if (o.signal === 'transient' && nm.obsCount >= 3 && sinceMin >= cfg.rcTransientMin) due.push(o.name);
  }
  return { members, due };
}

// Чистая функция: cap авто-рестартов. history — timestamps ВЕРИФИЦИРОВАННЫХ рестартов этого
// воркера (живёт в #rc.history НЕЗАВИСИМО от эпизода: выздоровление не обнуляет счётчик —
// иначе флапающий RC получал бы свежие 2 рестарта каждый цикл болезни). Мусор/просроченные
// записи отфильтровываются, защита от clock rollback — Number.isFinite + окно.
function rcAllowRestart(history, now, cfg) {
  const fresh = (Array.isArray(history) ? history : [])
    .filter((t) => Number.isFinite(t) && t <= now && now - t < cfg.rcWindowH * 3_600_000);
  return { fresh, allowed: fresh.length < cfg.rcMaxRestarts };
}

// Чистая решающая функция (тестируется отдельно).
function decide(prev, cur, cfg) {
  if (!cur.busy) return { action: 'none', reset: true };
  const staleMs = cur.ts - cur.transcriptMtime;
  if (staleMs < cfg.hungMin * 60_000) return { action: 'none', reset: true };
  if (!prev || prev.screenHash !== cur.screenHash) {
    // экран живёт, транскрипт мёртв: вторичный сигнал (всегда alert-only)
    if (staleMs >= cfg.animMin * 60_000 && !(prev && prev.animAlerted)) return { action: 'anim_alert', reset: false };
    if (prev && prev.animAlerted) return { action: 'none', reset: false }; // эпизод продолжается — не спамить
    return { action: 'none', reset: true };
  }
  const hungFor = cur.ts - prev.firstSeen;
  if (hungFor < cfg.hungMin * 60_000) return { action: 'none', reset: false };
  if (prev.restartedAt && cur.ts - prev.restartedAt < cfg.reincidentMin * 60_000) return { action: 'incident', reset: false };
  if (!prev.alerted) return { action: 'alert', reset: false };
  return { action: 'restart', reset: false };
}

// Чистая функция: следующий state[name] для веток reset / anim_alert / none-continuation / alert
// (restart/incident остаются инлайн в цикле — там ветвление по успеху подачи заявки в ledger
// (dept-liveness-request) / dept-ledger incident-open, не по hash). notifyOk — результат
// notify() для действий, где он нужен (anim_alert/alert); для reset/none игнорируется (у них
// нет своего notify-вызова).
// Экран считается "ожившим", если hash сменился относительно prev (или prev вовсе нет) — тогда
// alerted/wouldNotified/wouldIncidentNotified сбрасываем: алерт был про СТАРОЕ замершее состояние
// экрана, оно больше не актуально. Точное совпадение hash (no-op основной лестницы alert→restart)
// эти флаги НЕ трогает — иначе дедуп сломается и лестница будет слать alert повторно на каждый тик.
function nextState(prev, cur, action, notifyOk) {
  switch (action) {
    case 'reset':
      return { screenHash: cur.screenHash, firstSeen: cur.ts, alerted: false, restartedAt: prev?.restartedAt || 0 };
    case 'anim_alert': {
      // decide() гарантирует prev.screenHash !== cur.screenHash на входе (или !prev) — экран
      // сменился by construction, сброс alerted/wouldNotified/wouldIncidentNotified безусловен
      // (не зависит от notifyOk — устаревший алерт был про предыдущий кадр в любом случае).
      // p3#33: animAlerted (дедуп anim-эпизода) — по факту доставки ИМЕННО этого алерта.
      const base = prev || { screenHash: cur.screenHash, firstSeen: cur.ts, alerted: false, restartedAt: 0 };
      return { ...base, screenHash: cur.screenHash, animAlerted: notifyOk, alerted: false, wouldNotified: false, wouldIncidentNotified: false };
    }
    case 'none': {
      // none && !reset: hash равен prev.screenHash (no-op основной лестницы, дедуп alert→restart
      // живёт) ИЛИ hash сменился (anim-эпизод продолжается, старый алерт устарел). Различаем —
      // иначе сброс alerted задел бы no-op основной лестницы (см. её тест в liveness-decide).
      const moved = !prev || prev.screenHash !== cur.screenHash;
      if (!moved) return { ...prev, screenHash: cur.screenHash };
      return { ...prev, screenHash: cur.screenHash, alerted: false, wouldNotified: false, wouldIncidentNotified: false };
    }
    case 'alert':
      // p3#33: alerted (первая ступень лестницы) — только при доставленном алерте; провал
      // notify оставляет prev как есть (тот же объект), следующий тик повторит попытку.
      return notifyOk ? { ...prev, alerted: true } : prev;
    default:
      throw new Error(`nextState: неизвестное действие "${action}"`);
  }
}

// Чистая функция T3: следующий шаг по карточке liveness_restart. Вынесена из decide()/
// nextState() намеренно — её ветвление зависит от ВНЕШНЕГО источника (эффективный
// approval_status заявки в ledger), а не только от prev/cur, и вызывается циклом из ДВУХ
// разных мест:
//  (1) карточки ещё нет (prev.cardEventId пуст) — вызывается ТОЛЬКО когда лестница decide()
//      хочет action=restart; ledgerView = {existingCardId} — T2-review дедуп-слой б: если в
//      ledger уже висит НЕрешённая (open/approved/executing) liveness_restart на этого
//      воркера (например, state потерян между тиками), усыновляем её вместо подачи дубля.
//      → {op:'adopt', eventId} | {op:'file'}
//  (2) карточка уже отслеживается (prev.cardEventId жив) — вызывается КАЖДЫЙ тик независимо
//      от action этого тика (оператор мог решить заявку, пока экран стоит на месте);
//      ledgerView = {cardStatus, executedAt} — последний approval_status по ref
//      («последний выигрывает», как effectiveStatus в dept-ledger).
//      → {op:'close_executed', executedAt} | {op:'wait'} | {op:'silent_denied'} |
//        {op:'silent_withdrawn'} | {op:'clear'}
// close_executed отдаёт executedAt ИМЕННО из ledgerView (ts события executed в ledger), не
// cur.ts «сейчас» — от него зависит reincident-детект (decide(): prev.restartedAt свежий).
function cardStep(prev, cur, ledgerView) {
  const lv = ledgerView || {};
  if (prev && prev.cardEventId) {
    const status = lv.cardStatus;
    if (status === 'executed') return { op: 'close_executed', executedAt: lv.executedAt != null ? lv.executedAt : cur.ts };
    if (status === 'denied') {
      return prev.cardScreenHash === cur.screenHash ? { op: 'silent_denied' } : { op: 'clear' };
    }
    // T3-ревью F1: withdrawn — не переподавать мгновенно (буква плана T3.1: denied/executed/
    // withdrawn → не переподаём, пока экран тот же). Ведёт себя как denied: молчим, пока
    // экран не сменился; сменился — clear и разрешаем обычной лестнице подать заново.
    if (status === 'withdrawn') {
      return prev.cardScreenHash === cur.screenHash ? { op: 'silent_withdrawn' } : { op: 'clear' };
    }
    if (status === 'open' || status === 'approved' || status === 'executing') return { op: 'wait' };
    // Статус не определился (заявка потеряна/архивирована — queryCardStatus уже подтвердил
    // «approval тоже не найден» выше по стеку) — снять карточку безусловно, ИГНОРИРУЯ hash.
    // Исключение принято ревью намеренно: иначе архивная карточка на неизменном экране держала
    // бы cardEventId вечно (silent-веткам возвращаться некуда — approval_status для неё больше
    // не читается), и лестница никогда не подала бы заявку заново.
    return { op: 'clear' };
  }
  return lv.existingCardId ? { op: 'adopt', eventId: lv.existingCardId } : { op: 'file' };
}

module.exports = { decide, nextState, cardStep, authVerdict, authSignal, authVerdictFromFile, authEpisode, authNotified, rcSignal, rcEpisode, rcAllowRestart };
if (require.main !== module) return;

const dry = process.argv.includes('--dry-run');
// p3#19: видимые сбои — раньше notify/read/registry failures молча логировались, exit
// оставался 0, и systemd/cron не мог отличить «всё ок» от «сторож недоглядел воркера».
// dry-run — превью, не должен алармить: exit код для него всегда 0 (см. конец файла).
let notifyFailures = 0;
let readFailures = 0;
// T3 (Codex-ревью): провал подачи заявки/открытия инцидента — операционный сбой сам по себе,
// не только сбой ЧТЕНИЯ (readFailures) или ДОСТАВКИ алерта (notifyFailures). Раньше, если
// notify() об этом сбое ДОСТАВЛЯЛСЯ успешно, exitCode оставался 0 — systemd/cron не видел
// «сторож не смог подать заявку/открыть инцидент» как провал тика (п.4 плана T3 требует
// notify + exitCode-механику T1 разом, не только notify).
let actionFailures = 0;

// Best-effort лок: ручной запуск (напр. --dry-run для отладки) параллельно с таймером иначе
// делает read-modify-write watchdog-state.json без синхронизации — кто сохранил последним,
// тот и победил, откатывая alerted/restartedAt другого прогона (пропуск шага лестницы или
// задержка эскалации). 15 мин "протухания" — 3x интервал таймера (5 мин), с большим запасом
// на нормальное время выполнения (секунды), чтобы не звать stale замок за живой прогон.
const LOCK_FILE = path.join(DEPT, 'liveness.lock');
const LOCK_STALE_MS = 15 * 60_000;
function acquireLock() {
  fs.mkdirSync(DEPT, { recursive: true });
  try {
    const fd = fs.openSync(LOCK_FILE, 'wx');
    fs.writeSync(fd, String(process.pid));
    fs.closeSync(fd);
    return true;
  } catch (e) {
    if (e.code !== 'EEXIST') throw e;
    try {
      if (Date.now() - fs.statSync(LOCK_FILE).mtimeMs > LOCK_STALE_MS) { fs.unlinkSync(LOCK_FILE); return acquireLock(); }
    } catch {}
    return false;
  }
}
// p3#22: dry-run строго read-only — лок НЕ берём и НЕ пишем (превью-прогон не должен
// транзиентно блокировать реальный тик и вообще что-либо создавать на диске; dry-путь
// без лока безопасен — он не пишет state, гонки RMW нет).
if (!dry) {
  if (!acquireLock()) {
    console.log('liveness: другой прогон уже идёт (свежий lock) — пропуск во избежание гонки на watchdog-state.json');
    return;
  }
  // 'exit' — не try/finally: тоже снимает лок при незапойманном исключении в цикле ниже,
  // не только при штатном завершении (иначе один сбой навсегда блокирует следующие прогоны
  // на 15 мин, а не только на текущий тик).
  process.on('exit', () => { try { fs.unlinkSync(LOCK_FILE); } catch {} });
}

// timeout: подвисший tmux/dept-ledger/dept-liveness-request (напр. мёртвый tmux-сервер) иначе
// вешает execFileSync навсегда — сам watchdog зависает вместо детекта чужого зависания, и ни
// один воркер ПОСЛЕ зависшего в цикле не проверяется, saveState() не вызывается.
function sh(cmd, args) { try { return execFileSync(cmd, args, { encoding: 'utf8', timeout: 10_000 }); } catch { return null; } }
// ВАЖНО: и сокет, и сессия называются claude-<name> (см. claude-auto-run) —
// цель capture-pane именно claude-<name>, не <name>.
function screen(name) { return sh('tmux', ['-L', `claude-${name}`, 'capture-pane', '-p', '-t', `claude-${name}`]); }
function transcriptPath(name) {
  const spec = JSON.parse(fs.readFileSync(path.join(CC_HOME, 'workers', name, 'spec.json'), 'utf8'));
  const projRoot = path.join(process.env.HOME, '.claude', 'projects');
  for (const d of fs.readdirSync(projRoot)) {
    const f = path.join(projRoot, d, spec.session_id + '.jsonl');
    if (fs.existsSync(f)) return f;
  }
  return null;
}
function transcriptMtime(name) {
  const f = transcriptPath(name);
  // транскрипт не найден — не считать древним (эпохальный tm=0 отключал бы fresh-check)
  return f ? fs.statSync(f).mtimeMs : null;
}
// Вердикт авторизации по воркеру: любой сбой (нет spec.json, нет транскрипта, нечитаемо) —
// 'unknown', НЕ 'resolved'. Сбой чтения не является доказательством того, что воркер жив.
function workerAuthVerdict(name) {
  try {
    const f = transcriptPath(name);
    return f ? authVerdictFromFile(f) : 'unknown';
  } catch { return 'unknown'; }
}
// spec воркера (remote_control-гейт RC-надзора); null при любом сбое чтения.
function workerSpec(name) {
  try { return JSON.parse(fs.readFileSync(path.join(CC_HOME, 'workers', name, 'spec.json'), 'utf8')); } catch { return null; }
}
// Время создания tmux-сессии воркера (unix-секунды) — якорь идентичности сессии для
// RC-эпизода: смена значения = воркер пересоздан (кем угодно), grace и сброс эпизода.
function sessionCreated(name) {
  const out = sh('tmux', ['-L', `claude-${name}`, 'display-message', '-p', '-t', `claude-${name}`, '#{session_created}']);
  if (out === null) return null;
  const n = Number(out.trim());
  return Number.isFinite(n) ? n : null;
}
// claude-auto restart: exit 3 = DEFERRED (busy) — машинный контракт cmd_restart. Таймаут
// свой (90с, не общий 10с sh()): stop+start гоняет systemctl + tmux и живёт дольше.
// null-status (timeout/сигнал) → -1: «неопределённый исход», вызывающий не тратит cap.
function runRestart(name) {
  try { execFileSync(path.join(BIN, 'claude-auto'), ['restart', name], { encoding: 'utf8', timeout: 90_000 }); return 0; }
  catch (e) { return typeof e.status === 'number' && e.status !== null ? e.status : -1; }
}
const DEPT_LEDGER = path.join(BIN, 'dept-ledger');
const LIVENESS_REQUEST = path.join(BIN, 'dept-liveness-request');

// dept-ledger list → массив событий (JSONL-парсинг), null при сбое чтения (sh(), тот же 10с
// таймаут). null ОТЛИЧАЕТСЯ от [] намеренно: вызывающий обязан трактовать сбой чтения как
// «не смог узнать» (пропустить тик), а не как «карточек/статусов нет» — иначе state-провал/
// сетевой флап на дедуп-проверке (T2-review) плодил бы дублирующие заявки.
function dlList(args) {
  const out = sh(DEPT_LEDGER, ['list', ...args]);
  if (out === null) return null;
  const rows = [];
  for (const l of out.split('\n')) {
    if (!l.trim()) continue;
    try { rows.push(JSON.parse(l)); } catch { /* битая строка — пропускаем, не роняем весь запрос */ }
  }
  return rows;
}
// Эффективный статус заявки liveness_restart по event_id: последний approval_status по ref
// («последний выигрывает», как effectiveStatus в dept-ledger). Нет approval_status-событий —
// заявка ещё в исходном 'open' (cmdApprovalOpen пишет data.status='open' по умолчанию) —
// НО ТОЛЬКО если сам approval ещё жив в активном журнале: dept-ledger list читает ТОЛЬКО
// активный файл (не archive/), а dept-ledger-snapshot.timer реально гоняет `rotate` каждые
// ~30 мин с дефолтным 30-дневным cutoff (Codex-ревью T3) — закрытая (denied/withdrawn) цепочка
// старше cutoff уезжает в архив, и «approval_status не найден» перестаёт значить «ещё open»,
// начинает значить «событие уехало из вида». Без проверки существования approval денied-
// карточка, которую watchdog держит в state ГОДАМИ (screen не меняется — silent_denied не
// освобождает cardEventId), после архивации выглядела бы как свежая 'open' и лестница ждала
// бы решения оператора вечно. null — сбой чтения ledger (вызывающий обязан пропустить тик,
// не терять карточку из виду).
function queryCardStatus(eventId) {
  const rows = dlList(['--kind', 'approval_status', '--filter', `ref=${eventId}`]);
  if (rows === null) return null;
  if (rows.length) {
    const last = rows[rows.length - 1];
    let executedAt = null;
    if (last.data.status === 'executed') {
      const parsed = Date.parse(last.ts);
      // T3-ревью F2: битый/отсутствующий ts события — NaN дальше рвёт new Date(NaN).toISOString()
      // в dry-run и портит reincident-детект (decide(): prev.restartedAt должен быть числом) —
      // fallback на "сейчас", не теряем закрытие эпизода из-за плохого поля в ledger.
      executedAt = Number.isFinite(parsed) ? parsed : Date.now();
    }
    return { status: last.data.status, executedAt };
  }
  // Нет approval_status — подтверждаем, что сам approval ещё в активном файле (не архиве).
  const apr = dlList(['--kind', 'approval', '--event-id', eventId]);
  if (apr === null) return null;
  if (!apr.length) return { status: undefined, executedAt: null }; // ушёл в архив/потерян — cardStep даст 'clear'
  return { status: 'open', executedAt: null };
}
// T2-review advisory (дедуп-слой б): перед подачей НОВОЙ заявки — нет ли уже нерешённой
// (open/approved/executing) liveness_restart на этого воркера в ledger? Защита от state-
// провала (watchdog-state.json потерян/повреждён/не успел сохраниться) — без неё каждый тик
// после потери state плодил бы дубль заявки поверх ещё нерешённой. {ok:false} — не смогли
// проверить (сбой чтения) — вызывающий обязан пропустить подачу в этом тике, не рисковать дублем.
function findExistingCardForWorker(name) {
  const approvals = dlList(['--kind', 'approval', '--filter', 'kind_of=liveness_restart', '--filter', 'from=watchdog']);
  if (approvals === null) return { ok: false };
  const candidates = approvals.filter((e) => e && e.data && e.data.request && e.data.request.worker === name);
  for (let i = candidates.length - 1; i >= 0; i--) {
    const view = queryCardStatus(candidates[i].event_id);
    if (view === null) return { ok: false };
    if (view.status === 'open' || view.status === 'approved' || view.status === 'executing') {
      return { ok: true, eventId: candidates[i].event_id };
    }
  }
  return { ok: true, eventId: null };
}
// Подача заявки на перезапуск через гейт отдела (dept-liveness-request — НЕ worker-only,
// сторож не сессия воркера, см. заголовок dept-liveness-request). event_id или null при
// сбое (сеть/ledger/бот — FAIL-CLOSED внутри dept-liveness-request само пишет причину в stderr).
function fileLivenessRequest(name, frozenMin, transcriptMin) {
  const out = sh(LIVENESS_REQUEST, ['--worker', name, '--frozen-min', String(frozenMin), '--transcript-min', String(transcriptMin)]);
  if (out === null) return null;
  try { const j = JSON.parse(out.trim()); return j.event_id || null; } catch { return null; }
}

function loadState() { try { return JSON.parse(fs.readFileSync(STATE_FILE, 'utf8')); } catch { return {}; } }
function saveState(s) {
  fs.mkdirSync(DEPT, { recursive: true });
  const tmp = STATE_FILE + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(s, null, 2));
  fs.renameSync(tmp, STATE_FILE);
}
// p3#33: у notify СОБСТВЕННЫЙ таймаут 30с (не общий 10с sh()) — telegram_notify.sh при
// сетевом флапе не успевал добежать до своего fallback, алерт молча терялся. Возвращает
// успех/провал: там, где после алерта пишется дедуп-стейт эпизода (alerted/animAlerted/
// wouldNotified), провал notify НЕ помечает эпизод — следующий тик повторит.
function notify(msg) {
  if (dry) { console.log('[dry] notify:', msg); return true; }
  // card.send сама выбирает бота, ставит --parse-mode HTML и `--`, и ретраит plain-текстом
  // ТОЛЬКО на ошибке разметки (транспортный сбой telegram_notify.sh отрабатывает сам).
  //
  // notifyFailures считаем по .ok, а НЕ по исключению: card.send ловит сбой внутри и
  // возвращает {ok:false}, ничего не бросая. Оставить инкремент только в catch означало бы,
  // что счётчик навсегда нулевой, а строка 'process.exitCode = 1' ниже перестаёт срабатывать —
  // сторож рапортовал бы systemd успех ровно в тот момент, когда алерты не доходят.
  // catch остаётся страховкой на непредвиденное исключение самой библиотеки.
  let ok = false; let detail = '';
  try { const r = card.send(msg, { tg: NOTIFY }); ok = r.ok; detail = r.out; }
  catch (e) { detail = (e && e.message) || String(e); }
  if (!ok) { console.log('liveness: notify FAILED:', detail || msg); notifyFailures++; }
  return ok;
}

// p3#19: раньше непойманное исключение здесь роняло процесс голым stack trace'ом (exit код уже
// был ненулевым, но диагностика — нечитаемая). regFailed учитывается в итоговом exitCode внизу
// заодно с notify/read failures; при провале реестр считаем пустым — цикл ниже просто не найдёт
// воркеров (Object.entries({}) === []), а не упадёт повторно.
let regFailed = false;
let reg = {};
try {
  reg = JSON.parse(fs.readFileSync(path.join(CC_HOME, 'autonomous.json'), 'utf8'));
} catch (e) {
  console.log('liveness: не удалось прочитать реестр autonomous.json — пропуск тика:', e.message);
  regFailed = true;
}
const state = loadState();
const now = Date.now();
// Наблюдения auth-состояния за этот тик — собираются по ВСЕМ активным воркерам и разбираются
// ОДИН раз после цикла: протухший логин бьёт по всем разом, оператору нужно одно сообщение
// со списком, а не N отдельных алертов.
const authObs = [];
// Наблюдения RC-состояния за этот тик (ветка #rc) — тоже разбираются ОДИН раз после цикла:
// действия (рестарты) внутри цикла оставили бы остальную лестницу работать по снапшоту
// уже убитой сессии (Codex-ревью плана).
const rcObs = [];
for (const [name, meta] of Object.entries(reg.workers || reg)) {
  if (!meta || typeof meta !== 'object' || meta.state !== 'active') continue;
  const scr = screen(name);
  if (scr === null) {
    if (dry) console.log(`[dry] ${name}: tmux недоступен (зона reconciler)`);
    else console.log(`liveness: ${name}: tmux недоступен — зона reconciler`);
    // 'unknown', а не выбытие: сессии не видно — это не доказательство того, что логин жив.
    authObs.push({ name, signal: 'unknown', screenHash: '' });
    // RC-эпизод замораживаем, не рвём: tmux-флап — зона reconciler, не доказательство обрыва.
    const specNoTmux = workerSpec(name);
    if (specNoTmux && specNoTmux.remote_control === true) rcObs.push({ name, signal: 'skip', sessionCreated: null });
    continue;
  }
  // Auth-детект — ДО гейта транскрипта ниже и ДО lifecycle карточки liveness_restart: обе
  // ветки делают continue, и воркер с ненайденным транскриптом или с висящей карточкой
  // никогда бы не попал в эпизод (Codex-ревью плана, критичное 1).
  // Вердикт — лениво: транскрипт читается ТОЛЬКО когда на экране есть auth-маркер.
  const authSig = authSignal(scr, () => workerAuthVerdict(name));
  authObs.push({ name, signal: authSig, screenHash: crypto.createHash('sha1').update(scr).digest('hex') });
  if (dry && authSig !== 'clear') console.log(`[dry] ${name}: auth=${authSig}`);
  // RC-наблюдение — до auth-continue ниже, чтобы auth-blocked воркер ЗАМОРАЖИВАЛ свой
  // RC-эпизод (skip), а не выбывал из него. Гейты в порядке приоритета:
  //  1) auth не clear → skip (протухший логин роняет RC у всех разом; рестарт с мёртвыми
  //     креденшелами бесполезен — авторитет здесь auth-ветка);
  //  2) висит карточка liveness_restart → skip (воркер завис, RC вторичен — решает оператор);
  //  3) remote_control≠true в spec → воркер не под RC-надзором вовсе (не в obs → выбытие);
  //  4) сессия моложе grace → skip (RC подключается не мгновенно после старта).
  {
    const rcSpec = workerSpec(name);
    if (rcSpec && rcSpec.remote_control === true) {
      const sc = sessionCreated(name);
      let sig;
      if (authSig !== 'clear') sig = 'skip';
      else if (state[name] && state[name].cardEventId) sig = 'skip';
      else if (sc === null) sig = 'unknown';
      else if (now - sc * 1000 < CFG.rcGraceMin * 60_000) sig = 'skip';
      else sig = rcSignal(scr);
      rcObs.push({ name, signal: sig, sessionCreated: sc });
      if (dry) console.log(`[dry] ${name}: rc=${sig}`);
    }
  }
  // Codex-ревью 21.07: воркер с мёртвым логином НЕ должен идти по основной лестнице.
  // Иначе остаточный «esc to interrupt» выше хвоста экрана (cur.busy считается по ВСЕМУ
  // pane) плюс стоящий транскрипт дают alert → карточку рестарта → incident — ровно то,
  // чего оператор на этой ветке не хотел: рестарт с мёртвыми креденшелами бесполезен.
  // Этим воркером занимается групповой алерт после цикла.
  if (authSig === 'blocked') continue;
  let tm;
  try { tm = transcriptMtime(name); } catch { console.log(`liveness: ${name}: ошибка чтения spec/транскрипта — пропуск`); readFailures++; continue; }
  if (tm === null) {
    console.log(`liveness: ${name}: транскрипт не найден — пропуск (проверь spec.json session_id)`);
    continue;
  }
  const cur = { ts: now, busy: BUSY_RE.test(scr), screenHash: crypto.createHash('sha1').update(scr).digest('hex'), transcriptMtime: tm };
  if (dry) console.log(`[dry] ${name}: busy=${cur.busy} hash=${cur.screenHash.slice(0, 8)} transcript_age_min=${Math.round((now - tm) / 60000)}`);
  let prev = state[name] || null;
  const d = decide(prev, cur, CFG);

  // T3: жизненный цикл карточки liveness_restart — КАЖДЫЙ тик, пока она отслеживается,
  // НЕЗАВИСИМО от action этого тика (оператор мог решить заявку, пока экран стоит на месте
  // и decide() продолжает отдавать 'restart'). Приоритет над d.reset/остальной лестницей:
  // executed обязан выставить restartedAt = ts события ИЗ LEDGER, иначе reincident-детект
  // (decide(): prev.restartedAt свежий) не сработает при повторном зависании.
  if (prev && prev.cardEventId) {
    const view = queryCardStatus(prev.cardEventId);
    if (view === null) {
      console.log(`liveness: ${name}: не удалось прочитать статус карточки ${prev.cardEventId} — пропуск`);
      readFailures++;
      continue;
    }
    const step = cardStep(prev, cur, { cardStatus: view.status, executedAt: view.executedAt });
    if (step.op === 'close_executed') {
      if (dry) { console.log(`[dry] ${name}: карточка ${prev.cardEventId} исполнена — закрыл бы эпизод (restartedAt=${new Date(step.executedAt).toISOString()})`); continue; }
      // reincident-детект сохранён (p3#33-паттерн): state пишем по факту исполненной заявки,
      // независимо от исхода дальнейших notify — эпизод УЖЕ закрыт рестартом в ledger.
      state[name] = { screenHash: '', firstSeen: now, alerted: false, restartedAt: step.executedAt };
      continue;
    }
    if (step.op === 'wait') {
      if (dry) console.log(`[dry] ${name}: карточка ${prev.cardEventId} ещё не решена — жду`);
      continue;
    }
    if (step.op === 'silent_denied') {
      if (dry) console.log(`[dry] ${name}: карточка ${prev.cardEventId} отклонена, экран тот же — не переподаю`);
      continue;
    }
    if (step.op === 'silent_withdrawn') {
      if (dry) console.log(`[dry] ${name}: карточка ${prev.cardEventId} отозвана, экран тот же — не переподаю`);
      continue;
    }
    // step.op === 'clear': denied/withdrawn с изменившимся экраном ИЛИ статус не определился —
    // снять карточку и продолжить обычную лестницу ниже (reset её и так бы стёр — nextState('reset')
    // не спреадит card-поля).
    if (dry) { console.log(`[dry] ${name}: карточка ${prev.cardEventId} снята — переподал бы при следующем зависании`); continue; }
    prev = state[name] = { ...prev, cardEventId: undefined, cardScreenHash: undefined };
  }

  if (d.reset) { state[name] = nextState(prev, cur, 'reset'); continue; }
  if (d.action === 'anim_alert') {
    // p3#33: animAlerted (дедуп anim-эпизода) — только при ДОСТАВЛЕННОМ алерте,
    // иначе следующий тик повторит попытку (алерт не теряется на сетевом флапе).
    const animOk = notify(card.build({
      head: ['⚠️', 'Похоже на анимированное зависание'],
      fields: [['Воркер', name], ['Транскрипт не движется', `${Math.round((now - tm) / 60000)} мин`]],
      note: 'Экран активен, но работа не идёт. Обычная причина — лимиты подписки или сеть.',
      action: `tmux -L claude-${name} attach -t claude-${name}`,
    }));
    // nextState пишет СВЕЖИЙ cur.screenHash (не устаревший prev.screenHash) и безусловно
    // сбрасывает alerted/wouldNotified/wouldIncidentNotified — экран сменился by construction.
    state[name] = nextState(prev, cur, 'anim_alert', animOk);
    continue;
  }
  if (d.action === 'none') {
    // none && !reset (reset обработан выше). Для основной лестницы это no-op — hash в этой
    // ветке равен prev.screenHash. Для продолжающегося anim-эпизода продвигает hash каждый
    // тик: реально замерший после анимации экран на следующем тике совпадёт с prev.screenHash
    // и уйдёт в основную лестницу (иначе старый докадровый hash глушил бы её навсегда).
    // firstSeen сохраняется как якорь начала эпизода — переход anim→freeze эскалирует сразу
    // (воркер уже давно болен), это намеренно. Если экран при этом СМЕНИЛСЯ (anim продолжается) —
    // nextState() сбрасывает alerted/wouldNotified/wouldIncidentNotified (старый алерт устарел);
    // на no-op (hash равен) она эти флаги не трогает — дедуп основной лестницы не задет.
    state[name] = nextState(prev, cur, 'none');
    continue;
  }
  if (d.action === 'alert') {
    // p3#33: alerted (первая ступень лестницы) — только при доставленном алерте; провал
    // notify оставляет prev как есть, следующий тик снова даст action=alert и повторит.
    state[name] = nextState(prev, cur, 'alert', notify(card.build({
      head: ['⚠️', 'Воркер завис'],
      fields: [['Воркер', name], ['Занят', `${CFG.hungMin}+ мин`]],
      note: 'Транскрипт не движется. Следующий шаг — заявка на перезапуск, придёт карточкой от бота.',
    })));
  } else if (d.action === 'restart') {
    // T3 (решение оператора 19.07): вместо авто-рестарта — подача заявки через гейт отдела.
    // Сюда попадаем только когда карточка ЕЩЁ не отслеживается (живая cardEventId обработана
    // и continue'нута в блоке жизненного цикла выше — либо wait/silent_denied, либо только что
    // clear'нута и prev.cardEventId уже пуст).
    const dedup = findExistingCardForWorker(name);
    if (!dedup.ok) {
      console.log(`liveness: ${name}: не удалось проверить дедуп заявок в ledger — пропуск подачи`);
      readFailures++;
    } else {
      const step = cardStep(prev, cur, { existingCardId: dedup.eventId });
      if (step.op === 'adopt') {
        if (dry) console.log(`[dry] ${name}: усыновил бы существующую заявку ${step.eventId} вместо подачи новой`);
        else state[name] = { ...prev, cardEventId: step.eventId, cardScreenHash: cur.screenHash };
      } else {
        // N = минуты с prev.firstSeen (начало эпизода), M = минуты с cur.transcriptMtime.
        const frozenMin = Math.round((cur.ts - prev.firstSeen) / 60000);
        const transcriptMin = Math.round((cur.ts - cur.transcriptMtime) / 60000);
        if (dry) {
          console.log(`[dry] ${name}: подал бы заявку на перезапуск (завис ${frozenMin} мин, транскрипт не движется ${transcriptMin} мин)`);
        } else {
          const eid = fileLivenessRequest(name, frozenMin, transcriptMin);
          if (eid) {
            // notify оператору здесь НЕ шлём — карточка сама придёт от бота (dept-liveness-request).
            state[name] = { ...prev, cardEventId: eid, cardScreenHash: cur.screenHash };
          } else {
            notify(card.build({
              head: ['🚨', 'Заявка на перезапуск НЕ подана'],
              fields: [['Воркер', name], ['Завис', `${frozenMin} мин`]],
              note: 'Сторож не смог подать заявку через гейт отдела — автоматика дальше не пойдёт.',
              action: `Перезапустить вручную: claude-auto restart ${name}`,
            }));
            actionFailures++; // видимая деградация — не только readFailures/notifyFailures
            // state НЕ обновляем — повтор на следующем тике
          }
        }
      }
    }
  } else if (d.action === 'incident') {
    // reincident = зависание после ИСПОЛНЕННОЙ карточки (prev.restartedAt свежий, ставится в
    // блоке close_executed выше) — открытие инцидента ТП безусловно (не за флагом, ENFORCE
    // удалён): это запись+сообщение ТП, не перезапуск. Тот же принцип, что раньше: упавший
    // dept-ledger incident-open не должен "закрывать" наблюдение (чистить state), хотя
    // инцидент для ТП фактически не открылся.
    const opened = dry || sh(DEPT_LEDGER, ['incident-open', '--about', name, '--severity', 'high',
      '--summary', 'воркер виснет повторно после рестарта', '--actor', 'watchdog']) !== null;
    if (opened) {
      // p3#33-решение: state пишем НЕЗАВИСИМО от исхода notify — инцидент УЖЕ открыт в
      // ledger (ТП получил message), повтор на следующем тике открыл бы ВТОРОЙ инцидент;
      // уведомление информационное, факт эпизода зафиксирован инцидентом.
      notify(card.build({
        head: ['🚨', 'Повторное зависание после рестарта'],
        fields: [['Воркер', name]],
        note: 'Инцидент для ТП открыт автоматически — действий от тебя не требуется.',
      }));
      state[name] = { screenHash: '', firstSeen: now, alerted: false, restartedAt: 0 };
    } else {
      notify(card.build({
        head: ['🚨', 'Инцидент НЕ открыт'],
        fields: [['Воркер', name]],
        note: 'Воркер виснет повторно после рестарта, но инцидент для ТП завести не удалось.',
        action: `Открыть вручную: dept-ledger incident-open --about ${name} --severity high`,
      }));
      actionFailures++; // видимая деградация — не только readFailures/notifyFailures
      // state НЕ обновляем
    }
  }
}
// Эпизод протухшей авторизации — ОДИН на хост, разбирается после цикла: один групповой алерт
// со списком вместо N отдельных. Решение оператора 21.07: карточку liveness_restart на этой
// ветке НЕ подаём (рестарт с мёртвыми креденшелами поднимет воркера в ту же ошибку — лечит
// только /login на хосте) и инцидент ТП не открываем; вместо эскалации — напоминание раз в
// LIVENESS_AUTH_REMIND_MIN, пока эпизод не рассосётся.
{
  const prevEp = state[AUTH_KEY] || null;
  const { episode, alert } = authEpisode(prevEp, authObs, now, CFG);
  let ep = episode;
  if (alert) {
    const list = alert.members.join(', ');
    const msg = card.build({
      head: ['🔐', 'Протухла авторизация Claude Code',
             alert.kind === 'remind' ? 'напоминание' : ''],
      // Список воркеров — СЕКЦИЯ, а не хвост фразы: на большом флоте перечисление внутри
      // предложения снова превращалось в простыню, ради ухода от которой всё и делалось.
      sections: [{ emoji: '🔴', title: 'Живы, но не работают', items: alert.members }],
      note: alert.kind === 'remind'
        ? 'Авторизация на хосте всё ещё не восстановлена.'
        : 'Воркеры подняты, но каждая попытка работы упирается в неавторизованный CLI.',
      action: 'Сделать /login на хосте, затем: systemctl --user restart claude-auto@<имя> для перечисленных',
    });
    if (dry) console.log(`[dry] auth ${alert.kind}: ${list}`);
    // Двухфазность: notified проставляем ТОЛЬКО по факту доставки — иначе сетевой сбой
    // Telegram съест групповой алерт целиком и оператор не узнает об эпизоде вовсе.
    else if (notify(msg)) ep = authNotified(episode, alert, now);
  }
  if (Object.keys(ep.members || {}).length) state[AUTH_KEY] = ep;
  else delete state[AUTH_KEY];
}
// Эпизод RC-обрывов (#rc) — разбор после цикла (оператор 22.07: авто-рестарт + одно
// групповое уведомление; исключение из 19.07, см. rcSignal). Структура ключа:
//   members   — текущие эпизоды (rcEpisode)
//   history   — timestamps ВЕРИФИЦИРОВАННЫХ авто-рестартов, живёт независимо от эпизода
//               (cap 2/24ч не обнуляется выздоровлением — иначе флапающий RC получал бы
//               свежий лимит каждый цикл болезни)
//   escalated — {name:{lastAlertAt}} — cap исчерпан, напоминаем раз в remindMin
{
  const prevEp = state[RC_KEY] || null;
  const { members, due } = rcEpisode(prevEp, rcObs, now, CFG);
  // Object.create(null) — по той же причине, что members в rcEpisode (имя '__proto__').
  const history = Object.assign(Object.create(null),
    prevEp && prevEp.history && typeof prevEp.history === 'object' ? prevEp.history : {});
  const escalated = Object.assign(Object.create(null),
    prevEp && prevEp.escalated && typeof prevEp.escalated === 'object' ? prevEp.escalated : {});
  const doneList = []; const deferList = []; const failList = []; const escList = [];
  for (const name of due) {
    const cap = rcAllowRestart(history[name], now, CFG);
    history[name] = cap.fresh;
    if (!cap.allowed) {
      const e = escalated[name] && Number.isFinite(escalated[name].lastAlertAt) ? escalated[name] : { lastAlertAt: 0 };
      if (now - e.lastAlertAt >= CFG.remindMin * 60_000) escList.push(name);
      continue;
    }
    // Backoff неопределённых исходов: рестарт с exit≠0/3 или проваленной верификацией не
    // тратит cap, но и не молотит каждый тик — повтор не раньше rcAbsentMin.
    if (members[name].lastAttemptAt && now - members[name].lastAttemptAt < CFG.rcAbsentMin * 60_000) {
      console.log(`liveness: ${name}: rc-рестарт недавно уже пробовали (исход неопределён) — жду backoff`);
      continue;
    }
    if (dry) {
      console.log(`[dry] ${name}: rc-обрыв подтверждён (${members[name].badKind}, ${members[name].obsCount} набл.) — перезапустил бы`);
      continue;
    }
    // Повторная проверка eligibility ПОД ЗАНАВЕС (Codex-ревью: оператор мог усыпить/
    // перезапустить воркера, пока шёл цикл): state=active по СВЕЖЕМУ реестру (не reg,
    // прочитанному в начале тика), rc всё ещё включён в spec, и это ТА ЖЕ сессия.
    // cardEventId — по ТЕКУЩЕМУ state (обс-гейт видел state НАЧАЛА тика; основная лестница
    // могла подать карточку liveness_restart в ЭТОМ тике — рестартить поверх неё нельзя, и
    // delete state[name] ниже осиротил бы её отслеживание).
    if (state[name] && state[name].cardEventId) {
      console.log(`liveness: ${name}: rc-рестарт отменён — в этом тике подана карточка liveness_restart, решает оператор`);
      continue;
    }
    let freshReg = null;
    try { freshReg = JSON.parse(fs.readFileSync(path.join(CC_HOME, 'autonomous.json'), 'utf8')); } catch {}
    const freshMeta = freshReg && (freshReg.workers || freshReg)[name];
    const freshSpec = workerSpec(name);
    const scBefore = sessionCreated(name);
    if (!freshMeta || freshMeta.state !== 'active' || !freshSpec || freshSpec.remote_control !== true ||
        scBefore === null || scBefore !== members[name].sessionCreated) {
      console.log(`liveness: ${name}: rc-рестарт отменён — состояние воркера изменилось между наблюдением и действием`);
      delete members[name];
      continue;
    }
    const rrc = runRestart(name);
    if (rrc === 3) { deferList.push(name); continue; } // busy — cmd_restart DEFERRED, cap не тратим
    if (rrc === 4) {
      // «не active» — оператор усыпил/остановил воркера между наблюдением и действием;
      // cmd_restart отказался (и правильно). Эпизод снимаем: не-active выпадет из obs сам.
      console.log(`liveness: ${name}: rc-рестарт отменён — воркер уже не active (решение оператора)`);
      delete members[name];
      continue;
    }
    // Верификация исхода: только РЕАЛЬНО пересозданная сессия (новый session_created) при
    // живом юните считается рестартом и попадает в history. Codex-ревью (high): unit —
    // Type=simple, systemctl start возвращается ДО того, как claude-auto-run создаст tmux —
    // одноразовое чтение почти всегда давало бы ложное «не подтвердился» (и рестарт без
    // учёта в cap). Поэтому ПОЛЛИМ до 30с; заодно переживаем секундную гранулярность
    // session_created. systemctl is-active --quiet: exit 0 → sh() отдаёт '' (не null).
    let scAfter = null;
    for (let i = 0; i < 20; i++) {
      scAfter = sessionCreated(name);
      if (scAfter !== null && scAfter !== scBefore) break;
      Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 1_500);
    }
    const unitUp = sh('systemctl', ['--user', 'is-active', '--quiet', `claude-auto@${name}.service`]) !== null;
    if (rrc === 0 && unitUp && scAfter !== null && scAfter !== scBefore) {
      history[name] = [...cap.fresh, now];
      delete members[name];  // эпизод закрыт; новая сессия отработает grace и проверится заново
      delete state[name];    // свежий baseline основной лестницы: экран пересоздан
      doneList.push(name);
      console.log(`liveness: ${name}: rc-рестарт выполнен (session_created ${scBefore} → ${scAfter}, рестартов в окне: ${history[name].length}/${CFG.rcMaxRestarts})`);
    } else {
      // Неопределённый исход (timeout/провал/unit не поднялся/сессия не пересоздалась):
      // cap не тратим, member остаётся с lastAttemptAt-backoff — следующий тик разрешит
      // неоднозначность по session_created (пересоздана → эпизод сбросится сам).
      console.log(`liveness: ${name}: rc-рестарт с неопределённым исходом (exit=${rrc}, unit=${unitUp}, session ${scBefore} → ${scAfter}) — backoff`);
      if (!unitUp) {
        // Рестарт мог умереть МЕЖДУ stop и start (timeout убил claude-auto): воркер лежит
        // со state=stopped, а реконсилятор чинит только state=active — без добивки он
        // остался бы лежать навсегда. `start` идемпотентен (state=active + enable --now).
        // Гейт по state==='stopped' СТРОГО: sleeping = осознанное решение оператора,
        // будить его добивка не имеет права (Codex-ревью, гонка с операторским sleep).
        let stNow = null;
        try { stNow = (JSON.parse(fs.readFileSync(path.join(CC_HOME, 'autonomous.json'), 'utf8')).workers || {})[name]?.state; } catch {}
        if (stNow === 'stopped') {
          try {
            execFileSync(path.join(BIN, 'claude-auto'), ['start', name], { encoding: 'utf8', timeout: 60_000 });
            console.log(`liveness: ${name}: воркер лежал (state=stopped) после неудачного рестарта — добил start'ом`);
          } catch { console.log(`liveness: ${name}: добивка start'ом тоже не удалась — вмешайся`); }
        } else {
          console.log(`liveness: ${name}: unit лежит, но state=${stNow} — добивку не делаю (не мой артефакт)`);
        }
      }
      members[name] = { ...members[name], lastAttemptAt: now };
      failList.push(name);
      actionFailures++;
    }
  }
  // Групповое уведомление — одно за тик. escalated двухфазно (как auth): помечаем только
  // по факту ДОСТАВКИ, иначе сетевой флап съедает эскалацию навсегда.
  if (doneList.length || failList.length || escList.length) {
    // Каждая судьба — своя секция; пустые не печатаются. Прежняя строка склеивала все
    // четыре через '; ', и «нужен взгляд руками» терялся в хвосте рядом с рутинным
    // «перезапустил» — ровно та потеря сигнала, ради которой затевались карточки.
    const ok = notify(card.build({
      head: ['📡', 'Remote Control отвалился'],
      sections: [
        { emoji: '✅', title: 'Перезапустил', items: doneList },
        { emoji: '⏳', title: 'Заняты — отложено до следующего тика', items: deferList },
        { emoji: '⚠️', title: 'Рестарт не подтвердился — жду следующего тика', items: failList },
        { emoji: '🔴', title: `НЕ поднимается после ${CFG.rcMaxRestarts} рестартов за ${CFG.rcWindowH}ч`, items: escList },
      ],
      action: escList.length ? `Посмотреть руками: tmux -L claude-${escList[0]} attach -t claude-${escList[0]}` : '',
    }));
    if (ok) for (const n of escList) escalated[n] = { lastAlertAt: now };
  } else if (deferList.length) {
    // только отложенные: не спамим оператора каждые 5 минут, пока воркер занят — лог хватит
    console.log(`liveness: rc: заняты, отложено: ${deferList.join(', ')}`);
  }
  // Санитария: history — только живые окна; escalated — только пока воркер болен.
  for (const k of Object.keys(history)) {
    history[k] = (Array.isArray(history[k]) ? history[k] : []).filter((t) => Number.isFinite(t) && t <= now && now - t < CFG.rcWindowH * 3_600_000);
    if (!history[k].length) delete history[k];
  }
  for (const k of Object.keys(escalated)) if (!members[k]) delete escalated[k];
  if (Object.keys(members).length || Object.keys(history).length || Object.keys(escalated).length) {
    state[RC_KEY] = { members, history, escalated };
  } else delete state[RC_KEY];
}
// Воркеры, пропавшие из autonomous.json (снесены/переименованы) — их записи в state иначе
// никогда не трогаются циклом выше и копятся в файле навечно. SERVICE_KEYS (#auth, #rc) —
// служебные ключи эпизодов, а не воркеры: имена воркеров валидируются как ^[a-zA-Z0-9_-]+$,
// поэтому '#' гарантирует отсутствие коллизии; из cleanup их надо исключить явно, иначе
// эпизод стирался бы каждый тик и групповой алерт слался бы заново без конца.
const known = new Set(Object.keys(reg.workers || reg));
for (const name of Object.keys(state)) if (!SERVICE_KEYS.has(name) && !known.has(name)) delete state[name];
// dry-run обязан быть чисто read-only (см. docs/department.md): раньше saveState() писал
// БЕЗУСЛОВНО, и alerted:true из превью-прогона "съедал" ступень лестницы у следующего
// боевого прогона — watchdog прыгал сразу к restart, ни разу не послав настоящий alert.
// regFailed: реестр не прочитан → known пуст → цикл cleanup выше стёр бы весь state — не
// сохраняем, чтобы битый/временно недоступный autonomous.json не снёс историю наблюдения.
if (!dry && !regFailed) saveState(state);
// p3#19 + T3 (Codex-ревью): видимая деградация — notify/read/registry/action failures раньше
// тонули в логах, exit оставался 0, и systemd/cron не мог отличить «всё ок» от «сторож молча
// недоглядел». actionFailures — T3: провал подачи заявки/открытия инцидента виден в exitCode
// даже когда сам алерт о провале доставлен успешно (notifyFailures==0).
if (!dry && (notifyFailures || readFailures || regFailed || actionFailures)) process.exitCode = 1;
