#!/usr/bin/env node
// claude-auto-liveness — детерминированный watchdog «жив, но не отвечает».
// hung = busy-маркер на экране + замерший screen-hash + замерший транскрипт
// дольше HUNG_MIN. Лестница: alert → карточка перезапуска (кнопка оператора) → incident (ТП).
// Решение оператора 19.07: авто-рестарт отменён навсегда — сторож только подаёт заявку
// через dept-liveness-request, исполняет диспетчер по ✅ (см. liveness-button-plan.md).
// Запуск: systemd-таймер каждые 5 минут. Флаг --dry-run: только печать решений.
'use strict';
const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');
const crypto = require('crypto');
// T5: корень рантайма — через единый резолвер (lib/runtime-root.js, задача T1). Профиль
// auto_then_hardcoded воспроизводит прежнюю строку (CLAUDE_AUTO_HOME || '/home/rainor/.claude-control')
// без маркера; под CLAUDE_CONTROL_TEST_ROOT — fail-closed на корень песочницы. require('../lib')
// верен в repo- и install-layout (node резолвит по realpath модуля, как process-control.js в T4).
const { resolveRuntimeRoot } = require('../lib/runtime-root.js');

const CC_HOME = resolveRuntimeRoot('auto_then_hardcoded');
// DEPT остаётся производным от резолвленного CC_HOME (композитный DEPT): DEPT_HOME → CC_HOME/department.
const DEPT = process.env.DEPT_HOME || path.join(CC_HOME, 'department');
const STATE_FILE = path.join(DEPT, 'watchdog-state.json');
const BIN = __dirname;
// Number(garbage) === NaN, и NaN "просачивался" бы во все сравнения decide() как false —
// это ОТКЛЮЧАЕТ и fresh-check, и hung-порог разом (см. /bug-раунд), а не просто ломает дефолт.
function numEnv(name, def) {
  const n = Number(process.env[name]);
  return Number.isFinite(n) && n > 0 ? n : def;
}
const CFG = {
  hungMin: numEnv('LIVENESS_HUNG_MIN', 30),
  reincidentMin: numEnv('LIVENESS_REINCIDENT_MIN', 60),
  animMin: numEnv('LIVENESS_ANIM_HUNG_MIN', 90),
};
const BUSY_RE = /esc to interrupt|Thinking|Compacting|Forking|Summariz|tokens · esc/i;
const NOTIFY = process.env.TELEGRAM_NOTIFY || '/home/rainor/server/server_monitor/telegram_notify.sh';

// Чистая решающая функция (тестируется отдельно).
function decide(prev, cur, cfg) {
  if (!cur.busy) return { action: 'none', reset: true };
  const staleMs = cur.ts - cur.transcriptMtime;
  if (staleMs < cfg.hungMin * 60_000) return { action: 'none', reset: true };
  if (!prev || prev.screenHash !== cur.screenHash) {
    // экран живёт, транскрипт мёртв: вторичный сигнал (всегда alert-only)
    if (staleMs >= cfg.animMin * 60_000 && !(prev && prev.animAlerted)) return { action: 'anim_alert', reset: false };
    if (prev && prev.animAlerted) return { action: 'none', reset: false }; // эпизод продолжается — не спамить
    return { action: 'none', reset: true };
  }
  const hungFor = cur.ts - prev.firstSeen;
  if (hungFor < cfg.hungMin * 60_000) return { action: 'none', reset: false };
  if (prev.restartedAt && cur.ts - prev.restartedAt < cfg.reincidentMin * 60_000) return { action: 'incident', reset: false };
  if (!prev.alerted) return { action: 'alert', reset: false };
  return { action: 'restart', reset: false };
}

// Чистая функция: следующий state[name] для веток reset / anim_alert / none-continuation / alert
// (restart/incident остаются инлайн в цикле — там ветвление по успеху подачи заявки в ledger
// (dept-liveness-request) / dept-ledger incident-open, не по hash). notifyOk — результат
// notify() для действий, где он нужен (anim_alert/alert); для reset/none игнорируется (у них
// нет своего notify-вызова).
// Экран считается "ожившим", если hash сменился относительно prev (или prev вовсе нет) — тогда
// alerted/wouldNotified/wouldIncidentNotified сбрасываем: алерт был про СТАРОЕ замершее состояние
// экрана, оно больше не актуально. Точное совпадение hash (no-op основной лестницы alert→restart)
// эти флаги НЕ трогает — иначе дедуп сломается и лестница будет слать alert повторно на каждый тик.
function nextState(prev, cur, action, notifyOk) {
  switch (action) {
    case 'reset':
      return { screenHash: cur.screenHash, firstSeen: cur.ts, alerted: false, restartedAt: prev?.restartedAt || 0 };
    case 'anim_alert': {
      // decide() гарантирует prev.screenHash !== cur.screenHash на входе (или !prev) — экран
      // сменился by construction, сброс alerted/wouldNotified/wouldIncidentNotified безусловен
      // (не зависит от notifyOk — устаревший алерт был про предыдущий кадр в любом случае).
      // p3#33: animAlerted (дедуп anim-эпизода) — по факту доставки ИМЕННО этого алерта.
      const base = prev || { screenHash: cur.screenHash, firstSeen: cur.ts, alerted: false, restartedAt: 0 };
      return { ...base, screenHash: cur.screenHash, animAlerted: notifyOk, alerted: false, wouldNotified: false, wouldIncidentNotified: false };
    }
    case 'none': {
      // none && !reset: hash равен prev.screenHash (no-op основной лестницы, дедуп alert→restart
      // живёт) ИЛИ hash сменился (anim-эпизод продолжается, старый алерт устарел). Различаем —
      // иначе сброс alerted задел бы no-op основной лестницы (см. её тест в liveness-decide).
      const moved = !prev || prev.screenHash !== cur.screenHash;
      if (!moved) return { ...prev, screenHash: cur.screenHash };
      return { ...prev, screenHash: cur.screenHash, alerted: false, wouldNotified: false, wouldIncidentNotified: false };
    }
    case 'alert':
      // p3#33: alerted (первая ступень лестницы) — только при доставленном алерте; провал
      // notify оставляет prev как есть (тот же объект), следующий тик повторит попытку.
      return notifyOk ? { ...prev, alerted: true } : prev;
    default:
      throw new Error(`nextState: неизвестное действие "${action}"`);
  }
}

// Чистая функция T3: следующий шаг по карточке liveness_restart. Вынесена из decide()/
// nextState() намеренно — её ветвление зависит от ВНЕШНЕГО источника (эффективный
// approval_status заявки в ledger), а не только от prev/cur, и вызывается циклом из ДВУХ
// разных мест:
//  (1) карточки ещё нет (prev.cardEventId пуст) — вызывается ТОЛЬКО когда лестница decide()
//      хочет action=restart; ledgerView = {existingCardId} — T2-review дедуп-слой б: если в
//      ledger уже висит НЕрешённая (open/approved/executing) liveness_restart на этого
//      воркера (например, state потерян между тиками), усыновляем её вместо подачи дубля.
//      → {op:'adopt', eventId} | {op:'file'}
//  (2) карточка уже отслеживается (prev.cardEventId жив) — вызывается КАЖДЫЙ тик независимо
//      от action этого тика (оператор мог решить заявку, пока экран стоит на месте);
//      ledgerView = {cardStatus, executedAt} — последний approval_status по ref
//      («последний выигрывает», как effectiveStatus в dept-ledger).
//      → {op:'close_executed', executedAt} | {op:'wait'} | {op:'silent_denied'} |
//        {op:'silent_withdrawn'} | {op:'clear'}
// close_executed отдаёт executedAt ИМЕННО из ledgerView (ts события executed в ledger), не
// cur.ts «сейчас» — от него зависит reincident-детект (decide(): prev.restartedAt свежий).
function cardStep(prev, cur, ledgerView) {
  const lv = ledgerView || {};
  if (prev && prev.cardEventId) {
    const status = lv.cardStatus;
    if (status === 'executed') return { op: 'close_executed', executedAt: lv.executedAt != null ? lv.executedAt : cur.ts };
    if (status === 'denied') {
      return prev.cardScreenHash === cur.screenHash ? { op: 'silent_denied' } : { op: 'clear' };
    }
    // T3-ревью F1: withdrawn — не переподавать мгновенно (буква плана T3.1: denied/executed/
    // withdrawn → не переподаём, пока экран тот же). Ведёт себя как denied: молчим, пока
    // экран не сменился; сменился — clear и разрешаем обычной лестнице подать заново.
    if (status === 'withdrawn') {
      return prev.cardScreenHash === cur.screenHash ? { op: 'silent_withdrawn' } : { op: 'clear' };
    }
    if (status === 'open' || status === 'approved' || status === 'executing') return { op: 'wait' };
    // Статус не определился (заявка потеряна/архивирована — queryCardStatus уже подтвердил
    // «approval тоже не найден» выше по стеку) — снять карточку безусловно, ИГНОРИРУЯ hash.
    // Исключение принято ревью намеренно: иначе архивная карточка на неизменном экране держала
    // бы cardEventId вечно (silent-веткам возвращаться некуда — approval_status для неё больше
    // не читается), и лестница никогда не подала бы заявку заново.
    return { op: 'clear' };
  }
  return lv.existingCardId ? { op: 'adopt', eventId: lv.existingCardId } : { op: 'file' };
}

module.exports = { decide, nextState, cardStep };
if (require.main !== module) return;

const dry = process.argv.includes('--dry-run');
// p3#19: видимые сбои — раньше notify/read/registry failures молча логировались, exit
// оставался 0, и systemd/cron не мог отличить «всё ок» от «сторож недоглядел воркера».
// dry-run — превью, не должен алармить: exit код для него всегда 0 (см. конец файла).
let notifyFailures = 0;
let readFailures = 0;
// T3 (Codex-ревью): провал подачи заявки/открытия инцидента — операционный сбой сам по себе,
// не только сбой ЧТЕНИЯ (readFailures) или ДОСТАВКИ алерта (notifyFailures). Раньше, если
// notify() об этом сбое ДОСТАВЛЯЛСЯ успешно, exitCode оставался 0 — systemd/cron не видел
// «сторож не смог подать заявку/открыть инцидент» как провал тика (п.4 плана T3 требует
// notify + exitCode-механику T1 разом, не только notify).
let actionFailures = 0;

// Best-effort лок: ручной запуск (напр. --dry-run для отладки) параллельно с таймером иначе
// делает read-modify-write watchdog-state.json без синхронизации — кто сохранил последним,
// тот и победил, откатывая alerted/restartedAt другого прогона (пропуск шага лестницы или
// задержка эскалации). 15 мин "протухания" — 3x интервал таймера (5 мин), с большим запасом
// на нормальное время выполнения (секунды), чтобы не звать stale замок за живой прогон.
const LOCK_FILE = path.join(DEPT, 'liveness.lock');
const LOCK_STALE_MS = 15 * 60_000;
function acquireLock() {
  fs.mkdirSync(DEPT, { recursive: true });
  try {
    const fd = fs.openSync(LOCK_FILE, 'wx');
    fs.writeSync(fd, String(process.pid));
    fs.closeSync(fd);
    return true;
  } catch (e) {
    if (e.code !== 'EEXIST') throw e;
    try {
      if (Date.now() - fs.statSync(LOCK_FILE).mtimeMs > LOCK_STALE_MS) { fs.unlinkSync(LOCK_FILE); return acquireLock(); }
    } catch {}
    return false;
  }
}
// p3#22: dry-run строго read-only — лок НЕ берём и НЕ пишем (превью-прогон не должен
// транзиентно блокировать реальный тик и вообще что-либо создавать на диске; dry-путь
// без лока безопасен — он не пишет state, гонки RMW нет).
if (!dry) {
  if (!acquireLock()) {
    console.log('liveness: другой прогон уже идёт (свежий lock) — пропуск во избежание гонки на watchdog-state.json');
    return;
  }
  // 'exit' — не try/finally: тоже снимает лок при незапойманном исключении в цикле ниже,
  // не только при штатном завершении (иначе один сбой навсегда блокирует следующие прогоны
  // на 15 мин, а не только на текущий тик).
  process.on('exit', () => { try { fs.unlinkSync(LOCK_FILE); } catch {} });
}

// timeout: подвисший tmux/dept-ledger/dept-liveness-request (напр. мёртвый tmux-сервер) иначе
// вешает execFileSync навсегда — сам watchdog зависает вместо детекта чужого зависания, и ни
// один воркер ПОСЛЕ зависшего в цикле не проверяется, saveState() не вызывается.
function sh(cmd, args) { try { return execFileSync(cmd, args, { encoding: 'utf8', timeout: 10_000 }); } catch { return null; } }
// ВАЖНО: и сокет, и сессия называются claude-<name> (см. claude-auto-run) —
// цель capture-pane именно claude-<name>, не <name>.
function screen(name) { return sh('tmux', ['-L', `claude-${name}`, 'capture-pane', '-p', '-t', `claude-${name}`]); }
function transcriptMtime(name) {
  const spec = JSON.parse(fs.readFileSync(path.join(CC_HOME, 'workers', name, 'spec.json'), 'utf8'));
  const projRoot = path.join(process.env.HOME, '.claude', 'projects');
  for (const d of fs.readdirSync(projRoot)) {
    const f = path.join(projRoot, d, spec.session_id + '.jsonl');
    if (fs.existsSync(f)) return fs.statSync(f).mtimeMs;
  }
  return null; // транскрипт не найден — не считать древним (эпохальный tm=0 отключал бы fresh-check)
}
const DEPT_LEDGER = path.join(BIN, 'dept-ledger');
const LIVENESS_REQUEST = path.join(BIN, 'dept-liveness-request');

// dept-ledger list → массив событий (JSONL-парсинг), null при сбое чтения (sh(), тот же 10с
// таймаут). null ОТЛИЧАЕТСЯ от [] намеренно: вызывающий обязан трактовать сбой чтения как
// «не смог узнать» (пропустить тик), а не как «карточек/статусов нет» — иначе state-провал/
// сетевой флап на дедуп-проверке (T2-review) плодил бы дублирующие заявки.
function dlList(args) {
  const out = sh(DEPT_LEDGER, ['list', ...args]);
  if (out === null) return null;
  const rows = [];
  for (const l of out.split('\n')) {
    if (!l.trim()) continue;
    try { rows.push(JSON.parse(l)); } catch { /* битая строка — пропускаем, не роняем весь запрос */ }
  }
  return rows;
}
// Эффективный статус заявки liveness_restart по event_id: последний approval_status по ref
// («последний выигрывает», как effectiveStatus в dept-ledger). Нет approval_status-событий —
// заявка ещё в исходном 'open' (cmdApprovalOpen пишет data.status='open' по умолчанию) —
// НО ТОЛЬКО если сам approval ещё жив в активном журнале: dept-ledger list читает ТОЛЬКО
// активный файл (не archive/), а dept-ledger-snapshot.timer реально гоняет `rotate` каждые
// ~30 мин с дефолтным 30-дневным cutoff (Codex-ревью T3) — закрытая (denied/withdrawn) цепочка
// старше cutoff уезжает в архив, и «approval_status не найден» перестаёт значить «ещё open»,
// начинает значить «событие уехало из вида». Без проверки существования approval денied-
// карточка, которую watchdog держит в state ГОДАМИ (screen не меняется — silent_denied не
// освобождает cardEventId), после архивации выглядела бы как свежая 'open' и лестница ждала
// бы решения оператора вечно. null — сбой чтения ledger (вызывающий обязан пропустить тик,
// не терять карточку из виду).
function queryCardStatus(eventId) {
  const rows = dlList(['--kind', 'approval_status', '--filter', `ref=${eventId}`]);
  if (rows === null) return null;
  if (rows.length) {
    const last = rows[rows.length - 1];
    let executedAt = null;
    if (last.data.status === 'executed') {
      const parsed = Date.parse(last.ts);
      // T3-ревью F2: битый/отсутствующий ts события — NaN дальше рвёт new Date(NaN).toISOString()
      // в dry-run и портит reincident-детект (decide(): prev.restartedAt должен быть числом) —
      // fallback на "сейчас", не теряем закрытие эпизода из-за плохого поля в ledger.
      executedAt = Number.isFinite(parsed) ? parsed : Date.now();
    }
    return { status: last.data.status, executedAt };
  }
  // Нет approval_status — подтверждаем, что сам approval ещё в активном файле (не архиве).
  const apr = dlList(['--kind', 'approval', '--event-id', eventId]);
  if (apr === null) return null;
  if (!apr.length) return { status: undefined, executedAt: null }; // ушёл в архив/потерян — cardStep даст 'clear'
  return { status: 'open', executedAt: null };
}
// T2-review advisory (дедуп-слой б): перед подачей НОВОЙ заявки — нет ли уже нерешённой
// (open/approved/executing) liveness_restart на этого воркера в ledger? Защита от state-
// провала (watchdog-state.json потерян/повреждён/не успел сохраниться) — без неё каждый тик
// после потери state плодил бы дубль заявки поверх ещё нерешённой. {ok:false} — не смогли
// проверить (сбой чтения) — вызывающий обязан пропустить подачу в этом тике, не рисковать дублем.
function findExistingCardForWorker(name) {
  const approvals = dlList(['--kind', 'approval', '--filter', 'kind_of=liveness_restart', '--filter', 'from=watchdog']);
  if (approvals === null) return { ok: false };
  const candidates = approvals.filter((e) => e && e.data && e.data.request && e.data.request.worker === name);
  for (let i = candidates.length - 1; i >= 0; i--) {
    const view = queryCardStatus(candidates[i].event_id);
    if (view === null) return { ok: false };
    if (view.status === 'open' || view.status === 'approved' || view.status === 'executing') {
      return { ok: true, eventId: candidates[i].event_id };
    }
  }
  return { ok: true, eventId: null };
}
// Подача заявки на перезапуск через гейт отдела (dept-liveness-request — НЕ worker-only,
// сторож не сессия воркера, см. заголовок dept-liveness-request). event_id или null при
// сбое (сеть/ledger/бот — FAIL-CLOSED внутри dept-liveness-request само пишет причину в stderr).
function fileLivenessRequest(name, frozenMin, transcriptMin) {
  const out = sh(LIVENESS_REQUEST, ['--worker', name, '--frozen-min', String(frozenMin), '--transcript-min', String(transcriptMin)]);
  if (out === null) return null;
  try { const j = JSON.parse(out.trim()); return j.event_id || null; } catch { return null; }
}

function loadState() { try { return JSON.parse(fs.readFileSync(STATE_FILE, 'utf8')); } catch { return {}; } }
function saveState(s) {
  fs.mkdirSync(DEPT, { recursive: true });
  const tmp = STATE_FILE + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(s, null, 2));
  fs.renameSync(tmp, STATE_FILE);
}
// p3#33: у notify СОБСТВЕННЫЙ таймаут 30с (не общий 10с sh()) — telegram_notify.sh при
// сетевом флапе не успевал добежать до своего fallback, алерт молча терялся. Возвращает
// успех/провал: там, где после алерта пишется дедуп-стейт эпизода (alerted/animAlerted/
// wouldNotified), провал notify НЕ помечает эпизод — следующий тик повторит.
function notify(msg) {
  if (dry) { console.log('[dry] notify:', msg); return true; }
  try { execFileSync(NOTIFY, [msg], { encoding: 'utf8', timeout: 45_000 }); return true; }
  catch { console.log('liveness: notify FAILED:', msg); notifyFailures++; return false; }
}

// p3#19: раньше непойманное исключение здесь роняло процесс голым stack trace'ом (exit код уже
// был ненулевым, но диагностика — нечитаемая). regFailed учитывается в итоговом exitCode внизу
// заодно с notify/read failures; при провале реестр считаем пустым — цикл ниже просто не найдёт
// воркеров (Object.entries({}) === []), а не упадёт повторно.
let regFailed = false;
let reg = {};
try {
  reg = JSON.parse(fs.readFileSync(path.join(CC_HOME, 'autonomous.json'), 'utf8'));
} catch (e) {
  console.log('liveness: не удалось прочитать реестр autonomous.json — пропуск тика:', e.message);
  regFailed = true;
}
const state = loadState();
const now = Date.now();
for (const [name, meta] of Object.entries(reg.workers || reg)) {
  if (!meta || typeof meta !== 'object' || meta.state !== 'active') continue;
  const scr = screen(name);
  if (scr === null) {
    if (dry) console.log(`[dry] ${name}: tmux недоступен (зона reconciler)`);
    else console.log(`liveness: ${name}: tmux недоступен — зона reconciler`);
    continue;
  }
  let tm;
  try { tm = transcriptMtime(name); } catch { console.log(`liveness: ${name}: ошибка чтения spec/транскрипта — пропуск`); readFailures++; continue; }
  if (tm === null) {
    console.log(`liveness: ${name}: транскрипт не найден — пропуск (проверь spec.json session_id)`);
    continue;
  }
  const cur = { ts: now, busy: BUSY_RE.test(scr), screenHash: crypto.createHash('sha1').update(scr).digest('hex'), transcriptMtime: tm };
  if (dry) console.log(`[dry] ${name}: busy=${cur.busy} hash=${cur.screenHash.slice(0, 8)} transcript_age_min=${Math.round((now - tm) / 60000)}`);
  let prev = state[name] || null;
  const d = decide(prev, cur, CFG);

  // T3: жизненный цикл карточки liveness_restart — КАЖДЫЙ тик, пока она отслеживается,
  // НЕЗАВИСИМО от action этого тика (оператор мог решить заявку, пока экран стоит на месте
  // и decide() продолжает отдавать 'restart'). Приоритет над d.reset/остальной лестницей:
  // executed обязан выставить restartedAt = ts события ИЗ LEDGER, иначе reincident-детект
  // (decide(): prev.restartedAt свежий) не сработает при повторном зависании.
  if (prev && prev.cardEventId) {
    const view = queryCardStatus(prev.cardEventId);
    if (view === null) {
      console.log(`liveness: ${name}: не удалось прочитать статус карточки ${prev.cardEventId} — пропуск`);
      readFailures++;
      continue;
    }
    const step = cardStep(prev, cur, { cardStatus: view.status, executedAt: view.executedAt });
    if (step.op === 'close_executed') {
      if (dry) { console.log(`[dry] ${name}: карточка ${prev.cardEventId} исполнена — закрыл бы эпизод (restartedAt=${new Date(step.executedAt).toISOString()})`); continue; }
      // reincident-детект сохранён (p3#33-паттерн): state пишем по факту исполненной заявки,
      // независимо от исхода дальнейших notify — эпизод УЖЕ закрыт рестартом в ledger.
      state[name] = { screenHash: '', firstSeen: now, alerted: false, restartedAt: step.executedAt };
      continue;
    }
    if (step.op === 'wait') {
      if (dry) console.log(`[dry] ${name}: карточка ${prev.cardEventId} ещё не решена — жду`);
      continue;
    }
    if (step.op === 'silent_denied') {
      if (dry) console.log(`[dry] ${name}: карточка ${prev.cardEventId} отклонена, экран тот же — не переподаю`);
      continue;
    }
    if (step.op === 'silent_withdrawn') {
      if (dry) console.log(`[dry] ${name}: карточка ${prev.cardEventId} отозвана, экран тот же — не переподаю`);
      continue;
    }
    // step.op === 'clear': denied/withdrawn с изменившимся экраном ИЛИ статус не определился —
    // снять карточку и продолжить обычную лестницу ниже (reset её и так бы стёр — nextState('reset')
    // не спреадит card-поля).
    if (dry) { console.log(`[dry] ${name}: карточка ${prev.cardEventId} снята — переподал бы при следующем зависании`); continue; }
    prev = state[name] = { ...prev, cardEventId: undefined, cardScreenHash: undefined };
  }

  if (d.reset) { state[name] = nextState(prev, cur, 'reset'); continue; }
  if (d.action === 'anim_alert') {
    // p3#33: animAlerted (дедуп anim-эпизода) — только при ДОСТАВЛЕННОМ алерте,
    // иначе следующий тик повторит попытку (алерт не теряется на сетевом флапе).
    const animOk = notify(`⚠️ liveness [anim]: воркер ${name} — экран активен, но транскрипт не движется ${Math.round((now - tm) / 60000)} мин. Возможно «анимированное зависание» (лимиты подписки/сеть). Проверь: tmux -L claude-${name} attach -t claude-${name}`);
    // nextState пишет СВЕЖИЙ cur.screenHash (не устаревший prev.screenHash) и безусловно
    // сбрасывает alerted/wouldNotified/wouldIncidentNotified — экран сменился by construction.
    state[name] = nextState(prev, cur, 'anim_alert', animOk);
    continue;
  }
  if (d.action === 'none') {
    // none && !reset (reset обработан выше). Для основной лестницы это no-op — hash в этой
    // ветке равен prev.screenHash. Для продолжающегося anim-эпизода продвигает hash каждый
    // тик: реально замерший после анимации экран на следующем тике совпадёт с prev.screenHash
    // и уйдёт в основную лестницу (иначе старый докадровый hash глушил бы её навсегда).
    // firstSeen сохраняется как якорь начала эпизода — переход anim→freeze эскалирует сразу
    // (воркер уже давно болен), это намеренно. Если экран при этом СМЕНИЛСЯ (anim продолжается) —
    // nextState() сбрасывает alerted/wouldNotified/wouldIncidentNotified (старый алерт устарел);
    // на no-op (hash равен) она эти флаги не трогает — дедуп основной лестницы не задет.
    state[name] = nextState(prev, cur, 'none');
    continue;
  }
  if (d.action === 'alert') {
    // p3#33: alerted (первая ступень лестницы) — только при доставленном алерте; провал
    // notify оставляет prev как есть, следующий тик снова даст action=alert и повторит.
    state[name] = nextState(prev, cur, 'alert', notify(`⚠️ liveness: воркер ${name} завис (busy ${CFG.hungMin}+ мин, транскрипт не движется). Следующий шаг — заявка на перезапуск оператору.`));
  } else if (d.action === 'restart') {
    // T3 (решение оператора 19.07): вместо авто-рестарта — подача заявки через гейт отдела.
    // Сюда попадаем только когда карточка ЕЩЁ не отслеживается (живая cardEventId обработана
    // и continue'нута в блоке жизненного цикла выше — либо wait/silent_denied, либо только что
    // clear'нута и prev.cardEventId уже пуст).
    const dedup = findExistingCardForWorker(name);
    if (!dedup.ok) {
      console.log(`liveness: ${name}: не удалось проверить дедуп заявок в ledger — пропуск подачи`);
      readFailures++;
    } else {
      const step = cardStep(prev, cur, { existingCardId: dedup.eventId });
      if (step.op === 'adopt') {
        if (dry) console.log(`[dry] ${name}: усыновил бы существующую заявку ${step.eventId} вместо подачи новой`);
        else state[name] = { ...prev, cardEventId: step.eventId, cardScreenHash: cur.screenHash };
      } else {
        // N = минуты с prev.firstSeen (начало эпизода), M = минуты с cur.transcriptMtime.
        const frozenMin = Math.round((cur.ts - prev.firstSeen) / 60000);
        const transcriptMin = Math.round((cur.ts - cur.transcriptMtime) / 60000);
        if (dry) {
          console.log(`[dry] ${name}: подал бы заявку на перезапуск (завис ${frozenMin} мин, транскрипт не движется ${transcriptMin} мин)`);
        } else {
          const eid = fileLivenessRequest(name, frozenMin, transcriptMin);
          if (eid) {
            // notify оператору здесь НЕ шлём — карточка сама придёт от бота (dept-liveness-request).
            state[name] = { ...prev, cardEventId: eid, cardScreenHash: cur.screenHash };
          } else {
            notify(`🚨 liveness: не удалось подать заявку на перезапуск ${name} — вмешайся`);
            actionFailures++; // видимая деградация — не только readFailures/notifyFailures
            // state НЕ обновляем — повтор на следующем тике
          }
        }
      }
    }
  } else if (d.action === 'incident') {
    // reincident = зависание после ИСПОЛНЕННОЙ карточки (prev.restartedAt свежий, ставится в
    // блоке close_executed выше) — открытие инцидента ТП безусловно (не за флагом, ENFORCE
    // удалён): это запись+сообщение ТП, не перезапуск. Тот же принцип, что раньше: упавший
    // dept-ledger incident-open не должен "закрывать" наблюдение (чистить state), хотя
    // инцидент для ТП фактически не открылся.
    const opened = dry || sh(DEPT_LEDGER, ['incident-open', '--about', name, '--severity', 'high',
      '--summary', 'воркер виснет повторно после рестарта', '--actor', 'watchdog']) !== null;
    if (opened) {
      // p3#33-решение: state пишем НЕЗАВИСИМО от исхода notify — инцидент УЖЕ открыт в
      // ledger (ТП получил message), повтор на следующем тике открыл бы ВТОРОЙ инцидент;
      // уведомление информационное, факт эпизода зафиксирован инцидентом.
      notify(`🚨 liveness: ${name} завис ПОВТОРНО после рестарта — открыт инцидент для ТП.`);
      state[name] = { screenHash: '', firstSeen: now, alerted: false, restartedAt: 0 };
    } else {
      notify(`🚨 liveness: не удалось открыть инцидент по ${name} — открой вручную`);
      actionFailures++; // видимая деградация — не только readFailures/notifyFailures
      // state НЕ обновляем
    }
  }
}
// Воркеры, пропавшие из autonomous.json (снесены/переименованы) — их записи в state иначе
// никогда не трогаются циклом выше и копятся в файле навечно.
const known = new Set(Object.keys(reg.workers || reg));
for (const name of Object.keys(state)) if (!known.has(name)) delete state[name];
// dry-run обязан быть чисто read-only (см. docs/department.md): раньше saveState() писал
// БЕЗУСЛОВНО, и alerted:true из превью-прогона "съедал" ступень лестницы у следующего
// боевого прогона — watchdog прыгал сразу к restart, ни разу не послав настоящий alert.
// regFailed: реестр не прочитан → known пуст → цикл cleanup выше стёр бы весь state — не
// сохраняем, чтобы битый/временно недоступный autonomous.json не снёс историю наблюдения.
if (!dry && !regFailed) saveState(state);
// p3#19 + T3 (Codex-ревью): видимая деградация — notify/read/registry/action failures раньше
// тонули в логах, exit оставался 0, и systemd/cron не мог отличить «всё ок» от «сторож молча
// недоглядел». actionFailures — T3: провал подачи заявки/открытия инцидента виден в exitCode
// даже когда сам алерт о провале доставлен успешно (notifyFailures==0).
if (!dry && (notifyFailures || readFailures || regFailed || actionFailures)) process.exitCode = 1;
