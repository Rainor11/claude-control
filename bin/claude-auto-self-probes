#!/usr/bin/env bash
# claude-auto-self-probes — let an autonomous worker manage ITS OWN event-bridge
# probes (sensors) from inside its session: list / retime / remove / add.
#
# DESIGN (Codex-reviewed). What this does NOT let a worker do, by construction:
#   * touch ANOTHER worker's probes — identity is derived from the ANCESTOR
#     `claude` worker process's /proc environ (which the worker cannot forge),
#     NOT from the inheritable CLAUDE_AUTO_NAME env (a worker could prefix
#     `CLAUDE_AUTO_NAME=other ...`); cross-checked against the tmux session name.
#   * change its permission gates — this writes ONLY event-bridge.config.json
#     (probes), never settings.json. allow/ask/deny stay operator-only.
#   * read arbitrary local files into context — `add` builds the adapter argv
#     itself from typed params (forces --state-dir, never accepts --db /
#     --creds-file / --token-file / --contacts), and only whitelisted SENSOR
#     adapters (gmail/tg/asana/timer) may be added. The file-read adapter
#     `emit-lines` is operator-only.
#
# Validation + atomic write + live reload are reused from `claude-auto set-probes`
# (probes_validate_normalize). event-bridge-watch re-reads the config every ~5s,
# so changes are live with NO restart. Every change pings the operator on Telegram.
set -u

SELF_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
CLAUDE_AUTO="$SELF_DIR/claude-auto"               # absolute sibling (not via PATH)
ADAPTERS_DIR="$(cd "$SELF_DIR/.." 2>/dev/null && pwd)/channels/event-bridge/adapters"
# T5: корень рантайма — через единый резолвер (lib/runtime-root.sh, задача T1). Без маркера
# CLAUDE_CONTROL_TEST_ROOT возвращает ту же строку, что прежний inline-дефолт; под маркером —
# fail-closed на корень песочницы.
# shellcheck disable=SC1091
. "$SELF_DIR/../lib/runtime-root.sh"
CONTROL_DIR="$(resolve_runtime_root control_only)" || exit 1
TG="${CLAUDE_AUTO_TG:-/home/rainor/server/server_monitor/telegram_notify.sh}"
# Trusted claude install tree. HARDCODED on purpose (NOT $HOME / NOT an env var):
# identity is accepted only when the ancestor's real exe lives here, so a worker
# cannot redirect the check by setting HOME/env. A worker wrapping the call in
# bash/python/sqlite gets an ancestor whose exe is the interpreter (outside this
# tree) → rejected. (A worker with arbitrary code-exec in its allow list could
# still defeat any same-user fence — the documented OS-sandbox ceiling.)
CLAUDE_INSTALL="/home/rainor/.local/share/claude"

# Self-service policy bounds (operator via `claude-auto set-probes` is unbounded).
# MAX_PROBES is now PER-WORKER: spec.json `.max_probes` (set by the operator via
# `claude-auto set-probe-limit`), clamped to 1..100, falling back to this default.
# Read live inside apply_probes() under the RMW lock — see effective_max_probes().
MAX_PROBES_DEFAULT=20      # default ceiling on total probes when spec.json has no override
MIN_INTERVAL=300           # floor on interval_sec a worker may set (5 min)
MAX_INTERVAL=604800        # 1 week
MAX_LOOKBACK=336           # hours (14 days)
WL_ADD='gmail tg asana asana-project timer date-gate'   # adapter TYPES a worker may ADD (NOT emit-lines)
REASON=""                       # optional operator-facing reason (--reason) for a change

die() { echo "self-probes: $*" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || die "jq required"

# ---- identity (spoof-resistant) -------------------------------------------
# Walk the PPID chain to the worker's `claude` process — the one whose cmdline
# carries `--resume` (a worker-spawned shell can fake CLAUDE_AUTO_NAME in its own
# env, but cannot fabricate a `claude --resume` ancestor). Read THAT process's
# CLAUDE_AUTO_NAME from /proc (own-user → readable; the worker cannot rewrite an
# ancestor's environ).
resolve_name() {
  local pid="$PPID" depth=0 nm exe
  while [ "${pid:-0}" -gt 1 ] && [ "$depth" -lt 25 ]; do
    # An ancestor qualifies only if it (1) has `--resume` as a standalone argv
    # element AND (2) its REAL exe is inside the trusted claude tree (kernel-set,
    # unfakeable via argv[0]/exec -a). This is what makes a bash/python/sqlite
    # wrapper carrying a forged `--resume` + CLAUDE_AUTO_NAME fail to qualify.
    # --resume ИЛИ --session-id — fresh-запуск spawn/rebase (claude --session-id <W>
    # без --resume до первого рестарта). Остальные проверки (exe в CLAUDE_INSTALL,
    # CLAUDE_AUTO_NAME из environ предка) не меняются — спуф-стойкость сохранена.
    if tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null | grep -qxE -- '--resume|--session-id'; then
      exe="$(readlink -f "/proc/$pid/exe" 2>/dev/null)"
      case "$exe" in
        "$CLAUDE_INSTALL"/*)
          nm="$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | sed -n 's/^CLAUDE_AUTO_NAME=//p' | head -1)"
          [ -n "$nm" ] && { printf '%s' "$nm"; return 0; }
          ;;
      esac
    fi
    pid="$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null)"
    depth=$((depth+1))
  done
  return 1
}

NAME="$(resolve_name)" || die "cannot determine worker identity (no ancestor 'claude --resume' with CLAUDE_AUTO_NAME) — run this from inside a worker session"
[[ "$NAME" =~ ^[a-zA-Z0-9_-]+$ ]] || die "resolved worker name '$NAME' has illegal chars"
HOME_DIR="$CONTROL_DIR/workers/$NAME"
CFG="$HOME_DIR/event-bridge.config.json"
STATE_DIR="$HOME_DIR/state"
[ -d "$HOME_DIR" ] || die "worker '$NAME' has no home ($HOME_DIR)"

# Cross-check against the tmux session name when reachable (defense in depth; the
# worker is also denied `tmux`). Mismatch ⇒ refuse. Unreachable ⇒ rely on /proc.
# INTENTIONALLY socket-less (no `-L`): with per-worker sockets each pane's $TMUX points
# to its own server, so a `-L`-free `tmux display-message` reads the ACTUAL session this
# process runs in. Forcing `-L "claude-$NAME"` would address the socket derived from the
# (possibly spoofed) resolved $NAME and defeat this anti-spoof cross-check.
_sess="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
if [ -n "$_sess" ] && [ "$_sess" != "claude-$NAME" ]; then
  die "tmux session '$_sess' != expected 'claude-$NAME' — refusing (identity mismatch)"
fi

# ---- helpers ---------------------------------------------------------------
LOCK="$STATE_DIR/.probes-rmw.lock"   # shared with claude-auto set-probes
mkdir -p "$STATE_DIR" 2>/dev/null || true

# Fail CLOSED on a present-but-unreadable config (don't silently treat damage as
# empty — that would let `add` replace a malformed config with just the new probe).
current_probes() {
  [ -f "$CFG" ] || { echo '[]'; return 0; }
  jq -ce '.probes // []' "$CFG" 2>/dev/null || die "current config unreadable/invalid ($CFG) — refusing to modify; operator should fix it"
}

# Take the shared RMW lock (also honored by `claude-auto set-probes`) for the whole
# read→mutate→write, so a worker self-change and an operator set-probes can't clobber
# each other. One-shot process: the lock auto-releases on exit.
take_lock() {
  exec 8>"$LOCK" 2>/dev/null || die "lock open failed"
  flock -w 10 8 2>/dev/null || die "busy (another probe change in progress) — retry"
}

valid_interval() {
  local iv="$1"
  [[ "$iv" =~ ^[1-9][0-9]*$ ]] || die "interval must be a positive integer (seconds, no leading zeros)"
  [ "$iv" -ge "$MIN_INTERVAL" ] || die "interval too small: min for self-service is ${MIN_INTERVAL}s (operator can set lower)"
  [ "$iv" -le "$MAX_INTERVAL" ] || die "interval too large: max ${MAX_INTERVAL}s"
}

# Effective self-service probe ceiling for THIS worker: spec.json `.max_probes` clamped
# to an INTEGER in 1..100, else the default. Range-clamp here too (not only at the
# writer) so a corrupted/hand-edited `max_probes:100000` can't bypass the hard cap.
# Read fresh each call (the operator can change it live); mutation paths call this
# under take_lock, so the value is consistent with a concurrent set-probe-limit.
effective_max_probes() {
  local v
  v="$(jq -r 'if (.max_probes|type)=="number" and (.max_probes==(.max_probes|floor))
                 and .max_probes>=1 and .max_probes<=100
              then .max_probes else empty end' "$HOME_DIR/spec.json" 2>/dev/null)"
  printf '%s' "${v:-$MAX_PROBES_DEFAULT}"
}

# ---- presentation helpers (operator-facing Telegram card) ------------------
html_escape() {  # minimal HTML entity escape for parse_mode=HTML
  local s="${1:-}"; s="${s//&/&amp;}"; s="${s//</&lt;}"; s="${s//>/&gt;}"; printf '%s' "$s"
}

human_interval() {  # seconds -> human RU phrase (3600 -> "каждый час")
  local s="${1:-}"
  case "$s" in ''|*[!0-9]*) printf '%sс' "$s"; return ;; esac
  if [ "$s" -ge 86400 ] && [ $((s % 86400)) -eq 0 ]; then
    local d=$((s/86400)); [ "$d" -eq 1 ] && printf 'раз в сутки' || printf 'каждые %d сут' "$d"
  elif [ "$s" -ge 3600 ] && [ $((s % 3600)) -eq 0 ]; then
    local h=$((s/3600)); [ "$h" -eq 1 ] && printf 'каждый час' || printf 'каждые %d ч' "$h"
  elif [ "$s" -ge 60 ] && [ $((s % 60)) -eq 0 ]; then
    printf 'каждые %d мин' $((s/60))
  else
    printf 'каждые %dс' "$s"
  fi
}

probe_kind_label() {  # adapter source -> labelled kind (own emoji)
  case "${1:-}" in
    gmail)     printf '📧 Gmail' ;;
    telegram)  printf '💬 Telegram' ;;
    asana)     printf '📋 Asana' ;;
    timer)     printf '⏲ Таймер' ;;
    date-gate) printf '📅 Дата-напоминание' ;;
    *)         printf '%s' "${1:-}" ;;
  esac
}

# Operator ping for a probe change — corporate HTML card, routed to @RnR_Workers
# when its token is valid in .env (else default bot). Best-effort; never blocks
# the change. Args: <verb add|remove|retime> <probe-name> <detail-line>.
notify() {
  local verb="${1:-}" pname="${2:-}" detail="${3:-}"
  [ -x "$TG" ] || return 0
  local emoji word
  case "$verb" in
    add)    emoji='➕'; word='Добавлен датчик' ;;
    remove) emoji='🗑'; word='Удалён датчик' ;;
    retime) emoji='⏱'; word='Изменён интервал' ;;
    *)      emoji='🔧'; word='Изменение' ;;
  esac
  local body
  body="🔧 <b>Датчики · воркер «$(html_escape "$NAME")»</b>
━━━━━━━━━━━━━━
${emoji} ${word} <code>$(html_escape "$pname")</code>"
  [ -n "$detail" ] && body="${body}
$(html_escape "$detail")"
  if [ -n "$REASON" ]; then
    local r; r="$(printf '%s' "$REASON" | tr -d '\000-\010\013\014\016-\037' | cut -c1-300)"
    [ -n "$r" ] && body="${body}
💬 <i>$(html_escape "$r")</i>"
  fi
  # Route to the @RnR_Workers bot when its token is valid in .env; else default bot.
  local rnr_val
  rnr_val="$(grep -E '^RNR_WORKERS_BOT_TOKEN=' /home/rainor/server/.env 2>/dev/null | head -1 \
              | sed -e 's/^RNR_WORKERS_BOT_TOKEN=//' -e 's/^["'\'' ]*//' -e 's/["'\'' ]*$//')"
  local -a botflag=()
  [[ "$rnr_val" =~ ^[0-9]+:[A-Za-z0-9_-]+$ ]] && botflag=(--bot-token-env RNR_WORKERS_BOT_TOKEN)
  "$TG" "${botflag[@]}" --parse-mode HTML -- "$body" >/dev/null 2>&1 || true
}

# Apply a new probes array (compact JSON) via the operator validator. flock covers
# the whole read-modify-write so concurrent self/operator changes can't lose updates.
apply_probes() {
  local new_arr="$1" action="$2" verb="${3:-}" pname="${4:-}" detail="${5:-}"
  printf '%s' "$new_arr" | jq -e 'type=="array"' >/dev/null 2>&1 || die "internal: new probes not an array"
  local n; n="$(printf '%s' "$new_arr" | jq 'length')"
  # Per-worker ceiling, read under the caller's lock (every mutation holds take_lock).
  # Block ONLY growth beyond the cap: a reduce/retime (n not increasing) must always
  # pass, so lowering the limit below the current probe count can't trap the worker
  # (it could otherwise no longer even `remove` its way back under the cap).
  local max_probes old_count
  max_probes="$(effective_max_probes)"
  old_count="$(current_probes | jq 'length')"
  [[ "$old_count" =~ ^[0-9]+$ ]] || old_count=0   # fail-closed: unknown old count → treat growth as growth
  if [ "$n" -gt "$max_probes" ] && [ "$n" -gt "$old_count" ]; then
    die "too many probes ($n > $max_probes) — remove one first"
  fi
  local tmp; tmp="$(mktemp "$HOME_DIR/.sp.XXXXXX")" || die "mktemp failed"
  printf '%s\n' "$new_arr" | jq '{probes: .}' > "$tmp" 2>/dev/null || { rm -f "$tmp"; die "build config failed"; }
  # We already hold the shared lock (take_lock). Tell set-probes to skip re-locking
  # the SAME lock (a nested reopen would self-deadlock). Only this trusted binary
  # sets the flag; the worker cannot call set-probes directly (claude-auto denied).
  if CLAUDE_AUTO_PROBES_LOCKED=1 "$CLAUDE_AUTO" set-probes "$NAME" "$tmp" >/dev/null 2>&1; then
    rm -f "$tmp"
    local note="$action"
    if [ -n "$REASON" ]; then
      local r; r="$(printf '%s' "$REASON" | tr -d '\000-\010\013\014\016-\037' | cut -c1-300)"
      [ -n "$r" ] && note="$action — причина: $r"
    fi
    notify "$verb" "$pname" "$detail"
    echo "OK: $note."; cmd_list
  else
    rm -f "$tmp"
    die "set-probes rejected the change (validation failed) — config unchanged"
  fi
}

# ---- subcommands -----------------------------------------------------------
cmd_list() {  # redacted: name/source/adapter/interval only — no queries/ids/args
  local max_probes count
  max_probes="$(effective_max_probes)"
  count="$(current_probes | jq 'length')"
  echo "Активные датчики (${count}/${max_probes} — лимит самообслуживания):"
  current_probes | jq -r '
    if length==0 then "  (датчиков нет)"
    else .[] | "  • " + (.name // "?") + "  [" + (.source // "?") + "/"
               + ((.cmd[0] // "" | split("/") | last)) + "]  interval="
               + ((.interval_sec // "?")|tostring) + "s"
    end'
}

cmd_retime() {
  local name="" iv=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --reason) REASON="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      *) if [ -z "$name" ]; then name="$1"; elif [ -z "$iv" ]; then iv="$1"; else die "retime: unexpected arg '$1'"; fi; shift ;;
    esac
  done
  [ -n "$name" ] && [ -n "$iv" ] || die "usage: retime <probe-name> <interval-seconds> [--reason \"...\"]"
  valid_interval "$iv"
  take_lock
  local cur; cur="$(current_probes)"
  printf '%s' "$cur" | jq -e --arg n "$name" 'any(.[]; .name==$n)' >/dev/null 2>&1 || die "no probe named '$name' (see: list)"
  local new; new="$(printf '%s' "$cur" | jq -c --arg n "$name" --argjson iv "$iv" 'map(if .name==$n then .interval_sec=$iv else . end)')"
  apply_probes "$new" "перенастроен интервал '$name' → ${iv}s" retime "$name" "🔁 $(human_interval "$iv")"
}

cmd_remove() {
  local name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --reason) REASON="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      *) if [ -z "$name" ]; then name="$1"; else die "remove: unexpected arg '$1'"; fi; shift ;;
    esac
  done
  [ -n "$name" ] || die "usage: remove <probe-name> [--reason \"...\"]"
  take_lock
  local cur; cur="$(current_probes)"
  printf '%s' "$cur" | jq -e --arg n "$name" 'any(.[]; .name==$n)' >/dev/null 2>&1 || die "no probe named '$name' (see: list)"
  local new; new="$(printf '%s' "$cur" | jq -c --arg n "$name" 'map(select(.name != $n))')"
  apply_probes "$new" "удалён датчик '$name'" remove "$name" ""
}

# add: build the adapter argv ourselves from typed params (NEVER a raw cmd).
cmd_add() {
  local type="" name="" query="" account="alp" chat_id="" task="" author="" label="" lookback="" interval="" gate="" message="" project="" events=""
  # Every value-taking flag consumes its value with the SAME guarded pattern as
  # --reason: `shift; [ $# -gt 0 ] && shift || true`. A bare `shift 2` on a trailing
  # valueless flag (e.g. `... --message`) fails ("count out of range") but leaves $#
  # unchanged under `set -u`/no-`set -e` → the while loop spins forever. The guard
  # shifts the flag, then the value only if one is present (a missing value is then
  # caught by the per-type required-arg checks below).
  while [ $# -gt 0 ]; do
    case "$1" in
      --type) type="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --name) name="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --query) query="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --account) account="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --chat-id) chat_id="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --task) task="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --author) author="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --project) project="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --events) events="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --label) label="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --lookback-hours) lookback="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --interval) interval="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --at) gate="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --message) message="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      --reason) REASON="${2:-}"; shift; [ $# -gt 0 ] && shift || true ;;
      *) die "add: unknown option '$1'" ;;
    esac
  done
  case " $WL_ADD " in *" $type "*) ;; *) die "add: --type must be one of: $WL_ADD (emit-lines is operator-only)";; esac
  [[ "$name" =~ ^[a-zA-Z0-9_.-]+$ ]] || die "add: --name required, chars [a-zA-Z0-9_.-]"
  [ "${#name}" -le 64 ] || die "add: --name too long (max 64 chars)"
  take_lock
  current_probes | jq -e --arg n "$name" 'any(.[]; .name==$n) | not' >/dev/null 2>&1 || die "add: probe '$name' already exists (remove it first)"

  # interval default per type + floor
  [ -n "$interval" ] || case "$type" in
    timer) interval=86400 ;;
    asana-project) interval=900 ;;   # whole-project feed: few requests per tick, keep it responsive
    *) interval=3600 ;;
  esac
  valid_interval "$interval"
  if [ -n "$lookback" ]; then
    printf '%s' "$lookback" | grep -qE '^[0-9]+(\.[0-9]+)?$' || die "add: --lookback-hours must be a number"
    awk -v l="$lookback" -v m="$MAX_LOOKBACK" 'BEGIN{exit !(l<=m)}' || die "add: --lookback-hours max $MAX_LOOKBACK"
  fi

  local adapter source cmd_json
  case "$type" in
    gmail)
      [ -n "$query" ] || die "add gmail: --query required"
      # Reject control chars / newlines in the query: event-bridge-watch rebuilds
      # argv per cmd element, so a newline-laden value would split into EXTRA argv
      # (e.g. inject --token-file/--creds-file into gmail-messages). A Gmail search
      # query never needs control chars. (event-bridge-watch is also NUL-hardened.)
      # NOTE: `grep '[[:cntrl:]]'` does NOT catch newlines (grep is line-oriented —
      # a newline is the line separator, never seen as in-line content). Use a bash
      # glob over the control-char ranges, which matches the WHOLE string incl. \n.
      case "$query" in
        *[$'\001'-$'\037']*|*$'\177'*) die "add gmail: --query must not contain control characters or newlines" ;;
      esac
      case "$account" in alp|rainor) ;; *) die "add gmail: --account must be alp or rainor";; esac
      adapter="$ADAPTERS_DIR/gmail-messages"; source="gmail"
      cmd_json="$(jq -nc --arg a "$adapter" --arg q "$query" --arg acc "$account" \
        --arg lb "${lookback:-72}" --arg sd "$STATE_DIR" \
        '[$a,"--query",$q,"--account",$acc,"--lookback-hours",$lb,"--state-dir",$sd]')" ;;
    tg)
      printf '%s' "$chat_id" | grep -qE '^-?[0-9]+$' || die "add tg: --chat-id <numeric> required"
      adapter="$ADAPTERS_DIR/tg-messages"; source="telegram"
      cmd_json="$(jq -nc --arg a "$adapter" --arg c "$chat_id" \
        --arg lb "${lookback:-48}" --arg sd "$STATE_DIR" \
        '[$a,"--chat-id",$c,"--lookback-hours",$lb,"--state-dir",$sd]')" ;;
    asana)
      printf '%s' "$task" | grep -qE '^[0-9]+$' || die "add asana: --task <numeric gid> required"
      adapter="$ADAPTERS_DIR/asana-comments"; source="asana"
      if [ -n "$author" ]; then
        printf '%s' "$author" | grep -qE '^[0-9]+$' || die "add asana: --author must be a numeric gid"
        cmd_json="$(jq -nc --arg a "$adapter" --arg t "$task" --arg au "$author" --arg sd "$STATE_DIR" \
          '[$a,"--task",$t,"--author",$au,"--state-dir",$sd]')"
      else
        cmd_json="$(jq -nc --arg a "$adapter" --arg t "$task" --arg sd "$STATE_DIR" \
          '[$a,"--task",$t,"--state-dir",$sd]')"
      fi ;;
    asana-project)
      printf '%s' "$project" | grep -qE '^[0-9]+$' || die "add asana-project: --project <numeric gid> required"
      # State (snapshot/journal) is PER PROJECT — a second probe on the same
      # project would fight over it (different --events would cross-filter).
      current_probes | jq -e --arg p "$project" '
        [ .[] | (.cmd // []) as $c
          | select( (($c[0] // "")|split("/")|map(select(length>0))|last)=="asana-project" )
          | ([ range(1; ($c|length)) | select($c[.]=="--project") | ($c[.+1] // "") ] | first // "")
        ] | index($p) | not' >/dev/null 2>&1 \
        || die "add asana-project: a probe for project $project already exists (remove it first)"
      if [ -n "$events" ]; then
        printf '%s' "$events" | grep -qE '^(task_new|task_gone|due|completed|reopened|comments)(,(task_new|task_gone|due|completed|reopened|comments))*$' \
          || die "add asana-project: --events must be a csv subset of task_new,task_gone,due,completed,reopened,comments"
      fi
      adapter="$ADAPTERS_DIR/asana-project"; source="asana"
      if [ -n "$events" ]; then
        cmd_json="$(jq -nc --arg a "$adapter" --arg p "$project" --arg e "$events" --arg sd "$STATE_DIR" \
          '[$a,"--project",$p,"--events",$e,"--state-dir",$sd]')"
      else
        cmd_json="$(jq -nc --arg a "$adapter" --arg p "$project" --arg sd "$STATE_DIR" \
          '[$a,"--project",$p,"--state-dir",$sd]')"
      fi ;;
    timer)
      [[ "$label" =~ ^[a-zA-Z0-9_.-]+$ ]] || die "add timer: --label required, chars [a-zA-Z0-9_.-]"
      adapter="$ADAPTERS_DIR/timer-tick"; source="timer"
      cmd_json="$(jq -nc --arg a "$adapter" --arg l "$label" '[$a,$l]')" ;;
    date-gate)
      # One-shot reminder at a date: date-gate stays silent until the gate date, then
      # emits the message once (bridge dedups by line hash). Stateless → NO --state-dir.
      printf '%s' "$gate" | grep -qE '^[0-9]{8}$' || die "add date-gate: --at <YYYYMMDD> (exactly 8 digits) required"
      date -d "${gate:0:4}-${gate:4:2}-${gate:6:2}" >/dev/null 2>&1 || die "add date-gate: --at '$gate' is not a valid calendar date"
      # Reject a past gate: it would fire immediately on the next poll (no future event
      # to wait for) — almost always a mistake. Today is allowed (= wake on next poll).
      [ "$gate" -ge "$(date +%Y%m%d)" ] || die "add date-gate: --at '$gate' is in the past"
      [ -n "$message" ] || die "add date-gate: --message required (the reminder text you'll be woken with)"
      # The message is emitted VERBATIM as the event line and is also a cmd argv element;
      # event-bridge-watch rebuilds argv line-by-line (mapfile/jq -r .cmd[]). A control
      # char / newline would split the line → corrupt the single-line event frame. A
      # reminder never needs them. (Same guard as gmail --query; matches the WHOLE string
      # incl. \n via a bash glob, since grep is line-oriented and never sees a newline.)
      case "$message" in
        *[$'\001'-$'\037']*|*$'\177'*) die "add date-gate: --message must not contain control characters or newlines" ;;
      esac
      message="${message:0:500}"   # bound the event frame; bash substring is char-safe in UTF-8
      adapter="$ADAPTERS_DIR/date-gate"; source="date-gate"
      cmd_json="$(jq -nc --arg a "$adapter" --arg g "$gate" --arg m "$message" '[$a,$g,$m]')" ;;
  esac
  # realpath guard: the constructed adapter must be a regular (non-symlink) file
  # in the trusted adapters dir (TCB), not a swapped symlink.
  [ -f "$adapter" ] && [ ! -L "$adapter" ] && [ -x "$adapter" ] || die "add: adapter '$adapter' missing / not a regular executable"

  local probe new detail tmo_json="null"
  # asana-project crawls a whole project (+ stories of changed tasks) — the
  # watcher's default 30s probe timeout is too tight for a large project.
  [ "$type" = asana-project ] && tmo_json=120
  probe="$(jq -nc --arg n "$name" --arg s "$source" --argjson iv "$interval" --argjson c "$cmd_json" --argjson t "$tmo_json" \
    '{name:$n, source:$s, interval_sec:$iv, cmd:$c} + (if $t != null then {timeout_sec:$t} else {} end)')"
  new="$(current_probes | jq -c --argjson p "$probe" '. + [$p]')"
  if [ "$type" = date-gate ]; then
    detail="📅 сработает $(date -d "${gate:0:4}-${gate:4:2}-${gate:6:2}" +%d.%m.%Y 2>/dev/null)"
  else
    detail="$(probe_kind_label "$source") · $(human_interval "$interval")"
  fi
  apply_probes "$new" "добавлен датчик '$name' ($source, interval ${interval}s)" add "$name" "$detail"
}

# ---- dispatch --------------------------------------------------------------
sub="${1:-}"; shift || true
case "$sub" in
  list)   cmd_list ;;
  retime) cmd_retime "$@" ;;
  remove) cmd_remove "$@" ;;
  add)    cmd_add "$@" ;;
  ""|-h|--help)
    cat <<USAGE
claude-auto-self-probes — управление СВОИМИ датчиками (event-bridge probes).
Действует только на текущего воркера; разрешения (allow/ask/deny) не меняет.
Каждое изменение уведомляет оператора. Применяется за ~5с без рестарта.
Везде можно добавить [--reason "почему"] — причина попадёт в уведомление оператору.

  list
  retime <имя> <интервал-сек> [--reason "..."]        (мин ${MIN_INTERVAL}с)
  remove <имя> [--reason "..."]
  add --type gmail     --name N --query "..." [--account alp|rainor] [--lookback-hours H] [--interval S] [--reason "..."]
  add --type tg        --name N --chat-id <id> [--lookback-hours H] [--interval S] [--reason "..."]
  add --type asana     --name N --task <gid> [--author <gid>] [--interval S] [--reason "..."]
  add --type asana-project --name N --project <gid> [--events csv] [--interval S] [--reason "..."]
        ВЕСЬ проект Asana одним датчиком: новые/пропавшие задачи, сдвиги сроков,
        закрытие/переоткрытие, новые комменты. events ⊆ task_new,task_gone,due,
        completed,reopened,comments (по умолчанию все). Один датчик на проект.
  add --type date-gate --name N --at <YYYYMMDD> --message "..." [--interval S] [--reason "..."]
        разовое напоминание к дате — будит ОДИН раз на/после даты, потом молчит.
        ПРЕДПОЧТИТЕЛЬНО для напоминаний «сделать X к <дате>». После срабатывания
        (увидишь probe=<имя> в теге пробуждения) — remove, чтобы освободить слот.
  add --type timer     --name N --label <label> [--interval S] [--reason "..."]
        повторяющийся тик — будит и тратит токены КАЖДЫЙ интервал; только для
        НАСТОЯЩЕЙ повторяющейся работы, не для разовой даты (для неё — date-gate).
USAGE
    ;;
  *) die "unknown subcommand '$sub' (try --help)" ;;
esac
