#!/usr/bin/env node
// dept-rebase-check — автопороги пересборки сессий отдела (alert-only обкатка).
// Раз в час (systemd-таймер) проходит воркеров отдела (роль ∈ руководитель/мк/
// архивариус/тп, state==active) и считает триггеры: возраст сессии, число
// компакций, STALE-память (mtime транскрипта vs файлов памяти в brain_path).
// Без DEPT_REBASE_ENFORCE=1 — только [would-rebase]-алерт (дедуп на эпизод).
// С флагом — вызывает `claude-auto rebase <name>`; STALE — ВСЕГДА только алерт,
// никогда авто (rebase на несвежей памяти теряет контекст без предупреждения).
// Флаг --dry-run: только печать решений, ноль побочных эффектов (см. liveness).
'use strict';
const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');
const { memoryFreshness } = require('./dept-memory-freshness');
// T5: корень рантайма — через единый резолвер (lib/runtime-root.js, задача T1). Профиль
// auto_then_hardcoded воспроизводит прежнюю строку (CLAUDE_AUTO_HOME || '/home/rainor/.claude-control')
// без маркера; под CLAUDE_CONTROL_TEST_ROOT — fail-closed на корень песочницы.
const { resolveRuntimeRoot } = require('../lib/runtime-root.js');

const CC_HOME = resolveRuntimeRoot('auto_then_hardcoded');
// DEPT остаётся производным от резолвленного CC_HOME (композитный DEPT): DEPT_HOME → CC_HOME/department.
const DEPT = process.env.DEPT_HOME || path.join(CC_HOME, 'department');
const STATE_FILE = path.join(DEPT, 'rebase-check-state.json');
const BIN = __dirname;
// Number(garbage) === NaN просачивался бы во все сравнения decide() как false —
// отключая пороги разом, а не просто откатываясь на дефолт (см. liveness).
function numEnv(name, def) {
  const n = Number(process.env[name]);
  return Number.isFinite(n) && n > 0 ? n : def;
}
const CFG = {
  maxAgeDays: numEnv('DEPT_REBASE_MAX_AGE_DAYS', 14),
  maxCompactions: numEnv('DEPT_REBASE_MAX_COMPACTIONS', 3),
};
const STALE_AFTER_MS = numEnv('CLAUDE_AUTO_STALE_SECONDS', 1800) * 1000;
const ENFORCE = process.env.DEPT_REBASE_ENFORCE === '1'; // без него — alert-only (обкатка)
const DEPT_ROLES = new Set(['руководитель', 'мк', 'архивариус', 'тп']);
const NOTIFY = process.env.TELEGRAM_NOTIFY || '/home/rainor/server/server_monitor/telegram_notify.sh';

// Чистая решающая функция (тестируется отдельно). w: {ageMs, compactions, stale, alreadyAlerted, enforce}
//
// Фаза 4: STALE — НЕ самостоятельный триггер, а модификатор порога. Раньше `if (w.stale)`
// стоял первым и перебивал всё: алерт «сессия старая» врал про 18-часовые сессии, а
// «вечный STALE» (воркеру нечего фиксировать → память не двигается → транскрипт тикает
// от служебных событий) навсегда запрещал rebase. Теперь: нет порога — молчим.
function decide(w, cfg) {
  const overAge = w.ageMs >= cfg.maxAgeDays * 86400_000;
  const overCompact = w.compactions >= cfg.maxCompactions;
  if (!overAge && !overCompact) return { action: 'none' };
  const reason = overAge ? `возраст сессии ≥ ${cfg.maxAgeDays} дн` : `компакций ≥ ${cfg.maxCompactions}`;
  // Порог есть, но память не курируется: rebase стёр бы контекст, которого нет в файлах.
  // ENFORCE это НЕ обходит — инвариант курируемой памяти (policy 1.1) сильнее автопорога.
  if (w.stale) return { action: w.alreadyAlerted ? 'none' : 'stale_alert', reason: `${reason}, но память НЕ курируется (STALE) — нужна курация` };
  if (!w.enforce && w.alreadyAlerted) return { action: 'none' };
  return { action: 'rebase', reason };
}
// Чистка эпизод-стейта (чистая, тестируется отдельно). Запись выпадает, если воркер
// ушёл из реестра отдела / роль стала не-отдельной ИЛИ autonomous state !== 'active':
// уход из active закрывает эпизод — вернувшийся воркер начинает с чистого листа
// (иначе active(alerted)→sleeping→active вернулся бы со старым alerted и первый
// легитимный алерт нового эпизода был бы подавлен).
function pruneState(state, deptWorkers, autoWorkers) {
  for (const name of Object.keys(state)) {
    const meta = (deptWorkers || {})[name];
    const auto = (autoWorkers || {})[name];
    if (!meta || !DEPT_ROLES.has(meta.role) || !auto || auto.state !== 'active') delete state[name];
  }
  return state;
}
// M1: сообщение про доставку просьбы о курации (чистая, тестируется отдельно).
// dry всегда идёт с bus=false (ветка отправки по шине пропускается целиком) — нельзя
// подставлять его в тот же ${bus ? ... : '🔴 НЕ отправлена'}, иначе dry-превью врёт про
// провал доставки на каждом прогоне, хотя в боевом режиме просьба реально ушла бы.
function staleAlertMessage({ dry, bus, name, reason }) {
  return dry
    ? `⚠️ [dry] rebase-check: ${name} — ${reason}. Автопорог сработал бы; отправил бы воркеру просьбу докурировать.`
    : `⚠️ rebase-check: ${name} — ${reason}. Автопорог сработал, но rebase запрещён до курации; воркеру ${bus ? 'отправлена' : '🔴 НЕ отправлена'} просьба докурировать.`;
}
module.exports = { decide, pruneState, staleAlertMessage };
if (require.main !== module) return;

const dry = process.argv.includes('--dry-run');

// Best-effort лок (см. liveness): ручной --dry-run параллельно с таймером иначе
// делает read-modify-write rebase-check-state.json без синхронизации. Таймер бьёт
// раз в час — 30 мин "протухания" даёт запас на несколько последовательных ENFORCE
// rebase (до 300с timeout каждый), не звонит stale за живой, но медленный прогон.
const LOCK_FILE = path.join(DEPT, 'rebase-check.lock');
const LOCK_STALE_MS = 30 * 60_000;
function acquireLock() {
  fs.mkdirSync(DEPT, { recursive: true });
  try {
    const fd = fs.openSync(LOCK_FILE, 'wx');
    fs.writeSync(fd, String(process.pid));
    fs.closeSync(fd);
    return true;
  } catch (e) {
    if (e.code !== 'EEXIST') throw e;
    try {
      if (Date.now() - fs.statSync(LOCK_FILE).mtimeMs > LOCK_STALE_MS) { fs.unlinkSync(LOCK_FILE); return acquireLock(); }
    } catch {}
    return false;
  }
}
// p3#22: dry-run строго read-only — лок НЕ берём и НЕ пишем (превью не должен транзиентно
// блокировать реальный тик; dry-путь без лока безопасен — state он не пишет, гонки RMW нет).
if (!dry) {
  if (!acquireLock()) {
    console.log('rebase-check: другой прогон уже идёт (свежий lock) — пропуск во избежание гонки на rebase-check-state.json');
    return;
  }
  // 'exit', не try/finally — снимает лок и при незапойманном исключении в цикле ниже
  // (иначе один сбой блокирует все прогоны на LOCK_STALE_MS, а не только текущий тик).
  process.on('exit', () => { try { fs.unlinkSync(LOCK_FILE); } catch {} });
}

// timeout: подвисший claude-auto/tmux иначе вешает execFileSync навсегда — сам
// rebase-check зависает вместо детекта чужой проблемы, и ни один воркер ПОСЛЕ
// зависшего в цикле не проверяется, saveState() не вызывается.
function sh(cmd, args, timeoutMs = 10_000) { try { return execFileSync(cmd, args, { encoding: 'utf8', timeout: timeoutMs }); } catch { return null; } }
function loadState() { try { return JSON.parse(fs.readFileSync(STATE_FILE, 'utf8')); } catch { return {}; } }
function saveState(s) {
  fs.mkdirSync(DEPT, { recursive: true });
  const tmp = STATE_FILE + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(s, null, 2));
  fs.renameSync(tmp, STATE_FILE);
}
// p3#33: у notify СОБСТВЕННЫЙ таймаут 30с (не общий 10с sh()) — telegram_notify.sh при
// сетевом флапе не успевал добежать до fallback, алерт молча терялся. Возвращает
// успех/провал: дедуп-стейт эпизода (alerted) пишется только при доставленном алерте.
function notify(msg) {
  if (dry) { console.log('[dry] notify:', msg); return true; }
  if (sh(NOTIFY, [msg], 45_000) === null) { console.log('rebase-check: notify FAILED:', msg); return false; }
  return true;
}

function readSpec(name) {
  try { return JSON.parse(fs.readFileSync(path.join(CC_HOME, 'workers', name, 'spec.json'), 'utf8')); } catch { return null; }
}
// state/compactions — plain-text счётчик, пишет claude-auto-run при каждом /compact
// (Task 3-5), claude-auto rebase его удаляет. Мусор/отсутствие файла → 0, не die —
// иначе один битый файл роняет весь прогон вместо пропуска порога компакций.
function readCompactions(name) {
  try {
    const raw = fs.readFileSync(path.join(CC_HOME, 'workers', name, 'state', 'compactions'), 'utf8').trim();
    const n = Number(raw);
    return Number.isFinite(n) && n >= 0 ? Math.floor(n) : 0;
  } catch { return 0; }
}
// Битый/отсутствующий реестр НЕ должен валить прогон тихим стектрейсом в journal:
// работа watchdog-инструмента — замечать то, что никто не смотрит, включая
// собственную неспособность работать. Алерт → чистый exit (лок снимет 'exit'-хук).
function readRegistry(file, label) {
  try { return JSON.parse(fs.readFileSync(file, 'utf8')); }
  catch (e) {
    notify(`🚨 rebase-check: не смог прочитать ${label} (${file}): ${e.code || e.message} — проверка флота НЕ выполнена, почини вручную`);
    process.exit(0);
  }
}
const deptReg = readRegistry(path.join(DEPT, 'registry.json'), 'registry.json');
const autoReg = readRegistry(path.join(CC_HOME, 'autonomous.json'), 'autonomous.json');
const state = loadState();
const now = Date.now();
const CLAUDE_AUTO = path.join(BIN, 'claude-auto');
const DEPT_LEDGER = path.join(BIN, 'dept-ledger');

for (const [name, meta] of Object.entries(deptReg.workers || {})) {
  if (!meta || !DEPT_ROLES.has(meta.role)) continue;
  const autoMeta = (autoReg.workers || {})[name];
  if (!autoMeta || autoMeta.state !== 'active') continue;

  const spec = readSpec(name);
  if (!spec) { console.log(`rebase-check: ${name}: spec.json не найден/битый — пропуск`); continue; }
  const anchor = spec.rebased_at || spec.created_at;
  const anchorMs = anchor ? Date.parse(anchor) : NaN;
  const ageMs = Number.isFinite(anchorMs) ? now - anchorMs : 0;
  const compactions = readCompactions(name);
  const fresh = memoryFreshness(autoMeta.brain_path, spec.session_id, STALE_AFTER_MS);
  const stale = fresh.state === 'stale';
  // Эпизод-стейт фазовый, не булев (Codex важное №6): после stale_alert воркер может
  // докурировать память (stale→false), а порог возраста ещё активен — decide() обязан
  // вернуть свежий rebase, а не молчать по старому alerted чужой фазы.
  const alreadyAlerted = !!(state[name] && state[name].phase === (stale ? 'stale_alerted' : 'rebase_alerted'));
  const w = { ageMs, compactions, stale, alreadyAlerted, enforce: ENFORCE };

  if (dry) {
    console.log(`[dry] ${name}: age_days=${Math.round(ageMs / 86400_000)} compactions=${compactions} stale=${stale} action=${decide(w, CFG).action}`);
  }

  // Фаза 4: stale БЕЗ порога больше не триггер — иначе эпизод-стейт вечно жил бы у
  // воркера, которому нечего фиксировать (см. decide()). Синхронно с decide().
  const anyTrigger = ageMs >= CFG.maxAgeDays * 86400_000 || compactions >= CFG.maxCompactions;
  const d = decide(w, CFG);

  if (!anyTrigger) {
    // Эпизод-сброс: триггеров больше нет (успешный rebase обнулил age/compactions,
    // или память докурировали) — не спамить старым alerted на будущих эпизодах.
    delete state[name];
    continue;
  }

  if (d.action === 'none') continue; // дедуп внутри decide() — эпизод уже сообщён, state не трогаем

  if (d.action === 'stale_alert') {
    // Автодокурация: код не может курировать клиентскую память за МК — единственный, кто
    // может, это сам воркер. Шлём просьбу по шине И алертим оператора.
    //
    // Учёт РАЗДЕЛЬНЫЙ (Codex важное №6): провал шины при успешном TG (и наоборот) не должен
    // гасить эпизод целиком — иначе воркер не получит просьбу никогда, а оператор будет
    // думать, что получил.
    let bus = false;
    if (!dry) {
      try {
        execFileSync(DEPT_LEDGER, ['send', '--type', 'question', '--to', name, '--actor', 'rebase-check',
          '--subject', `Докурируй память: ${d.reason}`,
          '--body', 'Сессия подошла к порогу плановой пересборки, но файлы памяти клиента отстают от транскрипта. '
            + 'Докурируй (манифест/timeline/decisions) — или, если фиксировать нечего, так и запиши одной строкой в timeline (policy 1.5).'],
          { encoding: 'utf8', timeout: 30_000 });
        bus = true;
      } catch (e) {
        console.error(`rebase-check: не смог отправить просьбу о курации ${name}: ${e.message}`);
      }
    } else {
      console.log(`[dry] просьба о курации ${name} по шине: ${d.reason}`);
    }
    const tg = notify(staleAlertMessage({ dry, bus, name, reason: d.reason }));
    // Эпизод помечаем только если ОБА канала сработали; иначе следующий тик повторит.
    if (bus && tg) state[name] = { phase: 'stale_alerted' };
    continue;
  }

  // d.action === 'rebase'
  if (!ENFORCE) {
    // p3#33: тот же принцип — alerted только при доставленном [would-rebase]-алерте.
    if (notify(`⚠️ [would-rebase] rebase-check: ${name} — ${d.reason}. Включи DEPT_REBASE_ENFORCE=1 или ребейзни вручную: claude-auto rebase ${name}`)) {
      state[name] = { phase: 'rebase_alerted' };
    }
    continue;
  }

  // ENFORCE=1: dry-run должен остаться строго read-only — ни рабочего вызова
  // claude-auto rebase, ни notify через реальный канал (notify() сама глушится в dry).
  if (dry) {
    console.log(`[dry] ${name}: ENFORCE включён — реальный прогон вызвал бы 'claude-auto rebase ${name} --reason автопорог: ${d.reason}'`);
    continue;
  }
  try {
    execFileSync(CLAUDE_AUTO, ['rebase', name, '--reason', `автопорог: ${d.reason}`], { encoding: 'utf8', timeout: 300_000 });
    // p3#33-решение: state чистим НЕЗАВИСИМО от исхода notify — эпизод закрыт ФАКТОМ
    // rebase (триггеры обнулены), уведомление информационное; следующий тик и так
    // удалил бы запись по anyTrigger=false.
    notify(`✅ rebase-check: ${name} — автопорог сработал (${d.reason}), rebase выполнен.`);
    delete state[name];
  } catch (e) {
    if (e.status === 3) {
      console.log(`rebase-check: ${name} занят (exit 3) — rebase отложен, следующий тик повторит`);
      // эпизод НЕ сброшен: state как был, следующий тик пересчитает триггеры заново
    } else {
      notify(`🚨 rebase-check: ENFORCE rebase ${name} FAILED (${d.reason}): ${e.message}`);
    }
  }
}

// Воркеры, пропавшие из registry.json (роль ушла из-под ролей отдела/воркер снесён)
// ИЛИ ушедшие из autonomous active (sleeping/stopped) — их записи в state иначе
// никогда не трогаются циклом выше (он требует state=='active') и копятся навечно;
// уход из active закрывает эпизод — вернувшийся воркер начинает с чистого листа.
pruneState(state, deptReg.workers, autoReg.workers);

// dry-run обязан быть чисто read-only (см. docs/department.md паттерн liveness) —
// боевой state-файл не создаём и не трогаем при превью-прогоне.
if (!dry) saveState(state);
