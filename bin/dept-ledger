#!/usr/bin/env node
// dept-ledger — единственный писатель журнала цифрового отдела.
// Append-only JSONL + lockfile; статусы меняются событиями *_status (ref=event_id).
'use strict';
const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');

const HOME = process.env.DEPT_HOME || '/home/rainor/.claude-control/department';
const LEDGER = path.join(HOME, 'events.jsonl');
const LOCK = LEDGER + '.lock';
const KINDS = new Set(['message', 'message_status', 'approval', 'approval_status',
  'incident', 'incident_status', 'agent_run', 'registry_change', 'policy_ack']);
// обязательные поля data по kind (минимальная схема фазы 1)
const REQUIRED = {
  message: ['type', 'from', 'to', 'subject'],
  message_status: ['ref', 'status'],
  approval: ['kind_of', 'from', 'summary'],
  approval_status: ['ref', 'status'],
  incident: ['about_worker', 'severity', 'summary'],
  incident_status: ['ref', 'status'],
  agent_run: ['worker', 'run_kind'],
  registry_change: ['worker'],
  policy_ack: ['worker', 'policy_version'],
};
const MSG_TYPES = new Set(['question', 'proposal', 'incident', 'handoff']); // §5 спеки; НЕ выдумывать новые
const MSG_STATUSES = new Set(['acked', 'handled', 'dead']);
const POLICY_DIR = process.env.DEPT_POLICY_DIR || '/home/rainor/brain/wiki/work/ai-dev/отдел/правила';
// Number(garbage) → NaN, а `x > NaN` всегда false — старое `Number(env || 24)` при кривом
// значении молча ВЫКЛЮЧАЛО TTL (policy-check в cmdPolicyCheck ниже никогда не считал ack
// протухшим). Guard: невалидное/неположительное значение → дефолт 24, а не NaN.
const ttlH = Number(process.env.DEPT_POLICY_ACK_TTL_HOURS);
const ACK_TTL_MS = (Number.isFinite(ttlH) && ttlH > 0 ? ttlH : 24) * 3600_000;
const ROLES = new Set(['руководитель', 'мк', 'архивариус', 'тп', 'legacy']);
const INCIDENT_RESOLVE_STATUSES = ['resolved', 'wontfix', 'duplicate'];

function die(msg) { process.stderr.write(msg + '\n'); process.exit(1); }

function parseArgs(argv) {
  const args = { _: [] , filter: []};
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--filter') args.filter.push(argv[++i]);
    else if (a.startsWith('--')) args[a.slice(2)] = argv[++i];
    else args._.push(a);
  }
  return args;
}

function withLock(fn) {
  fs.mkdirSync(HOME, { recursive: true }); // ДО лока — иначе openSync упадёт с ENOENT на свежем DEPT_HOME
  const deadline = Date.now() + 10000;
  for (;;) {
    try { const fd = fs.openSync(LOCK, 'wx'); fs.writeSync(fd, String(process.pid)); fs.closeSync(fd); break; }
    catch (e) {
      if (e.code !== 'EEXIST') throw e;
      // протухший лок (>60с — append никогда столько не живёт) снимаем
      try { if (Date.now() - fs.statSync(LOCK).mtimeMs > 60000) fs.unlinkSync(LOCK); } catch {}
      if (Date.now() > deadline) die('ledger: lock timeout');
      Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 50); // синхронный sleep 50мс без busy-wait
    }
  }
  try { return fn(); } finally { try { fs.unlinkSync(LOCK); } catch {} }
}

function readAll() {
  if (!fs.existsSync(LEDGER)) return [];
  const rows = [];
  for (const l of fs.readFileSync(LEDGER, 'utf8').split('\n')) {
    if (!l.trim()) continue;
    try { rows.push(JSON.parse(l)); }
    catch { process.stderr.write('ledger: пропущена битая строка\n'); }
  }
  return rows;
}

function effectiveStatus(events, ev, statusKind, initial) {
  let st = initial;
  for (const e of events) if (e.kind === statusKind && e.data.ref === ev.event_id) st = e.data.status;
  return st;
}

function assertRefExists(ref, expectedKind) {
  const e = readAll().find((e) => e.event_id === ref);
  if (!e) die('ledger: ref не найден: ' + ref);
  // без проверки kind approval-resolve/incident-open/ack принимали ref ЛЮБОГО события
  // (например, event_id сообщения) и "успешно" закрывали несуществующий approval/incident.
  if (expectedKind && e.kind !== expectedKind) {
    die(`ledger: ref ${ref} имеет kind ${e.kind}, ожидался ${expectedKind}`);
  }
}

// Валидация без побочных эффектов на файл (можно звать до входа в лок).
function validateEvent(kind, data) {
  if (!KINDS.has(kind)) die('append: неизвестный kind: ' + kind);
  for (const f of REQUIRED[kind]) if (data[f] === undefined) die(`append: ${kind} требует поле data.${f}`);
  if (kind === 'message' && !MSG_TYPES.has(data.type)) die('append: message.type ∉ ' + [...MSG_TYPES]);
  if (kind === 'message_status') {
    if (!MSG_STATUSES.has(data.status)) die('append: message_status.status ∉ ' + [...MSG_STATUSES]);
    assertRefExists(data.ref, 'message');
  }
  if (kind === 'approval_status') {
    if (!['approved', 'denied'].includes(data.status)) die('append: approval_status.status ∉ approved|denied');
    assertRefExists(data.ref, 'approval');
  }
  if (kind === 'incident_status') assertRefExists(data.ref, 'incident');
  if (kind === 'message' && data.status === undefined) data.status = 'queued';
}

// Писатель, упавший посреди append (crash/disk-full), оставляет хвост БЕЗ '\n' —
// следующий append склеился бы с ним, и ОБЕ строки стали бы нечитаемыми (новое
// событие подтверждено вызывающему, но навсегда выпадает из readAll). Чиним хвост
// под уже взятым локом: дописываем '\n', частичная строка остаётся изолированно-битой.
function repairTailUnlocked() {
  let fd;
  try {
    const size = fs.statSync(LEDGER).size;
    if (!size) return;
    const buf = Buffer.alloc(1);
    fd = fs.openSync(LEDGER, 'r');
    fs.readSync(fd, buf, 0, 1, size - 1);
    if (buf[0] !== 0x0a) fs.appendFileSync(LEDGER, '\n');
  } catch (e) {
    if (e.code !== 'ENOENT') throw e; // журнала ещё нет — чинить нечего
  } finally {
    if (fd !== undefined) { try { fs.closeSync(fd); } catch {} }
  }
}

// Сама запись строки в журнал. ПРЕДПОЛАГАЕТ, что лок уже взят вызывающим (withLock).
function writeEventUnlocked(kind, data, actor) {
  repairTailUnlocked();
  const events = readAll();
  const seq = events.length ? events[events.length - 1].seq + 1 : 1;
  const e = {
    v: 1,
    event_id: `evt_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
    seq, ts: new Date().toISOString(),
    actor: actor || process.env.CLAUDE_AUTO_NAME || 'operator',
    kind, data,
  };
  fs.appendFileSync(LEDGER, JSON.stringify(e) + '\n');
  return e;
}

// Общая точка записи (и для CLI, и для внутренних вызовов сабкоманд — без подпроцессов).
function appendEvent(kind, data, actor) {
  validateEvent(kind, data);
  return withLock(() => writeEventUnlocked(kind, data, actor));
}

function cmdAppend(args) {
  const kind = args.kind || die('append: --kind обязателен');
  let data;
  try { data = JSON.parse(args.data || ''); } catch { die('append: --data не валидный JSON'); }
  if (data === null || typeof data !== 'object' || Array.isArray(data)) die('append: --data должен быть JSON-объектом');
  const env = appendEvent(kind, data, args.actor);
  process.stdout.write(JSON.stringify({ event_id: env.event_id, seq: env.seq }) + '\n');
}

function cmdList(args) {
  const events = readAll();
  let rows = events;
  if (args.kind) rows = rows.filter((e) => e.kind === args.kind);
  for (const f of args.filter) {
    // indexOf, не split('=') — split теряет всё после второго '=' (--filter subject=a=b терял "=b"),
    // и --filter без значения (argv кончился) даёт f===undefined → упасть чисто, а не TypeError'ом.
    const eq = typeof f === 'string' ? f.indexOf('=') : -1;
    if (eq < 0) die('list: --filter требует формат k=v, получено: ' + f);
    const k = f.slice(0, eq), v = f.slice(eq + 1);
    rows = rows.filter((e) => String(e.data[k]) === v);
  }
  if (args.status && !args.kind) die('list: --status работает только вместе с --kind');
  if (args.status) { // effective status для message/approval/incident
    const statusKind = args.kind + '_status';
    rows = rows.filter((e) => effectiveStatus(events, e, statusKind, e.data.status || 'open') === args.status);
  }
  if (args.limit !== undefined) {
    // Number('0') истинно как непустая строка — старое `if (args.limit)` пропускало --limit 0
    // (отдавало ВСЁ вместо ничего). Явная проверка целого неотрицательного числа + спецкейс n===0.
    const n = Number(args.limit);
    if (!Number.isInteger(n) || n < 0) die('list: --limit должен быть целым неотрицательным числом');
    rows = n === 0 ? [] : rows.slice(-n);
  }
  for (const e of rows) process.stdout.write(JSON.stringify(e) + '\n');
}

const REGISTRY = () => path.join(HOME, 'registry.json');
// strict=true (registry-set): битый JSON — не глотать, отменить запись (иначе перезапишем реестр с нуля).
// strict=false/omitted (registry-get/list, incident-open): битый JSON — warning в stderr, вернуть пустой реестр.
// Бросаем обычный Error (не die()) на strict, чтобы withLock корректно снял лок через finally —
// process.exit() внутри withLock() пропускает finally и оставляет lock-файл висеть.
function readRegistry(strict) {
  let raw;
  try { raw = fs.readFileSync(REGISTRY(), 'utf8'); }
  catch (e) { if (e.code === 'ENOENT') return { workers: {} }; throw e; }
  try { return JSON.parse(raw); }
  catch {
    if (strict) {
      const err = new Error('registry: registry.json повреждён — почини вручную, запись отменена');
      err.registryCorrupt = true;
      throw err;
    }
    process.stderr.write('registry: registry.json повреждён, использую пустой реестр\n');
    return { workers: {} };
  }
}
function writeRegistry(reg) {
  const tmp = REGISTRY() + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(reg, null, 2) + '\n');
  fs.renameSync(tmp, REGISTRY());
}

function out(obj) { process.stdout.write(JSON.stringify(obj) + '\n'); }
function brief(e) { return { event_id: e.event_id, seq: e.seq }; }

function cmdSend(a) {
  const from = a.actor || process.env.CLAUDE_AUTO_NAME || 'operator';
  const reg = readRegistry();
  const roleOf = (n) => (reg.workers[n] || {}).role;
  if (roleOf(from) === 'мк' && roleOf(a.to) === 'мк') {
    die('send: прямое сообщение МК→МК запрещено (policy 3.1) — отправь question руководителю');
  }
  if (roleOf(a.to) === 'руководитель' && !['question', 'proposal'].includes(a.type)) {
    die('send: руководителю идут только question/proposal (§5 спеки) — handoff шли профильному штабному, incident открывай через incident-open');
  }
  const data = { type: a.type, from,
    to: a.to, subject: a.subject, body: a.body || '', refs: (a.refs || '').split(',').filter(Boolean) };
  out(brief(appendEvent('message', data, a.actor)));
}
function cmdAck(a) {
  out(brief(appendEvent('message_status', { ref: a._[1], status: 'acked' }, a.actor)));
}
function cmdResolve(a) {
  out(brief(appendEvent('message_status', { ref: a._[1], status: a.status }, a.actor)));
}
function policyCurrentSafe() { // approval обязан открыться даже без каталога правил
  try {
    const files = fs.readdirSync(POLICY_DIR);
    let best = null;
    for (const f of files) {
      const m = /^policy-v(\d+)\.md$/.exec(f);
      if (m && (!best || Number(m[1]) > best.n)) best = { n: Number(m[1]), f };
    }
    return best ? 'v' + best.n : null;
  } catch { return null; }
}
function cmdApprovalOpen(a) {
  const data = { kind_of: a['kind-of'],
    from: a.actor || process.env.CLAUDE_AUTO_NAME || 'operator',
    summary: a.summary, status: 'open' };
  if (a.detail) data.detail = String(a.detail).slice(0, 4000);
  const pv = policyCurrentSafe();
  if (pv) data.policy_version_seen = pv;
  out(brief(appendEvent('approval', data, a.actor)));
}
function cmdApprovalResolve(a) {
  const ref = a._[1];
  // Дедуп-чтение ДО withLock давало гонку: два параллельных resolve одним статусом оба
  // проходили проверку «ещё не resolved» раньше, чем любой из них дописывал событие, и
  // оба писали approval_status (дубль). Вся операция — читаем, решаем deduped/write —
  // теперь один withLock; appendEvent() внутри withLock звать нельзя (он сам берёт лок —
  // дедлок), поэтому пишем через validateEvent+writeEventUnlocked напрямую (как в
  // cmdRegistrySet). validateEvent для approval_status делает assertRefExists→readAll —
  // это чтение, под уже взятым локом безопасно.
  const result = withLock(() => {
    const events = readAll();
    const apr = events.find((e) => e.event_id === ref && e.kind === 'approval');
    if (apr && effectiveStatus(events, apr, 'approval_status', 'open') === a.status) {
      return { event_id: ref, deduped: true };
    }
    const data = { ref, status: a.status };
    validateEvent('approval_status', data);
    return brief(writeEventUnlocked('approval_status', data, a.actor));
  });
  out(result);
}
function cmdIncidentOpen(a) {
  const r = appendEvent('incident', { about_worker: a.about, severity: a.severity,
    summary: a.summary, status: 'open', source: a.actor || 'operator' }, a.actor);
  // non-strict: инцидент обязан открыться, даже если реестр битый/пустой/без роли 'тп' —
  // но тогда честно предупреждаем, а не молча теряем маршрутизацию к ТП.
  const reg = readRegistry();
  const tp = Object.entries(reg.workers).find(([, w]) => w.role === 'тп');
  if (tp) {
    appendEvent('message', { type: 'incident', from: a.actor || 'operator', to: tp[0],
      subject: `incident ${a.severity}: ${a.about}`, body: a.summary, refs: [r.event_id], status: 'queued' }, a.actor);
  } else {
    process.stderr.write("incident-open: инцидент открыт, но НЕ маршрутизирован ТП (роль 'тп' не найдена в реестре)\n");
  }
  out(brief(r));
}
function cmdRegistrySet(a) {
  const name = a._[1];
  if (!name) die('usage: dept-ledger registry-set <worker> --role <r> …');
  let updated;
  try {
    // Один withLock на RMW реестра + аудит-событие — иначе под конкуренцией порядок
    // «запись registry.json» vs «appendEvent(registry_change)» может разъехаться.
    updated = withLock(() => {
      const reg = readRegistry(true); // strict — битый реестр не перезаписываем
      const cur = reg.workers[name] || {};
      reg.workers[name] = {
        role: a.role || cur.role, client: a.client ?? cur.client ?? null,
        escalates_to: a['escalates-to'] || cur.escalates_to || 'operator',
        mission_version: a['mission-version'] || cur.mission_version || 'v1',
      };
      const next = reg.workers[name];
      if (!ROLES.has(next.role)) {
        const err = new Error(`registry: роль «${next.role}» ∉ {${[...ROLES].join(', ')}}`);
        err.cliError = true; throw err;
      }
      if (next.role === 'мк' && !next.client) {
        const err = new Error('registry: роль «мк» требует --client');
        err.cliError = true; throw err;
      }
      writeRegistry(reg);
      const data = { worker: name, ...reg.workers[name] };
      validateEvent('registry_change', data);
      writeEventUnlocked('registry_change', data, a.actor);
      return reg.workers[name];
    });
  } catch (e) {
    if (e && (e.registryCorrupt || e.cliError)) die(e.message);
    throw e;
  }
  out(updated);
}
// registry-get/registry-list — диагностические команды, fail-loud: битый registry.json
// не должен молча притворяться пустым реестром (в отличие от incident-open, которому
// нужно открыться в любом случае).
function readRegistryStrict() {
  try { return readRegistry(true); }
  catch (e) { if (e && e.registryCorrupt) die(e.message); throw e; }
}
function cmdRegistryGet(a) {
  const w = readRegistryStrict().workers[a._[1]];
  if (!w) die('registry: не найден ' + a._[1]);
  process.stdout.write(JSON.stringify(w) + '\n');
}
function cmdRegistryList() { process.stdout.write(JSON.stringify(readRegistryStrict()) + '\n'); }

function policyCurrent() {
  let files;
  try { files = fs.readdirSync(POLICY_DIR); }
  catch { die('policy: каталог правил недоступен: ' + POLICY_DIR); }
  let best = null;
  for (const f of files) {
    const m = /^policy-v(\d+)\.md$/.exec(f);
    if (m && (!best || Number(m[1]) > best.n)) best = { n: Number(m[1]), f };
  }
  if (!best) die('policy: в ' + POLICY_DIR + ' нет файлов policy-vN.md');
  const file = path.join(POLICY_DIR, best.f);
  return { version: 'v' + best.n, file, mtimeMs: fs.statSync(file).mtimeMs };
}
function cmdPolicyCurrent() { const c = policyCurrent(); out({ version: c.version, file: c.file }); }
function cmdPolicyAck(a) {
  if (!a.version) die('policy-ack: --version обязателен (какую версию правил ты прочитал)');
  const cur = policyCurrent();
  if (a.version !== cur.version) {
    die(`policy-ack: действующая версия ${cur.version}, ты указал ${a.version} — перечитай ${cur.file} и повтори: dept-ledger policy-ack --version ${cur.version}`);
  }
  const worker = a.actor || process.env.CLAUDE_AUTO_NAME || 'operator';
  out(brief(appendEvent('policy_ack', { worker, policy_version: a.version }, worker)));
}
function cmdPolicyCheck(a) {
  const worker = a.worker || die('policy-check: --worker обязателен');
  const cur = policyCurrent();
  const fail = (why) => die(`policy-check: ${why}. Перечитай ${cur.file} и выполни: dept-ledger policy-ack --version ${cur.version} --actor ${worker}`);
  const acks = readAll().filter((e) => e.kind === 'policy_ack' && e.data.worker === worker);
  const last = acks[acks.length - 1];
  if (!last) fail(`у «${worker}» нет ни одного policy-ack`);
  if (last.data.policy_version !== cur.version) fail(`последний ack на ${last.data.policy_version}, действует ${cur.version}`);
  const ts = Date.parse(last.ts);
  if (ts < cur.mtimeMs) fail('правила изменились после последнего прочтения');
  if (Date.now() - ts > ACK_TTL_MS) fail('последнее прочтение правил слишком старое');
  out({ ok: true, policy_version: cur.version, acked_at: last.ts });
}
function cmdIncidentResolve(a) {
  const status = a.status || die('incident-resolve: --status обязателен (' + INCIDENT_RESOLVE_STATUSES.join('|') + ')');
  if (!INCIDENT_RESOLVE_STATUSES.includes(status)) die('incident-resolve: --status ∉ ' + INCIDENT_RESOLVE_STATUSES.join('|'));
  if (!a._[1]) die('usage: dept-ledger incident-resolve <event_id> --status <s> [--ref-main <event_id основного при duplicate>]');
  // duplicate без --ref-main — инцидент помечен дублем, но никто не знает основного (тупик
  // для читающего ledger); --ref-main на несуществующий/чужой kind event_id — то же самое,
  // с чего assertRefExists уже защищает *_status выше. С другими статусами --ref-main —
  // мусорное поле (не duplicate — не на что ссылаться), запрещаем явно, а не молча игнорируем.
  if (status === 'duplicate') {
    if (!a['ref-main']) die('incident-resolve: --status duplicate требует --ref-main <event_id основного инцидента>');
    assertRefExists(a['ref-main'], 'incident');
  } else if (a['ref-main']) {
    die('incident-resolve: --ref-main только со --status duplicate');
  }
  const data = { ref: a._[1], status };
  if (a['ref-main']) data.ref_main = a['ref-main'];
  out(brief(appendEvent('incident_status', data, a.actor)));
}
function cmdSnapshot() {
  const g = (...gargs) => execFileSync('git', ['-C', HOME, ...gargs], { encoding: 'utf8' });
  // Под ledger-локом: (а) git add не читает журнал посреди append (torn line в
  // аудит-коммите — detail до 4000 симв. пишется в несколько страниц), (б) два
  // snapshot'а (таймер + ручной) сериализуются, а не бьются об index.lock.
  const res = withLock(() => {
    try { g('rev-parse', '--git-dir'); } catch { g('init'); }
    // Пока snapshot держит лок, events.jsonl.lock существует — без ignore каждый
    // прогон коммитил бы лок-файл и никогда не был бы «чистым». Не перетираем
    // существующий .gitignore (в живом каталоге он свой, шире).
    const gi = path.join(HOME, '.gitignore');
    if (!fs.existsSync(gi)) fs.writeFileSync(gi, '*.lock\n*.tmp\n');
    if (!g('status', '--porcelain').trim()) return { committed: false };
    g('add', '-A');
    g('-c', 'user.email=dept@local', '-c', 'user.name=dept-ledger',
      'commit', '-m', 'snapshot ' + new Date().toISOString());
    return { committed: true };
  });
  out(res);
}

const HANDLERS = {
  append: cmdAppend, list: cmdList, send: cmdSend, ack: cmdAck, resolve: cmdResolve,
  'approval-open': cmdApprovalOpen, 'approval-resolve': cmdApprovalResolve,
  'incident-open': cmdIncidentOpen,
  'registry-set': cmdRegistrySet, 'registry-get': cmdRegistryGet, 'registry-list': cmdRegistryList,
  'policy-current': cmdPolicyCurrent, 'policy-ack': cmdPolicyAck, 'policy-check': cmdPolicyCheck,
  'incident-resolve': cmdIncidentResolve, snapshot: cmdSnapshot,
};
const args = parseArgs(process.argv.slice(2));
const cmd = args._[0];
