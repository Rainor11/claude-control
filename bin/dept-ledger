#!/usr/bin/env node
// dept-ledger — единственный писатель журнала цифрового отдела.
// Append-only JSONL + lockfile; статусы меняются событиями *_status (ref=event_id).
'use strict';
const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');

const HOME = process.env.DEPT_HOME || '/home/rainor/.claude-control/department';
const LEDGER = path.join(HOME, 'events.jsonl');
const LOCK = LEDGER + '.lock';
const KINDS = new Set(['message', 'message_status', 'approval', 'approval_status',
  'incident', 'incident_status', 'agent_run', 'registry_change', 'policy_ack']);
// обязательные поля data по kind (минимальная схема фазы 1)
const REQUIRED = {
  message: ['type', 'from', 'to', 'subject'],
  message_status: ['ref', 'status'],
  approval: ['kind_of', 'from', 'summary'],
  approval_status: ['ref', 'status'],
  incident: ['about_worker', 'severity', 'summary'],
  incident_status: ['ref', 'status'],
  agent_run: ['worker', 'run_kind'],
  registry_change: ['worker'],
  policy_ack: ['worker', 'policy_version'],
};
const MSG_TYPES = new Set(['question', 'proposal', 'incident', 'handoff',
  'kb_change_request', 'decision_request', 'policy_refresh']); // §5 спеки; worker_spawn/mission_change — approvals, не messages
const MSG_STATUSES = new Set(['acked', 'handled', 'dead']);
// Task 11-fix: 'executing' — промежуточный статус между approved и executed/exec_failed.
// Диспетчер помечает заявку executing ДО запуска исполнителя в отдельном юните (dept-exec-runner),
// чтобы следующий тик/прогон видел её НЕ approved (effectiveStatus) и не запускал второй
// исполнитель на ту же заявку — см. cmdApprovalExec ниже и wiki-бриф P3-Task-11fix.
const APPROVAL_STATUSES = ['approved', 'denied', 'executed', 'exec_failed', 'executing', 'withdrawn'];
// Типы событий, которые воркер не может писать generic-командой `append` (дыра 17.07).
// Гард К3 (assertNotWorkerSession) стоял только на approval-resolve/approval-exec, а
// `append --kind approval_status --data '{"ref":…,"status":"approved"}'` писал ТОТ ЖЕ
// статус в обход — воспроизведено: заявка становилась approved без оператора. Полная
// цепочка: registry-set self→руководитель + approval-open worker_spawn + append approved
// = найм без кнопки. У воркеров Bash(dept-ledger:*) в allow, так что вход открыт всем.
//
// agent_run/message/message_status/incident СОЗНАТЕЛЬНО не здесь: их штатно пишут
// claude-auto и сами воркеры (rebase-события, шина, открытие инцидента о себе).
const PRIVILEGED_KINDS = new Set(['approval_status', 'registry_change', 'incident_status', 'policy_ack']);
const ROTATE_DAYS_DEFAULT = 30;
const POLICY_DIR = process.env.DEPT_POLICY_DIR || '/home/rainor/brain/wiki/work/ai-dev/отдел/правила';
// Number(garbage) → NaN, а `x > NaN` всегда false — старое `Number(env || 24)` при кривом
// значении молча ВЫКЛЮЧАЛО TTL (policy-check в cmdPolicyCheck ниже никогда не считал ack
// протухшим). Guard: невалидное/неположительное значение → дефолт 24, а не NaN.
const ttlH = Number(process.env.DEPT_POLICY_ACK_TTL_HOURS);
const ACK_TTL_MS = (Number.isFinite(ttlH) && ttlH > 0 ? ttlH : 24) * 3600_000;
const ROLES = new Set(['руководитель', 'мк', 'архивариус', 'тп', 'legacy']);
const INCIDENT_RESOLVE_STATUSES = ['resolved', 'wontfix', 'duplicate'];

function die(msg) { process.stderr.write(msg + '\n'); process.exit(1); }
// Codex-аудит В3: validateEvent/assertRefExists раньше звали die() (=process.exit) — если это
// случалось ВНУТРИ уже взятого withLock (approval-resolve/approval-exec), finally withLock НЕ
// выполнялся и лок-файл висел до 60с-протухания. cliDie бросает обычный Error с меткой cliError —
// withLock корректно снимает лок через finally при любом throw, а хендлер-вызывающий конвертирует
// cliError в чистый die() уже ПОСЛЕ выхода из withLock (см. глобальный catch внизу файла и
// локальные try/catch в cmdApprovalResolve/cmdApprovalExec — по образцу cmdRegistrySet).
function cliDie(msg) { throw Object.assign(new Error(msg), { cliError: true }); }

// Вызов из сессии воркера? Поднимаемся по /proc-предкам: найден процесс с CLAUDE_AUTO_NAME
// в environ и exe внутри доверенного CLAUDE_INSTALL → это воркер. fail-open при ошибках
// чтения /proc НЕ допускается только для положительного матча: не смогли прочитать —
// продолжаем подъём (гард отсекает лёгкую/случайную эскалацию, как self-protection).
const CLAUDE_INSTALL = process.env.CLAUDE_INSTALL || '/home/rainor/.local/share/claude';
function callerWorkerName() {
  let pid = process.ppid, depth = 0;
  while (pid > 1 && depth++ < 25) {
    let exe = '', env = '', stat = '';
    try { exe = fs.readlinkSync(`/proc/${pid}/exe`); } catch {}
    try { env = fs.readFileSync(`/proc/${pid}/environ`, 'utf8'); } catch {}
    if (exe.startsWith(CLAUDE_INSTALL + '/')) {
      const m = /(?:^|\0)CLAUDE_AUTO_NAME=([^\0]+)/.exec(env);
      if (m) return m[1];
    }
    try { stat = fs.readFileSync(`/proc/${pid}/stat`, 'utf8'); } catch { return null; }
    const mm = /\)\s+\S\s+(\d+)/.exec(stat);
    if (!mm) return null;
    pid = Number(mm[1]);
  }
  return null;
}
// Codex-аудит К3: у воркеров allow на Bash(dept-ledger:*) — без механического запрета любой
// воркер мог бы записать approval_status approved --actor operator и диспетчер исполнил бы
// spawn/mission_change (эскалация привилегий). Гард — обратная /proc-идентичность (зеркало
// resolve_name из dept-approve, на Node).
function assertNotWorkerSession(cmd) {
  const w = callerWorkerName();
  if (w) die(`${cmd}: запрещено из сессии воркера («${w}») — решение записывает бот/оператор/диспетчер (policy 2.4)`);
}

function parseArgs(argv) {
  const args = { _: [] , filter: []};
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--filter') args.filter.push(argv[++i]);
    else if (a.startsWith('--')) args[a.slice(2)] = argv[++i];
    else args._.push(a);
  }
  return args;
}

function withLock(fn) {
  fs.mkdirSync(HOME, { recursive: true }); // ДО лока — иначе openSync упадёт с ENOENT на свежем DEPT_HOME
  const deadline = Date.now() + 10000;
  for (;;) {
    try { const fd = fs.openSync(LOCK, 'wx'); fs.writeSync(fd, String(process.pid)); fs.closeSync(fd); break; }
    catch (e) {
      if (e.code !== 'EEXIST') throw e;
      // протухший лок (>60с — append никогда столько не живёт) снимаем
      try { if (Date.now() - fs.statSync(LOCK).mtimeMs > 60000) fs.unlinkSync(LOCK); } catch {}
      if (Date.now() > deadline) die('ledger: lock timeout');
      Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, 50); // синхронный sleep 50мс без busy-wait
    }
  }
  try { return fn(); } finally { try { fs.unlinkSync(LOCK); } catch {} }
}

function readAll() {
  if (!fs.existsSync(LEDGER)) return [];
  const rows = [];
  for (const l of fs.readFileSync(LEDGER, 'utf8').split('\n')) {
    if (!l.trim()) continue;
    try { rows.push(JSON.parse(l)); }
    catch { process.stderr.write('ledger: пропущена битая строка\n'); }
  }
  return rows;
}

function effectiveStatus(events, ev, statusKind, initial) {
  let st = initial;
  for (const e of events) if (e.kind === statusKind && e.data.ref === ev.event_id) st = e.data.status;
  return st;
}

const ARCHIVE_DIR = () => path.join(HOME, 'archive');
function archiveFiles() { // новые первыми
  try { return fs.readdirSync(ARCHIVE_DIR()).filter((f) => /^events-\d{4}-\d{2}\.jsonl$/.test(f)).sort().reverse()
    .map((f) => path.join(ARCHIVE_DIR(), f)); } catch { return []; }
}
function findInArchives(eventId) {
  for (const f of archiveFiles()) {
    for (const l of fs.readFileSync(f, 'utf8').split('\n')) {
      if (!l.trim() || !l.includes(eventId)) continue;
      try { const e = JSON.parse(l); if (e.event_id === eventId) return e; } catch {}
    }
  }
  return null;
}
const ROT_STATE = () => path.join(HOME, 'rotate-state.json');
function rotateState() { try { return JSON.parse(fs.readFileSync(ROT_STATE(), 'utf8')); } catch { return { last_seq: 0 }; } }

function assertRefExists(ref, expectedKind) {
  const e = readAll().find((e) => e.event_id === ref);
  if (e) {
    // без проверки kind approval-resolve/incident-open/ack принимали ref ЛЮБОГО события
    // (например, event_id сообщения) и "успешно" закрывали несуществующий approval/incident.
    if (expectedKind && e.kind !== expectedKind) {
      cliDie(`ledger: ref ${ref} имеет kind ${e.kind}, ожидался ${expectedKind}`);
    }
    return;
  }
  // Task 1: не нашли в активном файле — ref мог уехать в архив ротацией (approval-resolve-дедуп
  // и incident-resolve --ref-main обязаны продолжать работать после rotate).
  const a = findInArchives(ref);
  if (!a) cliDie('ledger: ref не найден: ' + ref);
  if (expectedKind && a.kind !== expectedKind) {
    cliDie(`ledger: ref ${ref} имеет kind ${a.kind}, ожидался ${expectedKind}`);
  }
}

// Валидация без побочных эффектов на файл (можно звать до входа в лок).
function validateEvent(kind, data) {
  if (!KINDS.has(kind)) cliDie('append: неизвестный kind: ' + kind);
  for (const f of REQUIRED[kind]) if (data[f] === undefined) cliDie(`append: ${kind} требует поле data.${f}`);
  if (kind === 'message' && !MSG_TYPES.has(data.type)) cliDie('append: message.type ∉ ' + [...MSG_TYPES]);
  if (kind === 'message_status') {
    if (!MSG_STATUSES.has(data.status)) cliDie('append: message_status.status ∉ ' + [...MSG_STATUSES]);
    assertRefExists(data.ref, 'message');
  }
  if (kind === 'approval_status') {
    if (!APPROVAL_STATUSES.includes(data.status)) cliDie('append: approval_status.status ∉ ' + APPROVAL_STATUSES.join('|'));
    assertRefExists(data.ref, 'approval');
  }
  if (kind === 'incident_status') assertRefExists(data.ref, 'incident');
  if (kind === 'message' && data.status === undefined) data.status = 'queued';
}

// Писатель, упавший посреди append (crash/disk-full), оставляет хвост БЕЗ '\n' —
// следующий append склеился бы с ним, и ОБЕ строки стали бы нечитаемыми (новое
// событие подтверждено вызывающему, но навсегда выпадает из readAll). Чиним хвост
// под уже взятым локом: дописываем '\n', частичная строка остаётся изолированно-битой.
function repairTailUnlocked() {
  let fd;
  try {
    const size = fs.statSync(LEDGER).size;
    if (!size) return;
    const buf = Buffer.alloc(1);
    fd = fs.openSync(LEDGER, 'r');
    fs.readSync(fd, buf, 0, 1, size - 1);
    if (buf[0] !== 0x0a) fs.appendFileSync(LEDGER, '\n');
  } catch (e) {
    if (e.code !== 'ENOENT') throw e; // журнала ещё нет — чинить нечего
  } finally {
    if (fd !== undefined) { try { fs.closeSync(fd); } catch {} }
  }
}

// Сама запись строки в журнал. ПРЕДПОЛАГАЕТ, что лок уже взят вызывающим (withLock).
function writeEventUnlocked(kind, data, actor) {
  repairTailUnlocked();
  const events = readAll();
  // Task 1: seq строго монотонный через ротацию — активный файл после rotate может начинаться
  // "с нуля" (пуст или содержит только новые события), поэтому берём максимум с rotate-state.
  const seq = Math.max(events.length ? events[events.length - 1].seq : 0, rotateState().last_seq) + 1;
  const e = {
    v: 1,
    event_id: `evt_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
    seq, ts: new Date().toISOString(),
    actor: actor || process.env.CLAUDE_AUTO_NAME || 'operator',
    kind, data,
  };
  fs.appendFileSync(LEDGER, JSON.stringify(e) + '\n');
  return e;
}

// Общая точка записи (и для CLI, и для внутренних вызовов сабкоманд — без подпроцессов).
function appendEvent(kind, data, actor) {
  validateEvent(kind, data);
  return withLock(() => writeEventUnlocked(kind, data, actor));
}

function cmdAppend(args) {
  const kind = args.kind || die('append: --kind обязателен');
  // Дыра 17.07: generic append писал approval_status/registry_change в обход гарда К3,
  // стоявшего только на типизированных командах. Решение по аппруву записывает
  // бот/оператор/диспетчер (policy 2.4), роль в реестре меняет оператор.
  if (PRIVILEGED_KINDS.has(kind)) assertNotWorkerSession(`append --kind ${kind}`);
  let data;
  try { data = JSON.parse(args.data || ''); } catch { die('append: --data не валидный JSON'); }
  if (data === null || typeof data !== 'object' || Array.isArray(data)) die('append: --data должен быть JSON-объектом');
  const env = appendEvent(kind, data, args.actor);
  process.stdout.write(JSON.stringify({ event_id: env.event_id, seq: env.seq }) + '\n');
}

function cmdList(args) {
  const events = readAll();
  let rows = events;
  if (args.kind) rows = rows.filter((e) => e.kind === args.kind);
  if (args['event-id']) rows = rows.filter((e) => e.event_id === args['event-id']);
  for (const f of args.filter) {
    // indexOf, не split('=') — split теряет всё после второго '=' (--filter subject=a=b терял "=b"),
    // и --filter без значения (argv кончился) даёт f===undefined → упасть чисто, а не TypeError'ом.
    const eq = typeof f === 'string' ? f.indexOf('=') : -1;
    if (eq < 0) die('list: --filter требует формат k=v, получено: ' + f);
    const k = f.slice(0, eq), v = f.slice(eq + 1);
    rows = rows.filter((e) => String(e.data[k]) === v);
  }
  if (args.status && !args.kind) die('list: --status работает только вместе с --kind');
  if (args.status) { // effective status для message/approval/incident
    const statusKind = args.kind + '_status';
    rows = rows.filter((e) => effectiveStatus(events, e, statusKind, e.data.status || 'open') === args.status);
  }
  if (args.limit !== undefined) {
    // Number('0') истинно как непустая строка — старое `if (args.limit)` пропускало --limit 0
    // (отдавало ВСЁ вместо ничего). Явная проверка целого неотрицательного числа + спецкейс n===0.
    const n = Number(args.limit);
    if (!Number.isInteger(n) || n < 0) die('list: --limit должен быть целым неотрицательным числом');
    rows = n === 0 ? [] : rows.slice(-n);
  }
  for (const e of rows) process.stdout.write(JSON.stringify(e) + '\n');
}

const REGISTRY = () => path.join(HOME, 'registry.json');
// strict=true (registry-set): битый JSON — не глотать, отменить запись (иначе перезапишем реестр с нуля).
// strict=false/omitted (registry-get/list, incident-open): битый JSON — warning в stderr, вернуть пустой реестр.
// Бросаем обычный Error (не die()) на strict, чтобы withLock корректно снял лок через finally —
// process.exit() внутри withLock() пропускает finally и оставляет lock-файл висеть.
function readRegistry(strict) {
  let raw;
  try { raw = fs.readFileSync(REGISTRY(), 'utf8'); }
  catch (e) { if (e.code === 'ENOENT') return { workers: {} }; throw e; }
  try { return JSON.parse(raw); }
  catch {
    if (strict) {
      const err = new Error('registry: registry.json повреждён — почини вручную, запись отменена');
      err.registryCorrupt = true;
      throw err;
    }
    process.stderr.write('registry: registry.json повреждён, использую пустой реестр\n');
    return { workers: {} };
  }
}
function writeRegistry(reg) {
  const tmp = REGISTRY() + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(reg, null, 2) + '\n');
  fs.renameSync(tmp, REGISTRY());
}

function out(obj) { process.stdout.write(JSON.stringify(obj) + '\n'); }
function brief(e) { return { event_id: e.event_id, seq: e.seq }; }

function cmdSend(a) {
  const from = a.actor || process.env.CLAUDE_AUTO_NAME || 'operator';
  const reg = readRegistry();
  const roleOf = (n) => (reg.workers[n] || {}).role;
  if (roleOf(from) === 'мк' && roleOf(a.to) === 'мк') {
    die('send: прямое сообщение МК→МК запрещено (policy 3.1) — отправь question руководителю');
  }
  // Codex-крит (канон фазы 4, находка 2; добито /bug ф4: паритет с N1): policy_refresh шлёт
  // только исполнитель планёрки (systemd-раннер dept-planerka-exec, НЕ сессия воркера) и
  // Руководитель — напоминание молчунам (policy-v9 п. 3.1/8.5). cmdSend раньше ограничивал
  // только адресата (§5 ниже), отправителя — никак: любой воркер мог разослать policy_refresh,
  // в т.ч. подделав --actor dept-head. Гард — тот же /proc, что у policy-ack: если вызов
  // реально из сессии воркера — (а) отправитель обязан быть Руководителем, (б) РЕЗОЛВНУТАЯ
  // identity from (a.actor || CLAUDE_AUTO_NAME || 'operator' — то, что реально уйдёт в
  // data.from) обязана совпасть с реальным именем. Сравнение именно from, не сырого --actor —
  // иначе `CLAUDE_AUTO_NAME=<чужое-имя> send --type policy_refresh` (без --actor) подделывал
  // отправителя рассылки молча (ровно дыра N1 финального ревью, только в send). Раннер
  // планёрки НЕ воркер-сессия (callerWorkerName() === null) — его data.from=dept-head
  // продолжает работать без правок.
  if (a.type === 'policy_refresh') {
    const realCaller = callerWorkerName();
    if (realCaller) {
      if (roleOf(realCaller) !== 'руководитель') {
        die('send: policy_refresh шлёт исполнитель планёрки или Руководитель (policy 3.1/8.5)');
      }
      if (from !== realCaller) {
        die(`send: отправка policy_refresh за другого запрещена — шли от своего имени (ты «${realCaller}»)`);
      }
    }
  }
  // policy_refresh — рассылка планёрки «перечитай policy-vN + ack» (фаза 4): Руководитель
  // перечитывает правила наравне со всеми, поэтому исключён из фильтра §5. Остальные
  // ограничения адресата-руководителя не тронуты.
  if (roleOf(a.to) === 'руководитель' && !['question', 'proposal', 'decision_request', 'policy_refresh'].includes(a.type)) {
    die('send: руководителю идут только question/proposal/decision_request/policy_refresh (§5 спеки) — handoff шли профильному штабному, incident открывай через incident-open');
  }
  if (a.type === 'kb_change_request' && roleOf(a.to) && roleOf(a.to) !== 'архивариус') {
    die('send: kb_change_request адресуется только Архивариусу (policy 3.4)');
  }
  if (a.type === 'decision_request' && roleOf(a.to) && roleOf(a.to) !== 'руководитель') {
    die('send: decision_request адресуется только Руководителю');
  }
  const data = { type: a.type, from,
    to: a.to, subject: a.subject, body: a.body || '', refs: (a.refs || '').split(',').filter(Boolean) };
  out(brief(appendEvent('message', data, a.actor)));
}
function cmdAck(a) {
  out(brief(appendEvent('message_status', { ref: a._[1], status: 'acked' }, a.actor)));
}
function cmdResolve(a) {
  out(brief(appendEvent('message_status', { ref: a._[1], status: a.status }, a.actor)));
}
function policyCurrentSafe() { // approval обязан открыться даже без каталога правил
  try {
    const files = fs.readdirSync(POLICY_DIR);
    let best = null;
    for (const f of files) {
      const m = /^policy-v(\d+)\.md$/.exec(f);
      if (m && (!best || Number(m[1]) > best.n)) best = { n: Number(m[1]), f };
    }
    return best ? 'v' + best.n : null;
  } catch { return null; }
}
function cmdApprovalOpen(a) {
  const data = { kind_of: a['kind-of'],
    from: a.actor || process.env.CLAUDE_AUTO_NAME || 'operator',
    summary: a.summary, status: 'open' };
  // mission_change несёт ПОЛНЫЙ текст миссии (≤16000 симв.) в request И в detail — generic-кап
  // 8000/20000 провалил бы любую реальную миссию. Капы синхронны (request-json и detail), чтобы
  // dept-request-render, восстанавливающий detail из request в исполнителе (Task 8, anti-forge
  // К4), совпал байт-в-байт БЕЗ обрезки ни на одной стороне.
  const isMission = a['kind-of'] === 'mission_change';
  if (a.detail) data.detail = String(a.detail).slice(0, isMission ? 22000 : 20000);
  if (a['request-json'] !== undefined) {
    let req;
    try { req = JSON.parse(a['request-json']); } catch { die('approval-open: --request-json не валидный JSON'); }
    if (req === null || typeof req !== 'object' || Array.isArray(req)) die('approval-open: --request-json должен быть JSON-объектом');
    const reqCap = isMission ? 22000 : 8000;
    if (JSON.stringify(req).length > reqCap) die(`approval-open: --request-json слишком большой (>${reqCap})`);
    data.request = req;
  }
  const pv = policyCurrentSafe();
  if (pv) data.policy_version_seen = pv;
  out(brief(appendEvent('approval', data, a.actor)));
}
function cmdApprovalResolve(a) {
  const ref = a._[1];
  assertNotWorkerSession('approval-resolve'); // /proc-гард, см. 3.8 — решение записывает бот/оператор/диспетчер
  // Дедуп-чтение ДО withLock давало гонку: два параллельных resolve одним статусом оба
  // проходили проверку «ещё не resolved» раньше, чем любой из них дописывал событие, и
  // оба писали approval_status (дубль). Вся операция — читаем, решаем deduped/write —
  // теперь один withLock; appendEvent() внутри withLock звать нельзя (он сам берёт лок —
  // дедлок), поэтому пишем через validateEvent+writeEventUnlocked напрямую (как в
  // cmdRegistrySet). validateEvent для approval_status делает assertRefExists→readAll —
  // это чтение, под уже взятым локом безопасно.
  let result;
  try {
    result = withLock(() => {
      const events = readAll();
      // Task 1: активный файл мог не найти apr (уехал в архив ротацией) — искать там,
      // чтобы дедуп/гард «уже исполнен» работали и после rotate.
      let apr = events.find((e) => e.event_id === ref && e.kind === 'approval');
      if (!apr) { const arch = findInArchives(ref); if (arch && arch.kind === 'approval') apr = arch; }
      const eff = apr ? effectiveStatus(events, apr, 'approval_status', 'open') : null;
      // Task 11-fix: executing тоже блокирует resolve — заявка уже в работе у раннера,
      // менять решение (denied) под ней небезопасно (раннер продолжит исполнять «отменённую»).
      if (apr && ['executed', 'exec_failed'].includes(eff)) {
        const err = new Error('approval-resolve: аппрув уже исполнен (' + eff + ') — менять решение поздно');
        err.cliError = true; throw err;
      }
      if (apr && eff === 'executing') {
        const err = new Error('approval-resolve: аппрув уже исполняется (executing) — менять решение поздно');
        err.cliError = true; throw err;
      }
      // Фаза 4 (R14, второй ремень против гонки withdraw ↔ ✅): dept-withdraw гасит карточку
      // в SQLite ПЕРВОЙ, а ledger пишет ВТОРЫМ — окно между этими шагами оператор мог успеть
      // нажать ✅ до того, как бот увидел status!='open'. Без этой проверки такой approve
      // проехал бы в ledger уже ПОСЛЕ withdrawn (last-write-wins) и раннер исполнил бы отозванное.
      if (apr && eff === 'withdrawn') {
        const err = new Error('approval-resolve: заявка отозвана автором — решать нечего');
        err.cliError = true; throw err;
      }
      if (apr && eff === a.status) return { event_id: ref, deduped: true };
      const data = { ref, status: a.status };
      validateEvent('approval_status', data);
      return brief(writeEventUnlocked('approval_status', data, a.actor));
    });
  } catch (e) {
    if (e && e.cliError) die(e.message);
    throw e;
  }
  out(result);
}

// Логика допуска к отзыву — чистая и тестируемая. Вынесена из обработчика намеренно:
// подделать /proc в тестах нельзя, а env-шов в callerWorkerName() открыл бы ровно ту
// дыру, которую этот гард закрывает (Bash(dept-ledger:*) у воркеров в allow) — R16.
// caller: имя воркера из /proc либо null (не сессия воркера).
function authorizeWithdraw(caller, apr, eff) {
  if (!caller) return { err: 'approval-withdraw: запускается только из сессии воркера — у оператора для этого кнопка ❌ на карточке' };
  if (!apr) return { err: 'approval-withdraw: аппрув не найден' };
  if (apr.data.from !== caller) {
    return { err: `approval-withdraw: отозвать может только автор заявки («${apr.data.from}»), ты — «${caller}»` };
  }
  if (eff === 'withdrawn') return { ok: true, deduped: true };
  if (eff !== 'open') return { err: `approval-withdraw: заявка уже решена (${eff}) — отзывать поздно` };
  return { ok: true };
}

// Отзыв заявки автором (фаза 4). Кейс: оператор решил вопрос напрямую в сессии, заявка
// утратила смысл. ❌ работал бы, но врёт семантически — воркер получил бы «ОТКЛОНИЛ» и
// скорректировал поведение, хотя решение просто стало неактуально.
//
// Гард ИНВЕРСНЫЙ к assertNotWorkerSession: только из сессии воркера и только автору.
function cmdApprovalWithdraw(a) {
  const ref = a._[1] || die('approval-withdraw: нужен <event_id>');
  const caller = callerWorkerName();
  let result;
  try {
    result = withLock(() => {
      const events = readAll();
      let apr = events.find((e) => e.event_id === ref && e.kind === 'approval');
      if (!apr) { const arch = findInArchives(ref); if (arch && arch.kind === 'approval') apr = arch; }
      const eff = apr ? effectiveStatus(events, apr, 'approval_status', 'open') : null;
      const auth = authorizeWithdraw(caller, apr, eff);
      if (auth.err) { const err = new Error(auth.err); err.cliError = true; throw err; }
      if (auth.deduped) return { event_id: ref, deduped: true };
      const data = { ref, status: 'withdrawn' };
      if (a.reason) data.reason = String(a.reason).slice(0, 400);
      validateEvent('approval_status', data);
      return brief(writeEventUnlocked('approval_status', data, caller));
    });
  } catch (e) {
    if (e && e.cliError) die(e.message);
    throw e;
  }
  out(result);
}
function readChainStatuses(ref) { // статусы цепочки: активный файл + архивы (Codex-аудит В2)
  const rows = readAll().filter((e) => e.kind === 'approval_status' && e.data.ref === ref);
  for (const f of archiveFiles()) {
    for (const l of fs.readFileSync(f, 'utf8').split('\n')) {
      if (!l.trim() || !l.includes(ref)) continue;
      try { const e = JSON.parse(l); if (e.kind === 'approval_status' && e.data.ref === ref) rows.push(e); } catch {}
    }
  }
  rows.sort((x, y) => x.seq - y.seq);
  return rows;
}
// Task 11-fix: разрешённые ИСТОЧНИКИ для каждого целевого статуса approval-exec.
// executing — только из approved (диспетчер помечает ДО запуска раннера).
// executed/exec_failed — из approved (прямой путь, back-compat: операторский ручной
// approval-exec и старые тесты Task 1) ИЛИ из executing (раннер дописывает финал).
// executed/exec_failed сами не встречаются как источник ни для чего — уже финал (die).
const EXEC_TARGET_FROM = {
  executing: ['approved'],
  executed: ['approved', 'executing'],
  exec_failed: ['approved', 'executing'],
};
function cmdApprovalExec(a) {
  const ref = a._[1] || die('usage: dept-ledger approval-exec <event_id> --status <executing|executed|exec_failed> [--note <s>]');
  const status = a.status || die('approval-exec: --status обязателен (executing|executed|exec_failed)');
  if (!EXEC_TARGET_FROM[status]) die('approval-exec: --status ∉ executing|executed|exec_failed');
  assertNotWorkerSession('approval-exec'); // /proc-гард, см. 3.8
  let result;
  try {
    result = withLock(() => {
      let apr = readAll().find((e) => e.event_id === ref && e.kind === 'approval');
      if (!apr) { const arch = findInArchives(ref); if (arch && arch.kind === 'approval') apr = arch; }
      if (!apr) { const err = new Error('approval-exec: аппрув не найден: ' + ref); err.cliError = true; throw err; }
      const sts = readChainStatuses(ref);
      const eff = sts.length ? sts[sts.length - 1].data.status : (apr.data.status || 'open');
      if (eff === status) return { event_id: ref, deduped: true };
      if (!EXEC_TARGET_FROM[status].includes(eff)) {
        const err = new Error(`approval-exec: эффективный статус «${eff}», переход в «${status}» недопустим (нужен один из: ${EXEC_TARGET_FROM[status].join('/')})`);
        err.cliError = true; throw err;
      }
      const data = { ref, status };
      if (a.note) data.note = String(a.note).slice(0, 2000);
      return brief(writeEventUnlocked('approval_status', data, a.actor));
    });
  } catch (e) {
    if (e && e.cliError) die(e.message);
    throw e;
  }
  out(result);
}
function cmdIncidentOpen(a) {
  const r = appendEvent('incident', { about_worker: a.about, severity: a.severity,
    summary: a.summary, status: 'open', source: a.actor || 'operator' }, a.actor);
  // non-strict: инцидент обязан открыться, даже если реестр битый/пустой/без роли 'тп' —
  // но тогда честно предупреждаем, а не молча теряем маршрутизацию к ТП.
  const reg = readRegistry();
  const tp = Object.entries(reg.workers).find(([, w]) => w.role === 'тп');
  if (tp) {
    appendEvent('message', { type: 'incident', from: a.actor || 'operator', to: tp[0],
      subject: `incident ${a.severity}: ${a.about}`, body: a.summary, refs: [r.event_id], status: 'queued' }, a.actor);
  } else {
    process.stderr.write("incident-open: инцидент открыт, но НЕ маршрутизирован ТП (роль 'тп' не найдена в реестре)\n");
  }
  out(brief(r));
}
function cmdRegistrySet(a) {
  const name = a._[1];
  if (!name) die('usage: dept-ledger registry-set <worker> --role <r> …');
  // Дыра 17.07: воркер мог назначить себя руководителем (registry-set <self> --role
  // руководитель) — и pickExecutable диспетчера начал бы принимать его заявки
  // (worker_spawn/planerka/mission_change/sleep) как заявки Руководителя. Реестр ведут
  // оператор и bootstrap-исполнители (они идут из systemd-раннера, не из сессии воркера).
  assertNotWorkerSession('registry-set');
  let updated;
  try {
    // Один withLock на RMW реестра + аудит-событие — иначе под конкуренцией порядок
    // «запись registry.json» vs «appendEvent(registry_change)» может разъехаться.
    updated = withLock(() => {
      const reg = readRegistry(true); // strict — битый реестр не перезаписываем
      const cur = reg.workers[name] || {};
      reg.workers[name] = {
        role: a.role || cur.role, client: a.client ?? cur.client ?? null,
        escalates_to: a['escalates-to'] || cur.escalates_to || 'operator',
        mission_version: a['mission-version'] || cur.mission_version || 'v1',
      };
      const next = reg.workers[name];
      if (!ROLES.has(next.role)) {
        const err = new Error(`registry: роль «${next.role}» ∉ {${[...ROLES].join(', ')}}`);
        err.cliError = true; throw err;
      }
      if (next.role === 'мк' && !next.client) {
        const err = new Error('registry: роль «мк» требует --client');
        err.cliError = true; throw err;
      }
      writeRegistry(reg);
      const data = { worker: name, ...reg.workers[name] };
      validateEvent('registry_change', data);
      writeEventUnlocked('registry_change', data, a.actor);
      return reg.workers[name];
    });
  } catch (e) {
    if (e && (e.registryCorrupt || e.cliError)) die(e.message);
    throw e;
  }
  out(updated);
}
// registry-get/registry-list — диагностические команды, fail-loud: битый registry.json
// не должен молча притворяться пустым реестром (в отличие от incident-open, которому
// нужно открыться в любом случае).
function readRegistryStrict() {
  try { return readRegistry(true); }
  catch (e) { if (e && e.registryCorrupt) die(e.message); throw e; }
}
function cmdRegistryGet(a) {
  const w = readRegistryStrict().workers[a._[1]];
  if (!w) die('registry: не найден ' + a._[1]);
  process.stdout.write(JSON.stringify(w) + '\n');
}
function cmdRegistryList() { process.stdout.write(JSON.stringify(readRegistryStrict()) + '\n'); }

function policyCurrent() {
  let files;
  try { files = fs.readdirSync(POLICY_DIR); }
  catch { die('policy: каталог правил недоступен: ' + POLICY_DIR); }
  let best = null;
  for (const f of files) {
    const m = /^policy-v(\d+)\.md$/.exec(f);
    if (m && (!best || Number(m[1]) > best.n)) best = { n: Number(m[1]), f };
  }
  if (!best) die('policy: в ' + POLICY_DIR + ' нет файлов policy-vN.md');
  const file = path.join(POLICY_DIR, best.f);
  return { version: 'v' + best.n, file, mtimeMs: fs.statSync(file).mtimeMs };
}
function cmdPolicyCurrent() { const c = policyCurrent(); out({ version: c.version, file: c.file }); }
function cmdPolicyAck(a) {
  if (!a.version) die('policy-ack: --version обязателен (какую версию правил ты прочитал)');
  const cur = policyCurrent();
  if (a.version !== cur.version) {
    die(`policy-ack: действующая версия ${cur.version}, ты указал ${a.version} — перечитай ${cur.file} и повтори: dept-ledger policy-ack --version ${cur.version}`);
  }
  // Codex-крит (канон фазы 4, находка 1, добито финальным ревью N1): policy_ack в
  // PRIVILEGED_KINDS закрывает только generic append (см. cmdAppend), а типизированная
  // policy-ack проверяла ТОЛЬКО --actor против реального вызывающего — но identity, которая
  // реально пишется в ack, резолвится как `a.actor || CLAUDE_AUTO_NAME || 'operator'`. Воркер
  // мог выполнить `CLAUDE_AUTO_NAME=<чужое-имя> policy-ack --version vN` (без --actor) — гард
  // молчал, ack писался за другого. Фикс: резолвим worker (ту identity, что реально уйдёт в
  // событие) ДО гарда и сравниваем именно её с реальным вызывающим. Раннер/оператор/тесты
  // (callerWorkerName() === null) и self-ack (worker === realCaller) остаются свободны.
  const worker = a.actor || process.env.CLAUDE_AUTO_NAME || 'operator';
  const realCaller = callerWorkerName();
  if (realCaller && worker !== realCaller) {
    die(`policy-ack: ack за другого воркера запрещён — ack пишет тот, кто прочитал правила (ты «${realCaller}»)`);
  }
  out(brief(appendEvent('policy_ack', { worker, policy_version: a.version }, worker)));
}
function cmdPolicyCheck(a) {
  const worker = a.worker || die('policy-check: --worker обязателен');
  const cur = policyCurrent();
  const fail = (why) => die(`policy-check: ${why}. Перечитай ${cur.file} и выполни: dept-ledger policy-ack --version ${cur.version} --actor ${worker}`);
  const acks = readAll().filter((e) => e.kind === 'policy_ack' && e.data.worker === worker);
  const last = acks[acks.length - 1];
  if (!last) fail(`у «${worker}» нет ни одного policy-ack`);
  if (last.data.policy_version !== cur.version) fail(`последний ack на ${last.data.policy_version}, действует ${cur.version}`);
  const ts = Date.parse(last.ts);
  if (ts < cur.mtimeMs) fail('правила изменились после последнего прочтения');
  if (Date.now() - ts > ACK_TTL_MS) fail('последнее прочтение правил слишком старое');
  out({ ok: true, policy_version: cur.version, acked_at: last.ts });
}
function cmdIncidentResolve(a) {
  const status = a.status || die('incident-resolve: --status обязателен (' + INCIDENT_RESOLVE_STATUSES.join('|') + ')');
  if (!INCIDENT_RESOLVE_STATUSES.includes(status)) die('incident-resolve: --status ∉ ' + INCIDENT_RESOLVE_STATUSES.join('|'));
  if (!a._[1]) die('usage: dept-ledger incident-resolve <event_id> --status <s> [--ref-main <event_id основного при duplicate>]');
  // duplicate без --ref-main — инцидент помечен дублем, но никто не знает основного (тупик
  // для читающего ledger); --ref-main на несуществующий/чужой kind event_id — то же самое,
  // с чего assertRefExists уже защищает *_status выше. С другими статусами --ref-main —
  // мусорное поле (не duplicate — не на что ссылаться), запрещаем явно, а не молча игнорируем.
  if (status === 'duplicate') {
    if (!a['ref-main']) die('incident-resolve: --status duplicate требует --ref-main <event_id основного инцидента>');
    assertRefExists(a['ref-main'], 'incident');
  } else if (a['ref-main']) {
    die('incident-resolve: --ref-main только со --status duplicate');
  }
  const data = { ref: a._[1], status };
  if (a['ref-main']) data.ref_main = a['ref-main'];
  out(brief(appendEvent('incident_status', data, a.actor)));
}
function cmdSnapshot() {
  const g = (...gargs) => execFileSync('git', ['-C', HOME, ...gargs], { encoding: 'utf8' });
  // Под ledger-локом: (а) git add не читает журнал посреди append (torn line в
  // аудит-коммите — detail до 4000 симв. пишется в несколько страниц), (б) два
  // snapshot'а (таймер + ручной) сериализуются, а не бьются об index.lock.
  const res = withLock(() => {
    try { g('rev-parse', '--git-dir'); } catch { g('init'); }
    // Пока snapshot держит лок, events.jsonl.lock существует — без ignore каждый
    // прогон коммитил бы лок-файл и никогда не был бы «чистым». Не перетираем
    // существующий .gitignore (в живом каталоге он свой, шире).
    const gi = path.join(HOME, '.gitignore');
    if (!fs.existsSync(gi)) fs.writeFileSync(gi, '*.lock\n*.tmp\n');
    if (!g('status', '--porcelain').trim()) return { committed: false };
    g('add', '-A');
    g('-c', 'user.email=dept@local', '-c', 'user.name=dept-ledger',
      'commit', '-m', 'snapshot ' + new Date().toISOString());
    return { committed: true };
  });
  out(res);
}

// p3#35: маркеры зависших заявок (exec-stuck-<event_id>, dept-dispatcher:367) и логи
// раннеров (runner-<event_id>.log, dept-exec-runner:103) не чистил никто — копились
// вечно и попадали в snapshot-коммиты (в .gitignore DEPT_HOME их нет). Порог — тот же
// cutoff ротации: гарантирует, что раннер in-flight заявки не лишится своего лога.
// СТРОГИЕ имена: никаких glob'ов по каталогу, где живут registry.json и стейты юнитов.
const RUNTIME_JUNK = [/^exec-stuck-evt_[0-9]+_[a-z0-9]{4}$/, /^runner-evt_[0-9]+_[a-z0-9]{4}\.log$/];
function cleanupRuntimeFiles(cutoffMs) {
  let removed = 0;
  const dir = HOME;
  let entries;
  try { entries = fs.readdirSync(dir); } catch { return { removed }; }
  for (const f of entries) {
    if (!RUNTIME_JUNK.some((re) => re.test(f))) continue;
    const p = path.join(dir, f);
    try {
      if (fs.statSync(p).mtimeMs >= cutoffMs) continue;
      fs.unlinkSync(p); removed++;
    } catch { /* гонка с раннером/удалением — не наше дело, следующий прогон подметёт */ }
  }
  return { removed };
}

function cmdRotate(a) {
  const days = a.days !== undefined ? Number(a.days) : ROTATE_DAYS_DEFAULT_ENV();
  if (!Number.isFinite(days) || days <= 0) die('rotate: --days должен быть положительным числом');
  const cutoff = Date.now() - days * 86400_000;
  const res = withLock(() => {
    repairTailUnlocked();
    const events = readAll();
    const byRef = new Map(); // base event_id -> его *_status события
    for (const e of events) if (e.kind.endsWith('_status') && e.data && e.data.ref) {
      if (!byRef.has(e.data.ref)) byRef.set(e.data.ref, []);
      byRef.get(e.data.ref).push(e);
    }
    // Codex-аудит К6: для исполняемых диспетчером kind_of «approved» — НЕ финал
    // (ждёт executed/exec_failed); ротировать их на approved нельзя — dispatcher
    // читает только активный файл и потерял бы заявку.
    // Синхронно с EXEC_KINDS dispatcher (его пинит dept-dispatcher.test.mjs) и
    // WHITELIST dept-exec-runner; эту копию пинит dept-ledger.test.mjs (M-1).
    const EXEC_KINDS_ROT = new Set(['worker_spawn', 'mission_change', 'planerka', 'sleep']);
    const CLOSED = {
      message: (s) => ['handled', 'dead'].includes(s),
      // Task 11-fix: 'executing' НЕ перечислен здесь ни в одной ветке → всегда считается
      // "не закрыто" (как approved для exec-kind) и НЕ ротируется — заявка ждёт раннера,
      // dept-dispatcher читает только активный файл, потерять её ротацией нельзя.
      approval: (s, e) => ['denied', 'executed', 'exec_failed', 'withdrawn'].includes(s)
        || (s === 'approved' && !EXEC_KINDS_ROT.has(e.data.kind_of)),
      incident: (s) => ['resolved', 'wontfix', 'duplicate'].includes(s),
    };
    const lastAckByWorker = new Map();
    for (const e of events) if (e.kind === 'policy_ack') lastAckByWorker.set(e.data.worker, e.event_id);
    const moveIds = new Set();
    for (const e of events) {
      if (Date.parse(e.ts) >= cutoff) continue;
      if (e.kind === 'message' || e.kind === 'approval' || e.kind === 'incident') {
        const st = effectiveStatus(events, e, e.kind + '_status', e.data.status || 'open');
        const chain = [e, ...(byRef.get(e.event_id) || [])];
        // цепочка закрыта И вся старше cutoff (свежий статус держит цепочку в активном файле)
        if (CLOSED[e.kind](st, e) && chain.every((c) => Date.parse(c.ts) < cutoff)) chain.forEach((c) => moveIds.add(c.event_id));
      } else if (e.kind === 'policy_ack') {
        if (lastAckByWorker.get(e.data.worker) !== e.event_id) moveIds.add(e.event_id);
      } else if (e.kind === 'agent_run' || e.kind === 'registry_change') {
        moveIds.add(e.event_id);
      } // *_status без базы в moveIds остаются с базой (обработаны цепочкой выше)
    }
    if (!moveIds.size) return { rotated: 0, kept: events.length };
    fs.mkdirSync(ARCHIVE_DIR(), { recursive: true });
    const keep = [], byMonth = new Map();
    for (const e of events) {
      if (!moveIds.has(e.event_id)) { keep.push(e); continue; }
      const m = (e.ts || '').slice(0, 7) || 'unknown';
      if (!byMonth.has(m)) byMonth.set(m, []);
      byMonth.get(m).push(e);
    }
    // Codex-аудит В1 (crash-безопасный порядок): (1) архив с дедупом по event_id —
    // повторный прогон после crash не плодит дубли; (2) rotate-state (last_seq только
    // вперёд) ДО переписывания активного файла — crash между шагами не даёт seq-регресса
    // даже при полной ротации; (3) атомарный rename активного файла.
    for (const [m, rows] of byMonth) {
      const af = path.join(ARCHIVE_DIR(), `events-${m}.jsonl`);
      const already = new Set();
      try { for (const l of fs.readFileSync(af, 'utf8').split('\n')) { if (l.trim()) try { already.add(JSON.parse(l).event_id); } catch {} } } catch {}
      const fresh = rows.filter((e) => !already.has(e.event_id));
      if (fresh.length) fs.appendFileSync(af, fresh.map((e) => JSON.stringify(e)).join('\n') + '\n');
    }
    const lastSeq = Math.max(events.length ? events[events.length - 1].seq : 0, rotateState().last_seq);
    fs.writeFileSync(ROT_STATE(), JSON.stringify({ last_seq: lastSeq }) + '\n');
    const tmp = LEDGER + '.rotate.tmp';
    fs.writeFileSync(tmp, keep.map((e) => JSON.stringify(e)).join('\n') + (keep.length ? '\n' : ''));
    fs.renameSync(tmp, LEDGER);
    return { rotated: moveIds.size, kept: keep.length };
  });
  // R18: маркеры/логи не относятся к ledger-локу — чистим ВНЕ withLock.
  const junk = cleanupRuntimeFiles(cutoff);
  out({ ...res, junk_removed: junk.removed });
}
function ROTATE_DAYS_DEFAULT_ENV() {
  const n = Number(process.env.DEPT_ROTATE_DAYS);
  return Number.isFinite(n) && n > 0 ? n : ROTATE_DAYS_DEFAULT;
}
// ВАЖНО: *_status-события, чья база НЕ ротируется, остаются в активном файле безусловно
// (в moveIds попадают только элементы закрытых цепочек и самостоятельные kinds).
// approval_status, ссылающийся на ранее заархивированную базу (exec после ротации approved —
// не бывает при days=30, но всё же), при следующей ротации уедет как «*_status без активной
// базы старше cutoff» — НЕ реализуем в v1, YAGNI: такие строки безвредно живут в активном файле.

const HANDLERS = {
  append: cmdAppend, list: cmdList, send: cmdSend, ack: cmdAck, resolve: cmdResolve,
  'approval-open': cmdApprovalOpen, 'approval-resolve': cmdApprovalResolve, 'approval-exec': cmdApprovalExec,
  'approval-withdraw': cmdApprovalWithdraw,
  'incident-open': cmdIncidentOpen,
  'registry-set': cmdRegistrySet, 'registry-get': cmdRegistryGet, 'registry-list': cmdRegistryList,
  'policy-current': cmdPolicyCurrent, 'policy-ack': cmdPolicyAck, 'policy-check': cmdPolicyCheck,
  'incident-resolve': cmdIncidentResolve, snapshot: cmdSnapshot, rotate: cmdRotate,
};
// Экспорт чистой функции допуска для unit-тестов (createRequire в dept-ledger.test.mjs) —
// без этого раннего return require() выполнил бы CLI-хвост файла (argv пуст → usage → exit 1),
// убивая процесс тестового раннера (образец dept-dispatcher:112-113).
module.exports = { authorizeWithdraw, cleanupRuntimeFiles };
if (require.main !== module) return;
const args = parseArgs(process.argv.slice(2));
const cmd = args._[0];
try {
  (HANDLERS[cmd] || (() => die('usage: dept-ledger <append|list> …')))(args);
} catch (e) {
  // Task 1 (Codex-аудит В3): validateEvent/assertRefExists теперь бросают cliError вместо
  // die() изнутри withLock — единая точка конвертации в чистый die() после того, как withLock
  // уже снял лок через finally (см. cliDie выше).
  if (e && e.cliError) die(e.message);
  throw e;
}
