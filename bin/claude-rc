#!/usr/bin/env bash
# claude-rc: start a Claude Code remote-control session in a tmux window
# for a project listed in ~/.claude-control/projects.yaml.
set -euo pipefail

PROJECTS_FILE="${CLAUDE_RC_PROJECTS_FILE:-$HOME/.claude-control/projects.yaml}"
CAPACITY="${CLAUDE_RC_CAPACITY:-5}"

usage() {
  cat <<EOF
Usage:
  claude-rc list                 List configured projects.
  claude-rc <project-name>       Start a remote-control session in tmux.

Projects file: $PROJECTS_FILE
Environment:
  CLAUDE_RC_PROJECTS_FILE  Override path to projects.yaml.
  CLAUDE_RC_CAPACITY       Max parallel sessions per project (default: 5).
  CLAUDE_BIN               Override the claude binary name (default: claude).
EOF
}

if ! command -v yq >/dev/null 2>&1; then
  echo "claude-rc requires yq (https://github.com/mikefarah/yq)." >&2
  echo "  macOS: brew install yq" >&2
  echo "  Linux: download the binary from https://github.com/mikefarah/yq/releases" >&2
  exit 1
fi

if [[ ! -f "$PROJECTS_FILE" ]]; then
  echo "Projects file not found: $PROJECTS_FILE" >&2
  exit 1
fi

cmd="${1:-}"

if [[ -z "$cmd" || "$cmd" == "list" ]]; then
  yq -r 'keys | .[]' "$PROJECTS_FILE"
  exit 0
fi

if [[ "$cmd" == "-h" || "$cmd" == "--help" ]]; then
  usage
  exit 0
fi

project="$cmd"

# Strict charset for project: used as tmux session name, Claude --name, and YAML key lookup.
if [[ ! "$project" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "Invalid project name: $project (allowed: a-z A-Z 0-9 _ -)" >&2
  exit 1
fi

path="$(name="$project" yq -r '.[strenv(name)] // ""' "$PROJECTS_FILE")"
if [[ -z "$path" || "$path" == "null" ]]; then
  echo "Unknown project: $project" >&2
  echo >&2
  usage >&2
  exit 1
fi

# Expand a leading ~ to $HOME so projects.yaml entries can use shorthand.
# shellcheck disable=SC2088  # the ~ here is a literal char in a case-pattern, not a path to expand
case "$path" in
  "~"|"~/"*) path="$HOME${path#\~}" ;;
esac

# Reject .. traversal. Legitimate project paths don't need it; allowing it lets
# a projects.yaml entry like ~/../../etc land the session outside its intended root.
case "$path" in
  ".."|"../"*|*"/.."|*"/../"*)
    echo "Path traversal not allowed: $path" >&2
    exit 1 ;;
esac

if [[ ! -d "$path" ]]; then
  echo "Project directory not found: $path" >&2
  exit 1
fi

tmux_session="claude-${project}"

if tmux has-session -t "$tmux_session" 2>/dev/null; then
  echo "Session already running: $tmux_session"
  echo "Attach locally: tmux attach -t $tmux_session"
  existing_pane="$(tmux capture-pane -t "$tmux_session" -pJ 2>/dev/null || true)"
  if [[ "$existing_pane" =~ (https://claude\.ai/code[^[:space:]]*) ]]; then
    echo "Open:           ${BASH_REMATCH[1]}"
  fi
  exit 0
fi

if git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  spawn_mode="worktree"
else
  spawn_mode="same-dir"
fi

claude_bin="${CLAUDE_BIN:-claude}"
# Resolve to an absolute path *before* handing the command to tmux. If the tmux
# server was already running from an unrelated session, its PATH may differ
# from ours (in particular it may not have $HOME/.local/bin first, bypassing a
# user-installed claude wrapper). Resolving here pins the right binary.
if [[ "$claude_bin" != /* ]]; then
  resolved="$(command -v "$claude_bin" 2>/dev/null || true)"
  if [[ -z "$resolved" ]]; then
    echo "claude binary not found in PATH: $claude_bin" >&2
    exit 1
  fi
  claude_bin="$resolved"
fi

# tmux new-session concatenates trailing args into a single /bin/sh -c string,
# so each token must be shell-quoted. Build the command with printf %q to keep
# values from CLAUDE_BIN/CLAUDE_RC_CAPACITY/etc. from being re-parsed. The cwd
# is handled by `-c "$path"`, which tmux uses directly (no shell involved).
cmd_str="$(printf '%q ' "$claude_bin" remote-control \
  --name "$project" --spawn "$spawn_mode" --capacity "$CAPACITY")"
tmux new-session -d -s "$tmux_session" -c "$path" "$cmd_str"

# Capture the environment/session URL claude prints once it registers.
# Without this, an env spawned via spawn=worktree doesn't appear in the
# user's Recents until they visit the URL once — so we surface the URL
# back to whatever invoked claude-rc (typically the control session, which
# can then quote it in chat).
#
# Use `-pJ` to ask tmux to join wrapped lines (the URL is long enough to
# wrap in a default-width pane). Poll briefly because claude needs a few
# seconds to register the env with the remote.
url=""
for _ in $(seq 1 20); do
  pane="$(tmux capture-pane -t "$tmux_session" -pJ 2>/dev/null || true)"
  if [[ "$pane" =~ (https://claude\.ai/code[^[:space:]]*) ]]; then
    url="${BASH_REMATCH[1]}"
    break
  fi
  sleep 1
done

cat <<EOF
Started Claude Code remote-control session.
  Project: $project
  Path:    $path
  tmux:    $tmux_session
  spawn:   $spawn_mode
EOF
if [[ -n "$url" ]]; then
  echo "  Open:    $url"
  echo
  echo "First-time setup: open the link above once to register the session"
  echo "in your Claude account; after that '$project' appears in Recents."
else
  echo
  echo "Open the Claude app -> Code and select session: $project"
  echo "(URL not yet captured; check 'tmux attach -t $tmux_session' for QR/link.)"
fi
