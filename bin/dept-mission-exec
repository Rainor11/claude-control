#!/bin/bash
# dept-mission-exec — исполнитель заявки mission_change: пересобирает CLAUDE.md воркера
# от нового текста миссии и добивает rebase (миссия вступает в силу немедленно).
# Запускается dept-dispatcher'ом (--approval <event_id>) или оператором (прямые флаги
# --worker/--mission-file/--reason).
#
# Идемпотентен: перезапись CLAUDE.md от того же mission_text — тот же результат;
# повторный rebase безопасен (лишняя пересборка сессии, не потеря/дублирование эффекта).
# Повторный вызов с ТЕМ ЖЕ --approval после hard-kill между "миссия применена" и записью
# approval-exec диспетчером — просто повторяет ту же перезапись + rebase.
#
# Anti-forge (Codex-аудит К4): в режиме --approval detail заявки РЕНДЕРИТСЯ ЗАНОВО из
# data.request через dept-request-render и сверяется байт-в-байт с data.detail записи
# ledger — расхождение (заявка подделана/повреждена) → exit 1 до любых побочных эффектов.
set -u
CONTROL_DIR="${CLAUDE_CONTROL_DIR:-$HOME/.claude-control}"   # для partial_ok-гарда (Codex M-3)
BINDIR="$(cd "$(dirname "$0")" && pwd)"
DL="$BINDIR/dept-ledger"; RR="$BINDIR/dept-request-render"
CA="${CLAUDE_AUTO_BIN:-$BINDIR/claude-auto}"
DEPT="${DEPT_HOME:-$HOME/.claude-control/department}"
die() { echo "dept-mission-exec: $*" >&2; exit 1; }

approval="" worker="" mission_file="" reason=""
while [ $# -gt 0 ]; do case "$1" in
  --approval) approval="${2:-}"; shift 2 ;;
  --worker) worker="${2:-}"; shift 2 ;;
  --mission-file) mission_file="${2:-}"; shift 2 ;;
  --reason) reason="${2:-}"; shift 2 ;;
  *) die "unknown arg $1" ;;
esac; done

if [ -n "$approval" ]; then
  row="$("$DL" list --kind approval --event-id "$approval")" || die "аппрув не найден"
  [ -n "$row" ] || die "аппрув не найден: $approval"
  kind_of_row="$(jq -r '.data.kind_of // empty' <<<"$row")"
  [ "$kind_of_row" = "mission_change" ] || die "аппрув $approval имеет kind_of=$kind_of_row, ожидался mission_change"
  request_json="$(jq -c '.data.request // {}' <<<"$row")"
  ledger_detail="$(jq -r '.data.detail // empty' <<<"$row")"
  rendered_detail="$("$RR" mission_change "$request_json")" || die "detail ≠ request — заявка подделана или повреждена, исполнять нельзя (рендер не удался)"
  [ "$rendered_detail" = "$ledger_detail" ] || die "detail ≠ request — заявка подделана или повреждена, исполнять нельзя"
  worker="$(jq -r '.worker // empty' <<<"$request_json")"
  reason="$(jq -r '.reason // empty' <<<"$request_json")"
  mission_text="$(jq -r '.mission_text // empty' <<<"$request_json")"
  [ -n "$worker" ] && [ -n "$mission_text" ] || die "request неполный (нужны worker/mission_text)"
  mkdir -p "$DEPT/render"
  printf '%s' "$mission_text" > "$DEPT/render/$worker.mission.new.md"
  mission_file="$DEPT/render/$worker.mission.new.md"
fi
[ -n "$worker" ] || die "usage: dept-mission-exec --approval <event_id> | --worker <w> --mission-file <f> [--reason <s>]"
[ -n "$mission_file" ] && [ -f "$mission_file" ] || die "--mission-file обязателен и должен существовать"
reason="${reason:-смена миссии}"

out="$("$CA" mission-update "$worker" --mission-file "$mission_file" --reason "$reason" 2>&1)"; rc=$?
echo "$out"
if [ "$rc" -eq 0 ]; then
  echo "mission-exec complete: $worker"
  exit 0
fi
# rc=4 (I-1, ревью фазы 3): миссия ЗАПИСАНА (CLAUDE.md пересобран, копия в missions/),
# но rebase упал hard (STALE-память / воркер не поднялся). Это НЕ провал заявки —
# миссия вступит при следующем старте/компакции; писать exec_failed было бы ложью
# (эффект уже на диске и молча применится). Успех с явной note — raннер положит
# хвост stdout в approval-exec executed --note.
# Codex M-3 (/bug финала ф3): partial-успех объявляем только если эффект реально на диске —
# воркер мог быть удалён (claude-auto remove) между записью миссии и этим моментом;
# тогда «миссия записана, вступит при старте» — ложь, честный исход = exec_failed.
partial_ok() {
  [ -f "$CONTROL_DIR/workers/$worker/spec.json" ] && [ -f "$CONTROL_DIR/workers/$worker/CLAUDE.md" ]
}
if [ "$rc" -eq 4 ]; then
  partial_ok || die "mission-update rc=4, но воркер '$worker' исчез с диска (удалён во время операции?) — partial невозможен"
  echo "mission-exec complete: $worker (partial: миссия записана, rebase не прошёл — вступит при следующем старте; rebase добить: claude-auto rebase $worker / rebase-check)"
  exit 0
fi
if [ "$rc" -ne 3 ]; then
  die "mission-update завершился ошибкой (rc=$rc)"
fi

# rc=3: миссия УЖЕ записана (CLAUDE.md пересобран), rebase отложен (воркер busy) — ретраим
# отдельными вызовами claude-auto rebase, до 10 попыток с паузой 30с (§ Task 8 акцептанс).
# Пауза параметризована для тестов (зеркало PLANERKA_RETRY_SLEEP в dept-planerka-exec);
# мусор в env → дефолт, не сюрприз (зеркало TIMEOUT_MS-гарда в dept-exec-runner).
RETRY_SLEEP="${MISSION_RETRY_SLEEP:-30}"
case "$RETRY_SLEEP" in ''|*[!0-9]*) RETRY_SLEEP=30 ;; esac
ok=false
for i in $(seq 1 10); do
  [ "$RETRY_SLEEP" -gt 0 ] && sleep "$RETRY_SLEEP"
  rout="$("$CA" rebase "$worker" --reason "миссия: $reason" 2>&1)"; rrc=$?
  echo "$rout"
  if [ "$rrc" -eq 0 ]; then ok=true; break; fi
  if [ "$rrc" -ne 3 ]; then
    # Зеркало rc=4 (I-1): миссия УЖЕ применена (CLAUDE.md пересобран до ретраев) —
    # hard-провал ОТЛОЖЕННОГО rebase тоже не делает заявку exec_failed (аудит-след
    # противоречил бы реальности: эффект на диске и вступит при следующем старте).
    # Успех с явной partial-note, как и в ветке rc=4 выше.
    partial_ok || die "отложенный rebase упал (rc=$rrc) И воркер '$worker' исчез с диска — partial невозможен"
    echo "mission-exec complete: $worker (partial: миссия записана, отложенный rebase упал hard (rc=$rrc) — вступит при следующем старте; rebase добить: claude-auto rebase $worker / rebase-check)"
    exit 0
  fi
done
if [ "$ok" = true ]; then
  echo "mission-exec complete: $worker (rebase применён после отложенной попытки)"
  exit 0
fi
# НЕ провал: миссия применена и переживёт следующую компакцию/rebase-check/оператор.
echo "миссия применена, rebase отложен — добьёт rebase-check/оператор"
exit 0
