#!/usr/bin/env node
// dept-dispatcher — контурный диспетчер цифрового отдела (Task 7 фазы 3).
// systemd-таймер каждые 2 мин: `dept-dispatcher tick [--dry-run]`. Три обязанности:
//   1. Пробы СПЯЩИХ контуров (autonomous.json state=="sleeping") — на новое событие
//      будит воркера (`claude-auto start`), НЕ пишет .seen/.dead (доставит штатный
//      event-bridge-watch проснувшегося воркера — адаптеры детерминированно
//      перепечатают неподтверждённое).
//   2. Исполнение утверждённых заявок (dept-ledger approval --status approved),
//      отфильтрованных pickExecutable (kind_of ∈ EXEC_KINDS И from — руководитель/
//      operator). Codex-аудит К3: approved-строка сама по себе НЕ мандат — /proc-гард
//      в dept-ledger (approval-exec) первый забор, этот ролевой фильтр — второй,
//      сверка detail↔request в исполнителях Task 8 — третий. Task 11-fix: заявка
//      ПОМЕЧАЕТСЯ executing (дедуп на уровне ledger) и dept-exec-runner запускается в
//      СОБСТВЕННОМ transient-юните systemd-run — тик НЕ ждёт исполнения (P3-CRITICAL-2:
//      detached-ребёнок умирал при cgroup-зачистке oneshot-тика, см. runnerArgv).
//      Recovery: заявки, застрявшие в executing дольше DEPT_EXEC_MAX_MIN (раннер
//      умер) — алерт оператору, БЕЗ авто-рестарта (дедуп маркер-файлом на event_id).
//   3. Детект неактивности МК (решение оператора №6): без DEPT_SLEEP_AUTO=1 —
//      decision_request Руководителю (дедуп на эпизод); с флагом — авто-`claude-auto
//      sleep`. Чистая decideSleep() решает 'none'|'ask_head'|'auto_sleep'.
// Паттерны (lock/timeout/--dry-run) — как в bin/claude-auto-liveness и
// bin/dept-rebase-check: best-effort lock-файл, execFileSync с честным timeout на
// каждый подпроцесс, --dry-run строго read-only (ни одной записи на диск/в ledger/TG).
'use strict';
const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');
const crypto = require('crypto');
const { memoryFreshnessFromTx } = require('./dept-memory-freshness');
// T4: guard процесс-контроля (lib/process-control.js, задача T2). '../lib' работает и в
// repo-layout, и в install-layout (lib/ ставится рядом с bin/), в т.ч. через symlink —
// node резолвит __dirname по realpath модуля.
const processControl = require('../lib/process-control.js');
// T5: корень рантайма — через единый резолвер (lib/runtime-root.js, задача T1). Профиль
// auto_then_hardcoded воспроизводит прежнюю строку без маркера; под CLAUDE_CONTROL_TEST_ROOT —
// fail-closed на песочницу. Тот же кэшированный модуль, что уже тянет process-control.js.
const { resolveRuntimeRoot } = require('../lib/runtime-root.js');
// Рендер операторских карточек. Булев контракт notify() СОХРАНЁН — на нём висит дедуп
// эпизодов (маркер exec-stuck-*, remindState) — он пишется только по факту доставки.
const card = require('../lib/notify-card.js');

const EXEC_KINDS = new Set(['worker_spawn', 'mission_change', 'planerka', 'sleep', 'liveness_restart']);
// Codex-аудит К3: исполнять только заявки, поданные Руководителем (роль from по
// registry) — approved-строка сама по себе НЕ мандат (ledger-CLI доступен воркерам;
// /proc-гард в dept-ledger — первый забор, этот фильтр — второй).
// liveness_restart (T2 сторож-кнопки, plan п.5) — отдельная, СТРОЖЕ ветка: подать
// её мог только сторож (actor buквально 'watchdog', см. bin/dept-liveness-request
// header), НЕ руководитель и НЕ operator — у ручного рестарта есть свой прямой путь
// (systemctl), этот гейт существует только для сторожа. Не расширяет общую ветку —
// подмешивать liveness_restart в руководитель/operator-правило значило бы разрешить
// руководителю его тоже подавать, чего plan не просит («минимально, не ослабив
// существующие»).
function pickExecutable(rows, roleOf) {
  return rows.filter((r) => {
    if (!r.data || !EXEC_KINDS.has(r.data.kind_of)) return false;
    if (r.data.kind_of === 'liveness_restart') return r.data.from === 'watchdog';
    return roleOf(r.data.from) === 'руководитель' || r.data.from === 'operator';
  });
}
// Решение оператора №6: авто-сон по неактивности (human-in-the-loop через Руководителя).
function decideSleep(w, cfg) {
  if (w.idleDays < cfg.idleDays) return 'none';
  if (w.hasOpenApproval || w.hasQueued || w.stale) return 'none';
  if (w.auto) return 'auto_sleep';
  return w.alreadyAsked ? 'none' : 'ask_head';
}

// Зеркало дедупа event-bridge-watch, ВКЛЮЧАЯ legacy-миграцию (Codex-аудит В4):
// marked-строка подавляется и по 'g:<id>', и по legacy sha256 ВИДИМОЙ части
// (доставленное до появления stable-id не должно ложно будить контур).
function keysOf(rawline) {
  const m = /^\x1eebid=([^\x1e]+)\x1e/.exec(rawline);
  const visible = m ? rawline.slice(m[0].length) : rawline;
  const legacy = crypto.createHash('sha256').update(visible).digest('hex').slice(0, 32);
  return m ? ['g:' + m[1], legacy] : [legacy];
}
function newProbeLines(lines, seenSet, deadSet) {
  return lines.filter((l) => l.trim() && !keysOf(l).some((k) => seenSet.has(k) || deadSet.has(k)));
}
// Видимая часть строки (без маркера) — для excerpt в TG-уведомлении о пробуждении.
function visiblePart(rawline) {
  const m = /^\x1eebid=([^\x1e]+)\x1e/.exec(rawline);
  return m ? rawline.slice(m[0].length) : rawline;
}
// Task 11-fix: чистая функция recovery-детекта. rows — уже СКЛЕЕННЫЙ список заявок в
// эффективном статусе executing вместе с моментом входа в этот статус (executing_since —
// ts approval_status-события executing, НЕ ts самой approval-заявки): caller (executingApprovals()
// ниже) джойнит list --kind approval --status executing с list --kind approval_status
// --filter status=executing. Строго БОЛЬШЕ порога (не >=) — "ровно на пороге" ещё не зависла,
// чтобы не спамить алертом в момент, когда раннер, возможно, вот-вот допишет финал.
function stuckExecuting(rows, nowMs, maxMin) {
  const thresholdMs = maxMin * 60_000;
  return rows.filter((r) => r.executing_since && (nowMs - Date.parse(r.executing_since)) > thresholdMs);
}
// Task 7: напоминание о заявках, висящих без решения (фаза 4). Кейс 16.07: оператор решил
// вопрос в чате, аппрув повис open 18ч и не всплыл нигде — карточка ушла вверх по ленте TG.
// rows — сырые события ledger (list --kind approval --status open); битый/отсутствующий ts
// не роняет (Date.parse → NaN, Number.isFinite отсекает) и не считается зависшим (fail-safe:
// лучше пропустить напоминание, чем спамить на мусорных данных).
function staleOpenApprovals(rows, nowMs, maxMin) {
  const thresholdMs = maxMin * 60_000;
  return rows.filter((r) => {
    const t = Date.parse(r.ts);
    return Number.isFinite(t) && (nowMs - t) > thresholdMs;
  });
}
// M5 (Codex-аудит): напоминание о зависших open-заявках читало s.data.summary/s.data.from
// БЕЗ страховки — битая/безполевая строка approval (мусор в ledger) роняла бы TypeError'ом
// весь тик (этот блок стоит ДО исполнения approved-заявок ниже). Защитное чтение — конвенция
// файла, см. targetOfRequest (`r.data && …`). Чистая, тестируется отдельно без прогона тика.
function openReminderLabel(s) {
  const d = (s && s.data) || {};
  return { event_id: s && s.event_id, summary: d.summary, from: d.from };
}
// Фидбэк оператора 16.07: алерт «заявка evt_…» нечитаем — не видно, ЧТО за заявка и от кого;
// алерт должен читаться без похода в ledger. Чистая функция: человеческая метка заявки из
// {event_id, summary, from} → «<summary> — заявка <from> (<id>)»; summary схлопывается в одну
// строку и режется до ~120 codepoints (не UTF-16 units — кириллица/эмодзи не рвутся, зеркало
// utf8_head в dept-exec-runner); при пустом summary — честный fallback на голый id (как раньше).
function humanApproval(row) {
  const id = (row && row.event_id) || '';
  let summary = row && row.summary ? String(row.summary).replace(/\s+/g, ' ').trim() : '';
  const cp = [...summary];
  if (cp.length > 120) summary = cp.slice(0, 120).join('') + '…';
  if (!summary) return `заявка ${id}`;
  return `${summary} — заявка ${(row && row.from) || '?'} (${id})`;
}
// Те же данные, что humanApproval кладёт в одну строку, но разложенные по полям карточки:
// «смок stuck — заявка dept-head (evt_…)» одной строкой глазом не разбиралось. humanApproval
// сохранена — она по-прежнему нужна для dry-run-вывода и логов, где карточек нет.
function approvalFields(row) {
  const id = (row && row.event_id) || '';
  let summary = row && row.summary ? String(row.summary).replace(/\s+/g, ' ').trim() : '';
  const cp = [...summary];
  if (cp.length > 120) summary = cp.slice(0, 120).join('') + '…';
  return [
    ['Заявка', summary || 'без описания'],
    ['Автор', (row && row.from) || 'неизвестен'],
    ['ID', id],
  ];
}
// P3-CRITICAL-2 (2026-07-16, первый боевой найм): раннер, запущенный detached+unref из
// oneshot-тика, умирал через миллисекунды — detached выводит из process group, но НЕ из
// cgroup юнита; systemd (KillMode=control-group, дефолт) при завершении тика зачищает
// cgroup (SIGKILL, без следов: stdio ignore, а лог раннер пишет только ПОСЛЕ исполнителя).
// Ревью Task 11-fix гоняло раннеры из shell-сессии — вне oneshot-cgroup, слепая зона.
// Фикс: раннер живёт СОБСТВЕННЫМ transient-юнитом systemd-run (dept-runner-<event_id>) —
// жизненный цикл независим от диспетчера, журнал в journalctl --user -u dept-runner-*,
// --collect самоочищает failed-юниты, занятое имя юнита = доп. слой дедупа той же заявки.
// systemd-run НЕ наследует env клиента — значимые переменные прокидываются явно (--setenv).
// Whitelist = ровно то, что ЧИТАЕТ цепочка раннера (ревью P3-CRITICAL-2, сверено grep'ом):
// PATH; DEPT_HOME + DEPT_POLICY_DIR (dept-ledger); CLAUDE_CONTROL_DIR (claude-auto,
// planerka/sleep-exec); BRAIN_CLIENTS (spawn-exec); TELEGRAM_NOTIFY + таймаут (сам раннер);
// CLAUDE_AUTO_STALE_SECONDS (STALE-гард cmd_rebase в claude-auto — его читает цепочка
// planerka/mission-exec → rebase; без прокидки тюнинг порога в env диспетчера молча
// терялся бы, раннер ребейзил бы по дефолту 1800с — M-4 ревью фазы 3).
// CLAUDE_AUTO_HOME сюда НЕ входит — её читают только node-компоненты (dispatcher/liveness/
// inbox), в bash-цепочке раннера она мертва.
// Чистая функция: собирает argv systemd-run (тестируется без запуска).
function runnerArgv(eventId, runnerBin, executorBin, env) {
  const out = ['--user', '--collect', '--quiet', `--unit=dept-runner-${eventId}`];
  for (const k of ['PATH', 'DEPT_HOME', 'DEPT_POLICY_DIR', 'CLAUDE_CONTROL_DIR', 'BRAIN_CLIENTS', 'TELEGRAM_NOTIFY', 'DEPT_EXEC_RUNNER_TIMEOUT_MS', 'CLAUDE_AUTO_STALE_SECONDS'])
    if (env[k] !== undefined && env[k] !== '') out.push('--setenv', `${k}=${env[k]}`);
  out.push(runnerBin, '--approval', eventId, '--executor', executorBin);
  return out;
}
module.exports = { pickExecutable, newProbeLines, decideSleep, EXEC_KINDS, stuckExecuting, runnerArgv, humanApproval, staleOpenApprovals, openReminderLabel };
if (require.main !== module) return;

// ---- CLI ---------------------------------------------------------------
const argv = process.argv.slice(2);
if (argv[0] !== 'tick') {
  process.stderr.write('usage: dept-dispatcher tick [--dry-run]\n');
  process.exit(1);
}
const dry = argv.includes('--dry-run');

const CC_HOME = resolveRuntimeRoot('auto_then_hardcoded');
// DEPT остаётся производным от резолвленного CC_HOME (композитный DEPT): DEPT_HOME → CC_HOME/department.
const DEPT = process.env.DEPT_HOME || path.join(CC_HOME, 'department');
const WORKERS_DIR = path.join(CC_HOME, 'workers');
const BIN = __dirname;
const CLAUDE_AUTO = path.join(BIN, 'claude-auto');
const DEPT_LEDGER = path.join(BIN, 'dept-ledger');
const SLEEP_STATE_FILE = path.join(DEPT, 'sleep-check-state.json');
const NOTIFY = process.env.TELEGRAM_NOTIFY || '/home/rainor/server/server_monitor/telegram_notify.sh';

// Number(garbage) === NaN просачивался бы во все сравнения как false (см. liveness/
// rebase-check) — guard: невалидное/неположительное значение → дефолт, не NaN.
function numEnv(name, def) {
  const n = Number(process.env[name]);
  return Number.isFinite(n) && n > 0 ? n : def;
}
const CFG = { idleDays: numEnv('DEPT_SLEEP_IDLE_DAYS', 7) };
const STALE_AFTER_MS = numEnv('CLAUDE_AUTO_STALE_SECONDS', 1800) * 1000;
const AUTO = process.env.DEPT_SLEEP_AUTO === '1';
// Task 11-fix: сколько минут заявка может провести в executing, прежде чем считаться
// зависшей (раннер, вероятно, умер — hard-kill/OOM/systemd). НЕ авто-рестарт — только алерт,
// оператор решает (идемпотентность исполнителей есть, но авто-рестарт застрявшего = риск).
// ИНВАРИАНТ: EXEC_MAX_MIN*60000 должен быть ≥ DEPT_EXEC_RUNNER_TIMEOUT_MS (таймаут раннера,
// дефолт 900000 мс) — иначе ЖИВОЙ долгий runner ложно пометится «завис» до легитимного финала.
// Дефолты (20 мин = 1200000 ≥ 900000) инвариант держат; при тюнинге env — сохранять соотношение.
const EXEC_MAX_MIN = numEnv('DEPT_EXEC_MAX_MIN', 20);
const EXEC_RUNNER = path.join(BIN, 'dept-exec-runner');
// Task 7: сколько минут заявка (dept-approval) может провести open без решения оператора,
// прежде чем напомнить (кейс 16.07: rfpf провисела open 18ч, никто не заметил). Дефолт 4ч —
// заведомо дольше рабочего цикла реакции оператора, но заведомо меньше суток.
const OPEN_REMIND_MIN = numEnv('DEPT_OPEN_APPROVAL_REMIND_MIN', 240);
const OPEN_REMIND_STATE_FILE = path.join(DEPT, 'open-approval-reminders.json');
// Тест-шов: подменить systemd-run заглушкой в тестах/песочнице (DEPT_SYSTEMD_RUN=/bin/true).
// T4: сам бинарь резолвит guard (processControl.systemdRunArgv → e.DEPT_SYSTEMD_RUN ||
// 'systemd-run') — тот же шов и тот же дефолт, но читается в момент ВЫЗОВА, а не на
// module-load (конвенция репозитория, ср. execTimeoutMs в bin/dept-inbox). Отдельная
// module-level константа стала бы вторым источником правды о том же шве — убрана.

const EXECUTORS = {
  worker_spawn: 'dept-spawn-exec', mission_change: 'dept-mission-exec',
  planerka: 'dept-planerka-exec', sleep: 'dept-sleep-exec',
  liveness_restart: 'dept-liveness-exec',
};

// Best-effort лок (см. liveness/rebase-check): ручной прогон параллельно с таймером
// иначе гонит read-modify-write sleep-check-state.json/.dispatcher-lastrun-* без
// синхронизации. Task 11-fix: обязанность 2 (исполнение заявок) больше НЕ блокирует тик —
// раннер живёт в отдельном transient-юните, дольше всего тик может занять на обязанности 1/3 (пробы
// СПЯЩИХ + claude-auto start/sleep/rebase, execFileSync таймаут 60с на каждый вызов,
// воркеров может быть несколько). 20 мин "протухания" — таймер бьёт раз в 2 мин, запас
// на легитимно долгий прогон при большом флоте, не только на секундный.
const LOCK_FILE = path.join(DEPT, 'dispatcher.lock');
const LOCK_STALE_MS = 20 * 60_000;
function acquireLock() {
  fs.mkdirSync(DEPT, { recursive: true });
  try {
    const fd = fs.openSync(LOCK_FILE, 'wx');
    fs.writeSync(fd, String(process.pid));
    fs.closeSync(fd);
    return true;
  } catch (e) {
    if (e.code !== 'EEXIST') throw e;
    try {
      if (Date.now() - fs.statSync(LOCK_FILE).mtimeMs > LOCK_STALE_MS) { fs.unlinkSync(LOCK_FILE); return acquireLock(); }
    } catch {}
    return false;
  }
}
// p3#22: dry-run строго read-only — лок НЕ берём и НЕ пишем (превью не должен транзиентно
// блокировать реальный тик; dry-путь без лока безопасен — он не пишет state/lastrun/маркеры).
if (!dry) {
  if (!acquireLock()) {
    console.log('dispatcher: другой прогон уже идёт (свежий lock) — пропуск во избежание гонки на sleep-check-state.json');
    process.exit(0);
  }
  // 'exit' — не try/finally: снимает лок и при незапойманном исключении в цикле ниже
  // (иначе один сбой блокирует все прогоны на LOCK_STALE_MS, а не только текущий тик).
  process.on('exit', () => { try { fs.unlinkSync(LOCK_FILE); } catch {} });
}

// timeout на КАЖДЫЙ подпроцесс — иначе подвисший claude-auto/probe/tmux вешает
// execFileSync навсегда, и ни один воркер/заявка ПОСЛЕ зависшего не проверяется.
// Тихий best-effort (аналог agent_run append в claude-auto bash: `|| true`).
function sh(cmd, args, timeoutMs = 15_000) {
  try { return execFileSync(cmd, args, { encoding: 'utf8', timeout: timeoutMs }); } catch { return null; }
}
function tail(s, n) { s = String(s == null ? '' : s); return s.length > n ? s.slice(-n) : s; }
// p3#33: у notify СОБСТВЕННЫЙ таймаут 30с (не общий 15с sh()) — telegram_notify.sh при
// сетевом флапе не успевал добежать до fallback, алерт молча терялся. Возвращает
// успех/провал: дедуп-стейт эпизода (exec-stuck маркер) пишется только при доставке.
function notify(msg) {
  if (dry) { console.log('[dry] notify:', msg); return true; }
  // card.send сама выбирает бота, ставит --parse-mode HTML и `--`, ретраит plain-текстом
  // ТОЛЬКО на ошибке разметки. Возврат — прежний boolean.
  const r = card.send(msg, { tg: NOTIFY });
  if (!r.ok) { console.log('dispatcher: notify FAILED:', r.out); return false; }
  return true;
}
function loadJSON(file, fallback) {
  try { return JSON.parse(fs.readFileSync(file, 'utf8')); } catch { return fallback; }
}
function saveJSON(file, obj) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  const tmp = file + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(obj, null, 2));
  fs.renameSync(tmp, file);
}
function loadLineSet(file) {
  try { return new Set(fs.readFileSync(file, 'utf8').split('\n').map((l) => l.trim()).filter(Boolean)); }
  catch { return new Set(); }
}
// dept-ledger list — построчный JSON. Диагностика в stderr при сбое (не silent —
// пустая выборка по ошибке чтения ledger не должна маскироваться под "заявок нет").
function dlList(args) {
  let out;
  try { out = execFileSync(DEPT_LEDGER, ['list', ...args], { encoding: 'utf8', timeout: 15_000 }); }
  catch (e) { console.error('dispatcher: dept-ledger list ' + args.join(' ') + ' failed: ' + e.message); return []; }
  return out.split('\n').filter((l) => l.trim()).map((l) => { try { return JSON.parse(l); } catch { return null; } }).filter(Boolean);
}
function readSpec(name) {
  try { return JSON.parse(fs.readFileSync(path.join(WORKERS_DIR, name, 'spec.json'), 'utf8')); } catch { return null; }
}
// Та же эвристика транскрипта, что claude-auto-liveness/dept-rebase-check.
function transcriptMtime(name) {
  const spec = readSpec(name);
  if (!spec || !spec.session_id) return 0;
  const projRoot = path.join(process.env.HOME, '.claude', 'projects');
  try {
    for (const d of fs.readdirSync(projRoot)) {
      const f = path.join(projRoot, d, spec.session_id + '.jsonl');
      if (fs.existsSync(f)) return fs.statSync(f).mtimeMs;
    }
  } catch {}
  return 0;
}
// Запуск одной пробы: партиальный stdout возвращаем ДАЖЕ при ненулевом exit/timeout —
// probe-скрипты (как и в event-bridge-watch) могут упасть, но уже что-то напечатать.
function runProbe(cmd, timeoutSec) {
  const argv = Array.isArray(cmd) ? cmd : ['sh', '-c', String(cmd)];
  if (!argv.length || !argv[0]) return '';
  // EB_ASANA_EMIT_ID: без него asana-comments печатает строки БЕЗ ebid-маркера →
  // ключ дедупа = legacy-hash, а живой watcher писал в .seen только 'g:<id>' →
  // уже доставленное событие ложно будило спящего воркера. Диспетчер marker-aware
  // (keysForLine), поэтому просим маркер всегда — как event-bridge-watch.
  try { return execFileSync(argv[0], argv.slice(1), { encoding: 'utf8', timeout: (timeoutSec || 30) * 1000, env: { ...process.env, EB_ASANA_EMIT_ID: '1' } }); }
  catch (e) { return typeof e.stdout === 'string' ? e.stdout : ''; }
}

let deptReg, autoReg;
try { deptReg = JSON.parse(fs.readFileSync(path.join(DEPT, 'registry.json'), 'utf8')); }
catch (e) { notify(card.build({
  head: ['🚨', 'Тик диспетчера пропущен'],
  fields: [['Файл', 'registry.json']],
  sections: [{ emoji: '🔴', title: 'Ошибка чтения', text: e.code || e.message }],
  action: 'Починить файл — до этого заявки отдела не исполняются',
})); process.exit(0); }
try { autoReg = JSON.parse(fs.readFileSync(path.join(CC_HOME, 'autonomous.json'), 'utf8')); }
catch (e) { notify(card.build({
  head: ['🚨', 'Тик диспетчера пропущен'],
  fields: [['Файл', 'autonomous.json']],
  sections: [{ emoji: '🔴', title: 'Ошибка чтения', text: e.code || e.message }],
  action: 'Починить файл — до этого заявки отдела не исполняются',
})); process.exit(0); }
const autoWorkers = autoReg.workers || autoReg;
const deptWorkers = deptReg.workers || {};
const roleOf = (n) => (deptWorkers[n] || {}).role;
const now = Date.now();

// ---- 1) пробы СПЯЩИХ контуров: на новое событие — wake --------------------
let sleepingCount = 0, wokenCount = 0;
for (const [name, meta] of Object.entries(autoWorkers)) {
  if (!meta || typeof meta !== 'object' || meta.state !== 'sleeping') continue;
  sleepingCount++;
  const cfg = loadJSON(path.join(WORKERS_DIR, name, 'event-bridge.config.json'), null);
  if (!cfg || !Array.isArray(cfg.probes) || !cfg.probes.length) continue;
  const stateDir = path.join(WORKERS_DIR, name, 'state');
  let woke = false;
  for (const probe of cfg.probes) {
    if (woke) break; // один wake на воркера за тик — после wake его пробы в этом тике не гоняются
    const pname = probe && probe.name;
    if (!pname || !probe.cmd) continue;
    const ident = String(pname).replace(/[^A-Za-z0-9_-]/g, '_');
    const intervalSec = Number.isFinite(probe.interval_sec) && probe.interval_sec > 0 ? probe.interval_sec : 60;
    const timeoutSec = Number.isFinite(probe.timeout_sec) && probe.timeout_sec > 0 ? probe.timeout_sec : 30;
    const lastrunFile = path.join(stateDir, `.dispatcher-lastrun-${ident}`);
    const lastrun = Number(loadJSON(lastrunFile, 0)) || 0; // содержимое — просто epoch-секунды (не JSON-объект), но валидный JSON-скаляр
    const nowSec = Math.floor(now / 1000);
    if (nowSec - lastrun < intervalSec) continue;
    if (dry) {
      // Codex H-1 (/bug финала ф3): probe.cmd НЕ исполняется в dry — stateful-адаптеры
      // (asana-comments/gmail-messages/tg-messages) на ХОЛОДНОМ датчике пишут baseline
      // первым прогоном → реальный тик подавил бы события до baseline (missed wake).
      // dry строго read-only: только перечисляем, что проверили бы.
      console.log(`[dry] проверил бы датчик ${pname} контура ${name} (probe в dry не исполняется: stateful)`);
      continue;
    }
    fs.mkdirSync(stateDir, { recursive: true }); fs.writeFileSync(lastrunFile, String(nowSec));

    const out = runProbe(probe.cmd, timeoutSec);
    if (!out) continue;
    const lines = out.split('\n');
    const seen = loadLineSet(path.join(stateDir, `${ident}.seen`));
    const dead = loadLineSet(path.join(stateDir, `${ident}.dead`));
    const fresh = newProbeLines(lines, seen, dead);
    if (!fresh.length) continue;

    const excerpt = tail(visiblePart(fresh[0]), 160);
    woke = true;
    if (dry) { console.log(`[dry] ${name}: разбудил бы датчиком ${pname}: ${excerpt}`); break; }
    try {
      execFileSync(CLAUDE_AUTO, ['start', name], { encoding: 'utf8', timeout: 60_000 });
      wokenCount++;
      // agent_run wake — best-effort, зеркало spawn/rebase/mission_update в claude-auto (bash `|| true`).
      sh(DEPT_LEDGER, ['append', '--kind', 'agent_run', '--data', JSON.stringify({ worker: name, run_kind: 'wake', probe: pname }), '--actor', 'dispatcher']);
      notify(card.build({
        head: ['🌅', 'Контур разбужен'],
        fields: [['Воркер', name], ['Датчик', pname]],
        sections: [{ emoji: '📨', title: 'Событие', text: excerpt }],
      }));
    } catch (e) {
      notify(card.build({
        head: ['🚨', 'Не удалось разбудить контур'],
        fields: [['Воркер', name], ['Датчик', pname]],
        sections: [{ emoji: '🔴', title: 'Ошибка', text: e.message }],
        action: `Поднять вручную: claude-auto start ${name}`,
      }));
    }
  }
}

// ---- 2) исполнение утверждённых заявок (Task 11-fix: executing + отдельный юнит раннера) --
// Старый баг (боевая планёрка 2026-07-15): execFileSync(executor, timeout 15мин) блокировал
// тик диспетчера целиком; systemd (дефолтный TimeoutStartSec) убивал зависший на >N сек
// dispatcher, осиротевший exec продолжал жить, а следующий тик видел approval всё ещё
// "approved" и стартовал НОВЫЙ exec на ту же заявку → параллельные исполнители одной
// заявки, взаимоблокировка. Фикс: (1) пометить executing ДО запуска — дедуп на уровне
// ledger (approval-exec approved→executing идемпотентен: второй прогон получит
// deduped:true и пропустит заявку); (2) запустить dept-exec-runner в СОБСТВЕННОМ
// transient-юните (systemd-run, см. runnerArgv/P3-CRITICAL-2) — тик НЕ ждёт исполнения.
// Раннер сам пишет финальный статус (executed/exec_failed) независимо от диспетчера —
// см. bin/dept-exec-runner.

// Recovery: заявки, застрявшие в executing (раннер, вероятно, умер — hard-kill/OOM).
// ДО обычного цикла исполнения — оператору важно узнать про зависшую заявку даже если в
// этом тике нет новых approved. Дедуп алерта — маркер-файл на event_id (не спамить каждые
// 2 мин, пока оператор не разберётся и не тронет заявку/маркер).
function executingApprovals() {
  const executingRows = dlList(['--kind', 'approval', '--status', 'executing']); // effectiveStatus
  const executingMarks = dlList(['--kind', 'approval_status', '--filter', 'status=executing']); // сырые события
  const since = new Map(); // ref -> ts первого approval_status(executing) (approved→executing пишется РОВНО один раз — дедуп в ledger блокирует повтор)
  for (const m of executingMarks) if (!since.has(m.data.ref)) since.set(m.data.ref, m.ts);
  // summary/from — для человеческого алерта (фидбэк оператора 16.07, см. humanApproval);
  // stuckExecuting фильтрует rows как есть — лишние поля проезжают насквозь.
  return executingRows.map((r) => ({ event_id: r.event_id, kind_of: r.data.kind_of,
    summary: r.data.summary, from: r.data.from, executing_since: since.get(r.event_id) }))
    .filter((r) => r.executing_since);
}
const stuck = stuckExecuting(executingApprovals(), now, EXEC_MAX_MIN);
for (const s of stuck) {
  const marker = path.join(DEPT, `exec-stuck-${s.event_id}`);
  if (dry) { console.log(`[dry] алерт зависшей заявки: ${s.kind_of} ${s.event_id} (executing > ${EXEC_MAX_MIN}мин)`); continue; }
  if (fs.existsSync(marker)) continue; // уже алертили этот эпизод
  // humanApproval вместо голого event_id — фидбэк оператора 16.07: алерт читается без ledger.
  // p3#33: маркер (дедуп алерта) — только при ДОСТАВЛЕННОМ алерте; провал notify оставляет
  // эпизод несообщённым, следующий тик (2 мин) повторит попытку.
  if (!notify(card.build({
    head: ['🚨', 'Заявка зависла в executing'],
    fields: [...approvalFields(s), ['Тип', s.kind_of], ['Висит', `>${EXEC_MAX_MIN} мин`]],
    note: 'Похоже, раннер умер, не записав финал.',
    action: `Разобрать вручную: dept-ledger list --kind approval --event-id ${s.event_id}`,
  }))) continue;
  try { fs.writeFileSync(marker, String(now)); } catch (e) { console.error(`dispatcher: не смог записать маркер зависшей заявки ${s.event_id}: ${e.message}`); }
}

// Напоминание о заявках, зависших open без решения оператора (Task 7, кейс 16.07 — см.
// staleOpenApprovals). Состояние — JSON-файл с уборкой закрытых эпизодов, НЕ маркер-файлы:
// урок p3#35 (маркеры exec-stuck-* никто не чистит, они копятся) — не воспроизводить в
// новом месте. dry-run строго read-only: ни remindState не читаем на запись, ни файл не пишем.
const remindState = dry ? {} : loadJSON(OPEN_REMIND_STATE_FILE, {});
const openApprovalRows = dlList(['--kind', 'approval', '--status', 'open']);
const staleOpen = staleOpenApprovals(openApprovalRows, now, OPEN_REMIND_MIN);
const openIds = new Set(openApprovalRows.map((r) => r.event_id));
for (const s of staleOpen) {
  // M5: openReminderLabel защищает s.data (см. её комментарий выше) — было s.data.summary/from
  // напрямую, TypeError на мусорной строке ронял бы весь тик ДО исполнения approved-заявок.
  if (dry) { console.log(`[dry] напоминание о зависшей заявке: ${humanApproval(openReminderLabel(s))}`); continue; }
  if (remindState[s.event_id]) continue; // уже напоминали про этот эпизод
  // approvalFields ждёт ПЛОСКИЕ row.summary/row.from (см. её сигнатуру выше), а openApprovalRows —
  // сырые события ledger, где эти поля лежат в data. Без уплощения алерт выродился бы в
  // голый event_id — ровно то, от чего уходили по фидбэку оператора 16.07.
  const label = openReminderLabel(s);
  // p3#33: писать «напомнили» только при ДОСТАВЛЕННОМ алерте — иначе сетевой флап
  // проглотит напоминание навсегда (следующий тик повторит попытку).
  if (!notify(card.build({
    head: ['⏳', 'Заявка ждёт твоего решения'],
    fields: [...approvalFields(label), ['Висит', `>${OPEN_REMIND_MIN} мин`]],
    action: 'Решить кнопкой в боте — или попросить автора отозвать (dept-withdraw)',
  }))) continue;
  remindState[s.event_id] = now;
}
if (!dry) {
  // Уборка стейта: заявка закрыта (решена/отозвана) → эпизод больше не нужен. Без этого
  // файл рос бы вечно — ровно дефект p3#35, только в JSON, а не в маркер-файлах.
  for (const id of Object.keys(remindState)) if (!openIds.has(id)) delete remindState[id];
  saveJSON(OPEN_REMIND_STATE_FILE, remindState);
}

const approvalRows = dlList(['--kind', 'approval', '--status', 'approved']);
const executable = pickExecutable(approvalRows, roleOf);
// Codex H-2 (/bug финала ф3): заявки на ОДНОГО воркера сериализуются — вторая approved
// mission_change (или mission+sleep/spawn) на тот же target не запускается, пока первая
// executing/запущена в этом тике; иначе два раннера пишут CLAUDE.md/spec наперегонки,
// оба финализируются executed, а выживает last-writer. Отложенная возьмётся следующим
// тиком (approved никуда не денется). Цель: request.worker|request.name; planerka — null.
const targetOfRequest = (r) => { const q = (r.data && r.data.request) || {}; return q.worker || q.name || null; };
const busyTargets = new Set(
  dlList(['--kind', 'approval', '--status', 'executing']).map(targetOfRequest).filter(Boolean));
let execStartedCount = 0, execSkippedCount = 0;
for (const row of executable) {
  const kindOf = row.data.kind_of;
  const id = row.event_id;
  const executor = EXECUTORS[kindOf];
  if (dry) { console.log(`[dry] пометил бы executing + запустил бы раннер для заявки ${kindOf} ${id} через ${executor || '???'}`); continue; }
  if (!executor) { console.error(`dispatcher: заявка ${id} kind_of=${kindOf} — нет исполнителя в EXECUTORS (не должно случаться, EXEC_KINDS/EXECUTORS разошлись)`); continue; }
  const target = targetOfRequest(row);
  if (target && busyTargets.has(target)) {
    execSkippedCount++;
    console.log(`dispatcher: заявка ${kindOf} ${id} отложена — по воркеру «${target}» уже исполняется другая заявка (следующий тик возьмёт)`);
    continue;
  }
  // Шаг 0 (T4): preflight systemd-run СТРОГО ДО пометки executing. Пометка — необратимая
  // мутация леджера: заявка, помеченная executing без реально стартовавшего раннера, зависает
  // до recovery-бэкстопа (EXEC_MAX_MIN) и требует ручного разбора. Поэтому под тестовым
  // маркером CLAUDE_CONTROL_TEST_ROOT отказ (шов DEPT_SYSTEMD_RUN не подставлен заглушкой
  // внутри test root) обязан произойти ЗДЕСЬ, до побочного эффекта, а не на execFileSync
  // ниже. БЕЗ маркера preflight не проверяет ничего и не может бросить — поведение
  // диспетчера побитово прежнее.
  try {
    processControl.preflight('systemd_run');
  } catch (e) {
    console.error(`dispatcher: guard процесс-контроля не пропустил запуск раннера для заявки ${kindOf} ${id}: ${e.message} — заявка НЕ помечена executing, следующий тик повторит попытку`);
    continue;
  }
  // Шаг 1: пометить executing. Это САМА защита от повторного запуска (явная — поверх
  // неявной защиты list --status approved, которая эту заявку уже не выбрала бы на
  // следующем тике, но между "прочитали approved" и "пометили executing" возможна гонка
  // двух прогонов диспетчера в один момент — approval-exec-дедуп в ledger её закрывает).
  let mark;
  try {
    mark = JSON.parse(execFileSync(DEPT_LEDGER, ['approval-exec', id, '--status', 'executing', '--actor', 'dispatcher'], { encoding: 'utf8', timeout: 15_000 }));
  } catch (e) {
    console.error(`dispatcher: не удалось пометить заявку ${kindOf} ${id} executing: ${e.message} — пропуск, следующий тик повторит попытку`);
    continue;
  }
  if (mark.deduped) { execSkippedCount++; console.log(`dispatcher: заявка ${kindOf} ${id} уже executing (другой тик/прогон взял) — пропуск`); continue; }
  // Шаг 2: запуск раннера СОБСТВЕННЫМ transient-юнитом systemd-run, НЕ detached-ребёнком —
  // см. комментарий у runnerArgv (P3-CRITICAL-2: cgroup-зачистка oneshot убивала detached-раннер
  // через миллисекунды). execFileSync тик не блокирует: systemd-run возвращается сразу после
  // старта юнита (~десятки мс), исполнение идёт в отдельном юните. Провал старта (вкл. занятое
  // имя юнита при живом раннере той же заявки) — алерт; заявка остаётся executing,
  // recovery-бэкстоп (EXEC_MAX_MIN) штатный.
  try {
    // T4: argv собирает guard (systemdRunArgv) — он же ПРЕПЕНДИТ `--setenv
    // CLAUDE_CONTROL_TEST_ROOT=<root>` под маркером. Это обязательно: systemd-run НЕ наследует
    // env клиента, и без явной прокидки вложенная цепочка (dept-exec-runner → исполнитель →
    // claude-auto) потеряла бы маркер и осталась БЕЗ защиты — вызвала бы настоящие
    // systemctl/tmux уже ничем не прикрытая. Сборка через guard, а не дописывание маркера в
    // whitelist runnerArgv, потому что решение «какой маркер и с каким значением» принадлежит
    // T2 (systemdRunSetenvArgv) — второй копии этой логики быть не должно.
    // БЕЗ маркера setenv-часть пуста, argv побитово равен прежнему runnerArgv(...).
    const { bin: sdRunBin, argv: sdRunArgv } = processControl.systemdRunArgv(
      runnerArgv(id, EXEC_RUNNER, path.join(BIN, executor), process.env), process.env);
    execFileSync(sdRunBin, sdRunArgv,
      { encoding: 'utf8', timeout: 15_000 });
    execStartedCount++;
    if (target) busyTargets.add(target); // сериализация в рамках тика (Codex H-2)
    console.log(`dispatcher: заявка ${kindOf} ${id} — раннер запущен transient-юнитом dept-runner-${id}`);
  } catch (e) {
    const detail = ((e.stderr && String(e.stderr).trim()) || e.message || String(e)).slice(0, 300);
    // humanApproval вместо голого event_id — фидбэк оператора 16.07: алерт читается без ledger.
    notify(card.build({
      head: ['🚨', 'Раннер НЕ запустился'],
      fields: [...approvalFields({ event_id: id, summary: row.data.summary, from: row.data.from }), ['Тип', kindOf]],
      sections: [{ emoji: '🔴', title: 'Ошибка запуска', text: detail }],
      note: 'Заявка уже помечена executing и зависнет в этом статусе.',
      action: 'Нужен recovery-разбор вручную',
    }));
  }
}

// ---- 3) детект неактивности МК ---------------------------------------------
function lastActivityTs(allEvents, name) {
  let max = 0;
  for (const e of allEvents) {
    const d = e.data || {};
    if (e.actor === name || d.to === name || d.from === name || d.worker === name) {
      const t = Date.parse(e.ts);
      if (Number.isFinite(t) && t > max) max = t;
    }
  }
  return max;
}
function hasOpenApproval(name) {
  if (dlList(['--kind', 'approval', '--filter', 'from=' + name, '--status', 'open']).length) return true;
  return dlList(['--kind', 'approval', '--filter', 'from=' + name, '--status', 'approved']).length > 0;
}
function hasQueued(name) {
  return dlList(['--kind', 'message', '--filter', 'to=' + name, '--status', 'queued']).length > 0;
}

const sleepState = loadJSON(SLEEP_STATE_FILE, {});
let allLedgerEvents = null; // ленивая загрузка — только если есть хоть один активный МК
let mkChecked = 0, mkSignalled = 0;
for (const [name, meta] of Object.entries(deptWorkers)) {
  if (!meta || meta.role !== 'мк') continue;
  const autoMeta = autoWorkers[name];
  if (!autoMeta || autoMeta.state !== 'active') {
    delete sleepState[name]; // уход из active закрывает эпизод (см. dept-rebase-check.pruneState)
    continue;
  }
  mkChecked++;
  const txMtime = transcriptMtime(name);
  if (allLedgerEvents === null) allLedgerEvents = dlList([]);
  const lastAct = lastActivityTs(allLedgerEvents, name);
  const anchor = Math.max(txMtime, lastAct);
  if (!anchor) { console.log(`dispatcher: ${name}: недостаточно данных (нет транскрипта и ledger-активности) — пропуск детекта неактивности`); continue; }
  const idleDays = (now - anchor) / 86400_000;

  if (idleDays < CFG.idleDays) { delete sleepState[name]; continue; } // активен — сброс дедупа/эпизода

  // memoryFreshnessFromTx — не memoryFreshness: у нас на руках уже txMtime (:454), а
  // session_id диспетчер не читает вовсе. Подстановка sessionId-варианта отправила бы
  // txMtime на место session_id → транскрипт не найден → вечный fresh → STALE-гард
  // авто-сна отключился бы молча (Codex крит. №1).
  const stale = memoryFreshnessFromTx(autoMeta.brain_path, txMtime, STALE_AFTER_MS).state === 'stale';
  const openAppr = hasOpenApproval(name);
  const queued = hasQueued(name);
  const already = !!(sleepState[name] && sleepState[name].asked);
  const decision = decideSleep({ idleDays, hasOpenApproval: openAppr, hasQueued: queued, stale, alreadyAsked: already, auto: AUTO }, CFG);

  if (dry) {
    console.log(`[dry] ${name}: idle_days=${idleDays.toFixed(1)} open_approval=${openAppr} queued=${queued} stale=${stale} → ${decision}`);
    continue;
  }
  if (decision === 'ask_head') {
    mkSignalled++;
    const subject = `МК ${name} неактивен ${Math.floor(idleDays)} дн — предложи усыпить или обоснуй`;
    const sent = sh(DEPT_LEDGER, ['send', '--type', 'decision_request', '--to', 'dept-head', '--subject', subject, '--actor', 'dispatcher']);
    if (sent !== null) {
      // p3#33-решение: asked (дедуп эпизода) привязан к УСПЕХУ ledger-send, НЕ к notify —
      // содержательное действие (decision_request Руководителю) уже в журнале, повтор на
      // следующем тике создал бы ДУБЛЬ заявки; TG-уведомление здесь информационное.
      notify(card.build({
        head: ['💤', 'МК давно неактивен'],
        fields: [['Воркер', name], ['Простой', `${Math.floor(idleDays)} дн`]],
        note: 'Запрос Руководителю отправлен — он предложит усыпить или обоснует. Действий от тебя не требуется.',
      }));
      sleepState[name] = { asked: true };
    } else {
      console.error(`dispatcher: не удалось отправить decision_request по ${name} — попробуем на следующем тике`);
    }
  } else if (decision === 'auto_sleep') {
    mkSignalled++;
    try {
      execFileSync(CLAUDE_AUTO, ['sleep', name], { encoding: 'utf8', timeout: 60_000 });
      sh(DEPT_LEDGER, ['append', '--kind', 'agent_run', '--data', JSON.stringify({ worker: name, run_kind: 'auto_sleep', idle_days: Math.floor(idleDays) }), '--actor', 'dispatcher']);
      notify(card.build({
        head: ['😴', 'МК усыплён автоматически'],
        fields: [['Воркер', name], ['Простой', `${Math.floor(idleDays)} дн`]],
        note: 'Контур остаётся живым: датчики опрашиваются, новое событие разбудит воркера.',
      }));
      delete sleepState[name]; // эпизод закрыт сном
    } catch (e) {
      notify(card.build({
        head: ['🚨', 'Авто-сон НЕ удался'],
        fields: [['Воркер', name], ['Простой', `${Math.floor(idleDays)} дн`]],
        sections: [{ emoji: '🔴', title: 'Ошибка', text: e.message }],
        action: `Усыпить вручную: claude-auto sleep ${name}`,
      }));
    }
  }
  // decision === 'none' (гард активен или уже спрошено) — sleepState не трогаем
}
if (!dry) saveJSON(SLEEP_STATE_FILE, sleepState);

console.log(`dispatcher: tick complete — ${sleepingCount} sleeping (${wokenCount} woken), ${executable.length} заявок approved (${execStartedCount} раннеров запущено, ${execSkippedCount} пропущено — уже executing), ${stuck.length} зависших в executing, ${mkChecked} МК проверено (${mkSignalled} сигналов)`);
