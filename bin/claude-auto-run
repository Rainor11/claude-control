#!/usr/bin/env bash
# claude-auto-run <name> — foreground supervisor for one autonomous worker.
#
# Why foreground: this is the ExecStart of claude-auto@<name>.service. It must
# stay alive for as long as the worker lives, otherwise systemd's Restart=always
# is meaningless (it would relaunch a process that already exited). So it starts
# the worker inside a durable tmux session and then BLOCKS until that session
# ends (worker exits / crashes), at which point systemd restarts this unit and
# the worker resumes. With loginctl linger this also brings the worker back
# after a reboot. (Fixes the "tmux new-session -d && exit" pattern in claude-rc
# which is fine for on-demand projects but wrong for a supervised unit.)
#
# Worker spec lives in ~/.claude-control/workers/<name>/spec.json:
#   { session_id, origin_id, cwd, permission_mode, seeded, model }
# First start (seeded=false) forks the origin conversation into the worker's
# OWN pinned session id (verified: --resume <origin> --fork-session
# --session-id <W> copies history into a fresh W.jsonl, no double-write).
# Subsequent starts just --resume <W>, so restarts continue the SAME session.
set -u

# T4: guard процесс-контроля (lib/process-control.sh, задача T2) — оборачивает вызовы tmux
# ниже (per-worker сокет claude-<name> общий с боевым флотом). Резолв через readlink -f:
# юнит запускает нас полным путём __BIN_DIR__/claude-auto-run, но через symlink тоже должно
# работать; lib лежит в ../lib и в repo-, и в install-layout (сделано в T1). Это ГОРЯЧИЙ путь
# подъёма воркера — source библиотеки лишь определяет функции (без побочных эффектов) и не
# меняет поведение без маркера.
_CAR_SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
_CAR_BIN_DIR="$(cd "$(dirname "$_CAR_SELF")" && pwd)"
# shellcheck disable=SC1091
. "$_CAR_BIN_DIR/../lib/process-control.sh"

# T5: корень рантайма — через единый резолвер (lib/runtime-root.sh, задача T1), уже
# подгруженный transitively из process-control.sh выше. Без маркера CLAUDE_CONTROL_TEST_ROOT
# возвращает ту же строку, что прежний inline-дефолт; под маркером — fail-closed на песочницу.
# Горячий путь (ExecStart юнита): резолвер — чистая функция, без побочных эффектов.
CONTROL_DIR="$(resolve_runtime_root control_only)" || exit 1
WORKERS_DIR="$CONTROL_DIR/workers"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
# Default model for workers: force the 1M-context Opus variant. A forked/resumed
# session otherwise inherits the model its transcript was saved with (256k Opus),
# and a manual picker change does NOT survive restart (resume re-applies the saved
# model). So pin the model explicitly on every launch — `--model` is the highest-
# priority override after managed settings. Override per-worker via spec.json
# .model, or globally via CLAUDE_AUTO_DEFAULT_MODEL.
DEFAULT_MODEL="${CLAUDE_AUTO_DEFAULT_MODEL:-opus[1m]}"

name="${1:?usage: claude-auto-run <name>}"
[[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || { echo "claude-auto-run: bad name '$name'" >&2; exit 2; }

home="$WORKERS_DIR/$name"
spec="$home/spec.json"
[ -f "$spec" ] || { echo "claude-auto-run: no spec at $spec" >&2; exit 2; }
command -v jq >/dev/null 2>&1 || { echo "claude-auto-run: jq required" >&2; exit 2; }

j() { jq -r "$1" "$spec"; }
session_id="$(j '.session_id')"
origin_id="$(j '.origin_id // empty')"
cwd="$(j '.cwd')"
# Fallback is the SAFE mode, NOT auto (Codex): a spec missing permission_mode must
# not silently launch in auto WITHOUT the deny/ask fence. `auto` is set EXPLICITLY by
# adopt (default) and upgrade — always together with the fence. So a malformed/legacy
# spec falls back to acceptEdits, never to an unfenced auto.
mode="$(j '.permission_mode // "acceptEdits"')"
seeded="$(j '.seeded // false')"
model="$(j '.model // empty')"
remote_control="$(j '.remote_control // false')"
rc_name="$(j '.remote_control_name // empty')"

# The worker's OWN (forked, pinned) transcript, created on its FIRST turn (not at
# launch) — so seeding is confirmed by watching for this file in the supervise
# loop. Claude Code derives the project dir from cwd with a non-trivial slug
# (EVERY non-[A-Za-z0-9] char → '-', so a Cyrillic brain path like …/клиенты/…
# does NOT map via a simple s#/#-#). Don't guess the slug — locate the transcript
# by its globally-unique session-id filename, robust to any slug rule.
find_wfile() { ls -1 "$HOME/.claude/projects"/*/"$session_id.jsonl" 2>/dev/null | head -1; }

flip_seeded_if_ready() {
  [ "$seeded" = "true" ] && return 0
  [ -n "$(find_wfile)" ] || return 0
  # Take the SAME lock as the operator spec writers (claude-auto spec_rmw /
  # set-probe-limit, which flock $home/state/.probes-rmw.lock) so this full-file
  # rewrite can't lost-update a concurrent MCP-subscription / probe-limit change
  # made while the worker is seeding. flock contends on the FILE (inode), so a
  # different FD number here than claude-auto's still serializes correctly.
  mkdir -p "$home/state"
  (
    flock 202 || exit 1
    t="$(mktemp "$home/.spec.XXXXXX")" || exit 1
    if jq '.seeded = true' "$spec" > "$t" 2>/dev/null && [ -s "$t" ]; then mv "$t" "$spec"; else rm -f "$t"; exit 1; fi
  ) 202>"$home/state/.probes-rmw.lock" && { seeded=true; say "seeded confirmed (worker transcript present)"; }
}

[ -d "$cwd" ] || { echo "claude-auto-run: cwd missing: $cwd" >&2; exit 1; }
mkdir -p "$home/logs" "$home/state"
log="$home/logs/worker.log"
sess="claude-$name"
# Per-worker tmux socket (-L "$sess"): each worker runs its OWN tmux server, keyed by
# its session name, so that server lives in THIS unit's cgroup. Stopping/restarting one
# worker (KillMode=control-group) then reaps only its own socket — never a server shared
# with other workers. (Before this, all workers shared the default socket; its server
# lived in whichever worker started it first, so stopping THAT worker killed the whole
# fleet. See systemd/claude-auto@.service.tmpl.) Socket name == session name everywhere.

ts() { date '+%Y-%m-%d %H:%M:%S'; }
say() { echo "$(ts) claude-auto-run[$name]: $*" | tee -a "$log" >&2; }

# Best-effort one-way operator alert (NEVER blocks launch). Mirrors claude-auto-tg's
# fixed-recipient pattern: operator chat_id + bot token from the operator's server .env,
# telegram_notify.sh at an absolute path. Used to flag a dropped/malformed MCP subscription.
OPERATOR_ENV="/home/rainor/server/.env"
# Путь нотификатора: БОЕВОЕ значение — голый литерал, ровно как до T8. Тестовый шов (T8 п.1)
# живёт внутри маркер-гейта ниже.
TG_NOTIFY="/home/rainor/server/server_monitor/telegram_notify.sh"
# K1 (ревью T8): вызов шва гейтирован маркером, значение вычисляется НЕ через библиотеку.
# Библиотека здесь нужна и в бою (guard tmux + resolve_runtime_root выше), поэтому сам source
# не гейтируется — но путь нотификатора от неё зависеть не должен: пролог резолва каталога
# исполняет внешние команды (`readlink`/`dirname`/`cd`/`pwd`), а bash на старте импортирует
# функции из окружения (`BASH_FUNC_x%%=…`) и исполняет `$BASH_ENV` — подменив `readlink`,
# воркер уводил source в свой каталог и получал СВОЮ process_control_notifier_path (полный
# разбор и репро — в комментарии claude-auto-tg). Условие ИМЕННО `[[ ]]`: зарезервированное
# слово, функцией с таким именем не перекрывается (в отличие от builtin'а `[`).
# Под валидным маркером обязана быть заглушка ВНУТРИ test root, иначе явный отказ — без этого
# тестовый прогон писал бы живому оператору. `|| exit 1` — тот же fail-closed, что у
# resolve_runtime_root выше в этом файле (в бою недостижим: без маркера гейт закрыт).
if [[ -n "${CLAUDE_CONTROL_TEST_ROOT+set}" ]]; then
  TG_NOTIFY="$(process_control_notifier_path "$TG_NOTIFY")" || exit 1
fi
notify_operator() {
  local text="$1" chat rnr_val; local -a botflag=()
  chat="$(awk -F= '/^TELEGRAM_CHAT_ID=/{gsub(/[^0-9]/,"",$2);print $2;exit}' "$OPERATOR_ENV" 2>/dev/null)"
  { [ -n "$chat" ] && [ -x "$TG_NOTIFY" ]; } || return 0
  rnr_val="$(grep -E '^RNR_WORKERS_BOT_TOKEN=' "$OPERATOR_ENV" 2>/dev/null | head -1 \
              | sed -e 's/^RNR_WORKERS_BOT_TOKEN=//' -e 's/^["'\'' ]*//' -e 's/["'\'' ]*$//')"
  [[ "$rnr_val" =~ ^[0-9]+:[A-Za-z0-9_-]+$ ]] && botflag=(--bot-token-env RNR_WORKERS_BOT_TOKEN)
  "$TG_NOTIFY" "${botflag[@]}" --chat-id "$chat" -- "$text" >/dev/null 2>&1 || true
}

# Pre-accept the folder-trust dialog for this cwd. An interactive worker would
# otherwise BLOCK on "Is this a project you trust?" with no one to answer. In
# normal use the origin already trusted its cwd, but seed it idempotently so
# fresh dirs and headless-origin cases don't wedge. Atomic; only adds keys.
trust_cfg="$HOME/.claude.json"
if [ -f "$trust_cfg" ] && command -v jq >/dev/null 2>&1; then
  # flock serializes concurrent workers (e.g. several starting at boot) so they
  # don't lost-update each other's trust entries. (It can't serialize against
  # claude itself rewriting ~/.claude.json, but that read-modify-write window is
  # tiny; the multi-worker boot race is the real hazard.)
  (
    flock 201 || exit 1
    [ "$(jq -r --arg c "$cwd" '.projects[$c].hasTrustDialogAccepted // false' "$trust_cfg" 2>/dev/null)" = "true" ] && exit 0
    ttmp="$(mktemp "$trust_cfg.autotrust.XXXXXX")" || exit 1
    if jq --arg c "$cwd" '.projects[$c] = ((.projects[$c] // {}) + {hasTrustDialogAccepted:true, hasCompletedProjectOnboarding:true})' "$trust_cfg" > "$ttmp" 2>/dev/null && [ -s "$ttmp" ]; then
      mv "$ttmp" "$trust_cfg"
    else
      rm -f "$ttmp"; exit 2
    fi
  ) 201>"$trust_cfg.trustlock"
  [ $? = 0 ] && say "pre-trusted cwd $cwd (or already trusted)" || say "WARN: could not pre-trust $cwd"
fi

# Already running? Then just attach our lifetime to it (don't double-launch).
if process_control_tmux "$name" has-session -t "$sess" 2>/dev/null; then
  say "tmux session $sess already running — supervising existing"
else
  # Build claude argv.
  args=( "$CLAUDE_BIN" )
  # Resume the pinned worker session if it's seeded OR its transcript already
  # exists (don't re-fork into an existing id — that risks corrupting it if the
  # seeded flag merely lagged). Only fork when there is genuinely no worker
  # transcript yet.
  if [ "$seeded" = "true" ] || [ -n "$(find_wfile)" ]; then
    args+=( --resume "$session_id" )
  elif [ -n "$origin_id" ]; then
    args+=( --resume "$origin_id" --fork-session --session-id "$session_id" )
  else
    # fresh-запуск (spawn/rebase): новая сессия с пиновым id, истории нет by design.
    # Память воркера — файлы (правило 1.1); kickoff-инжект даёт стартовый контекст.
    args+=( --session-id "$session_id" )
  fi
  args+=( --permission-mode "$mode" )
  args+=( --settings "$home/settings.json" )
  # Mission + bounds prose pinned into the system-prompt layer (survives
  # compaction). NOTE: events are delivered by event-bridge-watch + session-inject,
  # NOT a channel — the channel's --dangerously-load-development-channels warning
  # re-prompts on every launch (no persisted ack), which would wedge an
  # unattended restart. (Channel mode is kept in channels/event-bridge for when
  # the preview gate is lifted.)
  # Pass the mission FILE (not its 16KB of content) — a long --append-system-prompt
  # argument blew past tmux new-session's command-length limit ("command too long")
  # once CLAUDE.md grew, wedging the launch. The path is short; claude reads the file.
  [ -s "$home/CLAUDE.md" ] && args+=( --append-system-prompt-file "$home/CLAUDE.md" )
  args+=( --model "${model:-$DEFAULT_MODEL}" )
  # Remote Control: expose this durable session to claude.ai/code + the Claude app.
  # It's a flag on the same interactive session, so --resume/--settings/mission all
  # still apply (durability kept). TTY is provided by tmux. Name defaults to worker.
  if [ "$remote_control" = "true" ]; then
    args+=( --remote-control "${rc_name:-$name}" )
  fi

  # ---- per-worker MCP subscription (resolved LIVE against the catalog) --------
  # spec.json .mcp_servers is the operator-owned subscription (worker has Write-deny).
  # Resolve it against the LIVE catalog (~/.claude.json .mcpServers) into a temp config +
  # --strict-mcp-config so this worker loads ONLY its subscribed servers (no stale
  # snapshot; survives a server's port/command change; skips a vanished one + alerts).
  #   absent/null → no flags → inherit ALL (legacy; byte-identical to pre-feature launch)
  #   []          → strict-zero (no MCP servers)
  #   [names…]    → strict, only those that still exist in the catalog
  mcp_runtime="$home/state/mcp.runtime.json"
  mcp_notified="$home/state/.mcp-missing-notified"
  mcp_sub="$(jq -c 'if (has("mcp_servers")|not) or (.mcp_servers|type)=="null" then "none"
                    elif (.mcp_servers|type)=="array" then (.mcp_servers|map(select(type=="string"))|unique)
                    else "bad" end' "$spec" 2>/dev/null)"
  [ -n "$mcp_sub" ] || mcp_sub='"none"'   # spec unreadable → safest legacy fallback
  if [ "$mcp_sub" = '"none"' ]; then
    rm -f "$mcp_runtime" 2>/dev/null || true   # drop a stale runtime from a prior subscription
  else
    # Fail CLOSED on a malformed value: strict-zero + alert, never inherit-all on garbage,
    # never crash-loop under systemd supervision.
    if [ "$mcp_sub" = '"bad"' ]; then
      say "WARN: spec.json .mcp_servers is malformed (not an array of strings) — failing closed to strict-zero MCP"
      notify_operator "⚠️ Воркер «$name»: поле .mcp_servers в spec.json повреждено — стартую БЕЗ MCP-серверов (strict-zero). Проверь подписку."
      mcp_sub='[]'
    fi
    catalog="$(jq -c '.mcpServers // {}' "$trust_cfg" 2>/dev/null || echo '{}')"
    resolved="$(jq -nc --argjson cat "$catalog" --argjson sub "$mcp_sub" \
      '{ resolved: { mcpServers: ($cat|to_entries|map(select(.key as $k|$sub|index($k)))|from_entries) },
         missing: [ $sub[] | select(. as $k | ($cat|has($k))|not) ] }' 2>/dev/null)"
    # Write the resolved config atomically (temp in the same dir → atomic rename). We HAVE a
    # subscription here, so on ANY write failure we must NOT inherit-all (that would silently
    # over-privilege the worker). Fail CLOSED: fall back to a strict-zero config; only a true
    # disk/permission catastrophe (can't write ANY file) skips the flag, with a CRITICAL alert.
    rtmp="$mcp_runtime.tmp.$$"
    if [ -n "$resolved" ] && printf '%s' "$resolved" | jq '.resolved' > "$rtmp" 2>/dev/null \
       && [ -s "$rtmp" ] && mv "$rtmp" "$mcp_runtime" 2>/dev/null; then
      chmod 600 "$mcp_runtime" 2>/dev/null || true
      args+=( --strict-mcp-config --mcp-config "$mcp_runtime" )
    else
      rm -f "$rtmp" 2>/dev/null || true
      if printf '%s\n' '{"mcpServers":{}}' > "$mcp_runtime" 2>/dev/null; then
        chmod 600 "$mcp_runtime" 2>/dev/null || true
        args+=( --strict-mcp-config --mcp-config "$mcp_runtime" )
        say "WARN: could not build resolved MCP config — failing CLOSED to strict-zero (no servers)"
        notify_operator "⚠️ Воркер «$name»: не смог собрать MCP-набор — стартую БЕЗ серверов (strict-zero, fail-closed). Проверь подписку/каталог."
      else
        say "CRITICAL: cannot write any MCP runtime config ($mcp_runtime) — launching WITHOUT --mcp-config (inherits all). Investigate disk/permissions."
        notify_operator "🔴 Воркер «$name»: не смог записать MCP-конфиг ВООБЩЕ ($home/state) — стартую с НАСЛЕДОВАНИЕМ всех серверов. Проверь диск/права."
      fi
    fi
    # Alert on subscribed-but-vanished servers (deduped by set hash; cleared on recovery).
    missing="$(printf '%s' "$resolved" | jq -c '.missing // []' 2>/dev/null)"
    if [ -n "$missing" ] && [ "$missing" != '[]' ]; then
      mhash="$(printf '%s' "$missing" | sha1sum 2>/dev/null | cut -c1-16)"
      if [ "$(cat "$mcp_notified" 2>/dev/null)" != "$mhash" ]; then
        say "subscribed MCP server(s) not in catalog — skipped: $missing"
        notify_operator "⚠️ Воркер «$name»: подписан на MCP-серверы, которых нет в каталоге — пропущены: $(printf '%s' "$missing" | jq -r 'join(", ")' 2>/dev/null). Обнови подписку (бот → 🧩 MCP-серверы)."
        printf '%s' "$mhash" > "$mcp_notified" 2>/dev/null || true
      fi
    else
      rm -f "$mcp_notified" 2>/dev/null || true   # recovery: clear so a later disappearance re-alerts
    fi
  fi

  say "launching: ${seeded:+resume }$session_id mode=$mode cwd=$cwd"
  # tmux -e passes env with NO shell parsing (robust). Worker-scoped env points
  # event-bridge at this worker's probe config + dedup state.
  # Suppress the interactive "resume from summary / full / don't ask" prompt that
  # claude shows for a large/old session on --resume. A headless worker has no one
  # to answer it and would WEDGE on every restart/reboot once its session grows.
  # Push both thresholds out of reach so the worker always resumes FULL (no context
  # loss) non-interactively; unbounded growth is handled by controlled compaction.
  #
  # One-time migration safety: reap a stale OWN orphan on the DEFAULT socket before launching
  # on our per-worker socket. Matters only during the switch to per-worker sockets: if this
  # unit restarts (e.g. a supervisor crash) while an OLD default-socket session is still
  # alive, a second `claude --resume <same id>` would double-write the transcript. We reap it
  # first to prevent that. (TMUX= forces the default socket regardless of any inherited $TMUX.)
  # Guard by the CLAUDE_AUTO_NAME marker the session was launched with (-e, below) so we kill
  # ONLY our own worker orphan — never an unrelated default-socket session that merely shares
  # the name, e.g. a claude-rc project session (also named claude-<x>; it sets CCR_*, never
  # CLAUDE_AUTO_NAME). A harmless no-op once no worker uses the default socket.
  # T4: этот reap адресует ДЕФОЛТНЫЙ tmux-сокет (без -L; TMUX= обнуляет унаследованный) — он
  # ОБЩИЙ с реальным tmux оператора. Обернуть в process_control_tmux НЕЛЬЗЯ: тот форсит свой
  # сокет (-L claude-<name> / -S <root>/tmux.sock) и сменил бы адресацию default→named,
  # сломав смысл reap'а БЕЗ маркера. Поэтому под тестовым маркером блок ПРОПУСКАЕТСЯ (в
  # песочнице легаси-сессии на дефолтном сокете нет и быть не может — kill там мог бы задеть
  # настоящую сессию claude-<name>); без маркера — выполняется побитово как раньше. Гейт —
  # тем же резолвером маркера, что и весь guard (пустой stdout при rc 0 = маркера нет).
  _car_test_root="$(_process_control_test_root)" && _car_resolver_ok=1 || _car_resolver_ok=0
  if [ "$_car_resolver_ok" = 1 ] && [ -z "$_car_test_root" ]; then
    # shellcheck disable=SC1007  # `TMUX= tmux …` — НАМЕРЕННО: пустое TMUX только для этой
    # команды (обращение к ДЕФОЛТНОМУ сокету из-под tmux-сессии), а не присваивание.
    if [ "$(TMUX= tmux show-environment -t "$sess" CLAUDE_AUTO_NAME 2>/dev/null)" = "CLAUDE_AUTO_NAME=$name" ]; then
      # shellcheck disable=SC1007  # то же самое, см. выше
      TMUX= tmux kill-session -t "$sess" 2>/dev/null || true
      say "reaped stale default-socket orphan $sess (pre-per-socket migration)"
    fi
  fi
  process_control_tmux "$name" new-session -d -s "$sess" -c "$cwd" \
    -e "EVENT_BRIDGE_CONFIG=$home/event-bridge.config.json" \
    -e "EVENT_BRIDGE_STATE_DIR=$home/state" \
    -e "CLAUDE_AUTO_NAME=$name" \
    -e "CLAUDE_AUTO_HOME=$home" \
    -e "CLAUDE_CODE_RESUME_TOKEN_THRESHOLD=999999999" \
    -e "CLAUDE_CODE_RESUME_THRESHOLD_MINUTES=999999999" \
    "${args[@]}" 2>>"$log" \
    || { say "tmux new-session failed"; exit 1; }

  # Seeding is confirmed on the worker's FIRST turn (when $wfile appears); the
  # supervise loop below flips it. Try briefly here too in case it's fast.
  for _ in $(seq 1 10); do flip_seeded_if_ready; [ "$seeded" = "true" ] && break; sleep 1; done
fi

# Start the per-worker event watcher (delivers external events as user turns via
# session-inject). Self-terminates when the tmux session ends; flock keeps it
# single-instance across supervisor restarts.
WATCH="$(dirname "$0")/event-bridge-watch"
if [ -x "$WATCH" ]; then
  setsid "$WATCH" "$name" >/dev/null 2>&1 &
  say "event watcher started"
fi

# Controlled compaction (H): the heartbeat hook drops a compact_requested
# flag when the transcript's latest usage exceeds the threshold. Here we honor it
# by injecting `/compact` (a slash command must be TYPED — a channel body would
# be treated as data, not parsed). session-inject only types when the TUI is idle
# and no approval prompt is up, so this can't land mid-turn or over a dialog. A
# cooldown prevents double-compaction and racing the native auto-compact backstop.
INJECT="$(dirname "$0")/session-inject"
COMPACT_FLAG="$home/state/compact_requested"
COMPACT_COOLDOWN="${CLAUDE_AUTO_COMPACT_COOLDOWN:-900}"
COMPACT_LAST="$home/state/.last_compact"
COMPACT_MSG='/compact Preserve verbatim: the mission and operating bounds, the current task state and progress, any open questions, and the immediate next steps.'

maybe_compact() {
  [ -f "$COMPACT_FLAG" ] || return 0
  local now last=0
  now="$(date +%s)"
  [ -f "$COMPACT_LAST" ] && last="$(cat "$COMPACT_LAST" 2>/dev/null || echo 0)"
  [ "$last" -eq "$last" ] 2>/dev/null || last=0
  [ $(( now - last )) -lt "$COMPACT_COOLDOWN" ] && return 0   # cooldown active
  say "compact_requested set — injecting /compact"
  if [ -x "$INJECT" ] && "$INJECT" --timeout 120 "$sess" "$COMPACT_MSG" >>"$log" 2>&1; then
    date +%s > "$COMPACT_LAST"
    rm -f "$COMPACT_FLAG"
    c="$(cat "$home/state/compactions" 2>/dev/null || echo 0)"; [[ "$c" =~ ^[0-9]+$ ]] || c=0
    echo $(( c + 1 )) > "$home/state/compactions"
    say "/compact injected"
  else
    say "/compact injection deferred (session busy or inject failed) — will retry"
  fi
}

# Liveness watchdog (Phase 1: ALERT-ONLY, no auto-recovery). An unattended worker can
# WEDGE on a blocking interactive TUI prompt nobody will answer — a first-run upsell
# (the "fullscreen renderer" modal), a folder-trust / "new MCP server" dialog from a
# future Claude Code update, or an `ask`-rule permission prompt. While wedged the main
# loop is frozen: it stops processing event-bridge wakeups. `tui:"default"` kills the one
# known upsell, but this catches the GENERAL class. We only ALERT the operator (never
# auto-dismiss — sending a key could wrongly answer a real prompt; Codex). Detection:
# a CHOICE/confirm dialog (not a running turn) whose pane region stays UNCHANGED for
# >= CLAUDE_AUTO_WEDGE_MINUTES (a real prompt during work clears fast; a wedge persists).
# One alert per episode (dedup by signature); cleared the moment the dialog goes away.
WEDGE_FLAG="$home/state/.wedge"
WEDGE_MIN="${CLAUDE_AUTO_WEDGE_MINUTES:-15}"
[[ "$WEDGE_MIN" =~ ^[0-9]+$ ]] || WEDGE_MIN=15   # sanitize env override
maybe_alert_wedged() {
  local pane tail sig now osig first alerted
  pane="$(process_control_tmux "$name" capture-pane -pt "$sess" 2>/dev/null)" || return 0
  # A running turn ('esc to interrupt') is progress, NOT a wedge → reset and bail.
  if printf '%s' "$pane" | grep -qiE 'esc to interrupt'; then rm -f "$WEDGE_FLAG" 2>/dev/null; return 0; fi
  # Look ONLY at the active bottom region — a blocking dialog always lives at the input
  # line; matching the whole pane would false-trigger on prompt-like TEXT scrolled up in
  # history (tool output / event payloads). Patterns aligned with worker_busy + session-inject.
  tail="$(printf '%s' "$pane" | grep -vE '^[[:space:]]*$' | tail -8)"
  if ! printf '%s' "$tail" | grep -qiE 'Do you want to|Would you like|Enter to confirm|permission to use|Allow .* to (run|use|edit|create|read)|Allow this|❯ ?[0-9]+\.|[0-9]+\. (Yes|No|Allow|Deny)|Continue\?|new MCP server|trust .*(folder|directory)|resume .*(summary|session)'; then
    rm -f "$WEDGE_FLAG" 2>/dev/null; return 0   # no dialog in the tail → worker progressed → reset
  fi
  # Signature of the dialog tail. Stable while wedged; a live turn's spinner/clock would
  # change it (and 'esc to interrupt' is excluded above anyway).
  sig="$(printf '%s' "$tail" | sha1sum 2>/dev/null | cut -c1-12)"
  now="$(date +%s)"
  if [ -f "$WEDGE_FLAG" ]; then
    read -r osig first alerted < "$WEDGE_FLAG" 2>/dev/null || { osig=""; first="$now"; alerted=0; }
    [[ "$first" =~ ^[0-9]+$ ]] || first="$now"     # decimal-only (avoid octal/arith crash)
    [[ "$alerted" =~ ^[01]$ ]] || alerted=0
    if [ "$osig" != "$sig" ]; then printf '%s %s 0\n' "$sig" "$now" > "$WEDGE_FLAG"; return 0; fi
  else
    printf '%s %s 0\n' "$sig" "$now" > "$WEDGE_FLAG"; return 0
  fi
  [ "$alerted" = "1" ] && return 0                              # already alerted this episode
  [ $(( (now - 10#$first) / 60 )) -ge "$WEDGE_MIN" ] || return 0 # not stable long enough yet
  local mins=$(( (now - 10#$first) / 60 )) excerpt
  excerpt="$(printf '%s' "$tail" | tail -6 | tr -d '\000-\010\013\014\016-\037' | cut -c1-200)"
  say "WEDGE: stuck on an interactive prompt for >=${WEDGE_MIN}m — alerting operator"
  notify_operator "⚠️ Воркер «$name» завис на интерактивном промпте уже ~${mins} мин — не обрабатывает события. Открой 'tmux -L claude-$name attach -t claude-$name' и реши, или перезапусти ('claude-auto restart $name'). Низ экрана:
$excerpt"
  printf '%s %s 1\n' "$sig" "$first" > "$WEDGE_FLAG"
}

# Block until the session ends. This keeps the systemd unit's main process alive
# for the worker's lifetime; when claude exits/crashes the loop returns, the unit
# exits, and Restart=always brings it back (resuming the pinned session).
while process_control_tmux "$name" has-session -t "$sess" 2>/dev/null; do
  flip_seeded_if_ready
  maybe_alert_wedged
  maybe_compact
  sleep 5
done
say "tmux session $sess ended — exiting (systemd will restart unless stopped)"
exit 0
