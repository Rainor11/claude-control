#!/usr/bin/env bash
# claude-auto-request — let an autonomous worker REQUEST a bounded, operator-approved
# action from a CLOSED catalog, delivered over the @RnR_Workers bot as a card with
# ✅/❌ buttons. The worker only REGISTERS the request (an 'open' row in the shared
# approvals DB); the BOT renders + sends the canonical card from that row, claims the
# operator's decision once-only, and (on ✅) EXECUTES the action itself. The worker
# NEVER mutates the whitelist or sends the message — it just asks and PARKS.
#
# Closed catalog (anything else is refused — no arbitrary command approval):
#   whitelist-add    --entry tg:<id>|email:<addr>   add a contact to MY people-allow
#   whitelist-remove --entry tg:<id>|email:<addr>   remove one
#   one-time-send    --to tg:<id> --body '<text>'   send ONE Telegram message without
#                                                    permanently whitelisting (TG only)
#   mcp-add          --server <name>                add an MCP server (from the catalog
#                                                    ONLY) to MY subscription + restart me
#   dept-approval    --event-id evt_… [--summary '<s>'] [--detail '<d>']
#                                                    ask the operator to resolve a
#                                                    department-ledger approval (bot writes
#                                                    approval-resolve itself, not me).
#                                                    --summary/--detail are OPTIONAL and
#                                                    advisory only — the card is always
#                                                    built from the CANONICAL summary/detail
#                                                    read straight from the ledger by
#                                                    event_id (a mismatching caller value is
#                                                    ignored with a stderr warning): the bot
#                                                    resolves BY event_id, so trusting the
#                                                    caller's text would let it show the
#                                                    operator one thing and resolve another.
#
# Operator-only BY CONSTRUCTION (same guarantees as claude-auto-ask):
#   * worker identity is the spoof-resistant /proc ancestor (resolve_name), NOT
#     CLAUDE_AUTO_NAME — so the request is bound to THIS worker's own name/whitelist;
#   * recipient (operator chat_id) is read from a FIXED absolute .env;
#   * this helper writes only an 'open' approvals row — it cannot whitelist or send;
#   * dept-approval's card text is read canonically from the ledger (see above), not
#     trusted from the caller's argv — anti-forge for the one action that resolves
#     something the caller doesn't own outright (a department-ledger approval).
#
# Usage (worker-facing):
#   claude-auto-request --action whitelist-add  --entry email:a@b.ru --reason '…'
#   claude-auto-request --action whitelist-remove --entry tg:12345 --reason '…'
#   claude-auto-request --action one-time-send  --to tg:12345 --body '…' --reason '…'
#   claude-auto-request --action mcp-add --server google-workspace --reason '…'
# Allow in a worker by ABSOLUTE path only:
#   Bash(/opt/projects/active/claude-control/bin/claude-auto-request:*)
set -u

OPERATOR_ENV="/home/rainor/server/.env"
CLAUDE_INSTALL="/home/rainor/.local/share/claude"        # trusted claude tree
DB="/opt/projects/active/claude-control/bot/rnr_db.py"
BINDIR="$(cd "$(dirname "$0")" && pwd)"
DEPT_LEDGER_BIN="$BINDIR/dept-ledger"                     # canonical source for dept-approval card text
MCP_CATALOG_FILE="${MCP_CATALOG_FILE:-$HOME/.claude.json}"  # MCP catalog (source of truth)
BODY_MAX=2000
REASON_MAX=400
SUMMARY_MAX=400
DETAIL_MAX=2000

die() { echo "claude-auto-request: $*" >&2; exit 1; }

# UTF-8-safe truncation to N CHARS. `cut -c` cuts BYTES and can split a multibyte
# char in half — the resulting lone-surrogate argv used to crash the sqlite insert
# (UnicodeEncodeError) and the whole request with it. python3 is already required.
utf8_trunc() {
  python3 -c 'import sys;sys.stdout.buffer.write(sys.stdin.buffer.read().decode("utf-8","replace")[:int(sys.argv[1])].encode("utf-8"))' "$1"
}

# ---- identity (spoof-resistant) — mirrors claude-auto-send/self-probes resolve_name --
resolve_name() {
  local pid="$PPID" depth=0 nm exe
  while [ "${pid:-0}" -gt 1 ] && [ "$depth" -lt 25 ]; do
    # --resume ИЛИ --session-id — fresh-запуск spawn/rebase (claude --session-id <W>
    # без --resume до первого рестарта). Остальные проверки (exe в CLAUDE_INSTALL,
    # CLAUDE_AUTO_NAME из environ предка) не меняются — спуф-стойкость сохранена.
    if tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null | grep -qxE -- '--resume|--session-id'; then
      exe="$(readlink -f "/proc/$pid/exe" 2>/dev/null)"
      case "$exe" in
        "$CLAUDE_INSTALL"/*)
          nm="$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null | sed -n 's/^CLAUDE_AUTO_NAME=//p' | head -1)"
          [ -n "$nm" ] && { printf '%s' "$nm"; return 0; }
          ;;
      esac
    fi
    pid="$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null)"
    depth=$((depth+1))
  done
  return 1
}

# ---- args ----
ACTION=""; ENTRY=""; TO=""; BODY=""; SUBJECT=""; REASON=""; SERVER=""
EVENT_ID=""; SUMMARY=""; DETAIL=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --action)   ACTION="${2-}";   shift 2 || die "missing --action value" ;;
    --entry)    ENTRY="${2-}";    shift 2 || die "missing --entry value" ;;
    --to)       TO="${2-}";       shift 2 || die "missing --to value" ;;
    --body)     BODY="${2-}";     shift 2 || die "missing --body value" ;;
    --subject)  SUBJECT="${2-}";  shift 2 || die "missing --subject value" ;;
    --server)   SERVER="${2-}";   shift 2 || die "missing --server value" ;;
    --reason)   REASON="${2-}";   shift 2 || die "missing --reason value" ;;
    --event-id) EVENT_ID="${2-}"; shift 2 || die "missing --event-id value" ;;
    --summary)  SUMMARY="${2-}";  shift 2 || die "missing --summary value" ;;
    --detail)   DETAIL="${2-}";   shift 2 || die "missing --detail value" ;;
    *) die "unknown arg '$1'" ;;
  esac
done

case "$ACTION" in
  whitelist-add|whitelist-remove|one-time-send|mcp-add|dept-approval) ;;
  "") die "missing --action (whitelist-add|whitelist-remove|one-time-send|mcp-add|dept-approval)" ;;
  *)  die "unknown --action '$ACTION' (closed catalog: whitelist-add|whitelist-remove|one-time-send|mcp-add|dept-approval)" ;;
esac

command -v python3 >/dev/null 2>&1 || die "python3 required"
[ -f "$DB" ] || die "db helper unavailable ($DB)"

# ---- validate a kind:value entry (mirror claude-auto allow / people-gate validators) --
# Echoes "<kind> <value>" on success.
parse_entry() {
  local e="$1" kind val
  case "$e" in
    tg:*)    kind=tg;    val="${e#tg:}";    [[ "$val" =~ ^-?[0-9]+$ ]] || die "tg chat_id must be numeric: '$val'" ;;
    email:*) kind=email; val="${e#email:}"
             case "$val" in *[[:space:]]*|*[!A-Za-z0-9._%+@-]*) die "email has illegal chars: '$val'" ;; esac
             case "$val" in *@*.*) ;; *) die "email looks invalid (need addr@dom.tld): '$val'" ;; esac
             val="$(printf '%s' "$val" | tr '[:upper:]' '[:lower:]')" ;;
    *) die "entry must be tg:<chat_id> or email:<addr> (got: '$e')" ;;
  esac
  printf '%s %s' "$kind" "$val"
}

ARG_KIND=""; ARG_VALUE=""; PAYLOAD=""
case "$ACTION" in
  whitelist-add|whitelist-remove)
    [ -n "$ENTRY" ] || die "--entry tg:<id>|email:<addr> required for $ACTION"
    # NB: parse_entry `die`s inside $(...) which only exits the SUBSHELL — so capture
    # its output AND propagate the exit (|| exit 1), else a bad entry would silently
    # yield empty ARG_KIND/ARG_VALUE and register a malformed request.
    parsed="$(parse_entry "$ENTRY")" || exit 1
    read -r ARG_KIND ARG_VALUE <<<"$parsed"
    ;;
  one-time-send)
    [ -n "$TO" ] || die "--to tg:<id> required for one-time-send"
    parsed="$(parse_entry "$TO")" || exit 1
    read -r ARG_KIND ARG_VALUE <<<"$parsed"
    [ "$ARG_KIND" = tg ] || die "one-time-send supports only TG in v1 (--to tg:<id>); for email use --action whitelist-add"
    [ -n "$BODY" ] || die "--body '<text>' required for one-time-send"
    # strip control bytes (keep tab/newline), cap (bidi-strip happens in the bot's renderer)
    PAYLOAD="$(printf '%s' "$BODY" | tr -d '\000-\010\013\014\016-\037' | utf8_trunc "$BODY_MAX")"
    [ -n "${PAYLOAD//[[:space:]]/}" ] || die "--body is empty after sanitization"
    ;;
  mcp-add)
    # Request to add an MCP server to MY subscription. The server MUST be in the live
    # catalog — a worker can only request a REAL server, never invent one. The bot adds
    # it (claude-auto mcp-add) + restarts me on ✅. arg_value carries the server name.
    [ -n "$SERVER" ] || die "--server <name> required for mcp-add"
    [[ "$SERVER" =~ ^[a-zA-Z0-9_-]+$ ]] || die "mcp-add: bad server name '$SERVER' (use [a-zA-Z0-9_-])"
    command -v jq >/dev/null 2>&1 || die "mcp-add: jq required to validate the server against the catalog"
    [ -f "$MCP_CATALOG_FILE" ] && jq -e --arg k "$SERVER" '(.mcpServers // {}) | has($k)' "$MCP_CATALOG_FILE" >/dev/null 2>&1 \
      || die "mcp-add: '$SERVER' is not in the MCP catalog ($MCP_CATALOG_FILE) — you may request only a catalog server"
    ARG_KIND=mcp; ARG_VALUE="$SERVER"
    ;;
  dept-approval)
    # Called by dept-approve (department flow), not typed ad hoc — event_id comes from a
    # dept-ledger approval-open row it already holds. arg_value carries the event_id; the
    # bot resolves it (approval-resolve) on decision — no reason field for this action.
    [ -n "$EVENT_ID" ] || die "--event-id required for dept-approval"
    printf '%s' "$EVENT_ID" | grep -qE '^evt_[0-9]+_[a-z0-9]{4}$' || die "malformed --event-id: '$EVENT_ID'"
    # Canonical card text comes from the ledger, NEVER from the caller's --summary/--detail:
    # the bot resolves this approval BY event_id (exec_dept_resolve in rnr_workers_bot.py),
    # not by matching the card text — so if the caller could freely set what the operator
    # reads, it could show one thing and have a DIFFERENT (or already-closed/stale) approval
    # resolved. --status open scopes the lookup to kind=approval AND currently-open in one
    # shot (die below covers: not found / wrong kind / already resolved — all indistinguishable
    # from "not currently an open approval under this event_id", which is the actual invariant
    # we need).
    [ -x "$DEPT_LEDGER_BIN" ] || die "dept-approval: dept-ledger недоступен ($DEPT_LEDGER_BIN)"
    canon_list="$("$DEPT_LEDGER_BIN" list --kind approval --status open)" \
      || die "dept-approval: dept-ledger list не удался"
    canon_summary="$(CANON_LIST="$canon_list" CANON_EVENT_ID="$EVENT_ID" node -e '
      const id = process.env.CANON_EVENT_ID;
      for (const line of (process.env.CANON_LIST || "").split("\n")) {
        if (!line.trim()) continue;
        let e; try { e = JSON.parse(line); } catch { continue; }
        if (e.event_id === id && e.kind === "approval") { process.stdout.write(e.data.summary || ""); process.exit(0); }
      }
      process.exit(1);
    ')" || die "dept-approval: аппрув '$EVENT_ID' не найден среди открытых в ledger (не существует, не approval, или уже resolved) — карточка не может быть построена"
    canon_detail="$(CANON_LIST="$canon_list" CANON_EVENT_ID="$EVENT_ID" node -e '
      const id = process.env.CANON_EVENT_ID;
      for (const line of (process.env.CANON_LIST || "").split("\n")) {
        if (!line.trim()) continue;
        let e; try { e = JSON.parse(line); } catch { continue; }
        if (e.event_id === id && e.kind === "approval") { process.stdout.write(e.data.detail || ""); process.exit(0); }
      }
      process.exit(1);
    ')"
    # caller-supplied --summary/--detail are now optional and purely advisory: a mismatch
    # is warned about (so a divergent caller is visible in logs) but never trusted — the
    # ledger's own record always wins.
    [ -n "$SUMMARY" ] && [ "$SUMMARY" != "$canon_summary" ] && \
      echo "claude-auto-request: warning: dept-approval caller --summary расходится с ledger — использую каноническую версию из ledger" >&2
    [ -n "$DETAIL" ] && [ "$DETAIL" != "$canon_detail" ] && \
      echo "claude-auto-request: warning: dept-approval caller --detail расходится с ledger — использую каноническую версию из ledger" >&2
    SUMMARY="$canon_summary"
    DETAIL="$canon_detail"
    # strip control bytes first (mirrors --body/--reason below) so invisible padding can't
    # trip the length die, then cap — summary is a headline the operator decides from, so an
    # oversized one is REJECTED (not silently mangled, unlike the more free-form detail).
    SUMMARY="$(printf '%s' "$SUMMARY" | tr -d '\000-\010\013\014\016-\037')"
    [ "${#SUMMARY}" -le "$SUMMARY_MAX" ] || die "--summary too long (>${SUMMARY_MAX} chars)"
    [ -n "$DETAIL" ] && DETAIL="$(printf '%s' "$DETAIL" | tr -d '\000-\010\013\014\016-\037' | utf8_trunc "$DETAIL_MAX")"
    ARG_KIND=event_id; ARG_VALUE="$EVENT_ID"
    # Operator feedback 16.07: the card's first line was visually DOUBLED — detail templates
    # (dept-request-render) open with the same headline phrase as the summary. If detail's
    # first line equals the summary (trimmed, case-insensitive — templates only differ in
    # the leading capital), drop the summary prefix and send detail alone. python3 (already
    # required) does the compare: casefold() is UTF-8-aware, unlike `tr` in a C locale.
    PAYLOAD="$SUMMARY"
    if [ -n "$DETAIL" ]; then
      if python3 -c 'import sys
s, d = sys.argv[1], sys.argv[2]
sys.exit(0 if d.split("\n", 1)[0].strip().casefold() == s.strip().casefold() else 1)' "$SUMMARY" "$DETAIL"; then
        PAYLOAD="$DETAIL"
      else
        PAYLOAD="$SUMMARY

$DETAIL"
      fi
    fi
    ;;
esac

# ---- reason (sanitize, cap) ----
if [ -n "$REASON" ]; then
  REASON="$(printf '%s' "$REASON" | tr -d '\000-\010\013\014\016-\037' | utf8_trunc "$REASON_MAX")"
fi

# ---- operator chat_id (fixed; not worker-controlled) ----
OPERATOR_CHAT_ID="$(awk -F= '/^TELEGRAM_CHAT_ID=/{gsub(/[^0-9]/,"",$2);print $2;exit}' "$OPERATOR_ENV" 2>/dev/null)"
[ -n "$OPERATOR_CHAT_ID" ] || die "operator chat_id unavailable ($OPERATOR_ENV)"

# ---- identity ----
NAME="$(resolve_name)" || die "cannot determine worker identity (run from inside a worker session)"
[[ "$NAME" =~ ^[a-zA-Z0-9_-]+$ ]] || die "resolved worker name '$NAME' has illegal chars"

# ---- register the request (unique qid; retry on PK collision) ----
gen_qid() { LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 16; }
qid=""
for _try in 1 2 3 4 5; do
  cand="$(gen_qid)"; [ -n "$cand" ] || die "qid generation failed"
  args=(insert-approval --qid "$cand" --worker "$NAME" --tmux-target "claude-$NAME"
        --chat-id "$OPERATOR_CHAT_ID" --action "$ACTION")
  [ -n "$ARG_KIND" ]  && args+=(--arg-kind "$ARG_KIND")
  [ -n "$ARG_VALUE" ] && args+=(--arg-value "$ARG_VALUE")
  [ -n "$PAYLOAD" ]   && args+=(--payload "$PAYLOAD")
  [ -n "$REASON" ]    && args+=(--reason "$REASON")
  # rc захватываем СРАЗУ после команды (не после `if ...; then ... fi`) — bash отдаёт
  # exit-код самого if-compound'а (0, если ветка then не выполнилась и elif/else нет),
  # а не exit-код упавшего условия. С захватом после `fi` retry по rc=3 (qid-коллизия)
  # был мёртв, а die ниже врал "rc=0" на любой реальной ошибке (найдено ревью T2, копия
  # того же паттерна из dept-liveness-request).
  python3 "$DB" "${args[@]}" 2>/dev/null
  rc=$?
  if [ "$rc" = 0 ]; then qid="$cand"; break; fi
  [ "$rc" = 3 ] && continue
  die "could not register the request (db error rc=$rc)"
done
[ -n "$qid" ] || die "could not allocate a unique qid"

echo "claude-auto-request: запрос «$ACTION» отправлен оператору на одобрение (qid=$qid). ПАРКУЙСЯ — придёт решение (✅/❌) новым ходом; НЕ ретрай, продолжай другую работу."
exit 0
