#!/bin/bash
# dept-planerka-exec — планёрка отдела: РАССЫЛКА правил по шине (фаза 4).
#
# Было (фазы 2-3): пересборка сессий всего активного флота через claude-auto rebase.
# Проблема, вскрытая боем: у МК с живым клиентским контекстом rebase упирался в STALE-гард
# → 🔴-сегмент «ошибки, разберись» на каждой планёрке (штатная защита, читалась как сбой),
# а успешный rebase сбрасывал контекст живого обсуждения ради перечитывания правил.
#
# Стало (решение оператора 17.07): планёрка = типизированное сообщение шины «перечитай
# policy-vN + ack» активным воркерам. Сессии не трогаются. Спящих не будим (догонят
# турникетом при первом approve после пробуждения). Rebase остаётся ТОЛЬКО гигиене
# (dept-rebase-check: возраст/компакции) и mission-update.
#
# Busy-воркеры отдельной обработки не требуют: доставку делает event-bridge-watch с
# backoff и карантином — отсюда ушли ретрай-бюджет и PLANERKA_RETRY_SLEEP.
#
# Режимы: --approval <event_id> (диспетчер, с anti-forge сверкой detail↔request)
#         --reason '<s>'        (оператор напрямую)
set -u
BINDIR="$(cd "$(dirname "$0")" && pwd)"
DL="$BINDIR/dept-ledger"; RR="$BINDIR/dept-request-render"
CONTROL_DIR="${CLAUDE_CONTROL_DIR:-$HOME/.claude-control}"
NOTIFY="${TELEGRAM_NOTIFY:-/home/rainor/server/server_monitor/telegram_notify.sh}"
die() { echo "dept-planerka-exec: $*" >&2; exit 1; }

approval="" reason=""
while [ $# -gt 0 ]; do
  case "$1" in
    # M2: bare "$2" под set -u падает уродливым "unbound variable" на флаге без значения;
    # "${2:-}" один не спасает — если проверку на пусто НЕ сделать до shift 2, shift 2 при
    # $#=1 молча провалится (не сдвинет $1) и while зациклится навечно. Проверка ДО shift.
    --approval) approval="${2:-}"; [ -n "$approval" ] || die "--approval требует значения"; shift 2 ;;
    --reason) reason="${2:-}"; [ -n "$reason" ] || die "--reason требует значения"; shift 2 ;;
    *) die "unknown arg: $1" ;;
  esac
done

deptReg="$("$DL" registry-list)" || die "registry-list не удался"
# Дефолтный отправитель — Руководитель отдела (единственная роль «руководитель» в
# реестре), а не буквально "operator": даже прямой --reason (оператор жмёт кнопку
# руками) рассылается ОТ ИМЕНИ Руководителя — это его ack'и потом трекать (R2).
head_worker="$(printf '%s' "$deptReg" | jq -r '.workers | to_entries[] | select(.value.role=="руководитель") | .key' | head -n1)"
requester="${head_worker:-operator}"

if [ -n "$approval" ]; then
  row="$("$DL" list --kind approval --event-id "$approval")" || die "аппрув не найден"
  [ -n "$row" ] || die "аппрув не найден: $approval"
  kind_of_row="$(jq -r '.data.kind_of // empty' <<<"$row")"
  [ "$kind_of_row" = "planerka" ] || die "аппрув $approval имеет kind_of=$kind_of_row, ожидался planerka"
  request_json="$(jq -c '.data.request // {}' <<<"$row")"
  ledger_detail="$(jq -r '.data.detail // empty' <<<"$row")"
  rendered_detail="$("$RR" planerka "$request_json")" || die "detail ≠ request — заявка подделана или повреждена, исполнять нельзя (рендер не удался)"
  [ "$rendered_detail" = "$ledger_detail" ] || die "detail ≠ request — заявка подделана или повреждена, исполнять нельзя"
  reason="$(jq -r '.reason // empty' <<<"$request_json")"
  # Отправитель рассылки — автор заявки (Руководитель): он же контролирует ack'и (R2).
  requester="$(jq -r '.data.from // "operator"' <<<"$row")"
fi
reason="${reason:-плановая планёрка}"

pol="$("$DL" policy-current)" || die "policy-current не удался"
pver="$(jq -r '.version' <<<"$pol")"; pfile="$(jq -r '.file' <<<"$pol")"
[ -n "$pver" ] && [ "$pver" != "null" ] || die "не удалось определить действующую версию правил"

targets="$(printf '%s' "$deptReg" | jq -r '.workers | to_entries[] | select(.value.role as $r | ["руководитель","мк","архивариус","тп"] | index($r)) | .key')"

# Кап reason в body: адаптер шины (ledger-messages) режет body до 300 символов МОЛЧА —
# без капа хвост инструкции (путь к правилам + команда ack) не доехал бы до воркера.
# Обрезка ПО КОДОВЫМ ТОЧКАМ через jq, а не `cut -c`: `cut -c` в этом окружении режет по
# БАЙТАМ независимо от локали (проверено: 400×«о» → cut -c1-80 отдаёт 40 символов, не 80,
# и на нечётной границе байт разрезал бы мультибайтный UTF-8 символ пополам).
reason_short="$(printf '%s' "$reason" | jq -Rsr '.[0:80]')"
subject="Планёрка: перечитай правила $pver и подтверди"
# Абсолютный путь к dept-ledger (не bare-имя) — policy 3.0: bare-имени нет в PATH воркера.
body="Причина: ${reason_short}. Перечитай ${pfile} и выполни: ${DL} policy-ack --version ${pver}"

# M3: reason_short капает ТОЛЬКО reason — ${pfile}/${DL}/${pver} капа не имеют. При переезде
# путей (длиннее сегодняшних $DL/pfile) итоговый body может перевалить за 300 и хвост
# (команда ack) молча срежется адаптером шины (channels/event-bridge/adapters/ledger-messages
# .slice(0,300)) — воркер получит инструкцию без команды, которую выполнить. Runtime-гард
# ловит это ДО отправки, а не после того как ack не пришёл ни от кого.
body_len="$(printf '%s' "$body" | jq -Rs 'length')"
[ "$body_len" -le 300 ] \
  || die "body планёрки $body_len симв. > 300 — адаптер шины молча обрежет команду ack; сократи путь policy-файла или dept-ledger ($pfile / $DL)"

sent=(); sleeping_list=(); failed=()
while IFS= read -r w; do
  [ -n "$w" ] || continue
  wstate="$(jq -r --arg n "$w" '.workers[$n].state // empty' "$CONTROL_DIR/autonomous.json" 2>/dev/null)"
  if [ "$wstate" = "sleeping" ]; then
    sleeping_list+=("$w")
    echo "$w: спит — пропуск (решение 17.07: не будим; догонит турникетом при первом approve)"
    continue
  fi
  if [ "$wstate" != "active" ]; then
    echo "$w: state=${wstate:-нет в autonomous.json} — пропуск (не active/sleeping)"
    continue
  fi
  if "$DL" send --type policy_refresh --to "$w" --subject "$subject" --body "$body" --actor "$requester" >/dev/null 2>&1; then
    sent+=("$w"); echo "$w: policy_refresh $pver отправлен"
  else
    failed+=("$w"); echo "$w: ОТПРАВКА НЕ УДАЛАСЬ" >&2
  fi
done <<<"$targets"

summary="Планёрка отдела («$reason»): разослано ${pver} — ${sent[*]:-нет}; спят (пропущены, догонят турникетом) — ${sleeping_list[*]:-нет}; 🔴 не разослано — ${failed[*]:-нет}. Сессии не пересобирались; ack'и контролирует Руководитель."
echo "$summary"
"$NOTIFY" "$summary" >/dev/null 2>&1 || echo "dept-planerka-exec: notify FAILED" >&2
# Частичная рассылка — НЕ успех (Codex важное №11): «разослано 5 из 7» с exit 0 дало бы
# executed на карточке, и оператор увидел бы 🔴 только внутри текста сводки. Ненулевой код
# → раннер пишет exec_failed + шлёт «🔴 НЕ исполнено» с хвостом лога.
# Повторный прогон безопасен: воркер, получивший второй policy_refresh, перечитает правила
# ещё раз — это no-op (policy-ack идемпотентен по версии, повторный ack той же vN штатен).
if [ "${#failed[@]}" -gt 0 ]; then
  echo "dept-planerka-exec: не доставлено ${#failed[@]} воркерам: ${failed[*]}" >&2
  exit 1
fi
exit 0
