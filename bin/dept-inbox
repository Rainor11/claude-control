#!/usr/bin/env node
// dept-inbox — read-only веб-дашборд «Цифровой отдел» поверх ledger отдела (Task 9, фаза 3).
// Слушает ТОЛЬКО 127.0.0.1; наружу — через Angie-vhost с basic auth.
// Никаких записей: решения — кнопками в TG-боте. Только http-сервер + dl() + сборщики
// данных + маршрутизация; весь HTML — в bin/dept-inbox-render.js.
'use strict';
const fs = require('fs');
const http = require('http');
const path = require('path');
const { execFile } = require('child_process');
const render = require('./dept-inbox-render.js');
// T4: guard процесс-контроля (lib/process-control.js, задача T2). Путь '../lib' работает и в
// repo-layout, и в install-layout (install.sh кладёт lib/ рядом с bin/) — node резолвит
// __dirname по realpath модуля, поэтому и через symlink путь верный (тот же принцип, что
// `readlink -f` в bash-обёртках, bin/claude-auto:46).
const processControl = require('../lib/process-control.js');

const PORT = Number(process.env.DEPT_INBOX_PORT || 8377);
const DEFAULT_DL_BIN = path.join(__dirname, 'dept-ledger');
const DEFAULT_TIMEOUT_MS = 15000;
const CC_HOME = process.env.CLAUDE_AUTO_HOME || '/home/rainor/.claude-control';
const WORKERS_DIR = path.join(CC_HOME, 'workers');
const DEPT_ROLES = new Set(['руководитель', 'мк', 'архивариус', 'тп']);

// p2#12: execFile-timeout читаем ВНУТРИ функции при каждом вызове (не на module-load) —
// иначе тестовая подмена env после require() дочернего модуля не сработала бы
// (Codex-аудит В9). Тот же таймаут переиспользует и systemctlIsActiveMany().
function execTimeoutMs() {
  const n = Number(process.env.DEPT_INBOX_EXEC_TIMEOUT_MS);
  return Number.isFinite(n) && n > 0 ? n : DEFAULT_TIMEOUT_MS;
}

// dl() — единственная точка чтения ledger. Ошибка чтения не должна маскироваться под
// «пустой инбокс» / «не найдено» (per-call {rows, error}: общий mutable lastReadError
// давал гонку — параллельный запрос затирал ошибку соседнего).
// p2#11: сырые детали (stderr, ENOENT-пути) НЕ попадают в error, который в итоге рендерится
// в HTML — только generic-текст; полный текст идёт в console.error (journald подберёт).
// p2#13: битые JSON-строки stdout считаются, а не молча отбрасываются — попадают в error
// баннером «N строк пропущено», чтобы оператор видел частичное повреждение журнала.
function dl(args) {
  const bin = process.env.DEPT_LEDGER_BIN || DEFAULT_DL_BIN;
  const timeout = execTimeoutMs();
  return new Promise((resolve) => {
    execFile(bin, args, { encoding: 'utf8', maxBuffer: 32 * 1024 * 1024, timeout }, (err, stdout, stderr) => {
      if (err) {
        console.error(`dept-inbox: dl(${JSON.stringify(args)}) failed [bin=${bin}]:`, String(stderr || err.message));
        return resolve({ rows: [], error: 'журнал недоступен (см. лог сервиса)' });
      }
      const rows = [];
      let broken = 0;
      if (stdout && stdout.trim()) {
        for (const l of stdout.trim().split('\n')) {
          try { rows.push(JSON.parse(l)); }
          catch { broken++; console.error(`dept-inbox: битая строка ledger [bin=${bin}, args=${JSON.stringify(args)}]`); }
        }
      }
      resolve({ rows, error: broken ? `${broken} строк${broken === 1 ? 'а' : ''} пропущено при разборе журнала` : null });
    });
  });
}

// Один execFile на все воркеры разом (не по одному) — systemctl is-active построчно
// возвращает статус в том же порядке, что и переданные юниты.
function systemctlIsActiveMany(names) {
  if (!names.length) return Promise.resolve(new Map());
  const units = names.map((n) => `claude-auto@${n}.service`);
  // T4: preflight ДО execFile — под маркером CLAUDE_CONTROL_TEST_ROOT отказ происходит ДО
  // побочного эффекта, а не «вызвали настоящий systemctl и потом пожаловались». БЕЗ маркера
  // preflight не проверяет ничего (checkBinarySeam выходит сразу при testRoot === null), а
  // SYSTEMCTL в боевых юнитах не выставлен — bin === 'systemctl', argv тот же побитово.
  // Провал preflight — НЕ исключение наружу: дашборд read-only и деградирует так же, как при
  // недоступном systemctl (все воркеры «не active» + запись в journald), но настоящего
  // бинаря при этом не касается вовсе — это и есть fail-closed для status-запроса.
  let bin;
  try {
    processControl.preflight('systemctl');
    bin = process.env.SYSTEMCTL || 'systemctl';
  } catch (e) {
    console.error('dept-inbox: guard процесс-контроля отказал в systemctl is-active:', e.message);
    return Promise.resolve(new Map(names.map((n) => [n, false])));
  }
  return new Promise((resolve) => {
    execFile(bin, ['--user', 'is-active', ...units], { encoding: 'utf8', timeout: execTimeoutMs() },
      (err, stdout) => {
        if (err && !stdout) console.error('dept-inbox: systemctl is-active недоступен:', err.message);
        const lines = String(stdout || '').trim().split('\n');
        const map = new Map();
        names.forEach((n, i) => map.set(n, lines[i] === 'active'));
        resolve(map);
      });
  });
}

// fs-читалки состояния воркера: битый/недоступный файл ОДНОГО воркера не валит страницу
// (поле остаётся n/a), но ошибку логируем в journald (console.error) — watchdog-философия
// фазы: не терять сигналы; проблема прав/порчи state должна быть видна в логах, даже если
// в HTML идёт generic. ENOENT (файла нет — штатно для не-brain/новых воркеров) НЕ логируем.
function logFsErr(kind, name, e) {
  if (e && e.code === 'ENOENT') return;
  console.error(`dept-inbox: ${kind}(${name}) fs error:`, (e && (e.code || e.message)) || e);
}
function readContext(name) {
  try { return JSON.parse(fs.readFileSync(path.join(WORKERS_DIR, name, 'state', 'context.json'), 'utf8')); }
  catch (e) { logFsErr('readContext', name, e); return null; }
}
// state/compactions — plain-text счётчик (claude-auto-run пишет при каждом /compact,
// claude-auto rebase его удаляет). Мусор/отсутствие файла → 0, не крашить страницу.
function readCompactions(name) {
  try {
    const raw = fs.readFileSync(path.join(WORKERS_DIR, name, 'state', 'compactions'), 'utf8').trim();
    const n = Number(raw);
    return Number.isFinite(n) && n >= 0 ? Math.floor(n) : 0;
  } catch (e) { logFsErr('readCompactions', name, e); return 0; }
}
function loadEbCfg(name) {
  try { return JSON.parse(fs.readFileSync(path.join(WORKERS_DIR, name, 'event-bridge.config.json'), 'utf8')); }
  catch (e) { logFsErr('loadEbCfg', name, e); return { probes: [] }; }
}
function minutesSince(ts) {
  const t = Date.parse(ts);
  if (!Number.isFinite(t)) return null;
  return Math.max(0, Math.round((Date.now() - t) / 60000));
}

// ---------------------------------------------------------------------------
// Сборщики данных — общее ядро collectDeptState() переиспользуют /, /w/<name>, /activity.
// fs-ошибка ОДНОГО воркера не валит страницу целиком — поле остаётся «n/a»/null.
// ---------------------------------------------------------------------------

async function collectDeptState() {
  const [openAprRes, openIncRes, regRes, polRes, ackRes, runRes, allRes] = await Promise.all([
    dl(['list', '--kind', 'approval', '--status', 'open']),
    dl(['list', '--kind', 'incident', '--status', 'open']),
    dl(['registry-list']),
    dl(['policy-current']),
    dl(['list', '--kind', 'policy_ack', '--limit', '500']),
    dl(['list', '--kind', 'agent_run', '--limit', '500']),
    dl(['list', '--limit', '1000']),
  ]);
  const registry = regRes.rows[0] || { workers: {} };
  const policy = polRes.rows[0] || {};
  const openApprovalsRows = openAprRes.rows;
  const openIncidentsRows = openIncRes.rows;
  const acks = ackRes.rows;
  const runs = runRes.rows;
  const recentRows = allRes.rows;

  let autoReg = { workers: {} };
  try { autoReg = JSON.parse(fs.readFileSync(path.join(CC_HOME, 'autonomous.json'), 'utf8')); }
  catch (e) { console.error('dept-inbox: autonomous.json недоступен:', e.message); }

  const names = Array.from(new Set([
    ...Object.keys(registry.workers || {}),
    ...Object.keys(autoReg.workers || {}),
  ]));

  const aprByWorker = new Map();
  for (const e of openApprovalsRows) { const w = e.data && e.data.from; if (w) aprByWorker.set(w, (aprByWorker.get(w) || 0) + 1); }
  const incByWorker = new Map();
  for (const e of openIncidentsRows) { const w = e.data && e.data.about_worker; if (w) incByWorker.set(w, (incByWorker.get(w) || 0) + 1); }
  const lastAck = new Map();
  for (const e of acks) if (e.data && e.data.worker) lastAck.set(e.data.worker, e); // append-order → последний перезаписывает
  const lastEventTs = new Map();
  const bump = (name, ts) => {
    if (!name || !ts) return;
    const cur = lastEventTs.get(name);
    if (!cur || Date.parse(ts) > Date.parse(cur)) lastEventTs.set(name, ts);
  };
  for (const e of recentRows) {
    const d = e.data || {};
    for (const n of new Set([e.actor, d.to, d.from, d.worker, d.about_worker].filter(Boolean))) bump(n, e.ts);
  }
  for (const e of runs) bump(e.data && e.data.worker, e.ts);

  const unitStatus = await systemctlIsActiveMany(names);

  const workersMap = new Map();
  let sleepingCount = 0;
  for (const name of names) {
    const reg = (registry.workers && registry.workers[name]) || {};
    const auto = (autoReg.workers && autoReg.workers[name]) || {};
    const state = auto.state || 'unknown';
    const role = reg.role || 'legacy';
    if (state === 'sleeping') sleepingCount++;
    const ctxRaw = readContext(name);
    const ctx = ctxRaw ? { tokens: ctxRaw.ctx_tokens, threshold: ctxRaw.threshold, ts: ctxRaw.ts } : null;
    const compactions = readCompactions(name);
    const cfg = loadEbCfg(name);
    const ackEv = lastAck.get(name);
    const policyAck = ackEv ? { version: ackEv.data.policy_version, ageMin: minutesSince(ackEv.ts) } : null;
    let lastTs = lastEventTs.get(name) || null;
    if (!lastTs && ctx && ctx.ts) lastTs = ctx.ts;
    workersMap.set(name, {
      name, role, client: reg.client || null, missionVersion: reg.mission_version || null,
      state, unitUp: unitStatus.has(name) ? unitStatus.get(name) : null,
      ctx, compactions, probes: (cfg.probes || []).map((p) => p.name).filter(Boolean),
      policyAck, lastActivityMin: lastTs ? minutesSince(lastTs) : null,
      openApprovals: aprByWorker.get(name) || 0, openIncidents: incByWorker.get(name) || 0,
    });
  }

  const readError = [openAprRes, openIncRes, regRes, polRes, ackRes, runRes, allRes].map((r) => r.error).find(Boolean) || null;
  const legacyCount = [...workersMap.values()].filter((w) => !DEPT_ROLES.has(w.role)).length;
  return { workersMap, recentRows, runs, legacyCount, sleepingCount, policy, registry,
    openApprovals: openApprovalsRows.length, openIncidents: openIncidentsRows.length, readError };
}

async function collectOffice() {
  const s = await collectDeptState();
  const workers = [...s.workersMap.values()].filter((w) => DEPT_ROLES.has(w.role));
  return { workers, legacyCount: s.legacyCount, sleepingCount: s.sleepingCount, policy: s.policy,
    openApprovals: s.openApprovals, openIncidents: s.openIncidents, readError: s.readError };
}

async function collectTimeline(name) {
  const s = await collectDeptState();
  const card = s.workersMap.get(name) || null;
  const events = s.recentRows.filter((e) => {
    const d = e.data || {};
    return e.actor === name || d.to === name || d.from === name || d.worker === name || d.about_worker === name;
  }).slice(-100);
  return { name, events, card, readError: s.readError };
}

async function collectActivity() {
  const s = await collectDeptState();
  const since7 = Date.now() - 7 * 86400_000;
  const perWorker = new Map();
  const ensure = (name) => {
    if (!perWorker.has(name)) perWorker.set(name, { name, events7d: 0, compactions: 0, wakes: 0, rebases: 0, spawns: 0, days: new Array(14).fill(0) });
    return perWorker.get(name);
  };
  for (const name of s.workersMap.keys()) { ensure(name).compactions = s.workersMap.get(name).compactions; }

  for (const e of s.recentRows) {
    const d = e.data || {};
    for (const n of new Set([e.actor, d.worker].filter(Boolean))) {
      if (!perWorker.has(n)) continue; // только известные отделу воркеры (registry ∪ autonomous)
      const w = ensure(n);
      const t = Date.parse(e.ts);
      if (Number.isFinite(t) && t >= since7) w.events7d++;
      if (Number.isFinite(t)) {
        const offDays = Math.floor((Date.now() - t) / 86400_000);
        if (offDays >= 0 && offDays < 14) w.days[13 - offDays]++;
      }
    }
  }
  for (const e of s.runs) {
    const w = e.data && e.data.worker && perWorker.get(e.data.worker);
    if (!w) continue;
    if (e.data.run_kind === 'wake') w.wakes++;
    if (e.data.run_kind === 'rebase') w.rebases++;
    if (e.data.run_kind === 'spawn') w.spawns++;
    // mission_update/auto_sleep — бриф §Produces /activity их не требует (только wake/rebase/spawn), YAGNI.
  }
  const rows = [...perWorker.values()].filter((w) => DEPT_ROLES.has((s.workersMap.get(w.name) || {}).role));
  return { rows, readError: s.readError };
}

// M-2 (ревью фазы 3): /approvals не видел заявки МЕЖДУ решением человека и финалом раннера
// (approved-исполняемые и executing) — «дыра видимости» до 20+ минут на долгих заявках.
// Секция «⚙️ Исполняются» = executing (любой kind_of: статус пишет только диспетчер перед
// раннером) + approved с kind_of ∈ EXEC_KINDS (ждут диспетчера). approved НЕ-исполняемых
// kind_of (outgoing/kb_change/…) сюда намеренно НЕ попадают: их «исполняет» сам воркер без
// финального статуса в ledger — они висели бы в секции вечно (rotate считает их закрытыми).
// Синхронно с EXEC_KINDS в bin/dept-dispatcher (пин — dept-dispatcher.test.mjs).
const EXEC_KINDS_INBOX = new Set(['worker_spawn', 'mission_change', 'planerka', 'sleep', 'liveness_restart']);
async function collectApprovalsPage() {
  const res = await Promise.all([
    dl(['list', '--kind', 'approval', '--status', 'open']),
    dl(['list', '--kind', 'incident', '--status', 'open']),
    dl(['list', '--limit', '50']),
    dl(['registry-list']),
    dl(['policy-current']),
    dl(['list', '--kind', 'approval_status', '--limit', '500']),
    dl(['list', '--kind', 'approval', '--status', 'executing']),
    dl(['list', '--kind', 'approval', '--status', 'approved']),
  ]);
  const [approvals, incidents, recent, reg, pol, aprStatuses, executingRes, approvedRes] = res;
  const since = Date.now() - 7 * 86400_000;
  const executed = aprStatuses.rows.filter((e) => e.data
    && (e.data.status === 'executed' || e.data.status === 'exec_failed')
    && Date.parse(e.ts) >= since);
  // pickExecutable-семантика (bin/dept-dispatcher): диспетчер исполняет только заявки
  // руководителя/operator. approved-исполняемую заявку НЕ от них он не возьмёт НИКОГДА —
  // показывать её «ждёт диспетчера» вводило бы в заблуждение; честная фаза —
  // 'approved_foreign' (багхант 16.07). При ошибке чтения реестра роли неизвестны —
  // не мислейблим (остаёмся на оптимистичном 'approved', баннер readError и так виден).
  const registry = reg.rows[0] || { workers: {} };
  // liveness_restart — зеркало watchdog-ветки pickExecutable в bin/dept-dispatcher: диспетчер
  // возьмёт её ТОЛЬКО от 'watchdog', а не от руководителя/operator (та же узкая ветка, не
  // общее ослабление). Без этого liveness_restart от watchdog всегда мислейблился бы
  // 'approved_foreign' — 'watchdog' не значится в реестре руководителем/оператором.
  const dispatcherWill = (from, kindOf) => {
    if (kindOf === 'liveness_restart') return from === 'watchdog';
    return reg.error || ((registry.workers || {})[from] || {}).role === 'руководитель' || from === 'operator';
  };
  const executingNow = [
    ...executingRes.rows.map((e) => ({ ...e, phase: 'executing' })),
    ...approvedRes.rows.filter((e) => e.data && EXEC_KINDS_INBOX.has(e.data.kind_of))
      .map((e) => ({ ...e, phase: dispatcherWill(e.data.from, e.data.kind_of) ? 'approved' : 'approved_foreign' })),
  ];
  return { approvals: approvals.rows.reverse(), incidents: incidents.rows.reverse(), recent: recent.rows.reverse(),
    executed: executed.reverse(), executingNow: executingNow.reverse(),
    registry, policy: pol.rows[0] || {},
    readError: res.map((r) => r.error).find(Boolean) || null };
}

const CLOSED_INCIDENT_STATUSES = new Set(['resolved', 'wontfix', 'duplicate']);
async function collectIncidents() {
  const res = await Promise.all([
    dl(['list', '--kind', 'incident', '--status', 'open']),
    dl(['list', '--kind', 'incident_status', '--limit', '1000']),
    dl(['list', '--kind', 'incident', '--limit', '1000']),
  ]);
  const [openRes, statusRes, allIncRes] = res;
  const since = Date.now() - 14 * 86400_000;
  const closedByRef = new Map();
  for (const e of statusRes.rows) {
    if (!(e.data && e.data.ref && CLOSED_INCIDENT_STATUSES.has(e.data.status))) continue;
    const cur = closedByRef.get(e.data.ref);
    if (!cur || Date.parse(e.ts) > Date.parse(cur.ts)) closedByRef.set(e.data.ref, e);
  }
  const closed = allIncRes.rows
    .filter((e) => closedByRef.has(e.event_id) && Date.parse(closedByRef.get(e.event_id).ts) >= since)
    .map((e) => ({ ...e, data: { ...e.data, status: closedByRef.get(e.event_id).data.status } }))
    .reverse();
  return { open: openRes.rows.reverse(), closed, readError: res.map((r) => r.error).find(Boolean) || null };
}

async function collectApproval(eid) {
  const [aprRes, stRes] = await Promise.all([
    dl(['list', '--kind', 'approval', '--event-id', eid]), // p2#13: O(1)-фильтр вместо полного списка
    dl(['list', '--kind', 'approval_status', '--filter', `ref=${eid}`]),
  ]);
  return { event: aprRes.rows[0] || null, statuses: stRes.rows, readError: aprRes.error || stRes.error || null };
}

// ---------------------------------------------------------------------------
// Сервер
// ---------------------------------------------------------------------------

if (require.main === module) {
  http.createServer(async (req, res) => {
    try {
      const u = new URL(req.url, 'http://x');
      if (u.pathname === '/healthz') { res.writeHead(200); res.end('ok'); return; }
      let html = null;
      if (u.pathname === '/') html = render.renderOffice(await collectOffice());
      else if (u.pathname === '/approvals') html = render.renderApprovalsPage(await collectApprovalsPage());
      else if (u.pathname === '/incidents') html = render.renderIncidents(await collectIncidents());
      else if (u.pathname === '/activity') { const a = await collectActivity(); html = render.renderActivity(a.rows, a.readError); }
      else if (u.pathname.startsWith('/a/')) {
        const eid = decodeURIComponent(u.pathname.slice(3));
        const { event, statuses, readError } = await collectApproval(eid);
        html = render.renderApproval(event, statuses, readError);
      } else if (u.pathname.startsWith('/w/')) {
        const name = decodeURIComponent(u.pathname.slice(3));
        const t = await collectTimeline(name);
        html = render.renderTimeline(name, t.events, t.readError, t.card);
      }
      if (html === null) { res.writeHead(404, { 'Content-Type': 'text/plain; charset=utf-8' }); res.end('404'); return; }
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8',
        'Content-Security-Policy': "default-src 'none'; style-src 'unsafe-inline'",
        'Cache-Control': 'no-store', 'X-Robots-Tag': 'noindex' });
      res.end(html);
    } catch (e) {
      // p2#11: без деталей (стек/пути) наружу — только в лог сервиса.
      console.error('dept-inbox: unhandled error on', req.url, '-', e.stack || e.message);
      res.writeHead(500, { 'Content-Type': 'text/plain; charset=utf-8' });
      res.end('internal error — см. лог сервиса');
    }
  }).listen(PORT, '127.0.0.1', () => console.log('dept-inbox on 127.0.0.1:' + PORT));
}

module.exports = {
  dl, collectDeptState, collectOffice, collectTimeline, collectActivity, collectApprovalsPage,
  collectIncidents, collectApproval, systemctlIsActiveMany, execTimeoutMs,
};
