#!/usr/bin/env node
// dept-inbox — read-only веб-инбокс оператора поверх ledger отдела.
// Слушает ТОЛЬКО 127.0.0.1; наружу — через Angie-vhost с basic auth.
// Никаких записей: решения — кнопками в TG-боте (дашборд с действиями — фаза 3+).
'use strict';
const http = require('http');
const path = require('path');
const { execFile } = require('child_process');

const PORT = Number(process.env.DEPT_INBOX_PORT || 8377);
const DL = process.env.DEPT_LEDGER_BIN || path.join(__dirname, 'dept-ledger');

// Ошибка чтения ledger не должна маскироваться под «пустой инбокс» / «не найдено».
// Результат per-call ({rows, error}) — общий mutable lastReadError давал гонку:
// параллельный запрос затирал ошибку соседнего (или забирал её в свой успешный ответ).
function dl(args) {
  return new Promise((resolve) => {
    execFile(DL, args, { encoding: 'utf8', maxBuffer: 32 * 1024 * 1024 }, (err, stdout, stderr) => {
      if (err) return resolve({ rows: [], error: String(stderr || err.message).slice(0, 300) });
      const rows = [];
      if (stdout && stdout.trim()) {
        for (const l of stdout.trim().split('\n')) { try { rows.push(JSON.parse(l)); } catch {} }
      }
      resolve({ rows, error: null });
    });
  });
}

const esc = (s) => String(s ?? '').replace(/[&<>"']/g, (c) =>
  ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

function age(ts) {
  const m = Math.max(0, Math.round((Date.now() - Date.parse(ts)) / 60000));
  if (!Number.isFinite(m)) return '?'; // битый/отсутствующий ts — не рисовать "NaN дн"
  if (m < 60) return m + ' мин';
  if (m < 1440) return Math.floor(m / 60) + ' ч ' + (m % 60) + ' мин';
  return Math.floor(m / 1440) + ' дн';
}

function summaryOf(e) {
  const d = e.data || {};
  return d.summary || d.subject || (d.status ? `${d.status} → ${d.ref || ''}` : '') || d.worker || '';
}

function page(title, body) {
  return `<!doctype html><html lang="ru"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1"><meta http-equiv="refresh" content="60">
<title>${esc(title)}</title><style>
body{font:15px/1.5 system-ui,sans-serif;margin:1rem auto;max-width:60rem;padding:0 1rem;background:#14161a;color:#d7dae0}
table{border-collapse:collapse;width:100%;margin:.5rem 0 1.5rem}
td,th{border-bottom:1px solid #2c313a;padding:.35rem .5rem;text-align:left;vertical-align:top}
th{color:#8b93a1;font-weight:600} a{color:#7ab7ff} h1{font-size:1.4rem} h2{margin:1.2rem 0 .3rem;font-size:1.1rem}
.meta{color:#7b8290} pre.diff{background:#0d1117;border:1px solid #2c313a;padding:.6rem .8rem;overflow-x:auto;line-height:1.35;font-size:13px}
.da{color:#7ee787}.dd{color:#ff8f7a}.dh{color:#8b93a1}.dc{color:#c8ccd4} blockquote{border-left:3px solid #3a4150;margin:.5rem 0;padding:.2rem .8rem;white-space:pre-wrap}
</style></head><body><h1>Цифровой отдел</h1>${body}</body></html>`;
}

// Единый стиль баннера ошибки чтения для инбокса и карточки аппрува.
function errBanner(readError) {
  return readError
    ? `<p style="color:#ff8f7a;border:1px solid #7a3a2e;padding:.4rem .8rem">⚠️ Ошибка чтения журнала — данные могут быть неполными: ${esc(readError)}</p>` : '';
}

function renderInbox(d) {
  const apr = d.approvals.map((e) => `<tr><td>${esc(age(e.ts))}</td><td>${esc(e.data.from)}</td>
<td>${esc(e.data.kind_of)}</td><td><a href="/a/${esc(e.event_id)}">${esc(e.data.summary)}</a></td></tr>`).join('')
    || '<tr><td colspan="4">пусто — решений никто не ждёт</td></tr>';
  const inc = d.incidents.map((e) => `<tr><td>${esc(age(e.ts))}</td><td>${esc(e.data.severity)}</td>
<td>${esc(e.data.about_worker)}</td><td>${esc(e.data.summary)}</td></tr>`).join('')
    || '<tr><td colspan="4">пусто</td></tr>';
  const rec = d.recent.map((e) => `<tr><td>${esc((e.ts || '').slice(0, 16).replace('T', ' '))}</td>
<td>${esc(e.actor)}</td><td>${esc(e.kind)}</td><td>${esc(summaryOf(e))}</td></tr>`).join('');
  const workers = Object.keys((d.registry && d.registry.workers) || {}).length;
  return page('Отдел — инбокс', `${errBanner(d.readError)}
<p class="meta">правила: ${esc(d.policy.version || '?')} · воркеров в реестре: ${workers} · автообновление 60с</p>
<h2>⏳ Ждут решения (${d.approvals.length})</h2>
<table><tr><th>висит</th><th>кто</th><th>тип</th><th>что</th></tr>${apr}</table>
<h2>🚨 Открытые инциденты (${d.incidents.length})</h2>
<table><tr><th>возраст</th><th>severity</th><th>о ком</th><th>что</th></tr>${inc}</table>
<h2>Последние события</h2>
<table><tr><th>когда (UTC)</th><th>кто</th><th>вид</th><th>что</th></tr>${rec}</table>`);
}


// detail с видом unified diff рендерим раскрашенным построчно; прочее — blockquote
function renderDetail(detail) {
  if (!detail) return '<p class="meta">детали не приложены</p>';
  const looksDiff = /^(@@ |--- |\+\+\+ )/m.test(detail);
  if (!looksDiff) return `<blockquote>${esc(detail)}</blockquote>`;
  const rows = detail.split('\n').map((l) => {
    const c = l.startsWith('+') ? 'da' : l.startsWith('-') ? 'dd' : l.startsWith('@@') ? 'dh' : 'dc';
    return `<span class="${c}">${esc(l)}</span>`;
  }).join('\n');
  return `<pre class="diff">${rows}</pre>`;
}

function renderApproval(e, statuses, readError) {
  if (!e) {
    // при ошибке чтения НЕ выдавать «не найдено» — реальное состояние аппрува неизвестно
    if (readError) return page('ошибка чтения журнала', `${errBanner(readError)}
<p>Не удалось прочитать журнал — состояние аппрува неизвестно, обнови страницу.</p>
<p><a href="/">← в инбокс</a></p>`);
    return page('не найдено', '<p>Аппрув не найден.</p><p><a href="/">← в инбокс</a></p>');
  }
  const st = statuses.length ? statuses[statuses.length - 1].data.status : (e.data.status || 'open');
  const hist = statuses.map((s) => `<li>${esc(s.ts)} — <b>${esc(s.data.status)}</b> (${esc(s.actor)})</li>`).join('');
  return page(`Аппрув ${e.event_id}`, `${errBanner(readError)}
<p><a href="/">← в инбокс</a></p>
<h2>${esc(e.data.summary)}</h2>
<p class="meta">${esc(e.event_id)} · от ${esc(e.data.from)} · тип ${esc(e.data.kind_of)} · открыт ${esc(e.ts)} (${esc(age(e.ts))} назад) · статус: <b>${esc(st)}</b></p>
${renderDetail(e.data.detail)}
${hist ? `<h2>История</h2><ul>${hist}</ul>` : ''}
<p class="meta">Решение — кнопками в Telegram (@RnR_Workers). Эта страница только показывает.</p>`);
}

async function collectInbox() {
  const res = await Promise.all([
    dl(['list', '--kind', 'approval', '--status', 'open']),
    dl(['list', '--kind', 'incident', '--status', 'open']),
    dl(['list', '--limit', '50']),
    dl(['registry-list']),
    dl(['policy-current']),
  ]);
  const [approvals, incidents, recent, reg, pol] = res;
  return { approvals: approvals.rows.reverse(), incidents: incidents.rows.reverse(), recent: recent.rows.reverse(),
    registry: reg.rows[0] || { workers: {} }, policy: pol.rows[0] || {},
    readError: res.map((r) => r.error).find(Boolean) || null };
}

if (require.main === module) {
  http.createServer(async (req, res) => {
    try {
      const u = new URL(req.url, 'http://x');
      if (u.pathname === '/healthz') { res.writeHead(200); res.end('ok'); return; }
      let html = null;
      if (u.pathname === '/') html = renderInbox(await collectInbox());
      else if (u.pathname.startsWith('/a/')) {
        const eid = u.pathname.slice(3);
        const [aprs, sts] = await Promise.all([dl(['list', '--kind', 'approval']),
          dl(['list', '--kind', 'approval_status'])]);
        html = renderApproval(aprs.rows.find((e) => e.event_id === eid),
          sts.rows.filter((s) => s.data && s.data.ref === eid),
          aprs.error || sts.error || null);
      }
      if (html === null) { res.writeHead(404, { 'Content-Type': 'text/plain; charset=utf-8' }); res.end('404'); return; }
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8',
        'Content-Security-Policy': "default-src 'none'; style-src 'unsafe-inline'",
        'Cache-Control': 'no-store', 'X-Robots-Tag': 'noindex' });
      res.end(html);
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'text/plain; charset=utf-8' });
      res.end('inbox error: ' + e.message);
    }
  }).listen(PORT, '127.0.0.1', () => console.log('dept-inbox on 127.0.0.1:' + PORT));
}
module.exports = { renderInbox, renderApproval, summaryOf };
