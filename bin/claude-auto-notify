#!/usr/bin/env bash
# claude-auto-notify <name> — Notification hook for an autonomous worker.
#
# Fires when the worker needs operator attention — most importantly when an
# action outside its allowed set hits a permission prompt and the session is
# BLOCKED waiting for a yes/no. Sends a one-way Telegram ping so the operator
# knows to attach and decide. This is the "queue for review" half of bounded
# autonomy that scales to many workers (a per-worker inline yes/no relay would
# need a separate bot token per worker — Telegram allows one getUpdates consumer
# per token, so co-loading the shared telegram channel in every worker conflicts).
#
# Throttled (default 60s) so a chatty notification stream doesn't spam. Fail-safe.
set -u

name="${1:-unknown}"
[[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || name="unknown"
# T5: корень рантайма — через единый резолвер (lib/runtime-root.sh, задача T1). Без маркера
# CLAUDE_CONTROL_TEST_ROOT возвращает ту же строку, что прежний inline-дефолт; под маркером —
# fail-closed. Фейл резолва (без маркера — лишь при пустом HOME) НЕ вклинивает воркера: тихий
# exit 0 (этот hook fail-safe — «any error exits 0», не должен блокировать ход).
_t5_self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
_t5_bindir="$(cd "$(dirname "$_t5_self")" && pwd)"
# shellcheck disable=SC1091
. "$_t5_bindir/../lib/runtime-root.sh"
# Рендер карточки + выбор бота (файл не входит в шов T8).
# shellcheck disable=SC1091
. "$_t5_bindir/../lib/notify-card.sh"
CONTROL_DIR="$(resolve_runtime_root control_only)" || exit 0
TG="${CLAUDE_AUTO_TG:-/home/rainor/server/server_monitor/telegram_notify.sh}"
THROTTLE="${CLAUDE_AUTO_NOTIFY_THROTTLE:-60}"
statedir="$CONTROL_DIR/workers/$name/state"
stamp="$statedir/.last_notify"

{
  command -v jq >/dev/null 2>&1 || exit 0
  payload="$(cat 2>/dev/null)"
  msg="$(printf '%s' "$payload" | jq -r '.message // "needs attention" ' 2>/dev/null \
        | tr -d '\000-\010\013\014\016-\037' | cut -c1-300)"
  ntype="$(printf '%s' "$payload" | jq -r '.notification_type // empty' 2>/dev/null)"

  # Forward ONLY notifications that need operator action. Primary signal is the
  # structured notification_type; matching on it (not English .message text) is
  # robust to wording changes. FAIL-OPEN: an unknown/missing type is forwarded
  # (a stray ping beats swallowing a real block). The text fallback covers the
  # idle case if the type field is absent on this build. Suppression happens
  # BEFORE the throttle stamp so a suppressed idle never throttles a later block.
  # force=1 ⇒ action REQUIRED (a real permission block / the worker is asking the
  # operator). These bypass the throttle entirely — a real block must NEVER be dropped
  # because some other notification fired in the last THROTTLE seconds (Codex). Only
  # the fail-open "unknown" class is throttled (anti-spam).
  force=0
  case "$ntype" in
    idle_prompt|auth_success|elicitation_complete|elicitation_response) exit 0 ;;  # no action needed → suppress
    permission_prompt|elicitation_dialog) force=1 ;;                               # real block / worker asks → ALWAYS notify
    "") case "$msg" in *"waiting for your input"*|*"is waiting"*) exit 0 ;; esac ;; # untyped idle → suppress
    *) : ;;                                                                         # unknown type → notify (fail-open, throttled)
  esac

  mkdir -p "$statedir" 2>/dev/null
  now="$(date +%s)"
  if [ "$force" != 1 ] && [ -f "$stamp" ]; then
    last="$(cat "$stamp" 2>/dev/null || echo 0)"
    [ "$last" -eq "$last" ] 2>/dev/null || last=0
    [ $(( now - last )) -lt "$THROTTLE" ] && exit 0   # throttled (only non-action-required)
  fi
  echo "$now" > "$stamp" 2>/dev/null || true

  [ -x "$TG" ] || exit 0

  # Friendly Russian framing. Claude Code's raw .message is English ("Claude is
  # waiting for your input" / "Claude needs your permission to use <tool>").
  # Translate the two common cases; fall back to the raw text for anything else.
  case "$msg" in
    *"waiting for your input"*)  human="Ждёт твоего ответа в чате" ;;
    *"permission"*|*"approve"*)  human="Просит разрешение на действие — нужно подтвердить или отклонить" ;;
    *)                           human="$msg" ;;
  esac

  nc_reset
  nc_head "🤖" "Воркер ждёт тебя"
  nc_field "Воркер" "$name"
  nc_note "$human"
  nc_action "tmux -L claude-$name attach -t claude-$name   (выйти: Ctrl-b, затем d)"
  NC_TG="$TG" nc_send >/dev/null 2>&1 || true
} 2>/dev/null
exit 0
