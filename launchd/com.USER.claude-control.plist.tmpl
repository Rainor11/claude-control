<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>__LABEL__</string>
  <key>ProgramArguments</key>
  <array>
    <string>__BIN_DIR__/claude-control-session</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <!-- Minimum delay between relaunches. Without this, claude crashing on
       startup (auth refresh, network blip) tight-loops at launchd's 10s floor. -->
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>StandardOutPath</key>
  <string>__CONTROL_DIR__/control.log</string>
  <key>StandardErrorPath</key>
  <string>__CONTROL_DIR__/control.err</string>
</dict>
</plist>
